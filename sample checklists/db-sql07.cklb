-103637","CCI-002418","CCI-002421"],"reference_identifier":"2041","uuid":"929c1ce7-bae8-4d5f-a7b2-465f0ac5221f","stig_uuid":"c33e275b-9377-4bae-a2ae-4c3250791f55","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2019_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 184712C7AB8D234DA1B6CED892D8C1A56178FD5F\r\n~~~~~\r\nConfiguration for 'Windows Server 2019 setting Domain member: Digitally sign secure channel data (when possible) must be configured to Enabled.' matches the expected value on the Windows Server 2019 host."},{"group_id_src":"V-205824","group_tree":[{"id":"V-205824","title":"SRG-OS-000423-GPOS-00187","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-205824","severity":"medium","group_title":"SRG-OS-000423-GPOS-00187","rule_id_src":"SV-205824r958908_rule","rule_id":"SV-205824","rule_version":"WN19-SO-000110","rule_title":"Windows Server 2019 must be configured to require a strong session key.","fix_text":"Configure the policy value for Computer Configuration >> Windows Settings >> Security Settings >> Local Policies >> Security Options >> \"Domain member: Require strong (Windows 2000 or Later) session key\" to \"Enabled\".","weight":"10.0","check_content":"If the following registry value does not exist or is not configured as specified, this is a finding:\n\nRegistry Hive: HKEY_LOCAL_MACHINE \nRegistry Path: \\SYSTEM\\CurrentControlSet\\Services\\Netlogon\\Parameters\\\n\nValue Name: RequireStrongKey\n\nValue Type: REG_DWORD\nValue: 0x00000001 (1)\n \nThis setting may prevent a system from being joined to a domain if not configured consistently between systems.","check_content_ref":{"href":"Microsoft_Windows_Server_2019_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A computer connecting to a domain controller will establish a secure channel. The secure channel connection may be subject to compromise, such as hijacking or eavesdropping, if strong session keys are not used to establish the connection. Requiring strong session keys enforces 128-bit encryption between systems.\n\nSatisfies: SRG-OS-000423-GPOS-00187, SRG-OS-000424-GPOS-00188","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["SV-103639","V-93553","CCI-002418","CCI-002421"],"reference_identifier":"6870","uuid":"c60041b2-f666-4893-ac72-439c8b89e076","stig_uuid":"c33e275b-9377-4bae-a2ae-4c3250791f55","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2019_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 8C96C7C23C2E8AA80AD5F73EAB010733D197046D\r\n~~~~~\r\nRequired configuration for 'Windows Server 2019 must be configured to require a strong session key.' was not present or did not match the expected value on the Windows Server 2019 host."},{"group_id_src":"V-205825","group_tree":[{"id":"V-205825","title":"SRG-OS-000423-GPOS-00187","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-205825","severity":"medium","group_title":"SRG-OS-000423-GPOS-00187","rule_id_src":"SV-205825r958908_rule","rule_id":"SV-205825","rule_version":"WN19-SO-000160","rule_title":"Windows Server 2019 setting Microsoft network client: Digitally sign communications (always) must be configured to Enabled.","fix_text":"Configure the policy value for Computer Configuration >> Windows Settings >> Security Settings >> Local Policies >> Security Options >> \"Microsoft network client: Digitally sign communications (always)\" to \"Enabled\".","weight":"10.0","check_content":"If the following registry value does not exist or is not configured as specified, this is a finding:\n\nRegistry Hive: HKEY_LOCAL_MACHINE \nRegistry Path: \\SYSTEM\\CurrentControlSet\\Services\\LanmanWorkstation\\Parameters\\\n\nVa