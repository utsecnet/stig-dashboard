ue on the Windows Server 2012 R2 host."},{"group_id_src":"V-225531","group_tree":[{"id":"V-225531","title":"SRG-OS-000095-GPOS-00049","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-225531","severity":"medium","group_title":"SRG-OS-000095-GPOS-00049","rule_id_src":"SV-225531r569185_rule","rule_id":"SV-225531","rule_version":"WN12-SV-000104","rule_title":"The Simple TCP/IP Services service must be disabled if installed.","fix_text":"Remove or disable the Simple TCP/IP Services (simptcp) service.","weight":"10.0","check_content":"Verify the Simple TCP/IP (simptcp) service is not installed or is disabled. \n\nRun \"Services.msc\".\n\nIf the following is installed and not disabled, this is a finding:\n\nSimple TCP/IP Services (simptcp)","check_content_ref":{"href":"Microsoft_Windows_Server_2012-2012_R2_MS_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Unnecessary services increase the attack surface of a system. Some of these services may not support required levels of authentication or encryption.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["V-26605","SV-52239","CCI-000381"],"reference_identifier":"3488","uuid":"ddeded7c-0936-4b9f-afce-a61888ccf4d2","stig_uuid":"c86c759d-312b-4407-8dff-54b4acc214e1","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2012R2MS_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 5D575C52B92E40537E44AC6D90C0BAC3F3952248\r\n~~~~~\r\nConfiguration for 'The Simple TCP/IP Services service must be disabled if installed.' matches the expected value on the Windows Server 2012 R2 host."},{"group_id_src":"V-225532","group_tree":[{"id":"V-225532","title":"SRG-OS-000096-GPOS-00050","description":"<GroupDescription></GroupDescription>"}