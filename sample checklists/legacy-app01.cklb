false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["SV-53143","V-16020","CCI-000381"],"reference_identifier":"1500","uuid":"3cf8b826-02dc-4a65-8ae9-b9f68ce3318c","stig_uuid":"c86c759d-312b-4407-8dff-54b4acc214e1","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2012R2MS_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: C95C4F3DD2DFE8E0C93F3334C28D90E1002A8973\r\n~~~~~\r\nConfiguration for 'The Windows Customer Experience Improvement Program must be disabled.' matches the expected value on the Windows Server 2012 R2 host."},{"group_id_src":"V-225347","group_tree":[{"id":"V-225347","title":"SRG-OS-000362-GPOS-00149","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-225347","severity":"medium","group_title":"SRG-OS-000362-GPOS-00149","rule_id_src":"SV-225347r852205_rule","rule_id":"SV-225347","rule_version":"WN12-CC-000047","rule_title":"Windows must be prevented from using Windows Update to search for drivers.","fix_text":"Configure the policy value for Computer Configuration -> Administrative Templates -> System -> Internet Communication Management -> Internet Communication settings -> \"Turn off Windows Update device driver searching\" to \"Enabled\".","weight":"10.0","check_content":"If the following registry value does not exist or is not configured as specified, this is a finding:\n\nRegistry Hive: HKEY_LOCAL_MACHINE\nRegistry Path: \\Software\\Policies\\Microsoft\\Windows\\DriverSearching\\\n\nValue Name: DontSearchWindowsUpdate\n\nType: REG_DWORD\nValue: 1","check_content_ref":{"href":"Microsoft_Windows_Server_2012-2012_R2_MS_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Some features may communicate with the vendor, sending system information or downloading data or components for the feature.  Turning off this capability will prevent potentially sensitive information from being sent outside the enterprise and uncontrolled updates to the system.  \nThis setting prevents Windows from searching Windows Update for device drivers when no local drivers for a device are present.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["SV-53000","V-14261","CCI-001812"],"reference_identifier":"1394","uuid":"1202e2f8-331b-41ac-8ad2-f9841da8c1db","stig_uuid":"c86c759d-312b-4407-8dff-54b4acc214e1","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2012R2MS_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 9B3B8E345F8F998D3A1C0EBDFD21466B4356C76F\r\n~~~~~\r\nConfiguration for 'Windows must be prevented from using Windows Update to search for drivers.' matches the expected value on the Windows Server 2012 R2 host."},{"group_id_src":"V-225348","group_tree":[{"id":"V-225348","title":"SRG-OS-000095-GPOS-00049","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-225348","severity":"medium","group_title":"SRG-OS-000095-GPOS-00049","rule_id_src":"SV-225348r569185_rule","rule_id":"SV-225348","rule_version":"WN12-CC-000048","rule_title":"Copying of user input methods to the system account for sign-in must be prevented.","fix_text":"Configure the policy value for Computer Configuration -> Administrative Templates -> System -> Locale Services -> \"Disallow copying of user input methods to the system account for sign-in\" to \"Enabled\".","weight":"10.0","check_content":"If the following registry value does not exist or is not configured as specified, this is a finding:\n\nRegistry Hive: HKEY_LOCAL_MACHINE\nRegistry Path: \\Software\\Policies\\Microsoft\\Control Panel\\International\\\n\nValue Name: BlockUserInputMethodsForSignIn\n\nType: REG_DWORD\nValue: 1","check_content_ref":{"href":"Microsoft_Windows_Server_2012-2012_R2_MS_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Allowing different input methods for sign-in could open different avenues of attack.  User input methods must be restricted to those enabled for the system account at sign-in.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["V-36681","SV-51610","CCI-000381"],"reference_identifier":"1465","uuid":"5f9dca52-73df-4c57-ba83-7ae05270ee8a","stig_uuid":"c86c759d-312b-4407-8dff-54b4acc214e1","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2012R2MS_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: 8005BF9772E9A0B87EFDD1C627FB39F72E6C9E91\r\n~~~~~\r\nThe feature/role addressed by 'Copying of user input methods to the system account for sign-in must be prevented.' is not present or not in use on this the Windows Server 2012 R2 host."},{"group_id_src":"V-225349","group_tree":[{"id":"V-225349","title":"SRG-OS-000095-GPOS-00049","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-225349","severity":"medium","group_title":"SRG-OS-000095-GPOS-00049","rule_id_src":"SV-225349r569185_rule","rule_id":"SV-225349","rule_version":"WN12-CC-000051","rule_title":"Local users on domain-joined computers must not be enumerated.","fix_text":"Configure the policy value for Computer Configuration -> Administrative Templates -> System -> Logon -> \"Enumerate local users on domain-joined computers\" to \"Disabled\".","weight":"10.0","check_content":"If the following registry value does not exist or is not configured as specified, this is a finding:\n\nRegistry Hive: HKEY_LOCAL_MACHINE\nRegistry Path: \\Software\\Policies\\Microsoft\\Windows\\System\\\n\nValue Name: EnumerateLocalUsers\n\nType: REG_DWORD\nValue: 0","check_content_ref":{"href":"Microsoft_Windows_Server_2012-2012_R2_MS_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The username is one part of logon credentials that could be used to gain access to a system.  Preventing the enumeration of users limits this information to authorized personnel.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["V-36684","SV-51611","CCI-000381"],"reference_identifier":"1587","uuid":"0b9641cd-1219-4ba1-aea0-46b5653a5e08","stig_uuid":"c86c759d-312b-4407-8dff-54b4acc214e1","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2012R2MS_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: 25B4901990910B314AF25B108FF3DAE3AD639772\r\n~~~~~\r\nThe feature/role addressed by 'Local users on domain-joined computers must not be enumerated.' is not present or not in use on this the Windows Server 2012 R2 host."},{"group_id_src":"V-225350","group_tree":[{"id":"V-225350","title":"SRG-OS-000095-GPOS-00049","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-225350","severity":"medium","group_title":"SRG-OS-000095-GPOS-00049","rule_id_src":"SV-225350r569185_rule","rule_id":"SV-225350","rule_version":"WN12-CC-000052","rule_title":"App notifications on the lock screen must be turned off.","fix_text":"Configure the policy value for Computer Configuration -> Administrative Templates -> System -> Logon -> \"Turn off app notifications on the lock screen\" to \"Enabled\".","weight":"10.0","check_content":"If the following registry value does not exist or is not configured as specified, this is a finding:\n\nRegistry Hive: HKEY_LOCAL_MACHINE\nRegistry Path: \\Software\\Policies\\Microsoft\\Windows\\System\\\n\nValue Name: DisableLockScreenAppNotifications\n\nType: REG_DWORD\nValue: 1","check_content_ref":{"href":"Microsoft_Windows_Server_2012-2012_R2_MS_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"App notifications that are displayed on the lock screen could display sensitive information to unauthorized personnel.  Turning off this feature will limit access to the information to a logged on user.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["V-36687","SV-51612","CCI-000381"],"reference_identifier":"4577","uuid":"6264aeaa-c14e-44eb-be1e-2b679c19c0db","stig_uuid":"c86c759d-312b-4407-8dff-54b4acc214e1","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2012R2MS_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: DB5547FE29D0B72984332BE81404D4E0645CD433\r\n~~~~~\r\nRequired configuration for 'App notifications on the lock screen must be turned off.' was not present or did not match the expected value on the Windows Server 2012 R2 host."},{"group_id_src":"V-225351","group_tree":[{"id":"V-225351","title":"SRG-OS-000373-GPOS-00156","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-225351","severity":"medium","group_title":"SRG-OS-000373-GPOS-00156","rule_id_src":"SV-225351r852206_rule","rule_id":"SV-225351","rule_version":"WN12-CC-000054","rule_title":"Users must be prompted to authenticate on resume from sleep (on battery).","fix_text":"Configure the policy value for Computer Configuration -> Administrative Templates -> System -> Power Management -> Sleep Settings -> \"Re