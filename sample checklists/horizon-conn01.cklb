:*\"\n\nCompare the \"AuditPol\" settings with the following:\n\nIf the system does not audit the following, this is a finding.\n\nObject Access >> Other Object Access Events - Failure","check_content_ref":{"href":"Microsoft_Windows_Server_2022_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Maintaining an audit trail of system activity logs can help identify configuration errors, troubleshoot service disruptions, and analyze compromises that have occurred, as well as detect attacks. Audit logs are necessary to provide a trail of evidence in case the system or network is compromised. Collecting this data is essential for analyzing the security of information assets and detecting signs of suspicious and unexpected behavior.\n\nAuditing for other object access records events related to the management of task scheduler jobs and COM+ objects.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000172"],"reference_identifier":"7259","uuid":"7167ab65-9e0a-44c3-8277-3c642988cb3f","stig_uuid":"0d0f782a-92a5-488f-9189-ef7df4f274ba","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2022_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 8C47D83BEBC09350E55B745919899D835E04B9C4\r\n~~~~~\r\nRequired configuration for 'Windows Server 2022 must be configured to audit Object Access - Other Object Access Events failures.' was not present or did not match the expected value on the Windows Server 2022 host."},{"group_id_src":"V-254317","group_tree":[{"id":"V-254317","title":"SRG-OS-000474-GPOS-00219","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-254317","severity":"medium","group_title":"SRG-OS-000474-GPOS-00219","rule_id_src":"SV-254317r991583_rule","rule_id":"SV-254317","rule_version":"WN22-AU-000240","rule_title":"Windows Server 2022 must be configured to audit Object Access - Removable Storage successes.","fix_text":"Configure the policy value for Computer Configuration >> Windows Settings >> Security Settings >> Advanced Audit Policy Configuration >> System Audit Policies >> Object Access >> Audit Removable Storage with \"Success\" selected.","weight":"10.0","check_content":"Security Option \"Audit: Force audit policy subcategory settings (Windows Vista or later) to override audit policy category settings\" must be set to \"Enabled\" (WN22-SO-000050) for the detailed auditing subcategories to be effective. \n\nUse the \"AuditPol\" tool to review the current Audit Policy configuration:\n\nOpen \"PowerShell\" or a \"Command Prompt\" with elevated privileges (\"Run as administrator\").\n\nEnter \"AuditPol /get /category:*\"\n\nCompare the \"AuditPol\" settings with the following:\n\nIf the system does not audit the following, this is a finding.\n\nObject Access >> Removable Storage - Success\n\nVirtual machines or systems that use network attached storage may generate excessive audit events for secondary virtual drives or the network attached storage when this setting is enabled. This may be set to Not Configured in such cases and would not be a finding.","check_content_ref":{"href":"Microsoft_Windows_Server_2022_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Maintaining an audit trail of system activity logs can help identify configuration errors, troubleshoot service disruptions, and analyze compromises that have occurred, as well as detect attacks. Audit logs are necessary to provide a trail of evidence in case the system or network is compromised. Collecting this data is essential for analyzing the security of information assets and detecting signs of suspicious and unexpected behavior.\n\nRemovable Storage auditing under Object Access records events related to access attempts on file system objects on removable storage devices.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000172"],"reference_identifier":"6542","uuid":"ca30ed1b-7d7e-438f-9e63-5cfbe8113b36","stig_uuid":"0d0f782a-92a5-488f-9189-ef7df4f274ba","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2022_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 99C66398CCA96FD76FB3D402EE8C94250D5393D9\r\n~~~~~\r\nConfiguration for 'Windows Server 2022 must be configured to audit Object Access - Removable Storage successes.' matches the expected value on the Windows Server 2022 host."},{"group_id_src":"V-254318","group_tree":[{"id":"V-254318","title":"SRG-OS-000474-GPOS-00219","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-254318","severity":"medium","group_title":"SRG-OS-000474-GPOS-00219","rule_id_src":"SV-254318r991583_rule","rule_id":"SV-254318","rule_version":"WN22-AU-000250","rule_title":"Windows Server 2022 must be configured to audit Object Access - Removable Storage failures.","fix_text":"Configure the policy value for Computer Configuration >> Windows Settings >> Security Settings >> Advanced Audit Policy Configuration >> System Audit Policies >> Object Access >> Audit Removable Storage with \"Failure\" selected.","weight":"10.0","check_content":"Security Option \"Audit: Force audit policy subcategory settings (Windows Vista or later) to override audit policy category settings\" must be set to \"Enabled\" (WN22-SO-000050) for the detailed auditing subcategories to be effective. \n\nUse the \"AuditPol\" tool to review the current Audit Policy configuration:\n\nOpen \"PowerShell\" or a \"Command Prompt\" with elevated privileges (\"Run as administrator\").\n\nEnter \"AuditPol /get /category:*\"\n\nCompare the \"AuditPol\