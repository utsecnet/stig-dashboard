Microsoft\\Windows\\ScriptedDiagnosticsProvider\\Policy\\\n\nValue Name: DisableQueryRemoteServer\n\nType: REG_DWORD\nValue: 0","check_content_ref":{"href":"Microsoft_Windows_Server_2012-2012_R2_DC_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Some features may communicate with the vendor, sending system information or downloading data or components for the feature.  Turning off this capability will prevent potentially sensitive information from being sent outside the enterprise and uncontrolled updates to the system.  \nThis setting prevents the MSDT from communicating with and sending collected data to Microsoft, the default support provider.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["SV-53187","V-21967","CCI-000381"],"reference_identifier":"3804","uuid":"d96e731c-0154-473e-a64a-20284bd5e7ef","stig_uuid":"3c28ef40-d2e7-4de8-80c7-a2d09a1263eb","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2012R2DC_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 2DD02A5CA95454770F5A7AEF2461DC94B109B101\r\n~~~~~\r\nConfiguration for 'Microsoft Support Diagnostic Tool (MSDT) interactive communication with Microsoft must be prevented.' matches the expected value on the Windows Server 2012 R2 domain controller."},{"group_id_src":"V-226179","group_tree":[{"id":"V-226179","title":"SRG-OS-000095-GPOS-00049","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-226179","severity":"low","group_title":"SRG-OS-000095-GPOS-00049","rule_id_src":"SV-226179r794435_rule","rule_id":"SV-226179","rule_version":"WN12-CC-000067","rule_title":"Access to Windows Online Troubleshooting Service (WOTS) must be prevented.","fix_text":"Configure the policy value for Computer Configuration -> Administrative Templates -> System -> Troubleshooting and Diagnostics -> Scripted Diagnostics -> \"Troubleshooting: Allow users to access online troubleshooting content on Microsoft servers from the Troubleshooting Control Panel (via the Windows Online Troubleshooting Service - WOTS)\" to \"Disabled\".","weight":"10.0","check_content":"If the following registry value does not exist or is not configured as specified, this is a finding:\n\nRegistry Hive: HKEY_LOCAL_MACHINE\nRegistry Path: \\Software\\Policies\\Microsoft\\Windows\\ScriptedDiagnosticsProvider\\Policy\\\n\nValue Name: EnableQueryRemoteServer\n\nType: REG_DWORD\nValue: 0","check_content_ref":{"href":"Microsoft_Windows_Server_2012-2012_R2_DC_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Some features may communicate with the vendor, sending system information or downloading data or components for the feature.  Turning off this capability will prevent potentially sensitive information from being sent outside the enterprise and uncontrolled updates to the system.  \nThis setting prevents users from searching troubleshooting content on Microsoft servers.  Only local content will be available.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["V-21969","SV-53188","CCI-000381"],"reference_identifier":"3734","uuid":"4ba03e9f-0902-4fb5-903f-9c698dbc8cb3","stig_uuid":"3c28ef40-d2e7-4de8-80c7-a2d09a1263eb","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2012R2DC_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 3180E8DE5A8CC63BB61F3FEB51BB616029FF5E9C\r\n~~~~~\r\nRequired configuration for 'Access to Windows Online Troubleshooting Service (WOTS) must be prevented.' was not present or did not match the expected value on the Windows Server 2012 R2 domain controller."},{"group_id_src":"V-226180","group_tree":[{"id":"V-226180","title":"SRG-OS-000095-GPOS-00049","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-226180","severity":"low","group_title":"SRG-OS-000095-GPOS-00049","rule_id_src":"SV-226180r794436_rule","rule_id":"SV-226180","rule_version":"WN12-CC-000068","rule_title":"Responsiveness events must be prevented from being aggregated and sent to Microsoft.","fix_text":"Configure the policy value for Computer Configuration -> Administrative Templates -> System -> Troubleshooting and Diagnostics -> Windows Performance PerfTrack -> \"Enable/Disable PerfTrack\" to \"Disabled\".","weight":"10.0","check_content":"If the following registry value does not exist or is not configured as specified, this is a finding:\n\nRegistry Hive: HKEY_LOCAL_MACHINE\nRegistry Path: \\Software\\Policies\\Microsoft\\Windows\\WDI\\{9c5a40da-b965-4fc3-8781-88dd50a6299d}\\\n\nValue Name: ScenarioExecutionEnabled\n\nType: REG_DWORD\nValue: 0","check_content_ref":{"href":"Microsoft_Windows_Server_2012-2012_R2_DC_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Some features may communicate with the vendor, sending system information or downloading data or components for the feature.  Turning off this capability will prevent potentially sensitive information from being sent outside the enterprise and uncontrolled updates to the system.  \nThis setting prevents responsiveness events from being aggregated and sent to Microsoft.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["SV-53128","V-21970","CCI-000381"],"reference_identifier":"1603","uuid":"1766bca6-83fd-4333-86ff-82085b67bbad","stig_uuid":"3c28ef40-d2e7-4de8-80c7-a2d09a1263eb","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2012R2DC_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: E806F0DAC02A62815B05474AA9B39039BF8723AB\r\n~~~~~\r\nConfiguration for 'Responsiveness events must be prevented from being aggregated and sent to Microsoft.' matches the expected value on the Windows Server 2012 R2 domain controller."},{"group_id_src":"V-226181","group_tree":[{"id":"V-226181","title":"SRG-OS-000355-GPOS-00143","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-226181","severity":"low","group_title":"SRG-OS-000355-GPOS-00143","rule_id_src":"SV-226181r877038_rule","rule_id":"SV-226181","rule_version":"WN12-CC-000069","rule_title":"The time service must synchronize with an appropriate DoD time source.","fix_text":"If the system needs to be configured to an NTP server, configure the system to point to an authorized time server by setting the policy value for Computer Configuration >> Administrative Templates >> System >> Windows Time Service >> Time Providers >> \"Configure Windows NTP Client\" to \"Enabled\", and configure the \"NtpServer\" field to point to an authorized time server.   \n\nThe US Naval Observatory operates stratum 1 time servers, which are identified at:\nhttps://www.cnmoc.usff.navy.mil/Organization/United-States-Naval-Observatory/Precise-Time-Department/Network-Time-Protocol-NTP/\n\nTime synchronization will occur through a hierarchy of time servers down to the local level. Clients and lower-level servers will synchronize with an authorized time server in the hierarchy.","weight":"10.0","check_content":"Open \"Windows PowerShell\" or an elevated \"Command Prompt\" (run as administrator).\n\nEnter \"W32tm /query /configuration\".\n\nDomain-joined systems are automatically configured with a \"Type\" of \"NT5DS\" to synchronize with domain controllers and would not be a finding.\n\nIf systems are configured with a \"Type\" of \"NTP\", including standalone systems and the forest root domain controller with the PDC Emulator role, and do not have a DoD time server defined for \"NTPServer\", this is a finding. (See V-8557 in the Active Directory Forest STIG for the time source requirement of the forest root domain PDC emulator.)\n\nIf an alternate time synchronization tool is used and is not enabled or not configured to synchronize with a DoD time source, this is a finding.\n\nThe US Naval Observatory operates stratum 1 time servers, which are identified at:\nhttps://www.cnmoc.usff.navy.mil/Organization/United-States-Naval-Observatory/Precise-Time-Department/Network-Time-Protocol-NTP/\n\nTime synchronization will occur through a hierarchy of time servers down to the local level. Clients and lower-level servers will synchronize with an authorized time server in the hierarchy.","check_content_ref":{"href":"Microsoft_Windows_Server_2012-2012_R2_DC_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The Windows Time Service controls time synchronization settings. Time synchronization is essential for authentication and auditing purposes. If the Windows Time Service is used, it must synchronize with a secure, authorized time source. Domain-joined systems are automatically configured to synchronize with domain controllers. If an NTP server is configured, it must synchronize with a secure, authorized time source.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["SV-52919","V-3472","CCI-001891"],"reference_identifier":"1851","uuid":"9ea3ecc3-9907-469f-98aa-aa05b041c01c","stig_uuid":"3c28ef40-d2e7-4de8-80c7-a2d09a1263eb","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2012R2DC_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 5AD83753A3F2D9F99EB1D8D63E67BCC5FE4BE001\r\n~~~~~\r\nRequired configuration for 'The time service must synchronize with an appropriate DoD time source.' was not present or did not match the expected value on the Windows Server 2012 R2 domain controller."},{"group_id_src":"V-226182","group_tree":[{"id":"V-226182","title":"SRG-OS-000095-GPOS-00049","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-226182","severity":"low","group_title":"SRG-OS-000095-GPOS-00049","rule_id_src":"SV-226182r794437_rule","rule_id":"SV-226182","rule_version":"WN12-CC-000070","rule_title":"Trusted app installation must be enabled to allow for signed enterprise line of business apps.","fix_text":"Configure the policy value for Computer Configuration -> Administrative Templates -> Windows Components -> App Package Deployment  -> \"Allow all trusted apps to install\" to \"Enabled\".","weight":"10.0","check_content":"If the following registry value does not exist or is not configured as specified, this is a finding:\n\nRegistry Hive: HKEY_LOCAL_MACHINE\nRegistry Path: \\Software\\Policies\\Microsoft\\Windows\\Appx\\\n\nValue Name: AllowAllTrustedApps\n\nType: REG_DWORD\nValue: 1","check_content_ref":{"href":"Microsoft_Windows_Server_2012-2012_R2_DC_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Enabling trusted app installation allows for enterprise line of business Windows 8 type apps.   A trusted app package is one that is signed with a certificate chain that can be successfully validated in the enterprise.  Configuring this ensures enterprise line of business apps are accessible.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["V-36697","SV-51738","CCI-000366"],"reference_identifier":"8783","uuid":"072496de-200d-4b55-b3da-a7f310f2d903","stig_uuid":"3c28ef40-d2e7-4de8-80c7-a2d09a1263eb","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2012R2DC_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: 24B279D7518907439E0B26AD60A1A5C2715B7928\r\n~~~~~\r\nThe feature/role addressed by 'Trusted app installation must be enabled to allow for signed enterprise line of business apps.' is not present or not in use on this the Windows Server 2012 R2 domain controller."},{"group_id_src":"V-226183","group_tree":[{"id":"V-226183","title":"SRG-OS-000095-GPOS-00049","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-226183","severity":"low","group_title":"SRG-OS-000095-GPOS-00049","rule_id_src":"SV-226183r794438_rule","rule_id":"SV-226183","rule_version":"WN12-CC-000071","rule_title":"The Application Compatibility Program Inventory must be prevented from collecting data and sending the information to Microsoft.","fix_text":"Configure the policy value for Computer Configuration -> Administrative Templates -> Windows Components -> Application Compatibility -> \"Turn off Inventory Collector\" to \"Enabled\".","weight":"10.0","check_content":"If the following registry value does not exist or is not configured as specified, this is a finding:\n\nRegistry Hive: HKEY_LOCAL_MACHINE\nRegistry Path: \\Software\\Policies\\Microsoft\\Windows\\AppCompat\\\n\nValue Name: DisableInventory\n\nType: REG_DWORD\nValue: 1","check_content_ref":{"href":"Microsoft_Windows_Server_2012-2012_R2_DC_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Some features may communicate with the vendor, sending system information or downloading data or components for the feature.  Turning off this capability will prevent potentially sensitive information from being sent outside the enterprise and uncontrolled updates to the system.  \nThis setting will prevent the Program Inventory from collecting data about a system and sending the information to Microsoft.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["V-21971","SV-53127","CCI-000381"],"reference_identifier":"5181","uuid":"f36c2a0d-b7e7-4da3-be7f-6754eecf413a","stig_uuid":"3c28ef40-d2e7-4de8-80c7-a2d09a1263eb","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2012R2DC_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 34AD6DFCADBC8D2247B975E531636408A83DEF28\r\n~~~~~\r\nRequired configuration for 'The Application Compatibility Program Inventory must be prevented from collecting data and sending the information to Microsoft.' was not present or did not match the expected value on the Windows Server 2012 R2 domain controller."},{"group_id_src":"V-226184","group_tree":[{"id":"V-226184","title":"SRG-OS-000368-GPOS-00154","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-226184","severity":"high","group_title":"SRG-OS-000368-GPOS-00154","rule_id_src":"SV-226184r852100_rule","rule_id":"SV-226184","rule_version":"WN12-CC-000072","rule_title":"Autoplay must be turned off for non-volume devices.","fix_text":"Configure the policy value for Computer Configuration -> Administrative Templates -> Windows Components -> AutoPlay Policies -> \"Disallow Autoplay for non-volume devices\" to \"Enabled\".","weight":"10.0","check_content":"If the following registry value does not exist or is not configured as specified, this is a finding:\n\nRegistry Hive: HKEY_LOCAL_MACHINE\nRegistry Path: \\Software\\Policies\\Microsoft\\Windows\\Explorer\\\n\nValue Name: NoAutoplayfornonVolume\n\nType: REG_DWORD\nValue: 1","check_content_ref":{"href":"Microsoft_Windows_Server_2012-2012_R2_DC_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Allowing Autoplay to execute may introduce malicious code to a system.  Autoplay begins reading from a drive as soon as media is inserted into the drive.  As a result, the setup file of programs or music on audio media may start.  This setting will disable Autoplay for non-volume devices (such as Media Transfer Protocol (MTP) devices).","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["SV-53126","V-21973","CCI-001764"],"reference_identifier":"9949","uuid":"421f90a2-9f44-4fa6-b252-01de032fe971","stig_uuid":"3c28ef40-d2e7-4de8-80c7-a2d09a1263eb","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2012R2DC_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: EC136C795AA01F13BF227D4F6D274FCF259A41A9\r\n~~~~~\r\nRequired configuration for 'Autoplay must be turned off for non-volume devices.' was not present or did not match the expected value on the Windows Server 2012 R2 domain controller."},{"group_id_src":"V-226185","group_tree":[{"id":"V-226185","title":"SRG-OS-000368-GPOS-00154","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-226185","severity":"high","group_title":"SRG-OS-000368-GPOS-00154","rule_id_src":"SV-226185r852101_rule","rule_id":"SV-226185","rule_version":"WN12-CC-000073","rule_title":"The default Autorun behavior must be configured to prevent Autorun commands.","fix_text":"Configure the policy value for Computer Configuration -> Administrative Templates -> Windows Components -> AutoPlay Policies -> \"Set the default behavior for AutoRun\" to \"Enabled:Do not execute any autorun commands\".","weight":"10.0","check_content":"If the following registry value does not exist or is not configured as specified, this is a finding:\n\nRegistry Hive: HKEY_LOCAL_MACHINE\nRegistry Path: \\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\Explorer\\\n\nValue Name: NoAutorun\n\nType: REG_DWORD\nValue: 1","check_content_ref":{"href":"Microsoft_Windows_Server_2012-2012_R2_DC_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Allowing Autorun commands to execute may introduce malicious code to a system.  Configuring this setting prevents Autorun commands from executing.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["SV-53124","V-22692","CCI-001764"],"reference_identifier":"4904","uuid":"94d908c6-ef05-44b9-be9c-68b55d6b5076","stig_uuid":"3c28ef40-d2e7-4de8-80c7-a2d09a1263eb","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2012R2DC_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: C9EC5ECE01CD0DD184B474D34153A9AEE6DF35D9\r\n~~~~~\r\nRequired configuration for 'The default Autorun behavior must be configured to prevent Autorun commands.' was not present or did not match the expected value on the Windows Server 2012 R2 domain controller."},{"group_id_src":"V-226186","group_tree":[{"id":"V-226186","title":"SRG-OS-000368-GPOS-00154","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-226186","severity":"high","group_title":"SRG-OS-000368-GPOS-00154","rule_id_src":"SV-226186r852102_rule","rule_id":"SV-226186","rule_version":"WN12-CC-000074","rule_title":"Autoplay must be disabled for all drives.","fix_text":"Configure the policy value for Computer Configuration -> Administrative Templates -> Windows Components -> AutoPlay Policies -> \"Turn off AutoPlay\" to \"Enabled:All Drives\".","weight":"10.0","check_content":"If the following registry value does not exist or is not configured as specified, this is a finding:\n\nRegistry Hive: HKEY_LOCAL_MACHINE\nRegistry Path:  \\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\policies\\Explorer\\\n\nValue Name: NoDriveTypeAutoRun\n\nType: REG_DWORD\nValue: 0x000000ff (255)","check_content_ref":{"href":"Microsoft_Windows_Server_2012-2012_R2_DC_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Allowing Autoplay to execute may introduce malicious code to a system.  Autoplay begins reading from a drive as soon media is inserted into the drive.  As a result, the setup file of programs or music on audio media may start.  By default, Autoplay is disabled on removable drives, such as the floppy disk drive (but not the CD-ROM drive) and on network drives.  Enabling this policy disables Autoplay on all drives.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["SV-52879","V-2374","CCI-001764"],"reference_identifier":"7047","uuid":"a25e51ff-de69-4123-9d63-42a50e7c5519","stig_uuid":"3c28ef40-d2e7-4de8-80c7-a2d09a1263eb","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2012R2DC_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 02FDA25349B57AF671F2CE884BF7C8B94D8F5B59\r\n~~~~~\r\nConfiguration for 'Autoplay must be disabled for all drives.' matches the expected value on the Windows Server 2012 R2 domain controller."},{"group_id_src":"V-226187","group_tree":[{"id":"V-226187","title":"SRG-OS-000095-GPOS-00049","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-226187","severity":"medium","group_title":"SRG-OS-000095-GPOS-00049","rule_id_src":"SV-226187r794439_rule","rule_id":"SV-226187","rule_version":"WN12-CC-000075","rule_title":"The use of biometrics must be disabled.","fix_text":"Configure the policy value for Computer Configuration -> Administrative Templates -> Windows Components -> Biometrics -> \"Allow the use of biometrics\" to \"Disabled\".","weight":"10.0","check_content":"If the following registry value does not exist or is not configured as specified, this is a finding:\n\nRegistry Hive: HKEY_LOCAL_MACHINE\nRegistry Path: \\SOFTWARE\\Policies\\Microsoft\\Biometrics\\\n\nValue Name: Enabled\n\nType: REG_DWORD\nValue: 0","check_content_ref":{"href":"Microsoft_Windows_Server_2012-2012_R2_DC_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Allowing biometrics may bypass required authentication methods.  Biometrics may only be used as an additional authentication factor where an enhanced strength of identity credential is necessary or desirable.  Additional factors must be met per DoD policy.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["SV-51739","V-36698","CCI-000381"],"reference_identifier":"5960","uuid":"4a80a421-5dd3-40f1-91f2-dc319f8b2ddf","stig_uuid":"3c28ef40-d2e7-4de8-80c7-a2d09a1263eb","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2012R2DC_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: B1B87B052A048508299D054303F8210B8C0A4C3F\r\n~~~~~\r\nRequired configuration for 'The use of biometrics must be disabled.' was not present or did not match the expected value on the Windows Server 2012 R2 domain controller."},{"group_id_src":"V-226188","group_tree":[{"id":"V-226188","title":"SRG-OS-000079-GPOS-00047","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-226188","severity":"medium","group_title":"SRG-OS-000079-GPOS-00047","rule_id_src":"SV-226188r794410_rule","rule_id":"SV-226188","rule_version":"WN12-CC-000076","rule_title":"The password reveal button must not be displayed.","fix_text":"Configure the policy value for Computer Configuration -> Administrative Templates -> Windows Components -> Credential User Interface -> \"Do not display the password reveal button\" to \"Enabled\".","weight":"10.0","check_content":"If the following registry value does not exist or is not configured as specified, this is a finding:\n\nRegistry Hive: HKEY_LOCAL_MACHINE\nRegistry Path: \\Software\\Policies\\Microsoft\\Windows\\CredUI\\\n\nValue Name: DisablePasswordReveal\n\nType: REG_DWORD\nValue: 1","check_content_ref":{"href":"Microsoft_Windows_Server_2012-2012_R2_DC_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Visible passwords may be seen by nearby persons, compromising them.  The password reveal button can be used to display an entered password and must not be allowed.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["V-36700","SV-51740","CCI-000206"],"reference_identifier":"6996","uuid":"9aa4c126-6320-40b0-9ac0-3224f2a421a2","stig_uuid":"3c28ef40-d2e7-4de8-80c7-a2d09a1263eb","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2012R2DC_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 878D44BAE69873E8E99D02FD4D048ABB0D8C17B2\r\n~~~~~\r\nConfiguration for 'The password reveal button must not be displayed.' matches the expected value on the Windows Server 2012 R2 domain controller."},{"group_id_src":"V-226189","group_tree":[{"id":"V-226189","title":"SRG-OS-000134-GPOS-00068","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-226189","severity":"medium","group_title":"SRG-OS-000134-GPOS-00068","rule_id_src":"SV-226189r794453_rule","rule_id":"SV-226189","rule_version":"WN12-CC-000077","rule_title":"Administrator accounts must not be enumerated during elevation.","fix_text":"Configure the policy value for Computer Configuration >> Administrative Templates >> Windows Components >> Credential User Interface >> \"Enumerate administrator accounts on elevation\" to \"Disabled\".","weight":"10.0","check_content":"If the following registry value does not exist or is not configured as specified, this is a finding:\n\nRegistry Hive: HKEY_LOCAL_MACHINE\nRegistry Path: \\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\CredUI\\\n\nValue Name: EnumerateAdministrators\n\nType: REG_DWORD\nValue: 0x00000000 (0)","check_content_ref":{"href":"Microsoft_Windows_Server_2012-2012_R2_DC_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Enumeration of administrator accounts when elevating can provide part of the logon information to an unauthorized user.  This setting configures the system to always require users to enter in a username and password to elevate a running application.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["V-14243","SV-52955","CCI-001084"],"reference_identifier":"2980","uuid":"48795766-7c75-4445-b177-336934999798","stig_uuid":"3c28ef40-d2e7-4de8-80c7-a2d09a1263eb","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2012R2DC_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: 388D36267B9876A8AD7B76D8031623E6B26DACD2\r\n~~~~~\r\nThe feature/role addressed by 'Administrator accounts must not be enumerated during elevation.' is not present or not in use on this the Windows Server 2012 R2 domain controller."},{"group_id_src":"V-226190","group_tree":[{"id":"V-226190","title":"SRG-OS-000341-GPOS-00132","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-226190","severity":"medium","group_title":"SRG-OS-000341-GPOS-00132","rule_id_src":"SV-226190r877391_rule","rule_id":"SV-226190","rule_version":"WN12-CC-000084","rule_title":"The Application event log size must be configured to 32768 KB or greater.","fix_text":"Configure the policy value for Computer Configuration >> Administrative Templates >> Windows Components >> Event Log Service >> Application >> \"Specify the maximum log file size (KB)\" to \"Enabled\" with a \"Maximum Log Size (KB)\" of \"32768\" or greater.","weight":"10.0","check_content":"If the system is configured to write events directly to an audit server, this is NA.\n\nIf the following registry value does not exist or is not configured as specified, this is a finding:\n\nRegistry Hive: HKEY_LOCAL_MACHINE\nRegistry Path: \\SOFTWARE\\Policies\\Microsoft\\Windows\\EventLog\\Application\\\n\nValue Name: MaxSize\n\nType: REG_DWORD\nValue: 0x00008000 (32768) (or greater)","check_content_ref":{"href":"Microsoft_Windows_Server_2012-2012_R2_DC_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Inadequate log size will cause the log to fill up quickly. This may prevent audit events from being recorded properly and require frequent attention by administrative personnel.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["SV-52966","V-26579","CCI-001849"],"reference_identifier":"2882","uuid":"7797b0bc-b39a-4acd-96c9-a2a0806cc983","stig_uuid":"3c28ef40-d2e7-4de8-80c7-a2d09a1263eb","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-WindowsServer2012R2DC_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 00CDA7103B5E01DA59EA34B3B6CAF6E00E570A40\r\n~~~~~\r\nRequired configuration for 'The Application event log size must be configured to 32768 KB or greater.' was not present or did not match the expected value on the Windows Server 2012 R2 domain controller."},{"group_id_src":"V-22