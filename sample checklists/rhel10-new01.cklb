ng, and termination events that affect \"/var/log/faillock\".","fix_text":"Configure RHEL 10 to generate audit records for all account creations, modifications, disabling, and termination events that affect \"/var/log/faillock\".\n\nAdd or update the following file system rule to \"/etc/audit/rules.d/audit.rules\":\n\n-a always,exit -F arch=b32 -F path=/var/log/faillock -F perm=wa -F key=identity\n-a always,exit -F arch=b64 -F path=/var/log/faillock -F perm=wa -F key=identity\n\nRestart the audit daemon with the following command for the changes to take effect:\n\n$ sudo service auditd restart","weight":"10.0","check_content":"Verify RHEL 10 generates audit records for all account creations, modifications, disabling, and termination events that affect \"/var/log/faillock\" with the following command:\n\n$ sudo auditctl -l | grep /var/log/faillock\n-a always,exit -F arch=b32 -F path=/var/log/faillock -F perm=wa -F key=identity\n-a always,exit -F arch=b64 -F path=/var/log/faillock -F perm=wa -F key=identity\n\nIf the command does not return a line, or the line is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Without generating audit records specific to the security and mission needs of the organization, it would be difficult to establish, correlate, and investigate the events relating to an incident or identify those responsible for one.\n\nSatisfies: SRG-OS-000392-GPOS-00172, SRG-OS-000470-GPOS-00214, SRG-OS-000473-GPOS-00218","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002884","CCI-000172"],"reference_identifier":"6165","uuid":"0711edae-04d6-4264-9d5b-a6bdec43dcce","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 8CADF778406AF2F6CDB7CC2DD144C328578F21EE\r\n~~~~~\r\nConfiguration for 'RHEL 10 must generate audit records for all account creations, modifications, disabling, and termination events that affect \"/var/log/faillock\".' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281162","group_tree":[{"id":"V-281162","title":"SRG-OS-000037-GPOS-00015","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281162","severity":"medium","group_title":"SRG-OS-000037-GPOS-00015","rule_id_src":"SV-281162r1166438_rule","rule_id":"SV-281162","rule_version":"RHEL-10-500760","rule_title":"RHEL 10 must generate audit records for all account creations, modifications, disabling, and termination events that affect \"/var/log/lastlog\".","fix_text":"Configure RHEL 10 to generate audit records for all account creations, modifications, disabling, and termination events that affect \"/var/log/lastlog\".\n\nAdd or update the following file system rule to \"/etc/audit/rules.d/audit.rules\":\n\n-a always,exit -F arch=b32 -F path=/var/log/lastlog -F perm=wa -F key=logins\n-a always,exit -F arch=b64 -F path=/var/log/lastlog -F perm=wa -F key=logins\n\nRestart the audit daemon with the following command for the changes to take effect:\n\n$ sudo service auditd restart","weight":"10.0","check_content":"Verify RHEL 10 generates audit records for all account creations, modifications, disabling, and termination events that affect \"/var/log/lastlog\" with the following command:\n\n$ sudo auditctl -l | grep /var/log/lastlog\n-a always,exit -F arch=b32 -F path=/var/log/lastlog -F perm=wa -F key=logins\n-a always,exit -F arch=b64 -F path=/var/log/lastlog -F perm=wa -F key=logins\n\nIf the command does not return a line, or the line is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Without generating audit records specific to the security and mission needs of the organization, it would be difficult to establish, correlate, and investigate the events relating to an incident or identify those responsible for one.\n\nSatisfies: SRG-OS-000037-GPOS-00015, SRG-OS-000042-GPOS-00020, SRG-OS-000062-GPOS-00031, SRG-OS-000392-GPOS-00172, SRG-OS-000462-GPOS-00206, SRG-OS-000471-GPOS-00215, SRG-OS-000473-GPOS-00218, SRG-OS-000470-GPOS-00214","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000130","CCI-000135","CCI-000169","CCI-002884","CCI-000172"],"reference_identifier":"1987","uuid":"2ef76e56-65a7-48f0-9e06-6414dfdccf4a","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 371DB7FF4BFB445805BE4BA1E301CD9D06C9C80C\r\n~~~~~\r\nConfiguration for 'RHEL 10 must generate audit records for all account creations, modifications, disabling, and termination events that affect \"/var/log/lastlog\".' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281163","group_tree":[{"id":"V-281163","title":"SRG-OS-000037-GPOS-00015","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281163","severity":"medium","group_title":"SRG-OS-000037-GPOS-00015","rule_id_src":"SV-281163r1166441_rule","rule_id":"SV-281163","rule_version":"RHEL-10-500780","rule_title":"RHEL 10 must generate audit records for all uses of the \"chmod\", \"fchmod\", \"fchmodat\", and \"fchmodat2\" syscalls.","fix_text":"Configure RHEL 10 to generate audit records upon successful and unsuccessful attempts to use the \"chmod\", \"fchmod\", \"fchmodat\", and \"fchmodat2\" syscalls.\n\nAdd or update the following rules in \"/etc/audit/rules.d/audit.rules\":\n\n-a always,exit -F arch=b32 -S chmod,fchmod,fchmodat,fchmodat2 -F auid>=1000 -F auid!=unset -k perm_mod\n\n-a always,exit -F arch=b64 -S chmod,fchmod,fchmodat,fchmodat2 -F auid>=1000 -F auid!=unset -k perm_mod\n\nRestart the audit daemon with the following command for the changes to take effect:\n\n$ sudo service auditd restart","weight":"10.0","check_content":"Verify RHEL 10 is configured to audit the execution of the \"chmod\", \"fchmod\", \"fchmodat\", and \"fchmodat2\" syscalls with the following command:\n\n$ sudo auditctl -l | grep chmod\n-a always,exit -F arch=b32 -S chmod,fchmod,fchmodat,fchmodat2 -F auid>=1000 -F auid!=unset -k perm_mod\n-a always,exit -F arch=b64 -S chmod,fchmod,fchmodat,fchmodat2 -F auid>=1000 -F auid!=unset -k perm_mod\n\nIf both the \"b32\" and \"b64\" audit rules are not defined for the \"chmod\", \"fchmod\", \"fchmodat\", and \"fchmodat2\" syscalls, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Without generating audit records that are specific to the security and mission needs of the organization, it would be difficult to establish, correlate, and investigate the events relating to an incident or identify those responsible for one.\n\nAudit records can be generated from various components within the information system (e.g., module or policy filter).\n\nWhen a user logs on, the auid is set to the uid of the account that is being authenticated. Daemons are not user sessions and have the loginuid set to -1. The auid representation is an unsigned 32-bit integer, which equals 4294967295. The audit system interprets -1, 4294967295, and \"unset\" in the same way.\n\nThe system call rules are loaded into a matching engine that intercepts each syscall made by all programs on the system. Therefore, it is very important to use syscall rules only when absolutely necessary because these affect performance. More rules lead to poorer performance. The performance can be helped, however, by combining syscalls into one rule whenever possible.\n\nSatisfies: SRG-OS-000037-GPOS-00015, SRG-OS-000042-GPOS-00020, SRG-OS-000062-GPOS-00031, SRG-OS-000392-GPOS-00172, SRG-OS-000462-GPOS-00206, SRG-OS-000471-GPOS-00215, SRG-OS-000064-GPOS-00033, SRG-OS-000466-GPOS-00210, SRG-OS-000458-GPOS-00203","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000130","CCI-000135","CCI-000169","CCI-002884","CCI-000172"],"reference_identifier":"7083","uuid":"7acc44e2-ca1b-46bc-8535-39826a093c36","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 97F6F384483F8C2EB13961DB7800B37ECDBB6C57\r\n~~~~~\r\nConfiguration for 'RHEL 10 must generate audit records for all uses of the \"chmod\", \"fchmod\", \"fchmodat\", and \"fchmodat2\" syscalls.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281164","group_tree":[{"id":"V-281164","title":"SRG-OS-000037-GPOS-00015","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281164","severity":"medium","group_title":"SRG-OS-000037-GPOS-00015","rule_id_src":"SV-281164r1166444_rule","rule_id":"SV-281164","rule_version":"RHEL-10-500790","rule_title":"RHEL 10 must generate audit records for all uses of the \"chown\", \"fchown\", \"fchownat\", and \"lchown\" syscalls.","fix_text":"Configure RHEL 10 to generate audit records upon successful/unsuccessful attempts to use the \"chown\", \"fchown\", \"fchownat\", and \"lchown\"\" syscalls.\n\nAdd or update the following rules in \"/etc/audit/rules.d/audit.rules\":\n\n-a always,exit -F arch=b32 -S chown,fchown,fchownat,lchown -F auid>=1000 -F auid!=unset -k perm_mod\n-a always,exit -F arch=b64 -S chown,fchown,fchownat,lchown -F auid>=1000 -F auid!=unset -k perm_mod\n\nRestart the audit daemon with the following command for the changes to take effect:\n\n$ sudo service auditd restart","weight":"10.0","check_content":"Verify RHEL 10 is configured to audit the execution of the \"chown\", \"fchown\", \"fchownat\", and \"lchown\" syscalls with the following command:\n\n$ sudo auditctl -l | grep chown\n-a always,exit -F arch=b32 -S chown,fchown,fchownat,lchown -F auid>=1000 -F auid!=unset -k perm_mod\n-a always,exit -F arch=b64 -S chown,fchown,fchownat,lchown -F auid>=1000 -F auid!=unset -k perm_mod\n\nIf both the \"b32\" and \"b64\" audit rules are not defined for the \"chown\", \"fchown\", \"fchownat\", and \"lchown\" syscalls, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Without generating audit records that are specific to the security and mission needs of the organization, it would be difficult to establish, correlate, and investigate the events relating to an incident or identify those responsible for one.\n\nAudit records can be generated from various components within the information system (e.g., module or policy filter).\n\nWhen a user logs on, the auid is set to the uid of the account that is being authenticated. Daemons are not user sessions and have the loginuid set to -1. The auid representation is an unsigned 32-bit integer, which equals 4294967295. The audit system interprets -1, 4294967295, and \"unset\" in the same way.\n\nThe system call rules are loaded into a matching engine that intercepts each syscall made by all programs on the system. Therefore, it is very important to use syscall rules only when absolutely necessary because these affect performance. More rules lead to poorer performance. The performance can be helped, however, by combining syscalls into one rule whenever possible.\n\nSatisfies: SRG-OS-000037-GPOS-00015, SRG-OS-000042-GPOS-00020, SRG-OS-000062-GPOS-00031, SRG-OS-000392-GPOS-00172, SRG-OS-000462-GPOS-00206, SRG-OS-000471-GPOS-00215, SRG-OS-000064-GPOS-00033, SRG-OS-000466-GPOS-00210, SRG-OS-000458-GPOS-00203, SRG-OS-000474-GPOS-00219","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000130","CCI-000135","CCI-000169","CCI-002884","CCI-000172"],"reference_identifier":"3497","uuid":"72fb827b-d756-4bb7-8bc4-fbbc926adf5e","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: C85C9DF9EA425236C8634CF4957B6789C61784F5\r\n~~~~~\r\nConfiguration for 'RHEL 10 must generate audit records for all uses of the \"chown\", \"fchown\", \"fchownat\", and \"lchown\" syscalls.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281165","group_tree":[{"id":"V-281165","title":"SRG-OS-000037-GPOS-00015","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281165","severity":"medium","group_title":"SRG-OS-000037-GPOS-00015","rule_id_src":"SV-281165r1166447_rule","rule_id":"SV-281165","rule_version":"RHEL-10-500810","rule_title":"RHEL 10 must generate audit records for all uses of the \"rename\", \"unlink\", \"rmdir\", \"renameat\", \"renameat2\", and \"unlinkat\" system calls.","fix_text":"Configure RHEL 10 to generate an audit event for any successful/unsuccessful use of the \"rename\", \"unlink\", \"rmdir\", \"renameat\", \"renameat2\", and \"unlinkat\" system calls by adding or updating the following rules in the \"/etc/audit/rules.d/audit.rules\" file:\n\n-a always,exit -F arch=b32 -S rename,unlink,rmdir,renameat,renameat2,unlinkat -F auid>=1000 -F auid!=unset -k delete\n-a always,exit -F arch=b64 -S rename,unlink,rmdir,renameat,renameat2,unlinkat -F auid>=1000 -F auid!=unset -k delete\n\nRestart the audit daemon with the following command for the changes to take effect:\n\n$ sudo service auditd restart","weight":"10.0","check_content":"Verify RHEL 10 is configured to audit successful/unsuccessful attempts to use the \"rename\", \"unlink\", \"rmdir\", \"renameat\", \"renameat2\", and \"unlinkat\" system calls with the following command:\n\n$ sudo auditctl -l | grep 'rename\\|unlink\\|rmdir'\n-a always,exit -F arch=b32 -S rename,unlink,rmdir,renameat,renameat2,unlinkat -F auid>=1000 -F auid!=unset -k delete\n-a always,exit -F arch=b64 -S rename,unlink,rmdir,renameat,renameat2,unlinkat -F auid>=1000 -F auid!=unset -k delete\n\nIf the command does not return an audit rule for \"rename\", \"unlink\", \"rmdir\", \"renameat\", and \"unlinkat\", or any of the lines returned are commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Without generating audit records that are specific to the security and mission needs of the organization, it would be difficult to establish, correlate, and investigate the events relating to an incident or identify those responsible for one.\n\nAudit records can be generated from various components within the information system (e.g., module or policy filter).\n\nWhen a user logs on, the auid is set to the uid of the account that is being authenticated. Daemons are not user sessions and have the loginuid set to -1. The auid representation is an unsigned 32-bit integer, which equals 4294967295. The audit system interprets -1, 4294967295, and \"unset\" in the same way.\n\nThe system call rules are loaded into a matching engine that intercepts each syscall made by all programs on the system. Therefore, it is very important to use syscall rules only when absolutely necessary because these affect performance. More rules lead to poorer performance. The performance can be helped, however, by combining syscalls into one rule whenever possible.\n\nSatisfies: SRG-OS-000037-GPOS-00015, SRG-OS-000042-GPOS-00020, SRG-OS-000062-GPOS-00031, SRG-OS-000392-GPOS-00172, SRG-OS-000462-GPOS-00206, SRG-OS-000471-GPOS-00215, SRG-OS-000466-GPOS-00210, SRG-OS-000467-GPOS-00211, SRG-OS-000468-GPOS-00212","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000130","CCI-000135","CCI-000169","CCI-002884","CCI-000172"],"reference_identifier":"4125","uuid":"bad2e5ee-02c6-47eb-9217-340ddea7e4a3","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: E418EB57E1D102B9C7D89A2D9E1C6F3598047D98\r\n~~~~~\r\nConfiguration for 'RHEL 10 must generate audit records for all uses of the \"rename\", \"unlink\", \"rmdir\", \"renameat\", \"renameat2\", and \"unlinkat\" system calls.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281166","group_tree":[{"id":"V-281166","title":"SRG-OS-000080-GPOS-00048","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281166","severity":"medium","group_title":"SRG-OS-000080-GPOS-00048","rule_id_src":"SV-281166r1166450_rule","rule_id":"SV-281166","rule_version":"RHEL-10-600000","rule_title":"RHEL 10 must require a boot loader superuser password.","fix_text":"Configure RHEL 10 to require a grub bootloader password for the grub superuser account.\n\nGenerate an encrypted grub2 password for the grub superuser account with the following command:\n\n$ sudo grub2-setpassword\nEnter password:\nConfirm password:","weight":"10.0","check_content":"Verify RHEL 10 requires a boot loader superuser password with the following command:\n\n$ sudo grep password_pbkdf2 /etc/grub2.cfg\n     password_pbkdf2  <superusers-accountname>   ${GRUB2_PASSWORD}\n\nTo verify the boot loader superuser account password has been set and the password encrypted, run the following command:\n\n$ sudo cat /boot/grub2/user.cfg\nGRUB2_PASSWORD=grub.pbkdf2.sha512.10000.C4E08AC72FBFF7E837FD267BFAD7AEB3D42DDC\n2C99F2A94DD5E2E75C2DC331B719FE55D9411745F82D1B6CFD9E927D61925F9BBDD1CFAA0080E0\n916F7AB46E0D.1302284FCCC52CD73BA3671C6C12C26FF50BA873293B24EE2A96EE3B57963E6D7\n0C83964B473EC8F93B07FE749AA6710269E904A9B08A6BBACB00A2D242AD828\n\nIf a \"GRUB2_PASSWORD\" is not set, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"To mitigate the risk of unauthorized access to sensitive information by entities that have been issued certificates by DOD-approved PKIs, all DOD systems (e.g., web servers and web portals) must be properly configured to incorporate access control methods that do not rely solely on the possession of a certificate for access. \n\nSuccessful authentication must not automatically give an entity access to an asset or security boundary. Authorization procedures and controls must be implemented to ensure each authenticated entity also has a validated and current authorization. Authorization is the process of determining whether an entity, once authenticated, is permitted to access a specific asset. Information systems use access control policies and enforcement mechanisms to implement this requirement.\n\nPassword protection on the boot loader configuration ensures users with physical access cannot trivially alter important bootloader settings. These include which kernel to use and whether to enter single-user mode.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000213"],"reference_identifier":"2591","uuid":"8cfe304c-f0e9-49a1-9db3-0071451fe4fa","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 6D8803A539091178056633CD2EF990D903ED1325\r\n~~~~~\r\nConfiguration for 'RHEL 10 must require a boot loader superuser password.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281167","group_tree":[{"id":"V-281167","title":"SRG-OS-000080-GPOS-00048","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281167","severity":"medium","group_title":"SRG-OS-000080-GPOS-00048","rule_id_src":"SV-281167r1166453_rule","rule_id":"SV-281167","rule_version":"RHEL-10-600010","rule_title":"RHEL 10 must require a unique superusers name upon booting into single-user and maintenance modes.","fix_text":"Configure RHEL 10 to have a unique username for the grub superuser account.\n\nEdit the \"/etc/grub.d/01_users\" file and add or modify the following lines with a nondefault username for the superuser account:\n\nset superusers=\"<accountname>\"\nexport superusers\n\nOnce the superuser account has been added, update the \"grub.cfg\" file by regenerating the GRUB configuration with the following command:\n\n$ sudo grub2-mkconfig -o /boot/grub2/grub.cfg --update-bls-cmdline\n\nReboot the system:\n\n$ sudo reboot","weight":"10.0","check_content":"Verify RHEL 10 requires a unique superusers name upon booting into single-user and maintenance modes.\n\nVerify that the boot loader superuser account has been set with the following command:\n\n$ sudo grep -A1 \"superusers\" /etc/grub2.cfg\nset superusers=\"<accountname>\"\nexport superusers\npassword_pbkdf2 <accountname> ${GRUB2_PASSWORD}\n\nVerify <accountname> is not a common name such as root, admin, or administrator.\n\nIf superusers contains easily guessable usernames, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Having a nondefault grub superuser username makes password-guessing attacks less effective.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000213"],"reference_identifier":"2734","uuid":"b03c0f48-4d8b-4225-856a-dd46cb154036","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 8589701DA7DC8BF86AB7CEC280461359CCFDF4F4\r\n~~~~~\r\nConfiguration for 'RHEL 10 must require a unique superusers name upon booting into single-user and maintenance modes.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281168","group_tree":[{"id":"V-281168","title":"SRG-OS-000445-GPOS-00199","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281168","severity":"medium","group_title":"SRG-OS-000445-GPOS-00199","rule_id_src":"SV-281168r1195416_rule","rule_id":"SV-281168","rule_version":"RHEL-10-600020","rule_title":"RHEL 10 must not assign an interactive login shell for system accounts.","fix_text":"Configure RHEL 10 so that all noninteractive accounts on the system do not have an interactive shell assigned to them.\n\nIf the system account needs a shell assigned for mission operations, document the need with the ISSO.\n\nRun the following command to disable the interactive shell for a specific noninteractive user account:\n\nReplace <user> with the user that has a login shell.\n\n$ sudo usermod --shell /sbin/nologin <user>\n\nDo not perform the steps in this section on the root account. Doing so will cause the system to become inaccessible.","weight":"10.0","check_content":"Verify RHEL 10 system accounts do not have an interactive login shell with the following command:\n\n$ awk -F: '($3<1000){print $1 \":\" $3 \":\" $7}' /etc/passwd\nroot:0:/bin/bash\nbin:1:/sbin/nologin\ndaemon:2:/sbin/nologin\nadm:3:/sbin/nologin\nlp:4:/sbin/nologin\n\nIdentify the listed system accounts that have a shell other than nologin.\n\nIf any system account (other than the root account) has a login shell and it is not documented with the information system security officer (ISSO), this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Ensuring shells are not given to system accounts upon login makes it more difficult for attackers to use system accounts.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002696"],"reference_identifier":"1581","uuid":"036b15de-bbdd-494d-84e9-294b55d8f9b2","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: C5D42873FDFD44686DE5EFBA1A31FFE884EF28D3\r\n~~~~~\r\nConfiguration for 'RHEL 10 must not assign an interactive login shell for system accounts.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281169","group_tree":[{"id":"V-281169","title":"SRG-OS-000076-GPOS-00044","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281169","severity":"medium","group_title":"SRG-OS-000076-GPOS-00044","rule_id_src":"SV-281169r1166459_rule","rule_id":"SV-281169","rule_version":"RHEL-10-600100","rule_title":"RHEL 10 must, for new users or password changes, have a 60-day maximum password lifetime restriction for user account passwords in \"/etc/login.defs\".","fix_text":"Configure RHEL 10 to enforce a 60-day maximum password lifetime.\n\nAdd or modify the following line in the \"/etc/login.defs\" file:\n\nPASS_MAX_DAYS 60","weight":"10.0","check_content":"Verify RHEL 10 enforces a 60-day maximum password lifetime for new user accounts by running the following command:\n\n$ sudo grep -i pass_max_days /etc/login.defs\nPASS_MAX_DAYS 60\n\nIf the \"PASS_MAX_DAYS\" parameter value is greater than \"60\" or is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Any password, no matter how complex, can eventually be cracked; therefore, passwords must be changed periodically. If the operating system does not limit the lifetime of passwords and force users to change their passwords, there is the risk that the operating system passwords could be compromised.\n\nSetting the password maximum age ensures users are required to periodically change their passwords. Requiring shorter password lifetimes increases the risk of users writing down the password in a convenient location subject to physical compromise.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066"],"reference_identifier":"7695","uuid":"1da75401-5747-4d68-9fa9-20ead0df3fec","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: A5CA0B75F6CFC1287860A391C0ED00639716CA54\r\n~~~~~\r\nConfiguration for 'RHEL 10 must, for new users or password changes, have a 60-day maximum password lifetime restriction for user account passwords in \"/etc/login.defs\".' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281170","group_tree":[{"id":"V-281170","title":"SRG-OS-000076-GPOS-00044","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281170","severity":"medium","group_title":"SRG-OS-000076-GPOS-00044","rule_id_src":"SV-281170r1184651_rule","rule_id":"SV-281170","rule_version":"RHEL-10-600110","rule_title":"RHEL 10 must, for user account passwords, have a 60-day maximum password lifetime restriction.","fix_text":"Configure RHEL 10 to enforce a 60-day maximum password lifetime restriction on user account passwords.\n\nSet the 60-day maximum password lifetime restriction with the following command:\n\n$ sudo passwd -x 60 [user]","weight":"10.0","check_content":"Verify RHEL 10 enforces a 60-day maximum time period for existing user account passwords with the following commands:\n\n$ sudo awk -F: '$5 > 60 {print $1 \"\" \"\" $5}' /etc/shadow\n\n$ sudo awk -F: '$5 <= 0 {print $1 \"\" \"\" $5}' /etc/shadow\n\nIf any results are returned that are not associated with a system account, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Any password, no matter how complex, can eventually be cracked. Therefore, passwords must be changed periodically. If the operating system does not limit the lifetime of passwords and force users to change their passwords, there is the risk that the operating system passwords could be compromised.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066"],"reference_identifier":"1066","uuid":"623a69b9-5039-432e-b2a6-ae918cc23123","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-281171","group_tree":[{"id":"V-281171","title":"SRG-OS-000433-GPOS-00192","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281171","severity":"medium","group_title":"SRG-OS-000433-GPOS-00192","rule_id_src":"SV-281171r1166465_rule","rule_id":"SV-281171","rule_version":"RHEL-10-600120","rule_title":"RHEL 10 must assign a home directory for local interactive user accounts upon creation.","fix_text":"Configure RHEL 10 to assign home directories to all new local interactive users by setting the \"CREATE_HOME\" parameter in \"/etc/login.defs\" to \"yes\" as follows:\n\nCREATE_HOME yes","weight":"10.0","check_content":"Verify RHEL 10 assigns a home directory for local interactive user accounts upon creation with the following command:\n\n$ sudo grep -i create_home /etc/login.defs\nCREATE_HOME yes\n\nIf the value for \"CREATE_HOME\" parameter is not set to \"yes\", the line is missing, or the line is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If local interactive users are not assigned a valid home directory, there is no place for the storage and control of files they should own.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002824"],"reference_identifier":"2775","uuid":"efd41195-bcdf-407c-88b0-b8a1237aa479","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: AF87E9C28DEAC9AA61BEC21A5B898B1694D3E0A1\r\n~~~~~\r\nConfiguration for 'RHEL 10 must assign a home directory for local interactive user accounts upon creation.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281172","group_tree":[{"id":"V-281172","title":"SRG-OS-000104-GPOS-00051","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281172","severity":"medium","group_title":"SRG-OS-000104-GPOS-00051","rule_id_src":"SV-281172r1166468_rule","rule_id":"SV-281172","rule_version":"RHEL-10-600130","rule_title":"RHEL 10 must not allow duplicate user IDs (UIDs) to exist for interactive users.","fix_text":"Configure RHEL 10 to not allow duplicate UIDs to exist for interactive users.\n\nEdit the file \"/etc/passwd\", and provide each interactive user account that has a duplicate UID with a unique UID.","weight":"10.0","check_content":"Verify RHEL 10 contains no duplicate UIDs for interactive users with the following command:\n\n$ sudo awk -F \":\" 'list[$3]++{print $1, $3}' /etc/passwd\n\nIf output is produced and the accounts listed are interactive user accounts, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"To ensure accountability and prevent unauthenticated access, interactive users must be identified and authenticated to prevent potential misuse and compromise of the system.\n\nSatisfies: SRG-OS-000104-GPOS-00051, SRG-OS-000121-GPOS-00062","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000764","CCI-000804"],"reference_identifier":"2196","uuid":"b34c2b66-5729-4126-8ec2-50fae7f802e4","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 747A621E787DE59164605C04A8E13E5ECBA87E90\r\n~~~~~\r\nConfiguration for 'RHEL 10 must not allow duplicate user IDs (UIDs) to exist for interactive users.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281173","group_tree":[{"id":"V-281173","title":"SRG-OS-000123-GPOS-00064","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281173","severity":"medium","group_title":"SRG-OS-000123-GPOS-00064","rule_id_src":"SV-281173r1166471_rule","rule_id":"SV-281173","rule_version":"RHEL-10-600140","rule_title":"RHEL 10 must automatically expire temporary accounts within 72 hours.","fix_text":"Configure RHEL 10 to expire temporary accounts after 72 hours with the following command:\n\n$ sudo chage -E $(date -d +3days +%Y-%m-%d) <temporary_account_name>","weight":"10.0","check_content":"Verify RHEL 10 automatically expires temporary accounts within 72 hours.\n\nFor every existing temporary account, run the following command to obtain its account expiration information:\n\n$ sudo chage -l <temporary_account_name> | grep -i \"account expires\"\n\nVerify each of these accounts has an expiration date set within 72 hours.\n\nIf any temporary accounts have no expiration date set or do not expire within 72 hours, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Temporary accounts are privileged or nonprivileged accounts that are established during pressing circumstances, such as new software or hardware configuration or an incident response, where the need for prompt account activation requires bypassing normal account authorization procedures. If any inactive temporary accounts are left enabled on the system and are not manually removed or automatically expired within 72 hours, the security posture of the system will be degraded and exposed to exploitation by unauthorized users or insider threat actors.\n\nTemporary accounts are different from emergency accounts. Emergency accounts, also known as \"last resort\" or \"break glass\" accounts, are local login accounts enabled on the system for emergency use by authorized system administrators to manage a system when standard login methods are failing or not available. Emergency accounts are not subject to manual removal or scheduled expiration requirements.\n\nThe automatic expiration of temporary accounts may be extended as needed by the circumstances, but it must not be extended indefinitely. A documented permanent account should be established for privileged users who need long-term maintenance accounts.\n\nSatisfies: SRG-OS-000123-GPOS-00064, SRG-OS-000002-GPOS-00002","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001682","CCI-000016"],"reference_identifier":"5613","uuid":"f7076e19-4c60-43ef-b15d-719893cef384","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 494628E8A16D1157AEC150332393D36FC99FA3B5\r\n~~~~~\r\nConfiguration for 'RHEL 10 must automatically expire temporary accounts within 72 hours.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281174","group_tree":[{"id":"V-281174","title":"SRG-OS-000104-GPOS-00051","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281174","severity":"medium","group_title":"SRG-OS-000104-GPOS-00051","rule_id_src":"SV-281174r1166474_rule","rule_id":"SV-281174","rule_version":"RHEL-10-600150","rule_title":"RHEL 10 must assign a primary group to all interactive users.","fix_text":"Configure RHEL 10 so that all GIDs referenced in \"/etc/passwd\" are defined in \"/etc/group\".\n\nEdit the file \"/etc/passwd\" and ensure that every user's GID is a valid GID.","weight":"10.0","check_content":"Verify RHEL 10 interactive users have a valid GID.\n\nCheck that the interactive users have a valid GID with the following command:\n\n$ sudo pwck -r\n\nIf pwck reports \"no group\" for any interactive user, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If a user is assigned the group identifier (GID) of a group that does not exist on the system, and a group with the GID is subsequently created, the user may have unintended rights to any files associated with the group.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000764"],"reference_identifier":"7257","uuid":"010ad2f4-5c9a-4a6d-b10b-610659d7eb0c","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: B6CDE64FEF7FAEE758DCB5FE45B40F468FB10E2E\r\n~~~~~\r\nConfiguration for 'RHEL 10 must assign a primary group to all interactive users.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281175","group_tree":[{"id":"V-281175","title":"SRG-OS-000118-GPOS-00060","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281175","severity":"medium","group_title":"SRG-OS-000118-GPOS-00060","rule_id_src":"SV-281175r1197238_rule","rule_id":"SV-281175","rule_version":"RHEL-10-600160","rule_title":"RHEL 10 must disable account identifiers (individuals, groups, roles, and devices) after 35 days of inactivity.","fix_text":"Configure RHEL 10 to disable account identifiers after 35 days of inactivity after the password expiration.\n\nRun the following command to change the configuration for \"useradd\":\n\n$ sudo useradd -D -f 35\n\nA recommendation is 35 days, but a lower value is acceptable.","weight":"10.0","check_content":"Verify RHEL 10 account identifiers (individuals, groups, roles, and devices) are disabled after 35 days of inactivity.\n\nCheck the account inactivity value by performing the following command:\n\n$ sudo grep -i inactive /etc/default/useradd\nINACTIVE=35\n\nIf \"INACTIVE\" is set to \"-1\", a value greater than \"35\", or is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Inactive identifiers pose a risk to systems and applications because attackers may exploit an inactive identifier and potentially obtain undetected access to the system.\n\nDisabling inactive accounts ensures accounts that may not have been responsibly removed are not available to attackers who may have compromised their credentials.\n\nOwners of inactive accounts will not notice if unauthorized access to their user account has been obtained.\n\nSatisfies: SRG-OS-000118-GPOS-00060, SRG-OS-000590-GPOS-00110","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-003627","CCI-003628"],"reference_identifier":"2951","uuid":"777c3fe3-87b5-4dd9-b359-791c930c0880","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: EE5A327EA3742B41142C204C3D631C5A3158C03B\r\n~~~~~\r\nConfiguration for 'RHEL 10 must disable account identifiers (individuals, groups, roles, and devices) after 35 days of inactivity.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281176","group_tree":[{"id":"V-281176","title":"SRG-OS-000362-GPOS-00149","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281176","severity":"medium","group_title":"SRG-OS-000362-GPOS-00149","rule_id_src":"SV-281176r1166480_rule","rule_id":"SV-281176","rule_version":"RHEL-10-600170","rule_title":"RHEL 10 must be configured so that all local interactive user initialization file executable search path statements do not contain statements that will reference a working directory other than user home directories.","fix_text":"Configure RHEL 10 so that all local interactive user initialization file executable search path statements do not contain statements that will reference a working directory other than user home directories.\n\nEdit the local interactive user initialization files to change any PATH variable statements that reference directories other than their home directory.\n\nIf a local interactive user requires path variables to reference a directory owned by the application, it must be documented with the ISSO.","weight":"10.0","check_content":"Verify RHEL 10 local interactive user initialization file executable search path statements do not contain statements that will reference a working directory other than user home directories with the following commands:\n\n$ sudo find /home -maxdepth 2 -type f -name \".[^.]*\" -exec grep -iH path= {} \\;\nPATH=\"$HOME/.local/bin:$HOME/bin:$PATH\"\n\nIf any local interactive user initialization files have executable search path statements that include directories outside of their home directory, and this is not documented with the ISSO as an operational requirement, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The executable search path (typically the PATH environment variable) contains a list of directories for the shell to search to find executables. If this path includes the current working directory (other than the user's home directory), executables in these directories may be executed instead of system commands.\n\nThis variable is formatted as a colon-separated list of directories. If there is an empty entry, such as a leading or trailing colon or two consecutive colons, this is interpreted as the current working directory. If deviations from the default system search path for the local interactive user are required, they must be documented with the information system security officer (ISSO).","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-003980"],"reference_identifier":"6932","uuid":"9a88f760-f438-490a-ae22-9ae6b87e5dff","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 2C2DACBFC93FEAF1239014B0C1E0A5E14F64107A\r\n~~~~~\r\nRequired configuration for 'RHEL 10 must be configured so that all local interactive user initialization file executable search path statements do not contain statements that will reference a working directory other than user home directories.' was not present or did not match the expected value on the RHEL 10 host."},{"group_id_src":"V-281177","group_tree":[{"id":"V-281177","title":"SRG-OS-000420-GPOS-00186","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281177","severity":"medium","group_title":"SRG-OS-000420-GPOS-00186","rule_id_src":"SV-281177r1184748_rule","rule_id":"SV-281177","rule_version":"RHEL-10-600180","rule_title":"RHEL 10 must assign a home directory to all local interactive users in the \"/etc/passwd\" file.","fix_text":"Configure RHEL 10 interactive users to have a home directory assigned in the \"/etc/passwd\" file.\n\nCreate and assign home directories to all local interactive users on RHEL 10 that do not have a home directory assigned.","weight":"10.0","check_content":"Verify RHEL 10 interactive users have a home directory assigned with the following command:\n\n$ sudo awk -F: '($3>=1000)&&($7 !~ /nologin/){print $1, $3, $6}' /etc/passwd\nnsauser:x:1000:1000:nsauser:/home/nsauser:/bin/bash\ndisauser:x:1001:1001:disauser:/home/disauser:/bin/bash\ndoduser:x:1002:1002:doduser:/home/doduser:/bin/bash\n\nInspect the output and verify that all interactive users (normally users with a user identifier [UID] greater than 1000) have a home directory defined.\n\nIf a user's home directory is not defined, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If local interactive users are not assigned a valid home directory, there is no place for the storage and control of files they should own.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002385"],"reference_identifier":"1012","uuid":"8f50f4a8-24a4-41bf-9fde-fbb4f0c3e3fd","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: B87A03A1F4FA6C894AA44DF47AAFDFE3BAEFA022\r\n~~~~~\r\nThe feature/role addressed by 'RHEL 10 must assign a home directory to all local interactive users in the \"/etc/passwd\" file.' is not present or not in use on this the RHEL 10 host."},{"group_id_src":"V-281178","group_tree":[{"id":"V-281178","title":"SRG-OS-000420-GPOS-00186","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281178","severity":"medium","group_title":"SRG-OS-000420-GPOS-00186","rule_id_src":"SV-281178r1195418_rule","rule_id":"SV-281178","rule_version":"RHEL-10-600190","rule_title":"RHEL 10 must ensure that all local interactive user home directories defined in the \"/etc/passwd\" file must exist.","fix_text":"Configure RHEL 10 interactive users' home directories to exist on the system.\n\nCreate home directories to all local interactive users that do not have a home directory assigned. Use the following commands to create the user home directory assigned in \"/etc/ passwd\":\n\nNote: The example will be for the user \"disauser\", who has a home directory of \"/home/disauser\", a user identifier (UID) of \"disauser\", and a group identifier (GID) of \"users assigned\" in \"/etc/passwd\".\n\n$ sudo mkdir /home/disauser\n$ sudo chown disauser /home/disauser\n$ sudo chgrp users /home/disauser\n$ sudo chmod 0750 /home/disauser","weight":"10.0","check_content":"Verify RHEL 10 interactive users' home directories exist on the system with the following command:\n\n$ sudo pwck -r\nuser 'mailnull': directory 'var/spool/mqueue' does not exist\n\nThe output should not return any interactive users.\n\nIf an interactive user's home directory does not exist, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If a local interactive user has a home directory defined that does not exist, the user may be given access to the / directory as the current working directory upon login. This could create a denial of service because the user would not be able to access their login configuration files, and it may give them visibility to system files they normally would not be able to access.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002385"],"reference_identifier":"2977","uuid":"9b910834-b9e3-4e5f-bfa4-7751eb3276bb","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: A1DD8D01A36620DC19E12AC5ADBC7F51BC64262C\r\n~~~~~\r\nConfiguration for 'RHEL 10 must ensure that all local interactive user home directories defined in the \"/etc/passwd\" file must exist.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281179","group_tree":[{"id":"V-281179","title":"SRG-OS-000329-GPOS-00128","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281179","severity":"medium","group_title":"SRG-OS-000329-GPOS-00128","rule_id_src":"SV-281179r1166489_rule","rule_id":"SV-281179","rule_version":"RHEL-10-600200","rule_title":"RHEL 10 must enforce a delay of at least four seconds between login prompts following a failed login attempt.","fix_text":"Configure RHEL 10 to enforce a delay of at least four seconds between login prompts following a failed console login attempt.\n\nModify the \"/etc/login.defs\" file to set the \"FAIL_DELAY\" parameter to \"4\" or greater:\n\nFAIL_DELAY 4","weight":"10.0","check_content":"Verify RHEL 10 enforces a delay of at least four seconds between console login prompts following a failed login attempt with the following command:\n\n$ sudo grep -i fail_delay /etc/login.defs\nFAIL_DELAY 4\n\nIf the value of \"FAIL_DELAY\" is not set to \"4\" or greater, or the line is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Increasing the time between a failed authentication attempt and reprompting to enter credentials helps to slow a single-threaded brute-force attack.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002238"],"reference_identifier":"3748","uuid":"da2d90fd-1545-46c0-b9bd-683fd2b9cc88","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 8D8013D2757B710D5CEC48C9E3A51C36C21C9051\r\n~~~~~\r\nConfiguration for 'RHEL 10 must enforce a delay of at least four seconds between login prompts following a failed login attempt.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281180","group_tree":[{"id":"V-281180","title":"SRG-OS-000075-GPOS-00043","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281180","severity":"medium","group_title":"SRG-OS-000075-GPOS-00043","rule_id_src":"SV-281180r1166492_rule","rule_id":"SV-281180","rule_version":"RHEL-10-600210","rule_title":"RHEL 10 must enforce a 24-hours minimum password lifetime restriction for passwords for new users or password changes in \"/etc/login.defs\".","fix_text":"Configure RHEL 10 to enforce 24 hours as the minimum password lifetime.\n\nAdd the following line in \"/etc/login.defs\" (or modify the line to have the required value):\n\nPASS_MIN_DAYS 1","weight":"10.0","check_content":"Verify RHEL 10 enforces 24 hours as the minimum password lifetime for new user accounts.\n\nCheck for the value of \"PASS_MIN_DAYS\" in \"/etc/login.defs\" with the following command:\n\n$ sudo grep -i pass_min_days /etc/login.defs\nPASS_MIN_DAYS 1\n\nIf the \"PASS_MIN_DAYS\" parameter value is not \"1\" or greater or is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Enforcing a minimum password lifetime helps to prevent repeated password changes to defeat the password reuse or history enforcement requirement. If users are allowed to immediately and continually change their password, the password could be repeatedly changed in a short period of time to defeat the organization's policy regarding password reuse.\n\nSetting the minimum password age protects against users cycling back to a favorite password after satisfying the password reuse requirement.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066"],"reference_identifier":"8193","uuid":"e75ac716-918d-4a32-bcee-d2cb43ff5ed6","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 4B0750E4BF55D209CC075AC55D1C4827E950AEE7\r\n~~~~~\r\nConfiguration for 'RHEL 10 must enforce a 24-hours minimum password lifetime restriction for passwords for new users or password changes in \"/etc/login.defs\".' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281181","group_tree":[{"id":"V-281181","title":"SRG-OS-000078-GPOS-00046","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281181","severity":"medium","group_title":"SRG-OS-000078-GPOS-00046","rule_id_src":"SV-281181r1195421_rule","rule_id":"SV-281181","rule_version":"RHEL-10-600220","rule_title":"RHEL 10 must enforce that passwords be created with a minimum of 15 characters.","fix_text":"Configure RHEL 10 to enforce a minimum 15-character password length.\n\nAdd or update the following line in the \"/etc/security/pwquality.conf\" file or a configuration file in the \"/etc/security/pwquality.conf.d/\" directory to contain the \"minlen\" parameter:\n\nminlen = 15","weight":"10.0","check_content":"Verify RHEL 10 enforces a minimum 15-character password length with the following command:\n\n$ sudo grep -s minlen /etc/security/pwquality.conf /etc/security/pwquality.conf.d/*.conf\n/etc/security/pwquality.conf:minlen = 15\n\nIf the command does not return a \"minlen\" value of \"15\" or greater, does not return a line, or the line is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The shorter the password, the lower the number of possible combinations that must be tested before the password is compromised.\n\nPassword complexity, or strength, is a measure of the effectiveness of a password in resisting attempts at guessing and brute-force attacks. Password length is one factor of several that helps to determine strength and how long it takes to crack a password. Use of more characters in a password helps to increase exponentially the time and/or resources required to compromise the password.\n\nRHEL 10 uses \"pwquality\" as a mechanism to enforce password complexity. Configurations are set in the \"etc/security/pwquality.conf\" file.\n\nThe \"minlen\", sometimes noted as minimum length, acts as a \"score\" of complexity based on the credit components of the \"pwquality\" module. By setting the credit components to a negative value, those components will not only be required but will not count toward the total \"score\" of \"minlen\". This will enable \"minlen\" to require a 15-character minimum.\n\nThe DOD minimum password requirement is 15 characters.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066"],"reference_identifier":"5900","uuid":"071c7c51-bc02-4a58-9454-161fa6a47e45","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 7B51163A29C98623BBC24FA8EF0F5DBEDC500740\r\n~~~~~\r\nConfiguration for 'RHEL 10 must enforce that passwords be created with a minimum of 15 characters.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281182","group_tree":[{"id":"V-281182","title":"SRG-OS-000266-GPOS-00101","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281182","severity":"medium","group_title":"SRG-OS-000266-GPOS-00101","rule_id_src":"SV-281182r1195424_rule","rule_id":"SV-281182","rule_version":"RHEL-10-600230","rule_title":"RHEL 10 must enforce password complexity by requiring at least one special character to be used.","fix_text":"Configure RHEL 10 to enforce password complexity by requiring that at least one special character be used by setting the \"ocredit\" option.\n\nAdd or update the following line in the \"/etc/security/pwquality.conf\" file or a configuration file in the \"/etc/security/pwquality.conf.d/\" directory to contain the \"ocredit\" parameter:\n\nocredit = -1","weight":"10.0","check_content":"Verify RHEL 10 enforces password complexity by requiring that at least one special character be used with the following command:\n\n$ sudo grep -s ocredit /etc/security/pwquality.conf /etc/security/pwquality.conf.d/*.conf\n/etc/security/pwquality.conf:# ocredit = 0\n\nIf the value of \"ocredit\" is a positive number or is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Use of a complex password helps to increase the time and resources required to compromise the password. Password complexity, or strength, is a measure of the effectiveness of a password in resisting attempts at guessing and brute-force attacks.\n\nPassword complexity is one factor of several that determines how long it takes to crack a password. The more complex the password, the greater the number of possible combinations that must be tested before the password is compromised.\n\nRHEL 10 uses \"pwquality\" as a mechanism to enforce password complexity. Note that to require special characters without degrading the \"minlen\" value, the credit value must be expressed as a negative number in \"/etc/security/pwquality.conf\".","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066"],"reference_identifier":"9414","uuid":"21673f78-2daa-4950-882b-29c351175933","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: A3B1943E82A381BCCD1998F5C6AD587CA96B06EF\r\n~~~~~\r\nRequired configuration for 'RHEL 10 must enforce password complexity by requiring at least one special character to be used.' was not present or did not match the expected value on the RHEL 10 host."},{"group_id_src":"V-281183","group_tree":[{"id":"V-281183","title":"SRG-OS-000070-GPOS-00038","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281183","severity":"medium","group_title":"SRG-OS-000070-GPOS-00038","rule_id_src":"SV-281183r1195427_rule","rule_id":"SV-281183","rule_version":"RHEL-10-600240","rule_title":"RHEL 10 must enforce password complexity by requiring that at least one lowercase character be used.","fix_text":"Configure RHEL 10 to enforce password complexity by requiring that at least one lowercase character be used by setting the \"lcredit\" option.\n\nAdd or update the following line in the \"/etc/security/pwquality.conf\" file or a configuration file in the \"/etc/security/pwquality.conf.d/\" directory to contain the \"lcredit\" parameter:\n\nlcredit = -1","weight":"10.0","check_content":"Verify RHEL 10 enforces password complexity by requiring that at least one lowercase character be used with the following command:\n\n$ sudo grep -s lcredit /etc/security/pwquality.conf /etc/security/pwquality.conf/*.conf\n/etc/security/pwquality.conf:lcredit = -1\n\nIf the value of \"lcredit\" is a positive number or is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Use of a complex password helps to increase the time and resources required to compromise the password. Password complexity, or strength, is a measure of the effectiveness of a password in resisting attempts at guessing and brute-force attacks.\n\nPassword complexity is one factor of several that determines how long it takes to crack a password. The more complex the password, the greater the number of possible combinations that must be tested before the password is compromised.\n\nRequiring a minimum number of lowercase characters makes password guessing attacks more difficult by ensuring a larger search space.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066"],"reference_identifier":"2535","uuid":"87bcfbce-878c-47fa-b086-e467833819c3","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 7E0AB3F697E1783F3CA9A83899C0943E72A9CECF\r\n~~~~~\r\nConfiguration for 'RHEL 10 must enforce password complexity by requiring that at least one lowercase character be used.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281184","group_tree":[{"id":"V-281184","title":"SRG-OS-000069-GPOS-00037","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281184","severity":"medium","group_title":"SRG-OS-000069-GPOS-00037","rule_id_src":"SV-281184r1197239_rule","rule_id":"SV-281184","rule_version":"RHEL-10-600250","rule_title":"RHEL 10 must enforce password complexity by requiring that at least one uppercase character be used.","fix_text":"Configure RHEL 10 to enforce password complexity by requiring that at least one uppercase character be used by setting the \"ucredit\" option.\n\nAdd or update the following line in the \"/etc/security/pwquality.conf\" file or a configuration file in the \"/etc/security/pwquality.conf.d/\" directory to contain the \"ucredit\" parameter:\n\nucredit = -1","weight":"10.0","check_content":"Verify RHEL 10 enforces password complexity by requiring that at least one uppercase character be used.\n\nCheck the value for \"ucredit\" with the following command:\n\n$ sudo grep -s ucredit /etc/security/pwquality.conf /etc/security/pwquality.conf/*.conf\n/etc/security/pwquality.conf:ucredit = -1\n\nIf the value of \"ucredit\" is a positive number or is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Use of a complex password helps to increase the time and resources required to compromise the password. Password complexity, or strength, is a measure of the effectiveness of a password in resisting attempts at guessing and brute-force attacks.\n\nPassword complexity is one factor of several that determines how long it takes to crack a password. The more complex the password, the greater the number of possible combinations that must be tested before the password is compromised.\n\nRequiring a minimum number of uppercase characters makes password guessing attacks more difficult by ensuring a larger search space.\n\nSatisfies: SRG-OS-000069-GPOS-00037, SRG-OS-000070-GPOS-00038","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066"],"reference_identifier":"9288","uuid":"e1bdab5d-71c5-4797-849e-ce0e246efec0","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 638326ADADEEE4383AB260A1816E106D3E48F415\r\n~~~~~\r\nConfiguration for 'RHEL 10 must enforce password complexity by requiring that at least one uppercase character be used.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281185","group_tree":[{"id":"V-281185","title":"SRG-OS-000072-GPOS-00040","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281185","severity":"medium","group_title":"SRG-OS-000072-GPOS-00040","rule_id_src":"SV-281185r1195433_rule","rule_id":"SV-281185","rule_version":"RHEL-10-600260","rule_title":"RHEL 10 must require the change of at least eight characters when passwords are changed.","fix_text":"Configure RHEL 10 to require the change of at least eight of the total number of characters when passwords are changed by setting the \"difok\" option.\n\nAdd or update the following line in the \"/etc/security/pwquality.conf\" file or a configuration file in the \"/etc/security/pwquality.conf.d/\" directory to contain the \"difok\" parameter:\n\ndifok = 8","weight":"10.0","check_content":"Verify RHEL 10 requires the change of at least eight characters when passwords are changed by checking the value of the \"difok\" option in \"/etc/security/pwquality.conf\" with the following command:\n\n$ sudo grep difok -s /etc/security/pwquality.conf /etc/security/pwquality.conf.d/*.conf\n/etc/security/pwquality.conf:difok = 8\n\nIf the value of \"difok\" is set to less than \"8\" or is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Use of a complex password helps to increase the time and resources required to compromise the password. Password complexity, or strength, is a measure of the effectiveness of a password in resisting attempts at guessing and brute\u2013force attacks.\n\nPassword complexity is one factor of several that determines how long it takes to crack a password. The more complex the password, the greater the number of possible combinations that must be tested before the password is compromised.\n\nRequiring a minimum number of different characters during password changes ensures that newly changed passwords should not resemble previously compromised ones.\n\nNote that passwords that are changed on compromised systems will still be compromised.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066"],"reference_identifier":"1231","uuid":"549d5871-ea6a-46fe-9fcc-6f8afd43da0b","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 3F4FAD55C985DD268969D9C4422106F61ED4C3EC\r\n~~~~~\r\nConfiguration for 'RHEL 10 must require the change of at least eight characters when passwords are changed.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281186","group_tree":[{"id":"V-281186","title":"SRG-OS-000075-GPOS-00043","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281186","severity":"medium","group_title":"SRG-OS-000075-GPOS-00043","rule_id_src":"SV-281186r1184622_rule","rule_id":"SV-281186","rule_version":"RHEL-10-600270","rule_title":"RHEL 10 must enforce that passwords have a 24 hours/1 day minimum lifetime restriction in \"/etc/shadow\".","fix_text":"Configure RHEL 10 so that noncompliant accounts enforce a 24 hours/1 day minimum password lifetime:\n\n$ sudo passwd -n 1 [user]","weight":"10.0","check_content":"Verify the minimum time period between password changes for each user account is one day or greater with the following command:\n\n$ sudo awk -F: '$4 < 1 {printf \"%s %d\\n\", $1, $4}' /etc/shadow\n\nIf any results are returned that are not associated with a system account, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Enforcing a minimum password lifetime helps to prevent repeated password changes to defeat the password reuse or history enforcement requirement. If users are allowed to immediately and continually change their password, the password could be repeatedly changed in a short period of time to defeat the organization's policy for password reuse.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066"],"reference_identifier":"5582","uuid":"2f28d2ff-3fef-4497-aacf-b38a34dd5d98","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: F576424037D6C034077A0377F9BC06B82159335A\r\n~~~~~\r\nConfiguration for 'RHEL 10 must enforce that passwords have a 24 hours/1 day minimum lifetime restriction in \"/etc/shadow\".' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281187","group_tree":[{"id":"V-281187","title":"SRG-OS-000072-GPOS-00040","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281187","severity":"medium","group_title":"SRG-OS-000072-GPOS-00040","rule_id_src":"SV-281187r1195436_rule","rule_id":"SV-281187","rule_version":"RHEL-10-600280","rule_title":"RHEL 10 must require the maximum number of repeating characters of the same character class to be limited to four when passwords are changed.","fix_text":"Configure RHEL 10 to require the change of the number of repeating characters of the same character class when passwords are changed by setting the \"maxclassrepeat\" option.\n\nAdd or update the following line in the \"/etc/security/pwquality.conf\" file or a configuration file in the \"/etc/security/pwquality.conf.d/\" directory to contain the \"maxclassrepeat\" parameter:\n\nmaxclassrepeat = 4","weight":"10.0","check_content":"Verify RHEL 10 limits the value of the \"maxclassrepeat\" option in \"/etc/security/pwquality.conf\" with the following command:\n\n$ sud grep -s maxclassrepeat /etc/security/pwquality.conf /etc/security/pwquality.conf.d/*.conf\n/etc/security/pwquality.conf:maxclassrepeat = 4\n\nIf the value of \"maxclassrepeat\" is set to \"0\" or more than \"4\" or is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Use of a complex password helps to increase the time and resources required to compromise the password.\n\nPassword complexity, or strength, is a measure of the effectiveness of a password in resisting attempts at guessing and brute-force attacks.\n\nPassword complexity is one factor of several that determines how long it takes to crack a password. The more complex a password is, the greater the number of possible combinations that must be tested before the password is compromised.\n\nSatisfies: SRG-OS-000072-GPOS-00040, SRG-OS-000730-GPOS-00190","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066","CCI-004065"],"reference_identifier":"9172","uuid":"66c62a00-6e3f-4960-8c37-a4d9c2133690","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: E12F2F48BFE31D4E8A84D3F8BC89224C0A05D57E\r\n~~~~~\r\nConfiguration for 'RHEL 10 must require the maximum number of repeating characters of the same character class to be limited to four when passwords are changed.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281188","group_tree":[{"id":"V-281188","title":"SRG-OS-000072-GPOS-00040","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281188","severity":"medium","group_title":"SRG-OS-000072-GPOS-00040","rule_id_src":"SV-281188r1195439_rule","rule_id":"SV-281188","rule_version":"RHEL-10-600290","rule_title":"RHEL 10 must require that the maximum number of repeating characters be limited to three when passwords are changed.","fix_text":"Configure RHEL 10 to require the change of the number of repeating consecutive characters when passwords are changed by setting the \"maxrepeat\" option.\n\nAdd or update the following line in the \"/etc/security/pwquality.conf\" file or a configuration file in the \"/etc/security/pwquality.conf.d/\" directory to contain the \"maxrepeat\" parameter:\n\nmaxrepeat = 3","weight":"10.0","check_content":"Verify RHEL 10 limits the value of the \"maxrepeat\" option in \"/etc/security/pwquality.conf\" with the following command:\n\n$ sudo grep -s maxrepeat /etc/security/pwquality.conf /etc/security/pwquality.conf.d/*.conf\n/etc/security/pwquality.conf:maxrepeat = 3\n\nIf the value of \"maxrepeat\" is set to more than \"3\" or is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Use of a complex password helps to increase the time and resources required to compromise the password.\n\nPassword complexity, or strength, is a measure of the effectiveness of a password in resisting attempts at guessing and brute-force attacks.\n\nPassword complexity is one factor of several that determines how long it takes to crack a password. The more complex a password is, the greater the number of possible combinations that must be tested before the password is compromised.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066"],"reference_identifier":"1365","uuid":"d00166a2-1a2e-458b-9b06-90f0e3136c8f","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 3DE0F8A4277A5B9F2D2EAD171C858C57443B19C5\r\n~~~~~\r\nConfiguration for 'RHEL 10 must require that the maximum number of repeating characters be limited to three when passwords are changed.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281189","group_tree":[{"id":"V-281189","title":"SRG-OS-000072-GPOS-00040","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281189","severity":"medium","group_title":"SRG-OS-000072-GPOS-00040","rule_id_src":"SV-281189r1195442_rule","rule_id":"SV-281189","rule_version":"RHEL-10-600300","rule_title":"RHEL 10 must require the change of at least four character classes when passwords are changed.","fix_text":"Configure RHEL 10 to require the change of at least four character classes when passwords are changed by setting the \"minclass\" option.\n\nAdd or update the following line in the \"/etc/security/pwquality.conf\" file or a configuration file in the \"/etc/security/pwquality.conf.d/\" directory to contain the \"minclass\" parameter:\n\nminclass = 4","weight":"10.0","check_content":"Verify RHEL 10 sets the value of the \"minclass\" option in \"/etc/security/pwquality.conf\" with the following command:\n\n$ sudo grep -s minclass /etc/security/pwquality.conf /etc/security/pwquality.conf.d/*.conf\n/etc/security/pwquality.conf:minclass = 4\n\nIf the value of \"minclass\" is set to less than \"4\" or is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Use of a complex password helps to increase the time and resources required to compromise the password. \n\nPassword complexity, or strength, is a measure of the effectiveness of a password in resisting attempts at guessing and brute-force attacks.\n\nPassword complexity is one factor of several that determines how long it takes to crack a password. The more complex a password is, the greater the number of possible combinations that must be tested before the password is compromised.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066"],"reference_identifier":"1432","uuid":"06228b27-cd95-46c0-9e5a-c8b8f55a4aeb","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: A912CC3F1799747C94E1F4B5210A08F73DD333B6\r\n~~~~~\r\nConfiguration for 'RHEL 10 must require the change of at least four character classes when passwords are changed.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281190","group_tree":[{"id":"V-281190","title":"SRG-OS-000071-GPOS-00039","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281190","severity":"medium","group_title":"SRG-OS-000071-GPOS-00039","rule_id_src":"SV-281190r1195445_rule","rule_id":"SV-281190","rule_version":"RHEL-10-600310","rule_title":"RHEL 10 must enforce password complexity by requiring that at least one numeric character be used.","fix_text":"Configure RHEL 10 to enforce password complexity by requiring that at least one numeric character be used by setting the \"dcredit\" option.\n\nAdd or update the following line in the \"/etc/security/pwquality.conf\" file or a configuration file in the \"/etc/security/pwquality.conf.d/\" directory to contain the \"dcredit\" parameter:\n\ndcredit = -1","weight":"10.0","check_content":"Verify RHEL 10 enforces password complexity by requiring that at least one numeric character be used.\n\nCheck the value for \"dcredit\" with the following command:\n\n$ sudo grep -s dcredit /etc/security/pwquality.conf /etc/security/pwquality.conf.d/*.conf\n/etc/security/pwquality.conf:dcredit = -1\n\nIf the value of \"dcredit\" is a positive number or is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Use of a complex password helps to increase the time and resources required to compromise the password. Password complexity, or strength, is a measure of the effectiveness of a password in resisting attempts at guessing and brute-force attacks.\n\nPassword complexity is one factor of several that determines how long it takes to crack a password. The more complex the password is, the greater the number of possible combinations that must be tested before the password is compromised.\n\nRequiring digits makes password guessing attacks more difficult by ensuring a larger search space.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066"],"reference_identifier":"2951","uuid":"bbcb6ed7-20b2-42cc-b337-d77f38eb5193","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: 9AD71062F3A1D20D1CF645D7A06382EC02DB7671\r\n~~~~~\r\nThe feature/role addressed by 'RHEL 10 must enforce password complexity by requiring that at least one numeric character be used.' is not present or not in use on this the RHEL 10 host."},{"group_id_src":"V-281191","group_tree":[{"id":"V-281191","title":"SRG-OS-000480-GPOS-00225","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281191","severity":"medium","group_title":"SRG-OS-000480-GPOS-00225","rule_id_src":"SV-281191r1195448_rule","rule_id":"SV-281191","rule_version":"RHEL-10-600320","rule_title":"RHEL 10 must prevent the use of dictionary words for passwords.","fix_text":"Configure RHEL 10 to prevent the use of dictionary words for passwords.\n\nAdd or update the following line in the \"/etc/security/pwquality.conf\" file or a configuration file in the \"/etc/security/pwquality.conf.d/\" directory to contain the \"dictcheck\" parameter:\n\ndictcheck=1","weight":"10.0","check_content":"Verify RHEL 10 prevents the use of dictionary words for passwords with the following command:\n\n$ sudo grep -s dictcheck /etc/security/pwquality.conf /etc/pwquality.conf.d/*.conf\n/etc/security/pwquality.conf:dictcheck=1\n\nIf \"dictcheck\" does not have a value other than \"0\" or is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Use of a complex password helps to increase the time and resources required to compromise the password. Password complexity, or strength, is a measure of the effectiveness of a password in resisting attempts at guessing and brute-force attacks.\n\nIf RHEL 10 allows the user to select passwords based on dictionary words, this increases the chances of password compromise by increasing the opportunity for successful guesses and brute-force attacks.\n\nSatisfies: SRG-OS-000480-GPOS-00225, SRG-OS-000072-GPOS-00040","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066"],"reference_identifier":"2073","uuid":"cb81b098-7515-41ef-8e91-609ec351a729","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 595FD07D2BFEF709E672F0596222F3B48E506B14\r\n~~~~~\r\nConfiguration for 'RHEL 10 must prevent the use of dictionary words for passwords.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281192","group_tree":[{"id":"V-281192","title":"SRG-OS-000080-GPOS-00048","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281192","severity":"medium","group_title":"SRG-OS-000080-GPOS-00048","rule_id_src":"SV-281192r1166528_rule","rule_id":"SV-281192","rule_version":"RHEL-10-600400","rule_title":"RHEL 10 must allow only the root account to have unrestricted access to the system.","fix_text":"Configure RHEL 10 so that only the \"root\" account has a UID assignment of \"0\".\n\nChange the UID of any account on the system, other than \"root\", that has a UID of \"0\".\n\nIf the account is associated with system commands or applications, the UID should be changed to one greater than \"0\" but less than \"1000\". Otherwise, assign a UID of greater than \"1000\" that has not already been assigned.","weight":"10.0","check_content":"Verify RHEL 10 is configured so that only the \"root\" account has a UID \"0\" assignment with the following command:\n\n$ awk -F: '$3 == 0 {print $1}' /etc/passwd\nroot\n\nIf any accounts other than \"root\" have a UID of \"0\", this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"An account has root authority if it has a user identifier (UID) of \"0\". Multiple accounts with a UID of \"0\" afford more opportunity for potential intruders to guess a password for a privileged account. Proper configuration of sudo is recommended to afford multiple system administrators access to root privileges in an accountable manner.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000213"],"reference_identifier":"2097","uuid":"e907e3c7-3889-45e2-94f2-155ea894f758","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 17817164A6B55FECC54F3812613DB55FCC4EA5AE\r\n~~~~~\r\nConfiguration for 'RHEL 10 must allow only the root account to have unrestricted access to the system.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281193","group_tree":[{"id":"V-281193","title":"SRG-OS-000072-GPOS-00040","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281193","severity":"medium","group_title":"SRG-OS-000072-GPOS-00040","rule_id_src":"SV-281193r1166531_rule","rule_id":"SV-281193","rule_version":"RHEL-10-600405","rule_title":"RHEL 10 must enforce password complexity rules for the \"root\" account.","fix_text":"Configure RHEL 10 to enforce password complexity on the \"root\" account.\n\nAdd or update the following line in the \"/etc/security/pwquality.conf\" file or a configuration file in the \"/etc/security/pwquality.conf.d/\" directory to contain the \"enforce_for_root\" parameter:\n\nenforce_for_root","weight":"10.0","check_content":"Verify RHEL 10 enforces password complexity rules for the \"root\" account.\n\nCheck if \"root\" user is required to use complex passwords with the following command:\n\n$ sudo grep enforce_for_root /etc/security/pwquality.conf /etc/security/pwquality.conf.d/*.conf\n/etc/security/pwquality.conf:enforce_for_root\n\nIf \"enforce_for_root\" is commented out or is missing, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Use of a complex password helps to increase the time and resources required to compromise the password. Password complexity, or strength, is a measure of the effectiveness of a password in resisting attempts at guessing and brute-force attacks.\n\nPassword complexity is one factor of several that determines how long it takes to crack a password. The more complex the password, the greater the number of possible combinations that must be tested before the password is compromised.\n\nSatisfies: SRG-OS-000072-GPOS-00040, SRG-OS-000071-GPOS-00039, SRG-OS-000070-GPOS-00038, SRG-OS-000266-GPOS-00101, SRG-OS-000078-GPOS-00046, SRG-OS-000480-GPOS-00225, SRG-OS-000069-GPOS-00037","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066"],"reference_identifier":"7456","uuid":"9038bb93-cb71-4e91-b68d-338607559d0c","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: B9DF6D8C4CD89A79B59E840021163A69E8861C23\r\n~~~~~\r\nConfiguration for 'RHEL 10 must enforce password complexity rules for the \"root\" account.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281194","group_tree":[{"id":"V-281194","title":"SRG-OS-000329-GPOS-00128","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281194","severity":"medium","group_title":"SRG-OS-000329-GPOS-00128","rule_id_src":"SV-281194r1166534_rule","rule_id":"SV-281194","rule_version":"RHEL-10-600410","rule_title":"RHEL 10 must automatically lock an account when three unsuccessful login attempts occur.","fix_text":"Configure RHEL 10 to lock an account when three unsuccessful login attempts occur.\n\nAdd/modify the \"/etc/security/faillock.conf\" file to match the following line:\n\ndeny = 3","weight":"10.0","check_content":"Verify RHEL 10 is configured to lock an account after three unsuccessful login attempts with the following command:\n\n$ sudo grep 'deny =' /etc/security/faillock.conf\ndeny = 3\n\nIf the \"deny\" option is not set to \"3\" or less (but not \"0\"), or is missing or commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"By limiting the number of failed login attempts, the risk of unauthorized system access via user password guessing, otherwise known as brute-force attacks, is reduced. Limits are imposed by locking the account.\n\nSatisfies: SRG-OS-000329-GPOS-00128, SRG-OS-000021-GPOS-00005","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002238","CCI-000044"],"reference_identifier":"6684","uuid":"8e877817-4adf-4911-8ab9-84a2f30840b0","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 758DBB7BB20698EB58A870BBEA8EE083BB3624EF\r\n~~~~~\r\nConfiguration for 'RHEL 10 must automatically lock an account when three unsuccessful login attempts occur.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281195","group_tree":[{"id":"V-281195","title":"SRG-OS-000329-GPOS-00128","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281195","severity":"medium","group_title":"SRG-OS-000329-GPOS-00128","rule_id_src":"SV-281195r1166537_rule","rule_id":"SV-281195","rule_version":"RHEL-10-600415","rule_title":"RHEL 10 must automatically lock the root account until the root account is released by an administrator when three unsuccessful login attempts occur during a 15-minute time period.","fix_text":"Configure RHEL 10 to lock out the \"root\" account after a number of incorrect login attempts using \"pam_faillock.so\".\n\nEnable the feature using the following command:\n\n$ sudo authselect enable-feature with-faillock\n\nEdit the \"/etc/security/faillock.conf\" by uncommenting or adding the following line:\n\neven_deny_root","weight":"10.0","check_content":"Verify RHEL 10 is configured to lock the root account after three unsuccessful login attempts with the following command:\n\n$ sudo grep even_deny_root /etc/security/faillock.conf\neven_deny_root\n\nIf the \"even_deny_root\" option is not set or is missing or commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"By limiting the number of failed login attempts, the risk of unauthorized system access via user password guessing, also known as brute-forcing, is reduced. Limits are imposed by locking the account.\n\nSatisfies: SRG-OS-000329-GPOS-00128, SRG-OS-000021-GPOS-00005","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002238","CCI-000044"],"reference_identifier":"8689","uuid":"12ee2b53-cc2b-4420-84f7-870532519815","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 7DCDA517E5899EFDF47BD3FBFDDE9D36201E4365\r\n~~~~~\r\nConfiguration for 'RHEL 10 must automatically lock the root account until the root account is released by an administrator when three unsuccessful login attempts occur during a 15-minute time period.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281196","group_tree":[{"id":"V-281196","title":"SRG-OS-000329-GPOS-00128","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281196","severity":"medium","group_title":"SRG-OS-000329-GPOS-00128","rule_id_src":"SV-281196r1166540_rule","rule_id":"SV-281196","rule_version":"RHEL-10-600420","rule_title":"RHEL 10 must automatically lock an account when three unsuccessful login attempts occur during a 15-minute time period.","fix_text":"Configure RHEL 10 to lock out the \"root\" account after a number of incorrect login attempts within 15 minutes using \"pam_faillock.so\". \n\nEnable the feature using the following command:\n\n$ authselect enable-feature with-faillock\n\nEdit the \"/etc/security/faillock.conf\" file as follows:\n\nfail_interval = 900","weight":"10.0","check_content":"Verify RHEL 10 locks an account after three unsuccessful login attempts within a period of 15 minutes with the following command:\n\n$ sudo grep fail_interval /etc/security/faillock.conf\nfail_interval = 900\n\nIf the \"fail_interval\" option is not set to \"900\" or less (but not \"0\"), the line is commented out, or the line is missing, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"By limiting the number of failed login attempts, the risk of unauthorized system access via user password guessing, otherwise known as brute-forcing, is reduced. Limits are imposed by locking the account.\n\nSatisfies: SRG-OS-000329-GPOS-00128, SRG-OS-000021-GPOS-00005","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002238","CCI-000044"],"reference_identifier":"1449","uuid":"a2bef310-8dad-4e75-97ab-0ff6c9e10d07","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 3174AA27B7A79987059A3DE0ACB8D989BD0B11F8\r\n~~~~~\r\nConfiguration for 'RHEL 10 must automatically lock an account when three unsuccessful login attempts occur during a 15-minute time period.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281197","group_tree":[{"id":"V-281197","title":"SRG-OS-000329-GPOS-00128","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281197","severity":"medium","group_title":"SRG-OS-000329-GPOS-00128","rule_id_src":"SV-281197r1166543_rule","rule_id":"SV-281197","rule_version":"RHEL-10-600425","rule_title":"RHEL 10 must maintain an account lock until the locked account is released by an administrator.","fix_text":"Configure RHEL 10 to lock an account after three unsuccessful login attempts until released by an administrator with the following command:\n\n$ authselect enable-feature with-faillock\n\nEdit the \"/etc/security/faillock.conf\" file as follows:\n\nunlock_time = 0","weight":"10.0","check_content":"Verify RHEL 10 is configured to lock an account after three unsuccessful login attempts until released by an administrator with the following command:\n\n$ sudo grep 'unlock_time =' /etc/security/faillock.conf\nunlock_time = 0\n\nIf the \"unlock_time\" option is not set to \"0\", or the line is missing or commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"By limiting the number of failed login attempts, the risk of unauthorized system access via user password guessing, otherwise known as brute-forcing, is reduced. Limits are imposed by locking the account.\n\nSatisfies: SRG-OS-000329-GPOS-00128, SRG-OS-000021-GPOS-00005","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002238","CCI-000044"],"reference_identifier":"5029","uuid":"b2cf4d7d-da36-499b-95c0-073232acc87a","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 6D76AD7DF36E8C7BAA64E70FF7CAE6337D692D7A\r\n~~~~~\r\nConfiguration for 'RHEL 10 must maintain an account lock until the locked account is released by an administrator.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281198","group_tree":[{"id":"V-281198","title":"SRG-OS-000021-GPOS-00005","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281198","severity":"medium","group_title":"SRG-OS-000021-GPOS-00005","rule_id_src":"SV-281198r1166546_rule","rule_id":"SV-281198","rule_version":"RHEL-10-600430","rule_title":"RHEL 10 must ensure account lockouts persist.","fix_text":"Configure RHEL 10 to maintain the contents of the \"faillock\" directory after a reboot.\n\nAdd/modify the \"/etc/security/faillock.conf\" file to match the following line:\n\ndir = /var/log/faillock","weight":"10.0","check_content":"Verify RHEL 10 is configured so that the \"/etc/security/faillock.conf\" file uses a nondefault \"faillock\" directory to ensure contents persist after reboot with the following command:\n\n$ sudo grep -w dir /etc/security/faillock.conf\ndir = /var/log/faillock\n\nIf the \"dir\" option is not set to a nondefault documented tally log directory, is commented out, or is missing, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Having lockouts persist across reboots ensures that an account is unlocked only by an administrator. If the lockouts did not persist across reboots, an attacker could reboot the system to continue brute force attacks against the accounts on the system.\n\nSatisfies: SRG-OS-000021-GPOS-00005, SRG-OS-000329-GPOS-00128","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000044","CCI-002238"],"reference_identifier":"2696","uuid":"46993757-24a6-477d-b576-3b459edf0317","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: B54250B92B8A0474190CFDAE378F3E98242F0039\r\n~~~~~\r\nRequired configuration for 'RHEL 10 must ensure account lockouts persist.' was not present or did not match the expected value on the RHEL 10 host."},{"group_id_src":"V-281199","group_tree":[{"id":"V-281199","title":"SRG-OS-000080-GPOS-00048","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281199","severity":"medium","group_title":"SRG-OS-000080-GPOS-00048","rule_id_src":"SV-281199r1166549_rule","rule_id":"SV-281199","rule_version":"RHEL-10-600450","rule_title":"RHEL 10 must not have unauthorized accounts.","fix_text":"Configure RHEL 10 to have no unauthorized local interactive user accounts with the following command, where <unauthorized_user> is the unauthorized account:\n\n$ sudo userdel  <unauthorized_user>","weight":"10.0","check_content":"Verify RHEL 10 has no unauthorized local interactive user accounts with the following command:\n\n$ less /etc/passwd\nroot:x:0:0:root:/root:/bin/bash\n...\nnsauser:x:1000:1000:nsauser:/home/nsauser:/bin/bash\ndoduser:x:1001:1001:doduser:/home/doduser:/bin/bash\n\nInteractive user accounts generally will have a user ID (UID) of 1000 or greater, a home directory in a specific partition, and an interactive shell.\n\nObtain the list of interactive user accounts authorized to be on the system from the system administrator or information system security officer and compare it to the list of local interactive user accounts on the system.\n\nIf there are unauthorized local user accounts on the system, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Having lockouts persist across reboots ensures that account is unlocked only by an administrator. If the lockouts did not persist across reboots, an attacker could reboot the system to continue brute force attacks against the accounts on the system.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000213"],"reference_identifier":"1494","uuid":"14a8bfbb-6dc5-4f26-ab88-627d73289995","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: BFC36498F37967F66C4AC15661B905729D40E83B\r\n~~~~~\r\nConfiguration for 'RHEL 10 must not have unauthorized accounts.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281200","group_tree":[{"id":"V-281200","title":"SRG-OS-000069-GPOS-00037","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281200","severity":"medium","group_title":"SRG-OS-000069-GPOS-00037","rule_id_src":"SV-281200r1166552_rule","rule_id":"SV-281200","rule_version":"RHEL-10-600455","rule_title":"RHEL 10 must not allow blank or null passwords.","fix_text":"Configure RHEL 10 to prohibit the use of null passwords.\n\nIf PAM is managed with \"authselect\", use the following command to remove instances of \"nullok\":\n\n$ sudo authselect enable-feature without-nullok\n\nOtherwise, remove any instances of the \"nullok\" option in the \"/etc/pam.d/password-auth\" and \"/etc/pam.d/system-auth\" files to prevent logins with empty passwords.\n\nNote: Manual changes to the listed file may be overwritten by the \"authselect\" program.","weight":"10.0","check_content":"Verify RHEL 10 prohibits the use of null passwords with the following command:\n\n$ sudo grep -i nullok /etc/pam.d/system-auth /etc/pam.d/password-auth\n\nIf output is produced, this is a finding.\n\nIf the system administrator (SA) can demonstrate that the required configuration is contained in a PAM configuration file included or substacked from the \"system-auth\" file, this is not a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If an account has an empty password, anyone could log in and run commands with the privileges of that account. Accounts with empty passwords must never be used in operational environments.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066"],"reference_identifier":"4747","uuid":"87fba96e-5adb-48e0-a66c-f2024ba18fc6","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 7E7E8557D0FF0B638C07FB489B40565B7727C50D\r\n~~~~~\r\nConfiguration for 'RHEL 10 must not allow blank or null passwords.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281201","group_tree":[{"id":"V-281201","title":"SRG-OS-000069-GPOS-00037","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281201","severity":"medium","group_title":"SRG-OS-000069-GPOS-00037","rule_id_src":"SV-281201r1166555_rule","rule_id":"SV-281201","rule_version":"RHEL-10-600460","rule_title":"RHEL 10 must not have accounts configured with blank or null passwords.","fix_text":"Configure RHEL 10 so that all accounts have a password, or lock the account with the following commands:\n\nPerform a password reset:\n\n$ sudo passwd [username]\n\nTo lock an account:\n\n$ sudo passwd -l [username]","weight":"10.0","check_content":"Verify RHEL 10 prohibits null or blank passwords with the following command:\n\n$ sudo awk -F: '!$2 {print $1}' /etc/shadow\n\nIf the command returns any results, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If an account has an empty password, anyone could log in and run commands with the privileges of that account. Accounts with empty passwords should never be used in operational environments.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066"],"reference_identifier":"6445","uuid":"9afc35fa-0d4f-43cf-80da-b45a4a63d129","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: B5150A1010AF3D4D3D1468A439D7C57DDC297B45\r\n~~~~~\r\nConfiguration for 'RHEL 10 must not have accounts configured with blank or null passwords.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281202","group_tree":[{"id":"V-281202","title":"SRG-OS-000104-GPOS-00051","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281202","severity":"medium","group_title":"SRG-OS-000104-GPOS-00051","rule_id_src":"SV-281202r1166558_rule","rule_id":"SV-281202","rule_version":"RHEL-10-600470","rule_title":"RHEL 10 must have a unique group ID (GID) for each group in \"/etc/group\".","fix_text":"Configure RHEL 10 to contain no duplicate GIDs for interactive users.\n\nEdit the file \"/etc/group\", and provide each group that has a duplicate GID with a unique GID.","weight":"10.0","check_content":"Verify RHEL 10 contains no duplicate GIDs for interactive users with the following command:\n\n $  cut -d : -f 3 /etc/group | uniq -d\n\nIf the system has duplicate GIDs, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"To ensure accountability and prevent unauthenticated access, groups must be identified uniquely to prevent potential misuse and compromise of the system.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000764"],"reference_identifier":"6570","uuid":"111f093e-3820-4313-9de2-6fc0480b6cc9","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-281203","group_tree":[{"id":"V-281203","title":"SRG-OS-000027-GPOS-00008","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281203","severity":"low","group_title":"SRG-OS-000027-GPOS-00008","rule_id_src":"SV-281203r1166561_rule","rule_id":"SV-281203","rule_version":"RHEL-10-600475","rule_title":"RHEL 10 must limit the number of concurrent sessions to 10 for all accounts and/or account types.","fix_text":"Configure RHEL 10 to limit the number of concurrent sessions to \"10\" for all accounts and/or account types.\n\nAdd the following line to the top of \"/etc/security/limits.conf\" or in a \".conf\" file defined in \"/etc/security/limits.d/\":\n\n* hard maxlogins 10","weight":"10.0","check_content":"Verify RHEL 10 limits the number of concurrent sessions to \"10\" for all accounts and/or account types with the following command:\n\n$ sudo grep -rs maxlogins /etc/security/limits.conf /etc/security/limits.d/*.conf | grep -v '#'\n/etc/security/limits.d/maxlogins.conf:* hard maxlogins 10\n\nThis can be set as a global domain (with the * wildcard) but may be set differently for multiple domains.\n\nIf the \"maxlogins\" item is missing or commented out, or the value is set greater than \"10\" and is not documented with the information system security officer as an operational requirement for all domains that have the \"maxlogins\" item assigned, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Operating system management includes the ability to control the number of users and user sessions that use an operating system. Limiting the number of allowed users and sessions per user is helpful in reducing the risks related to denial-of-service (DoS) attacks.\n\nThis requirement addresses concurrent sessions for information system accounts and does not address concurrent sessions by single users via multiple system accounts. The maximum number of concurrent sessions should be defined based on mission needs and the operational environment for each system.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000054"],"reference_identifier":"3275","uuid":"38628e4b-e9b3-4c33-a2f6-c77c88f5feb2","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 29B7C6D55168FE66F8F176A155C16506BBFDBE18\r\n~~~~~\r\nConfiguration for 'RHEL 10 must limit the number of concurrent sessions to 10 for all accounts and/or account types.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281204","group_tree":[{"id":"V-281204","title":"SRG-OS-000069-GPOS-00037","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281204","severity":"medium","group_title":"SRG-OS-000069-GPOS-00037","rule_id_src":"SV-281204r1197240_rule","rule_id":"SV-281204","rule_version":"RHEL-10-600485","rule_title":"RHEL 10 must ensure the password complexity module in the system-auth file is configured for three or fewer retries.","fix_text":"Configure RHEL 10 to limit the \"pwquality\" retry option to \"3\".\n\nAdd or update the following line in the \"/etc/security/pwquality.conf\" file or a file in the \"/etc/security/pwquality.conf.d/\" directory to contain the \"retry\" parameter:\n\nretry = 3","weight":"10.0","check_content":"Verify RHEL 10 is configured to limit the \"pwquality\" retry option to \"3\" with the following command:\n\n$ sudo grep -w retry /etc/security/pwquality.conf /etc/security/pwquality.conf.d/*.conf \nretry = 3 \n\nIf the value of \"retry\" is set to \"0\" or greater than \"3\", is commented out, or is missing, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Use of a complex password helps to increase the time and resources required to compromise the password. Password complexity, or strength, is a measure of the effectiveness of a password in resisting attempts at guessing and brute-force attacks. \"pwquality\" enforces complex password construction configuration and has the ability to limit brute-force attacks on the system.\n\nRHEL 10 uses \"pwquality\" as a mechanism to enforce password complexity. This is set in both of the following: \n\n\"/etc/pam.d/password-auth\"\n\"/etc/pam.d/system-auth\"\n\nBy limiting the number of attempts to meet the pwquality module complexity requirements before returning with an error, the system will audit abnormal attempts at password changes.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066"],"reference_identifier":"7268","uuid":"ce8a3ff2-0050-43d0-abf3-08a1473a95ff","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 55229E7D1D6C2DFC087E83387F79E453DB3F4ABB\r\n~~~~~\r\nConfiguration for 'RHEL 10 must ensure the password complexity module in the system-auth file is configured for three or fewer retries.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281205","group_tree":[{"id":"V-281205","title":"SRG-OS-000373-GPOS-00156","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281205","severity":"medium","group_title":"SRG-OS-000373-GPOS-00156","rule_id_src":"SV-281205r1166567_rule","rule_id":"SV-281205","rule_version":"RHEL-10-600500","rule_title":"RHEL 10 must restrict the use of the \"su\" command.","fix_text":"Configure RHEL 10 to require users to be in the \"wheel\" group to run the \"su\" command.\n\nEdit the configuration file:\n\n$ sudo vi /etc/pam.d/su\n\nAdd the following lines:\n\nauth    required    pam_wheel.so use_uid\n$ sed '/^[[:space:]]*#[[:space:]]*auth[[:space:]]\\+required[[:space:]]\\+pam_wheel\\.so[[:space:]]\\+use_uid$/s/^[[:space:]]*#//' -i /etc/pam.d/su\n\nIf necessary, create a \"wheel\" group and add administrative users to the group.","weight":"10.0","check_content":"Verify RHEL 10 requires users to be members of the \"wheel\" group to run \"su\".\n\nVerify the configuration with the following command:\n\n$ sudo grep pam_wheel /etc/pam.d/su\nauth             required        pam_wheel.so use_uid\n\nIf a line for \"pam_wheel.so\" does not exist or is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"su\" program allows commands to be run with a substitute user and group ID. It is commonly used to run commands as the root user. Limiting access to such commands is considered a good security practice.\n\nSatisfies: SRG-OS-000373-GPOS-00156, SRG-OS-000312-GPOS-00123","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002038","CCI-002165"],"reference_identifier":"4475","uuid":"84708755-f330-4964-bd0f-e5331891ba56","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 87335211099DE48389C3CDA4A904EB2BAAEF7EF3\r\n~~~~~\r\nConfiguration for 'RHEL 10 must restrict the use of the \"su\" command.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281206","group_tree":[{"id":"V-281206","title":"SRG-OS-000373-GPOS-00156","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281206","severity":"medium","group_title":"SRG-OS-000373-GPOS-00156","rule_id_src":"SV-281206r1166570_rule","rule_id":"SV-281206","rule_version":"RHEL-10-600510","rule_title":"RHEL 10 must be configured to not bypass password requirements for privilege escalation.","fix_text":"Configure RHEL 10 to require users to supply a password for privilege escalation.\n\nRemove any occurrences of \" pam_succeed_if \" in the \"/etc/pam.d/sudo\" file.","weight":"10.0","check_content":"Verify RHEL 10 is not configured to bypass password requirements for privilege escalation with the following command:\n\n$ sudo grep pam_succeed_if /etc/pam.d/sudo\n\nIf any occurrences of \"pam_succeed_if\" are returned, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Without reauthentication, users may access resources or perform tasks for which they do not have authorization. When operating systems provide the capability to escalate a functional capability, it is critical the user reauthenticate.\n\nSatisfies: SRG-OS-000373-GPOS-00156, SRG-OS-000373-GPOS-00157, SRG-OS-000373-GPOS-00158","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002038"],"reference_identifier":"9378","uuid":"c65917e6-679a-49ed-9454-51649032a96b","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: FFA0C473CEA1E6EABD45708A2A3F2152039F30F7\r\n~~~~~\r\nConfiguration for 'RHEL 10 must be configured to not bypass password requirements for privilege escalation.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281207","group_tree":[{"id":"V-281207","title":"SRG-OS-000445-GPOS-00199","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281207","severity":"medium","group_title":"SRG-OS-000445-GPOS-00199","rule_id_src":"SV-281207r1166573_rule","rule_id":"SV-281207","rule_version":"RHEL-10-600520","rule_title":"RHEL 10 must restrict privilege elevation to authorized personnel.","fix_text":"Configure RHEL 10 to restrict privilege elevation to authorized personnel.\n\nRemove the following entries from the \"/etc/sudoers\" file or configuration file under \"/etc/sudoers.d/\":\n\nALL     ALL=(ALL) ALL\nALL     ALL=(ALL:ALL) ALL","weight":"10.0","check_content":"Verify RHEL 10 restricts privilege elevation to authorized personnel with the following command:\n\n$ sudo grep -riw ALL /etc/sudoers /etc/sudoers.d/ | grep -v \"#\"\n\nIf the either of the following entries is returned, this is a finding:\n\nALL     ALL=(ALL) ALL\nALL     ALL=(ALL:ALL) ALL","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If the \"sudoers\" file is not configured correctly, any user defined on the system can initiate privileged actions on the target system.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002696"],"reference_identifier":"4676","uuid":"2473ef37-9799-457c-98b1-b9b9be6f0896","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 3D1B25F3C8AAC296DE6E9C3A65D0B55C89C07C06\r\n~~~~~\r\nConfiguration for 'RHEL 10 must restrict privilege elevation to authorized personnel.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281208","group_tree":[{"id":"V-281208","title":"SRG-OS-000373-GPOS-00156","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281208","severity":"medium","group_title":"SRG-OS-000373-GPOS-00156","rule_id_src":"SV-281208r1166576_rule","rule_id":"SV-281208","rule_version":"RHEL-10-600530","rule_title":"RHEL 10 must require users to reauthenticate for privilege escalation.","fix_text":"Configure RHEL 10 to not allow users to execute privileged actions without authenticating.\n\nRemove any occurrence of \"!authenticate\" found in the \"/etc/sudoers\" file or files in the \"/etc/sudoers.d\" directory:\n\n$ sudo sed -i '/\\!authenticate/ s/^/# /g' /etc/sudoers /etc/sudoers.d/*","weight":"10.0","check_content":"Verify RHEL 10 \"/etc/sudoers\" has no occurrences of \"!authenticate\" with the following command:\n\n$ sudo grep -ir '!authenticate' /etc/sudoers /etc/sudoers.d/\n\nIf any occurrences of \"!authenticate\" are returned, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Without reauthentication, users may access resources or perform tasks for which they do not have authorization.\n\nWhen operating systems provide the capability to escalate a functional capability, it is critical that the user reauthenticate.\n\nSatisfies: SRG-OS-000373-GPOS-00156, SRG-OS-000373-GPOS-00157, SRG-OS-000373-GPOS-00158","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002038"],"reference_identifier":"1118","uuid":"0327f06f-fca8-4ba5-ae93-da3bd4eee1ab","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: ACDB2D4B489CF1928561C2B612B7EC4038A05C47\r\n~~~~~\r\nConfiguration for 'RHEL 10 must require users to reauthenticate for privilege escalation.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281209","group_tree":[{"id":"V-281209","title":"SRG-OS-000373-GPOS-00156","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281209","severity":"medium","group_title":"SRG-OS-000373-GPOS-00156","rule_id_src":"SV-281209r1166579_rule","rule_id":"SV-281209","rule_version":"RHEL-10-600540","rule_title":"RHEL 10 must require reauthentication when using the \"sudo\" command.","fix_text":"Configure RHEL 10 to reauthenticate \"sudo\" commands after the specified timeout.\n\nAdd the following line to \"/etc/sudoers\" or a file in \"/etc/sudoers.d\":\n\nDefaults timestamp_timeout=0","weight":"10.0","check_content":"Verify RHEL 10 requires reauthentication when using the \"sudo\" command to elevate privileges with the following command:\n\n$ sudo grep -ir 'timestamp_timeout' /etc/sudoers /etc/sudoers.d/\n/etc/sudoers:Defaults timestamp_timeout=0\n\nIf results are returned from more than one file location, this is a finding.\n\nIf \"timestamp_timeout\" is set to a negative number, is commented out, or no results are returned, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Without reauthentication, users may access resources or perform tasks for which they do not have authorization.\n\nWhen operating systems provide the capability to escalate a functional capability, it is critical that the organization requires the user to reauthenticate when using the \"sudo\" command.\n\nIf the value is set to an integer less than \"0\", the user's time stamp will not expire, and the user will not have to reauthenticate for privileged actions until the user's session is terminated.\n\nSatisfies: SRG-OS-000373-GPOS-00156, SRG-OS-000373-GPOS-00157, SRG-OS-000373-GPOS-00158","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002038"],"reference_identifier":"7865","uuid":"6508d6a4-6447-420d-85e3-9a1860a72e8e","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 5971157FF2D5E031C1C6D04740566DF2333814B6\r\n~~~~~\r\nConfiguration for 'RHEL 10 must require reauthentication when using the \"sudo\" command.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281210","group_tree":[{"id":"V-281210","title":"SRG-OS-000373-GPOS-00156","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281210","severity":"medium","group_title":"SRG-OS-000373-GPOS-00156","rule_id_src":"SV-281210r1166582_rule","rule_id":"SV-281210","rule_version":"RHEL-10-600550","rule_title":"RHEL 10 must use the invoking user's password for privilege escalation when using \"sudo\".","fix_text":"Configure RHEL 10 to use the invoking user's password for privilege escalation when using \"sudo\".\n\nDefine the following in the Defaults section of the /etc/sudoers file or a single configuration file in the /etc/sudoers.d/ directory:\n\nDefaults !targetpw\nDefaults !rootpw\nDefaults !runaspw","weight":"10.0","check_content":"Verify RHEL 10 sudoers security policy is configured to use the invoking user's password for privilege escalation with the following command:\n\n$ sudo grep -irE '(!rootpw|!targetpw|!runaspw)' /etc/sudoers /etc/sudoers.d/ | grep -v '#'\n/etc/sudoers:Defaults !targetpw\n/etc/sudoers:Defaults !rootpw\n/etc/sudoers:Defaults !runaspw\n\nIf no results are returned, this is a finding.\n\nIf results are returned from more than one file location, this is a finding.\n\nIf \"Defaults !targetpw\" is not defined, this is a finding.\n\nIf \"Defaults !rootpw\" is not defined, this is a finding.\n\nIf \"Defaults !runaspw\" is not defined, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If the \"rootpw\", \"targetpw\", or \"runaspw\" flags are defined and not disabled, by default the operating system will prompt the invoking user for the \"root\" user password.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002038"],"reference_identifier":"1047","uuid":"3c5877c6-43ee-4b6a-9da1-b0961407619b","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 075324DFF5DF7C05D683FCFB5BB189901B27F05D\r\n~~~~~\r\nRequired configuration for 'RHEL 10 must use the invoking user's password for privilege escalation when using \"sudo\".' was not present or did not match the expected value on the RHEL 10 host."},{"group_id_src":"V-281211","group_tree":[{"id":"V-281211","title":"SRG-OS-000373-GPOS-00156","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281211","severity":"high","group_title":"SRG-OS-000373-GPOS-00156","rule_id_src":"SV-281211r1166585_rule","rule_id":"SV-281211","rule_version":"RHEL-10-600560","rule_title":"RHEL 10 must require users to provide a password for privilege escalation.","fix_text":"Configure RHEL 10 to not allow users to execute privileged actions without authenticating with a password.\n\nRemove any occurrence of \"NOPASSWD\" found in the \"/etc/sudoers\" file or files in the \"/etc/sudoers.d\" directory:\n\n$ sudo find /etc/sudoers /etc/sudoers.d -type f -exec sed -i '/NOPASSWD/ s/^/# /g' {} \\;","weight":"10.0","check_content":"Verify RHEL 10 has no occurrences of \"NOPASSWD\" in \"/etc/sudoers\" with the following command:\n\n$ sudo grep -ir nopasswd /etc/sudoers /etc/sudoers.d/ | grep -v '#'\n\nIf any occurrences of \"NOPASSWD\" are returned from the command and have not been documented with the information system security officer as an organizationally defined administrative group using multifactor authentication, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Without reauthentication, users may access resources or perform tasks for which they do not have authorization.\n\nWhen operating systems provide the capability to escalate a functional capability, it is critical that the user reauthenticate.\n\nSatisfies: SRG-OS-000373-GPOS-00156, SRG-OS-000373-GPOS-00157, SRG-OS-000373-GPOS-00158","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002038"],"reference_identifier":"9535","uuid":"68d8a41e-e267-4a62-9e63-08f0b04aa532","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 073D0A4D62885E9F1756059A12AC0CEE9A86DA94\r\n~~~~~\r\nConfiguration for 'RHEL 10 must require users to provide a password for privilege escalation.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281212","group_tree":[{"id":"V-281212","title":"SRG-OS-000021-GPOS-00005","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281212","severity":"medium","group_title":"SRG-OS-000021-GPOS-00005","rule_id_src":"SV-281212r1166588_rule","rule_id":"SV-281212","rule_version":"RHEL-10-600600","rule_title":"RHEL 10 must configure the use of the pam_faillock.so module in the \"/etc/pam.d/system-auth\" file.","fix_text":"Configure RHEL 10 to include the use of the pam_faillock.so module in the \"/etc/pam.d/system-auth\" file.\n\nIf PAM is managed with authselect, enable the feature with the following command:\n\n$ sudo authselect enable-feature with-faillock\n\nOtherwise, add/modify the appropriate sections of the \"/etc/pam.d/system-auth\" file to match the following lines:\n\nNote: The \"preauth\" line must be listed before pam_unix.so.\n\nauth required pam_faillock.so preauth\nauth required pam_faillock.so authfail\naccount required pam_faillock.so","weight":"10.0","check_content":"Verify RHEL 10 includes the use of the pam_faillock.so module in the \"/etc/pam.d/system-auth\" file:\n\n$ sudo grep pam_faillock.so /etc/pam.d/system-auth\nauth required pam_faillock.so preauth\nauth required pam_faillock.so authfail\naccount required pam_faillock.so\n\nIf the pam_faillock.so module is not present in the \"/etc/pam.d/system-auth\" file with the \"preauth\" line listed before pam_unix.so, this is a finding.\n\nIf the system administrator can demonstrate that the required configuration is contained in a PAM configuration file included or substacked from the \"system-auth\" file, this is not a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If the pam_faillock.so module is not loaded, the system will not correctly lock out accounts to prevent password guessing attacks.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000044"],"reference_identifier":"6536","uuid":"21c64ac0-00c5-4ddf-b805-2096461503dc","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: DFBBC2C1955915EF4AEE724C4806E0E3D544123E\r\n~~~~~\r\nConfiguration for 'RHEL 10 must configure the use of the pam_faillock.so module in the \"/etc/pam.d/system-auth\" file.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281213","group_tree":[{"id":"V-281213","title":"SRG-OS-000021-GPOS-00005","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281213","severity":"medium","group_title":"SRG-OS-000021-GPOS-00005","rule_id_src":"SV-281213r1166591_rule","rule_id":"SV-281213","rule_version":"RHEL-10-600610","rule_title":"RHEL 10 must configure the use of the pam_faillock.so module in the \"/etc/pam.d/password-auth\" file.","fix_text":"Configure RHEL 10 to include the use of the pam_faillock.so module in the \"/etc/pam.d/password-auth\" file. If PAM is managed with \"authselect\", enable the feature with the following command:\n\n$ sudo authselect enable-feature with-faillock\n\nOtherwise, add/modify the appropriate sections of the \"/etc/pam.d/password-auth\" file to match the following lines:\n\nNote: The \"preauth\" line must be listed before pam_unix.so.\n\nauth required pam_faillock.so preauth\nauth required pam_faillock.so authfail\naccount required pam_faillock.so","weight":"10.0","check_content":"Verify RHEL 10 includes the pam_faillock.so module in the \"/etc/pam.d/password-auth\" file:\n\n$ sudo grep pam_faillock.so /etc/pam.d/password-auth\nauth required pam_faillock.so preauth\nauth required pam_faillock.so authfail\naccount required pam_faillock.so\n\nIf the pam_faillock.so module is not present in the \"/etc/pam.d/password-auth\" file with the \"preauth\" line listed before pam_unix.so, this is a finding.\n\nIf the system administrator can demonstrate that the required configuration is contained in a Pluggable Authentication Module (PAM) configuration file included or substacked from the \"system-auth\" file, this is not a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If the pam_faillock.so module is not loaded, the system will not correctly lock out accounts to prevent password guessing attacks.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000044"],"reference_identifier":"4131","uuid":"f80b1a30-9a43-4d85-bc0a-65b9723ec880","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: ABAC0D39799CEE5B0EB24B4D8DEA4CA2EFBB5B0A\r\n~~~~~\r\nConfiguration for 'RHEL 10 must configure the use of the pam_faillock.so module in the \"/etc/pam.d/password-auth\" file.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281214","group_tree":[{"id":"V-281214","title":"SRG-OS-000069-GPOS-00037","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281214","severity":"medium","group_title":"SRG-OS-000069-GPOS-00037","rule_id_src":"SV-281214r1166594_rule","rule_id":"SV-281214","rule_version":"RHEL-10-600620","rule_title":"RHEL 10 must ensure the password complexity module is enabled in the \"password-auth\" file.","fix_text":"Configure RHEL 10 to use \"pwquality\" to enforce password complexity rules.\n\nAdd the following line to the \"/etc/pam.d/password-auth\" file (or modify the line to have the required value):\n\npassword required pam_pwquality.so","weight":"10.0","check_content":"Verify RHEL 10 uses \"pwquality\" to enforce the password complexity rules in the \"password-auth\" file with the following command:\n\n$ sudo grep pam_pwquality /etc/pam.d/password-auth\npassword required pam_pwquality.so\n\nIf the command does not return a line containing the value \"pam_pwquality.so\", or the line is commented out, this is a finding.\n\nIf the system administrator can demonstrate that the required configuration is contained in a PAM configuration file included or substacked from the \"system-auth\" file, this is not a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Enabling Pluggable Authentication Module (PAM) password complexity permits enforcement of strong passwords and consequently makes the system less prone to dictionary attacks.\n\nSatisfies: SRG-OS-000069-GPOS-00037, SRG-OS-000070-GPOS-00038","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066"],"reference_identifier":"7199","uuid":"705aa1b5-ad30-4a00-80d0-6e9c9f77548e","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: B400E205866BA6847A82DEA7F114A9CF0EA1BB5F\r\n~~~~~\r\nConfiguration for 'RHEL 10 must ensure the password complexity module is enabled in the \"password-auth\" file.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281215","group_tree":[{"id":"V-281215","title":"SRG-OS-000069-GPOS-00037","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281215","severity":"medium","group_title":"SRG-OS-000069-GPOS-00037","rule_id_src":"SV-281215r1166597_rule","rule_id":"SV-281215","rule_version":"RHEL-10-600630","rule_title":"RHEL 10 must ensure the password complexity module is enabled in the \"system-auth\" file.","fix_text":"Configure RHEL 10 to use \"pwquality\" to enforce password complexity rules.\n\nAdd the following line to the \"/etc/pam.d/system-auth\" file (or modify the line to have the required value):\n\npassword required pam_pwquality.so","weight":"10.0","check_content":"Verify RHEL 10 uses \"pwquality\" to enforce the password complexity rules in the \"system-auth\" file with the following command:\n\n$ sudo grep pam_pwquality /etc/pam.d/system-auth\npassword required pam_pwquality.so\n\nIf the command does not return a line containing the value \"pam_pwquality.so\", or the line is commented out, this is a finding.\n\nIf the system administrator can demonstrate that the required configuration is contained in a PAM configuration file included or substacked from the \"system-auth\" file, this is not a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Enabling Pluggable Authentication Module (PAM) password complexity permits enforcement of strong passwords and consequently makes the system less prone to dictionary attacks.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004066"],"reference_identifier":"8627","uuid":"4b089848-1e1a-4375-81be-e277a9e2ac6e","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: FF10CBEC9177D39D80551C8F6699167A33189517\r\n~~~~~\r\nConfiguration for 'RHEL 10 must ensure the password complexity module is enabled in the \"system-auth\" file.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281216","group_tree":[{"id":"V-281216","title":"SRG-OS-000125-GPOS-00065","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281216","severity":"high","group_title":"SRG-OS-000125-GPOS-00065","rule_id_src":"SV-281216r1166600_rule","rule_id":"SV-281216","rule_version":"RHEL-10-600640","rule_title":"RHEL 10 must enable the Pluggable Authentication Module (PAM) interface for SSHD.","fix_text":"Configure RHEL 10 SSHD to use the \"UsePAM\" interface by adding or modifying the following line in \"/etc/ssh/sshd_config\" or in a file in \"/etc/ssh/sshd_config.d\".\n\nUsePAM yes\n\nRestart the SSH daemon with the following command for the settings to take effect:\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify RHEL 10 SSHD is configured to allow for the \"UsePAM\" interface with the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*usepam'\nUsePAM yes\n\nIf the \"UsePAM\" keyword is set to \"no\", is missing, or is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"When \"UsePAM\" is set to \"yes\", PAM runs through account and session types properly. This is important when restricted access to services based on IP, time, or other factors of the account is needed. Additionally, this ensures users can inherit certain environment variables on login or disallow access to the server.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000877"],"reference_identifier":"4592","uuid":"168e8e98-fdcd-4524-8231-8137476e3d83","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 95401F60FDB315700DE6535E4E038ECD646DD89D\r\n~~~~~\r\nConfiguration for 'RHEL 10 must enable the Pluggable Authentication Module (PAM) interface for SSHD.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281217","group_tree":[{"id":"V-281217","title":"SRG-OS-000073-GPOS-00041","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281217","severity":"medium","group_title":"SRG-OS-000073-GPOS-00041","rule_id_src":"SV-281217r1195450_rule","rule_id":"SV-281217","rule_version":"RHEL-10-600650","rule_title":"RHEL 10 must ensure that the pam_unix.so module is configured in the password-auth file to use a FIPS 140-3-approved cryptographic hashing algorithm for system authentication.","fix_text":"Configure RHEL 10 to use the sha512 cryptographic hashing algorithm for local account passwords.\n\nEdit/modify the following line in the \"/etc/pam.d/password-auth\" file to include the sha512 option for pam_unix.so:\n\npassword sufficient pam_unix.so sha512","weight":"10.0","check_content":"Verify RHEL 10 configures the pam_unix.so module to use sha512 in \"/etc/pam.d/password-auth\" with the following command:\n\n$ sudo grep \"^password.*pam_unix.so.*sha512\" /etc/pam.d/password-auth\npassword sufficient pam_unix.so sha512\n\nIf \"sha512\" is missing, or the line is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Unapproved mechanisms that are used for authentication to the cryptographic module are not verified; therefore, they cannot be relied on to provide confidentiality or integrity, and DOD data may be compromised.\n\nRHEL 10 systems using encryption are required to use FIPS-compliant mechanisms for authenticating to cryptographic modules.\n\nFIPS 140-3 is the current standard for validating that mechanisms used to access cryptographic modules use authentication that meets DOD requirements. This allows for Security Levels 1, 2, 3, or 4 for use on a general-purpose computing system.\n\nSatisfies: SRG-OS-000073-GPOS-00041, SRG-OS-000120-GPOS-00061","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004062","CCI-000803"],"reference_identifier":"2093","uuid":"c641ba7a-6c02-45b3-9c08-8c75b1619157","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 02DA2795EF3C85D8C18F438A63B32F5BDFB78BF1\r\n~~~~~\r\nConfiguration for 'RHEL 10 must ensure that the pam_unix.so module is configured in the password-auth file to use a FIPS 140-3-approved cryptographic hashing algorithm for system authentication.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281218","group_tree":[{"id":"V-281218","title":"SRG-OS-000073-GPOS-00041","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281218","severity":"medium","group_title":"SRG-OS-000073-GPOS-00041","rule_id_src":"SV-281218r1166606_rule","rule_id":"SV-281218","rule_version":"RHEL-10-600700","rule_title":"RHEL 10 must be configured to use a sufficient number of hashing rounds for the shadow password suite.","fix_text":"Configure RHEL 10 to use a sufficient number of hashing rounds for shadow password suite.\n\nAdd or modify the following line in \"/etc/pam.d/system-auth\" and set \"rounds\" to 100000:\n\npassword sufficient pam_unix.so sha512 rounds=100000","weight":"10.0","check_content":"Verify RHEL 10 uses a sufficient number of rounds for the shadow password suite hashing algorithm with the following command:\n\n$ sudo grep rounds /etc/pam.d/system-auth\npassword sufficient pam_unix.so sha512 rounds=100000\n\nIf the setting is not configured or \"rounds\" is less than 100000, this a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Passwords must be protected at all times, and encryption is the standard method for protecting passwords. If passwords are not encrypted, they can be plainly read (i.e., clear text) and easily compromised. Passwords that are encrypted with a weak algorithm are no more protected than if they are kept in plain text.\n\nUsing more hashing rounds makes password cracking attacks more difficult.\n\nSatisfies: SRG-OS-000073-GPOS-00041, SRG-OS-000120-GPOS-00061","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004062","CCI-000803"],"reference_identifier":"9590","uuid":"d2743ff7-55d7-42b5-96a9-58f4e78b5a95","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 6DBD2B13A8659BB8BCEB8986132D65636C8FA2B8\r\n~~~~~\r\nConfiguration for 'RHEL 10 must be configured to use a sufficient number of hashing rounds for the shadow password suite.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281219","group_tree":[{"id":"V-281219","title":"SRG-OS-000073-GPOS-00041","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281219","severity":"medium","group_title":"SRG-OS-000073-GPOS-00041","rule_id_src":"SV-281219r1166609_rule","rule_id":"SV-281219","rule_version":"RHEL-10-600710","rule_title":"RHEL 10 must be configured to use a FIPS 140-3-approved cryptographic hashing algorithm for system authentication by ensuring that the pam_unix.so module is configured in the \"system-auth\" file.","fix_text":"Configure RHEL 10 to use a FIPS 140-3-approved cryptographic hashing algorithm for system authentication in \"/etc/pam.d/system-auth\" via the \"pam_unix.so\" module.\n\nEdit/modify the following line in the \"/etc/pam.d/system-auth\" file to include the sha512 option for pam_unix.so:\n\npassword sufficient pam_unix.so sha512","weight":"10.0","check_content":"Verify RHEL 10 is configured to use a FIPS 140-3-approved cryptographic hashing algorithm in \"/etc/pam.d/system-auth\" via the pam_unix.so module with the following command:\n\n$ sudo grep \"^password.*pam_unix.so.*sha512\" /etc/pam.d/system-auth\npassword sufficient pam_unix.so sha512\n\nIf \"sha512\" is missing, or the line is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Unapproved mechanisms that are used for authentication to the cryptographic module are not verified and therefore cannot be relied on to provide confidentiality or integrity, and DOD data may be compromised.\n\nRHEL 10 systems using encryption are required to use FIPS-compliant mechanisms for authenticating to cryptographic modules.\n\nFIPS 140-3 is the current standard for validating that mechanisms used to access cryptographic modules use authentication that meets DOD requirements. This allows for Security Levels 1, 2, 3, or 4 for use on a general-purpose computing system.\n\nSatisfies: SRG-OS-000073-GPOS-00041, SRG-OS-000120-GPOS-00061","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004062","CCI-000803"],"reference_identifier":"7701","uuid":"1efd0ffe-6649-4ebc-8883-e44700c39efb","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: AC472E4E43FA298F53CE1D820C583F08B9F42B25\r\n~~~~~\r\nConfiguration for 'RHEL 10 must be configured to use a FIPS 140-3-approved cryptographic hashing algorithm for system authentication by ensuring that the pam_unix.so module is configured in the \"system-auth\" file.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281220","group_tree":[{"id":"V-281220","title":"SRG-OS-000073-GPOS-00041","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281220","severity":"medium","group_title":"SRG-OS-000073-GPOS-00041","rule_id_src":"SV-281220r1166612_rule","rule_id":"SV-281220","rule_version":"RHEL-10-600720","rule_title":"RHEL 10 must be configured so that password-auth uses a sufficient number of hashing rounds.","fix_text":"Configure RHEL 10 to use \"100000\" hashing rounds for hashing passwords.\n\nAdd or modify the following line in \"/etc/pam.d/password-auth\" and set \"rounds\" to \"100000\":\n\npassword sufficient pam_unix.so sha512 rounds=100000","weight":"10.0","check_content":"Verify RHEL 10 is configured to use a sufficient number of rounds for password hashing with the following command:\n\n$ sudo grep rounds /etc/pam.d/password-auth\npassword sufficient pam_unix.so sha512 rounds=100000\n\nIf the setting is not configured or \"rounds\" is less than \"100000\", this a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Passwords must be protected at all times, and encryption is the standard method for protecting passwords. If passwords are not encrypted, they can be plainly read (i.e., clear text) and easily compromised. Passwords that are encrypted with a weak algorithm are no more protected than if they are kept in plain text.\n\nUsing more hashing rounds makes password cracking attacks more difficult.\n\nSatisfies: SRG-OS-000073-GPOS-00041, SRG-OS-000120-GPOS-00061","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004062","CCI-000803"],"reference_identifier":"8442","uuid":"26991095-c231-4e37-bfb9-8ad02537a488","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: 0FD6B94CFF6B1487763B8CCEE5B77DEC5E5A2706\r\n~~~~~\r\nThe feature/role addressed by 'RHEL 10 must be configured so that password-auth uses a sufficient number of hashing rounds.' is not present or not in use on this the RHEL 10 host."},{"group_id_src":"V-281221","group_tree":[{"id":"V-281221","title":"SRG-OS-000073-GPOS-00041","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281221","severity":"high","group_title":"SRG-OS-000073-GPOS-00041","rule_id_src":"SV-281221r1166615_rule","rule_id":"SV-281221","rule_version":"RHEL-10-600730","rule_title":"RHEL 10 must employ FIPS 140-3-approved cryptographic hashing algorithms for all stored passwords.","fix_text":"Configure RHEL 10 to employ FIPS 140-3-approved cryptographic hashing algorithms for all stored passwords.\n\nLock all interactive user accounts not using SHA-512 hashing until the passwords can be regenerated with SHA-512.","weight":"10.0","check_content":"Verify RHEL 10 employs FIPS 140-3-approved cryptographic hashing algorithms for all stored passwords for interactive user accounts with the following command:\n\n$ sudo cut -d: -f2 /etc/shadow\n$6$kcOnRq/5$NUEYPuyL.wghQwWssXRcLRFiiru7f5JPV6GaJhNC2aK5F3PZpE/BCCtwrxRc/AInKMNX3CdMw11m9STiql12f/\n\nPassword hashes \"!\" or \"*\" indicate inactive accounts not available for login and are not evaluated.\n\nIf any interactive user password hash does not begin with \"$6\", this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The system must use a strong hashing algorithm to store the password.\n\nPasswords must be protected at all times, and encryption is the standard method for protecting passwords. If passwords are not encrypted, they can be plainly read (i.e., clear text) and easily compromised.\n\nSatisfies: SRG-OS-000073-GPOS-00041, SRG-OS-000120-GPOS-00061","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004062","CCI-000803"],"reference_identifier":"4111","uuid":"3ef82491-1623-4f28-b58e-5865e8039dca","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: E60E0ABE9BABCF329825C3123E1F04E8D9750A0E\r\n~~~~~\r\nRequired configuration for 'RHEL 10 must employ FIPS 140-3-approved cryptographic hashing algorithms for all stored passwords.' was not present or did not match the expected value on the RHEL 10 host."},{"group_id_src":"V-281222","group_tree":[{"id":"V-281222","title":"SRG-OS-000073-GPOS-00041","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281222","severity":"high","group_title":"SRG-OS-000073-GPOS-00041","rule_id_src":"SV-281222r1184626_rule","rule_id":"SV-281222","rule_version":"RHEL-10-600740","rule_title":"RHEL 10 must be configured to use the shadow file to store only encrypted representations of passwords.","fix_text":"Configure RHEL 10 to store only SHA512 encrypted representations of passwords.\n\nAdd or update the following line in the \"/etc/login.defs\" file:\n\nENCRYPT_METHOD SHA512","weight":"10.0","check_content":"Verify RHEL 10 is configured so that the shadow file stores only encrypted representations of passwords with a hash value of SHA512 with the following command:\n\n$ sudo grep -i encrypt_method /etc/login.defs\nENCRYPT_METHOD SHA512\n\nIf \"ENCRYPT_METHOD\" does not have a value of \"SHA512\", or the line is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Passwords must be protected at all times, and encryption is the standard method for protecting passwords. If passwords are not encrypted, they can be plainly read (i.e., clear text) and easily compromised. Passwords that are encrypted with a weak algorithm are no more protected than if they are kept in plain text.\n\nThis setting ensures user and group account administration utilities are configured to store only encrypted representations of passwords. Additionally, the \"crypt_style\" configuration option ensures the use of a strong hashing algorithm that makes password cracking attacks more difficult.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004062"],"reference_identifier":"3150","uuid":"e77f39d0-417f-4074-abfd-d298b7ca5fc5","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 3F5D6BBC1FCFC10B584AF1C08AF3C6F69752578F\r\n~~~~~\r\nConfiguration for 'RHEL 10 must be configured to use the shadow file to store only encrypted representations of passwords.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281223","group_tree":[{"id":"V-281223","title":"SRG-OS-000073-GPOS-00041","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281223","severity":"high","group_title":"SRG-OS-000073-GPOS-00041","rule_id_src":"SV-281223r1166621_rule","rule_id":"SV-281223","rule_version":"RHEL-10-600750","rule_title":"RHEL 10 must be configured so that user and group account administration utilities are configured to store only encrypted representations of passwords.","fix_text":"Configure RHEL 10 to use the SHA-512 algorithm for password hashing.\n\nAdd or change the following line in the \"[default]\" section of the \"/etc/libuser.conf\" file:\n\ncrypt_style = sha512","weight":"10.0","check_content":"Verify RHEL 10 user and group account administration utilities are configured to store only encrypted representations of passwords with the following command:\n\n$ sudo grep crypt /etc/libuser.conf\ncrypt_style = sha512\n\nIf the \"crypt_style\" variable is not set to \"yescrypt\", is not in the defaults section, is commented out, or does not exist, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Passwords must be protected at all times, and encryption is the standard method for protecting passwords. If passwords are not encrypted, they can be plainly read (i.e., clear text) and easily compromised. Passwords that are encrypted with a weak algorithm are no more protected than if they are kept in plain text.\n\nThis setting ensures user and group account administration utilities are configured to store only encrypted representations of passwords. Additionally, the \"crypt_style\" configuration option ensures the use of a strong hashing algorithm that makes password cracking attacks more difficult.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004062"],"reference_identifier":"6696","uuid":"24e05924-094a-4cb5-8f1a-f93676aa32b0","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 46969BA07F0BDE366055CC1B480B3AFE91A569CF\r\n~~~~~\r\nConfiguration for 'RHEL 10 must be configured so that user and group account administration utilities are configured to store only encrypted representations of passwords.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281224","group_tree":[{"id":"V-281224","title":"SRG-OS-000080-GPOS-00048","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281224","severity":"medium","group_title":"SRG-OS-000080-GPOS-00048","rule_id_src":"SV-281224r1184753_rule","rule_id":"SV-281224","rule_version":"RHEL-10-700010","rule_title":"RHEL 10 must display the Standard Mandatory DOD Notice and Consent Banner before granting local or remote access to the system via a Secure Shell (SSH) login.","fix_text":"Configure RHEL 10 to display the Standard Mandatory DOD Notice and Consent Banner before granting access to the system via SSH.\n\nEdit a file in \"/etc/ssh/sshd_config.d\" to uncomment or add the banner keyword and configure it to point to a file that will contain the login banner (this file may be named differently or be in a different location if using a version of SSH that is provided by a third-party vendor).\n\nAn example configuration line is:\n\nBanner /etc/issue","weight":"10.0","check_content":"Verify RHEL 10 is configured so that any SSH connection to the operating system displays the Standard Mandatory DOD Notice and Consent Banner before granting access to the system.\n\nCheck for the location of the banner file currently being used with the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*banner'\n/etc/ssh/sshd_config.d/10-stig.conf:Banner /etc/issue\n\nIf the line is commented out or the file is missing, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The warning message reinforces policy awareness during the login process and facilitates possible legal action against attackers. Alternatively, systems whose ownership should not be obvious should ensure use of a banner that does not provide easy attribution.\n\nOpenSSH uses the first occurrence of a keyword it sees, and drop-in files are read in lexicographical order at the start of the configuration. Red Hat recommends using drop-in files rather than changing base configuration files.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000213"],"reference_identifier":"5590","uuid":"3dbb11a7-72e5-431a-8871-b1badc675f5a","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 2E9DF81A1903924F6A6B3B7B534548A71EA9D1D1\r\n~~~~~\r\nConfiguration for 'RHEL 10 must display the Standard Mandatory DOD Notice and Consent Banner before granting local or remote access to the system via a Secure Shell (SSH) login.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281225","group_tree":[{"id":"V-281225","title":"SRG-OS-000023-GPOS-00006","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281225","severity":"medium","group_title":"SRG-OS-000023-GPOS-00006","rule_id_src":"SV-281225r1166627_rule","rule_id":"SV-281225","rule_version":"RHEL-10-700020","rule_title":"RHEL 10 must display the Standard Mandatory DOD Notice and Consent Banner before granting local or remote access to the system via a graphical user login.","fix_text":"Configure RHEL 10 to display the Standard Mandatory DOD Notice and Consent Banner before granting access to the system.\n\nAdd the following lines to the [org/gnome/login-screen] section of the \"/etc/dconf/db/local.d/01-banner-message\":\n\nbanner-message-text='You are accessing a U.S. Government (USG) Information System (IS) that is provided for USG-authorized use only.\\nBy using this IS (which includes any device attached to this IS), you consent to the following conditions:\\n-The USG routinely intercepts and monitors communications on this IS for purposes including, but not limited to, penetration testing, COMSEC monitoring, network operations and defense, personnel misconduct (PM), law enforcement (LE), and counterintelligence (CI) investigations.\\n-At any time, the USG may inspect and seize data stored on this IS.\\n-Communications using, or data stored on, this IS are not private, are subject to routine monitoring, interception, and search, and may be disclosed or used for any USG-authorized purpose.\\n-This IS includes security measures (e.g., authentication and access controls) to protect USG interests--not for your personal benefit or privacy.\\n-Notwithstanding the above, using this IS does not constitute consent to PM, LE or CI investigative searching or monitoring of the content of privileged communications, or work product, related to personal representation or services by attorneys, psychotherapists, or clergy, and their assistants. Such communications and work product are private and confidential. See User Agreement for details. '\n\nNote: The \"\\n \" characters are for formatting only. They will not be displayed on the graphical interface.\n\nRun the following command to update the database:\n\n$ sudo dconf update","weight":"10.0","check_content":"Note: This requirement assumes the use of the RHEL 10 default graphical user interface, Gnome Shell. If the system does not have any graphical user interface installed, this requirement is not applicable.\n\nVerify RHEL 10 displays the Standard Mandatory DOD Notice and Consent Banner before granting access to the operating system via a graphical user login with the following command:\n\n$ gsettings get org.gnome.login-screen banner-message-text\nbanner-message-text=\n'You are accessing a U.S. Government (USG) Information System (IS) that is provided for USG-authorized use only.\\nBy using this IS (which includes any device attached to this IS), you consent to the following conditions:\\n-The USG routinely intercepts and monitors communications on this IS for purposes including, but not limited to, penetration testing, COMSEC monitoring, network operations and defense, personnel misconduct (PM), law enforcement (LE), and counterintelligence (CI) investigations.\\n-At any time, the USG may inspect and seize data stored on this IS.\\n-Communications using, or data stored on, this IS are not private, are subject to routine monitoring, interception, and search, and may be disclosed or used for any USG-authorized purpose.\\n-This IS includes security measures (e.g., authentication and access controls) to protect USG interests--not for your personal benefit or privacy.\\n-Notwithstanding the above, using this IS does not constitute consent to PM, LE or CI investigative searching or monitoring of the content of privileged communications, or work product, related to personal representation or services by attorneys, psychotherapists, or clergy, and their assistants. Such communications and work product are private and confidential. See User Agreement for details. '\n\nNote: The \"\\n \" characters are for formatting only. They will not be displayed on the graphical interface.\n\nIf the banner does not match the Standard Mandatory DOD Notice and Consent Banner exactly, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Display of a standardized and approved use notification before granting access to the operating system ensures privacy and security notification verbiage used is consistent with applicable federal laws, Executive Orders, directives, policies, regulations, standards, and guidance.\n\nSystem use notifications are required only for access via login interfaces with human users and are not required when such human interfaces do not exist.\n\nThe banner must be formatted in accordance with applicable DOD policy. Use the following verbiage for operating systems that can accommodate banners of 1300 characters:\n\n\"You are accessing a U.S. Government (USG) Information System (IS) that is provided for USG-authorized use only.\n\nBy using this IS (which includes any device attached to this IS), you consent to the following conditions:\n\n-The USG routinely intercepts and monitors communications on this IS for purposes including, but not limited to, penetration testing, COMSEC monitoring, network operations and defense, personnel misconduct (PM), law enforcement (LE), and counterintelligence (CI) investigations.\n\n-At any time, the USG may inspect and seize data stored on this IS.\n\n-Communications using, or data stored on, this IS are not private, are subject to routine monitoring, interception, and search, and may be disclosed or used for any USG-authorized purpose.\n\n-This IS includes security measures (e.g., authentication and access controls) to protect USG interests--not for your personal benefit or privacy.\n\n-Notwithstanding the above, using this IS does not constitute consent to PM, LE or CI investigative searching or monitoring of the content of privileged communications, or work product, related to personal representation or services by attorneys, psychotherapists, or clergy, and their assistants. Such communications and work product are private and confidential. See User Agreement for details.\"\n\nSatisfies: SRG-OS-000023-GPOS-00006, SRG-OS-000228-GPOS-00088","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000048","CCI-001384","CCI-001385","CCI-001386","CCI-001387","CCI-001388"],"reference_identifier":"3368","uuid":"74a90163-c4f0-4b98-98e5-e9562ad3bbdf","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 7CBBC3DD5F659466E60ADA32B23DCC11036883B8\r\n~~~~~\r\nConfiguration for 'RHEL 10 must display the Standard Mandatory DOD Notice and Consent Banner before granting local or remote access to the system via a graphical user login.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281226","group_tree":[{"id":"V-281226","title":"SRG-OS-000023-GPOS-00006","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281226","severity":"medium","group_title":"SRG-OS-000023-GPOS-00006","rule_id_src":"SV-281226r1166630_rule","rule_id":"SV-281226","rule_version":"RHEL-10-700030","rule_title":"RHEL 10 must prevent a user from overriding the banner-message-enable setting for the graphical user interface.","fix_text":"Configure RHEL 10 to prevent a user from overriding the banner setting for graphical user interfaces.\n\nCreate a database to contain the systemwide graphical user login settings (if it does not already exist) with the following command:\n\n$ sudo vi /etc/dconf/db/local.d/locks/session\n\nAdd the following setting to prevent nonprivileged users from modifying it:\n\n/org/gnome/login-screen/banner-message-enable\n\nRun the following command to update the database:\n\n$ sudo dconf update","weight":"10.0","check_content":"Note: This requirement assumes the use of the RHEL 10 default graphical user interface, the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is not applicable.\n\nVerify RHEL 10 prevents a user from overriding settings for graphical user interfaces with the following command:\n\n$ gsettings writable org.gnome.login-screen banner-message-enable\nfalse\n\nIf \"banner-message-enable\" is writable, or the result is \"true\", this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Display of a standardized and approved use notification before granting access to the operating system ensures privacy and security notification verbiage used is consistent with applicable federal laws, Executive Orders, directives, policies, regulations, standards, and guidance.\n\nFor U.S. Government systems, system use notifications are required only for access via login interfaces with human users and are not required when such human interfaces do not exist.\n\nSatisfies: SRG-OS-000023-GPOS-00006, SRG-OS-000228-GPOS-00088","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000048","CCI-001384","CCI-001385","CCI-001386","CCI-001387","CCI-001388"],"reference_identifier":"7180","uuid":"c6a6eeda-3bca-4b9e-8d91-213012739690","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: D85737FD4F617932B4202DFFCC85712BAF6B74DC\r\n~~~~~\r\nConfiguration for 'RHEL 10 must prevent a user from overriding the banner-message-enable setting for the graphical user interface.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281227","group_tree":[{"id":"V-281227","title":"SRG-OS-000023-GPOS-00006","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281227","severity":"medium","group_title":"SRG-OS-000023-GPOS-00006","rule_id_src":"SV-281227r1184627_rule","rule_id":"SV-281227","rule_version":"RHEL-10-700040","rule_title":"RHEL 10 must display the Standard Mandatory DOD Notice and Consent Banner before granting local or remote access to the system via a command line user login.","fix_text":"Configure RHEL 10 to display the Standard Mandatory DOD Notice and Consent Banner before granting access to the system via command line login.\n\nEdit the \"/etc/issue\" file to replace the default text with the Standard Mandatory DOD Notice and Consent Banner. The DOD-required text is:\n\n\"You are accessing a U.S. Government (USG) Information System (IS) that is provided for USG-authorized use only.\n\nBy using this IS (which includes any device attached to this IS), you consent to the following conditions:\n\n-The USG routinely intercepts and monitors communications on this IS for purposes including, but not limited to, penetration testing, COMSEC monitoring, network operations and defense, personnel misconduct (PM), law enforcement (LE), and counterintelligence (CI) investigations.\n\n-At any time, the USG may inspect and seize data stored on this IS.\n\n-Communications using, or data stored on, this IS are not private, are subject to routine monitoring, interception, and search, and may be disclosed or used for any USG-authorized purpose.\n\n-This IS includes security measures (e.g., authentication and access controls) to protect USG interests -- not for your personal benefit or privacy.\n\n-Notwithstanding the above, using this IS does not constitute consent to PM, LE or CI investigative searching or monitoring of the content of privileged communications, or work product, related to personal representation or services by attorneys, psychotherapists, or clergy, and their assistants. Such communications and work product are private and confidential. See User Agreement for details.\"","weight":"10.0","check_content":"Verify RHEL 10 displays the Standard Mandatory DOD Notice and Consent Banner before granting access to the operating system via a command line login screen with the following command:\n\n$ cat /etc/issue\n\nIf the banner is set correctly, it will return the following text:\n\n\"You are accessing a U.S. Government (USG) Information System (IS) that is provided for USG-authorized use only.\n\nBy using this IS (which includes any device attached to this IS), you consent to the following conditions:\n\n-The USG routinely intercepts and monitors communications on this IS for purposes including, but not limited to, penetration testing, COMSEC monitoring, network operations and defense, personnel misconduct (PM), law enforcement (LE), and counterintelligence (CI) investigations.\n\n-At any time, the USG may inspect and seize data stored on this IS.\n\n-Communications using, or data stored on, this IS are not private, are subject to routine monitoring, interception, and search, and may be disclosed or used for any USG-authorized purpose.\n\n-This IS includes security measures (e.g., authentication and access controls) to protect USG interests--not for your personal benefit or privacy.\n\n-Notwithstanding the above, using this IS does not constitute consent to PM, LE or CI investigative searching or monitoring of the content of privileged communications, or work product, related to personal representation or services by attorneys, psychotherapists, or clergy, and their assistants. Such communications and work product are private and confidential. See User Agreement for details.\"\n\nIf the banner text does not match the Standard Mandatory DOD Notice and Consent Banner exactly, or the line is commented out, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Display of a standardized and approved use notification before granting access to the operating system ensures privacy and security notification verbiage used is consistent with applicable federal laws, Executive Orders, directives, policies, regulations, standards, and guidance.\n\nSystem use notifications are required only for access via login interfaces with human users and are not required when such human interfaces do not exist.\n\nSatisfies: SRG-OS-000023-GPOS-00006, SRG-OS-000228-GPOS-00088","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000048","CCI-001384","CCI-001385","CCI-001386","CCI-001387","CCI-001388"],"reference_identifier":"6235","uuid":"c1d0644a-3729-4443-8f5a-f3cd59e49468","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: D617AA0E11E619ADE0B5C17C3368BB79064C9796\r\n~~~~~\r\nConfiguration for 'RHEL 10 must display the Standard Mandatory DOD Notice and Consent Banner before granting local or remote access to the system via a command line user login.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281228","group_tree":[{"id":"V-281228","title":"SRG-OS-000080-GPOS-00048","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281228","severity":"medium","group_title":"SRG-OS-000080-GPOS-00048","rule_id_src":"SV-281228r1166636_rule","rule_id":"SV-281228","rule_version":"RHEL-10-700100","rule_title":"RHEL 10 must prevent special devices on file systems that are imported via Network File System (NFS).","fix_text":"Configure RHEL 10 to prevent special devices on file systems that are imported via NFS.\n\nUpdate each NFS mounted file system to use the \"nodev\" option on file systems that are being imported via NFS.","weight":"10.0","check_content":"Note: If no NFS mounts are configured, this requirement is not applicable.\n\nVerify RHEL 10 has the \"nodev\" option configured for all NFS mounts with the following command:\n\n$ sudo grep nfs /etc/fstab\n192.168.22.2:/mnt/export /data nfs4 rw,nosuid,nodev,noexec,sync,soft,sec=krb5:krb5i:krb5p\n\nIf the system is mounting file systems via NFS and the \"nodev\" option is missing, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"nodev\" mount option causes the system to not interpret character or block special devices. Executing character or block special devices from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000213"],"reference_identifier":"2266","uuid":"de93dec1-a90b-4885-82fe-bfe27a71f7e4","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: D9853ACED383AD750A7334005BE306367ED6AC74\r\n~~~~~\r\nConfiguration for 'RHEL 10 must prevent special devices on file systems that are imported via Network File System (NFS).' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281229","group_tree":[{"id":"V-281229","title":"SRG-OS-000080-GPOS-00048","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281229","severity":"medium","group_title":"SRG-OS-000080-GPOS-00048","rule_id_src":"SV-281229r1166639_rule","rule_id":"SV-281229","rule_version":"RHEL-10-700105","rule_title":"RHEL 10 must prevent code from being executed on file systems that are imported via Network File System (NFS).","fix_text":"Configure RHEL 10 to prevent code from being executed on file systems that are imported via NFS.\n\nUpdate each NFS mounted file system to use the \"noexec\" option on file systems that are being imported via NFS.","weight":"10.0","check_content":"Note: If no NFS mounts are configured, this requirement is not applicable.\n\nVerify RHEL 10 has the \"noexec\" option configured for all NFS mounts with the following command:\n\n$ sudo grep nfs /etc/fstab\n192.168.22.2:/mnt/export /data nfs4 rw,nosuid,nodev,noexec,sync,soft,sec=krb5:krb5i:krb5p\n\nIf the system is mounting file systems via NFS and the \"noexec\" option is missing, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"noexec\" mount option causes the system not to execute binary files. This option must be used for mounting any file system not containing approved binary as they may be incompatible. Executing files from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000213"],"reference_identifier":"2139","uuid":"dc754d1c-ae93-4d97-bb29-44a5c7014bf7","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 308FCF9A558CB69FA4EF5C822044B5E10B71E37B\r\n~~~~~\r\nRequired configuration for 'RHEL 10 must prevent code from being executed on file systems that are imported via Network File System (NFS).' was not present or did not match the expected value on the RHEL 10 host."},{"group_id_src":"V-281230","group_tree":[{"id":"V-281230","title":"SRG-OS-000080-GPOS-00048","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281230","severity":"medium","group_title":"SRG-OS-000080-GPOS-00048","rule_id_src":"SV-281230r1166642_rule","rule_id":"SV-281230","rule_version":"RHEL-10-700110","rule_title":"RHEL 10 must prevent files with the \"setuid\" and \"setgid\" bit set from being executed on file systems that are imported via Network File System (NFS).","fix_text":"Configure RHEL 10 to prevent files with the \"setuid\" and \"setgid\" bit set from being executed on file systems that are imported via NFS.\n\nUpdate each NFS mounted file system to use the \"nosuid\" option on file systems that are being imported via NFS.","weight":"10.0","check_content":"Note: If no NFS mounts are configured, this requirement is not applicable.\n\nVerify RHEL 10 has the \"nosuid\" option configured for all NFS mounts with the following command:\n\n$ sudo grep nfs /etc/fstab\n192.168.22.2:/mnt/export /data nfs4 rw,nosuid,nodev,noexec,sync,soft,sec=krb5:krb5i:krb5p\n\nIf the system is mounting file systems via NFS and the \"nosuid\" option is missing, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"nosuid\" mount option causes the system not to execute \"setuid\" and \"setgid\" files with owner privileges. This option must be used for mounting any file system not containing approved \"setuid\" and \"setguid\" files. Executing files from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000213"],"reference_identifier":"7941","uuid":"2a8da656-3e70-45a0-aef5-ef6769b8b16f","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 9C1CB1EE283259B8B054A51C5A4C7A000B15D936\r\n~~~~~\r\nConfiguration for 'RHEL 10 must prevent files with the \"setuid\" and \"setgid\" bit set from being executed on file systems that are imported via Network File System (NFS).' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281231","group_tree":[{"id":"V-281231","title":"SRG-OS-000080-GPOS-00048","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281231","severity":"medium","group_title":"SRG-OS-000080-GPOS-00048","rule_id_src":"SV-281231r1166645_rule","rule_id":"SV-281231","rule_version":"RHEL-10-700115","rule_title":"RHEL 10 must be configured so that the Network File System (NFS) is configured to use RPCSEC_GSS.","fix_text":"Configure RHEL 10 so that the \"/etc/fstab\" file \"sec\" option is defined for each NFS mounted file system, and the \"sec\" option does not have the \"sys\" setting.\n\nEnsure the \"sec\" option is defined as \"krb5p:krb5i:krb5\".","weight":"10.0","check_content":"Note: If no NFS mounts are configured, this requirement is not applicable.\n\nVerify RHEL 10 has the \"sec\" option configured for all NFS mounts with the following command:\n\n$ sudo grep nfs /etc/fstab\n192.168.22.2:/mnt/export /data nfs4 rw,nosuid,nodev,noexec,sync,soft,sec=krb5p:krb5i:krb5\n\nIf the system is mounting file systems via NFS and has the sec option without the \"krb5:krb5i:krb5p\" settings, the \"sec\" option has the \"sys\" setting, or the \"sec\" option is missing, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"When an NFS server is configured to use RPCSEC_SYS, a selected userid and groupid are used to handle requests from the remote user. The userid and groupid could mistakenly or maliciously be set incorrectly. The RPCSEC_GSS method of authentication uses certificates on the server and client systems to more securely authenticate the remote mount request.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000213"],"reference_identifier":"6031","uuid":"029eaa8c-94e7-4dd0-881f-99949a28ff3c","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 873266AC44718221734D304F546B166BAA8E6C6C\r\n~~~~~\r\nConfiguration for 'RHEL 10 must be configured so that the Network File System (NFS) is configured to use RPCSEC_GSS.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281232","group_tree":[{"id":"V-281232","title":"SRG-OS-000368-GPOS-00154","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281232","severity":"medium","group_title":"SRG-OS-000368-GPOS-00154","rule_id_src":"SV-281232r1166648_rule","rule_id":"SV-281232","rule_version":"RHEL-10-700120","rule_title":"RHEL 10 must mount \"/boot\" with the \"nodev\" option.","fix_text":"Configure RHEL 10 to mount \"/boot\" with the \"nodev\" option.\n\nModify \"/etc/fstab\" to use the \"nodev\" option on the \"/boot\" directory.\n\nTo reload all implicit mount units and update the dependency graph so that new options will apply correctly at next remount, run the following command:\n\n$ sudo systemctl daemon-reload\n\nUse the following command to apply the changes immediately without a reboot:\n\n$ sudo mount -o remount /boot","weight":"10.0","check_content":"Verify RHEL 10 is configured so that the \"/boot\" mount point has the \"nodev\" option with the following command:\n\n$ mount | grep '\\s/boot\\s'\n/dev/sda1 on /boot type xfs (rw,nodev,nosuid,relatime,seclabel,attr2)\n\nIf the \"/boot\" file system does not have the \"nodev\" option set, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The only legitimate location for device files is the \"/dev\" directory located on the root partition. The only exception to this is chroot jails.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001764"],"reference_identifier":"3238","uuid":"ffa7dac0-8bc3-4fd4-b744-b28b137b1f8b","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 00CD740B929FE810D6C6235E9F047526B53F16A0\r\n~~~~~\r\nConfiguration for 'RHEL 10 must mount \"/boot\" with the \"nodev\" option.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281233","group_tree":[{"id":"V-281233","title":"SRG-OS-000368-GPOS-00154","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281233","severity":"medium","group_title":"SRG-OS-000368-GPOS-00154","rule_id_src":"SV-281233r1166651_rule","rule_id":"SV-281233","rule_version":"RHEL-10-700125","rule_title":"RHEL 10 must prevent files with the \"setuid\" and \"setgid\" bit set from being executed on the \"/boot\" directory.","fix_text":"Configure RHEL 10 to prevent files with the \"setuid\" and \"setgid\" bit set from being executed on the \"/boot\" directory.\n\nModify \"/etc/fstab\" to use the \"nosuid\" option on the \"/boot\" directory.\n\nTo reload all implicit mount units and update the dependency graph so that new options will apply correctly at next remount, run the following command:\n\n$ sudo systemctl daemon-reload\n\nUse the following command to apply the changes immediately without a reboot:\n\n$ sudo mount -o remount /boot","weight":"10.0","check_content":"Verify RHEL 10 is configured so that the \"/boot\" directory is mounted with the \"nosuid\" option with the following command:\n\n$ mount | grep '\\s/boot\\s'\n/dev/sda1 on /boot type xfs (rw,nodev,nosuid,relatime,seclabel,attr2)\n\nIf the \"/boot\" file system does not have the \"nosuid\" option set, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"nosuid\" mount option causes the system not to execute \"setuid\" and \"setgid\" files with owner privileges. This option must be used for mounting any file system not containing approved \"setuid\" and \"setguid\" files. Executing files from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001764"],"reference_identifier":"7959","uuid":"a01d0fdb-6502-43be-8161-8a796412bcfe","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 2D00D6859BBF06C7C54005DA295C24FC27E78BFC\r\n~~~~~\r\nConfiguration for 'RHEL 10 must prevent files with the \"setuid\" and \"setgid\" bit set from being executed on the \"/boot\" directory.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281234","group_tree":[{"id":"V-281234","title":"SRG-OS-000080-GPOS-00048","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281234","severity":"medium","group_title":"SRG-OS-000080-GPOS-00048","rule_id_src":"SV-281234r1166654_rule","rule_id":"SV-281234","rule_version":"RHEL-10-700130","rule_title":"RHEL 10 must prevent files with the \"setuid\" and \"setgid\" bit set from being executed on the \"/boot/efi\" directory.","fix_text":"Configure RHEL 10 to prevent files with the \"setuid\" and \"setgid\" bit set from being executed on the \"/boot/efi\" directory.\n\nModify \"/etc/fstab\" to use the \"nosuid\" option on the \"/boot/efi\" directory.\n\nTo reload all implicit mount units and update the dependency graph so that new options will apply correctly at next remount, run the following command:\n\n$ sudo systemctl daemon-reload\n\nUse the following command to apply the changes immediately without a reboot:\n\n$ sudo mount -o remount /boot/efi","weight":"10.0","check_content":"Note: For systems that use BIOS and for vfat systems, this requirement is not applicable.\n\nVerify RHEL 10 is configured so that the \"/boot/efi \"directory is mounted with the \"nosuid\" option with the following command:\n\n$ mount | grep '\\s/boot/efi\\s'\n/dev/sda1 on /boot/efi type vfat (rw,nosuid,relatime,fmask=0077,dmask=0077,codepage=437,iocharset=ascii,shortname=winnt,errors=remount-ro)\n\nIf the \"/boot/efi\" file system does not have the \"nosuid\" option set, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"nosuid\" mount option causes the system not to execute \"setuid\" and \"setgid\" files with owner privileges. This option must be used for mounting any file system not containing approved \"setuid\" and \"setguid\" files. Executing files from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000213"],"reference_identifier":"7043","uuid":"8c6b2a8d-8a39-423f-bdc2-9a4a777ba341","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 41505E6DD7906BA32E3924A8BE3B64FB7C3F0810\r\n~~~~~\r\nConfiguration for 'RHEL 10 must prevent files with the \"setuid\" and \"setgid\" bit set from being executed on the \"/boot/efi\" directory.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281235","group_tree":[{"id":"V-281235","title":"SRG-OS-000368-GPOS-00154","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281235","severity":"medium","group_title":"SRG-OS-000368-GPOS-00154","rule_id_src":"SV-281235r1166657_rule","rule_id":"SV-281235","rule_version":"RHEL-10-700135","rule_title":"RHEL 10 must mount \"/dev/shm\" with the \"nodev\" option.","fix_text":"Configure RHEL 10 to mount \"/dev/shm\" with the \"nodev\" option.\n\nModify \"/etc/fstab\" to use the \"nodev\" option on the \"/dev/shm\" file system.\n\nTo reload all implicit mount units and update the dependency graph so that new options will apply correctly at next remount, run the following command:\n\n$ sudo systemctl daemon-reload\n\nUse the following command to apply the changes immediately without a reboot:\n\n$ sudo mount -o remount /dev/shm","weight":"10.0","check_content":"Verify RHEL 10 is configured so that \"/dev/shm\" is mounted with the \"nodev\" option with the following command:\n\n$ mount | grep /dev/shm\ntmpfs on /dev/shm type tmpfs (rw,nodev,nosuid,noexec,seclabel)\n\nIf the \"/dev/shm\" file system is mounted without the \"nodev\" option, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"nodev\" mount option causes the system to not interpret character or block special devices. Executing character or block special devices from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.\n\nThe only legitimate location for device files is the \"/dev\" directory located on the root partition, with the exception of chroot jails if implemented.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001764"],"reference_identifier":"9216","uuid":"b5f530f8-c37c-498e-8a19-88fc8c4688c8","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-281236","group_tree":[{"id":"V-281236","title":"SRG-OS-000368-GPOS-00154","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281236","severity":"medium","group_title":"SRG-OS-000368-GPOS-00154","rule_id_src":"SV-281236r1166660_rule","rule_id":"SV-281236","rule_version":"RHEL-10-700140","rule_title":"RHEL 10 must mount \"/dev/shm\" with the \"noexec\" option.","fix_text":"Configure RHEL 10 to mount \"/dev/shm\" with the \"noexec\" option.\n\nModify \"/etc/fstab\" to use the \"noexec\" option on the \"/dev/shm\" file system.\n\nTo reload all implicit mount units and update the dependency graph so that new options will apply correctly at next remount, run the following command:\n\n$ sudo systemctl daemon-reload\n\nUse the following command to apply the changes immediately without a reboot:\n\n$ sudo mount -o remount /dev/shm","weight":"10.0","check_content":"Verify RHEL 10 is configured so that \"/dev/shm\" is mounted with the \"noexec\" option with the following command:\n\n$ mount | grep /dev/shm\ntmpfs on /dev/shm type tmpfs (rw,nodev,nosuid,noexec,seclabel)\n\nIf the \"/dev/shm\" file system is mounted without the \"noexec\" option, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"noexec\" mount option causes the system to not execute binary files. This option must be used for mounting any file system not containing approved binary files, as they may be incompatible. Executing files from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001764"],"reference_identifier":"6108","uuid":"6e8e6def-c198-4281-9192-9382e4640526","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: B406C6789909D9D06072DFE318A9C1178BE9D576\r\n~~~~~\r\nConfiguration for 'RHEL 10 must mount \"/dev/shm\" with the \"noexec\" option.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281237","group_tree":[{"id":"V-281237","title":"SRG-OS-000368-GPOS-00154","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281237","severity":"medium","group_title":"SRG-OS-000368-GPOS-00154","rule_id_src":"SV-281237r1166663_rule","rule_id":"SV-281237","rule_version":"RHEL-10-700145","rule_title":"RHEL 10 must mount \"/dev/shm\" with the \"nosuid\" option.","fix_text":"Configure RHEL 10 to mount \"/dev/shm\" with the \"nosuid\" option.\n\nModify \"/etc/fstab\" to use the \"nosuid\" option on the \"/dev/shm\" file system.\n\nTo reload all implicit mount units and update the dependency graph so that new options will apply correctly at next remount, run the following command:\n\n$ sudo systemctl daemon-reload\n\nUse the following command to apply the changes immediately without a reboot:\n\n$ sudo mount -o remount /dev/shm","weight":"10.0","check_content":"Verify RHEL 10 is configured so that \"/dev/shm\" is mounted with the \"nosuid\" option with the following command:\n\n$ mount | grep /dev/shm\ntmpfs on /dev/shm type tmpfs (rw,nodev,nosuid,noexec,seclabel)\n\nIf the \"/dev/shm\" file system is mounted without the \"nosuid\" option, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_10_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"nosuid\" mount option causes the system to not execute \"setuid\" and \"setgid\" files with owner privileges. This option must be used for mounting any file system not containing approved \"setuid\" and \"setguid\" files. Executing files from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001764"],"reference_identifier":"8270","uuid":"03fe8417-46d0-46e8-bb77-7374c82313bf","stig_uuid":"a68f390c-b115-428d-9158-12d640fd1211","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL10_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 7E366734F778E95FCF32D6F08B87BFBE912BB96A\r\n~~~~~\r\nConfiguration for 'RHEL 10 must mount \"/dev/shm\" with the \"nosuid\" option.' matches the expected value on the RHEL 10 host."},{"group_id_src":"V-281238","group_tree":[{"id":"V-281238","title":"SRG-OS-000368-GPOS-00154","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-281238","severity