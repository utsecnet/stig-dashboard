dit with the noexec option.' was not present or did not match the expected value on the RHEL 9 host."},{"group_id_src":"V-257875","group_tree":[{"id":"V-257875","title":"SRG-OS-000368-GPOS-00154","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-257875","severity":"medium","group_title":"SRG-OS-000368-GPOS-00154","rule_id_src":"SV-257875r958804_rule","rule_id":"SV-257875","rule_version":"RHEL-09-231170","rule_title":"RHEL 9 must mount /var/log/audit with the nosuid option.","fix_text":"Modify \"/etc/fstab\" to use the \"nosuid\" option on the \"/var/log/audit\" directory.","weight":"10.0","check_content":"Verify \"/var/log/audit\" is mounted with the \"nosuid\" option:\n\n$ mount | grep /var/log/audit\n\n/dev/mapper/rhel-var-log-audit on /var/log/audit type xfs (rw,nodev,nosuid,noexec,seclabel)\n\nIf the \"/var/log/audit\" file system is mounted without the \"nosuid\" option, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"nosuid\" mount option causes the system to not execute \"setuid\" and \"setgid\" files with owner privileges. This option must be used for mounting any file system not containing approved \"setuid\" and \"setguid\" files. Executing files from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001764"],"reference_identifier":"4560","uuid":"ecab0f0b-ec4d-4e61-8550-32dad50d93a5","stig_uuid":"b3b51a67-7722-426f-875b-86e3b52497cd","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 7729D89205982A1461B8AC543CFF45144526F466\r\n~~~~~\r\nRequired configuration for 'RHEL 9 must mount /var/log/audit with the nosuid option.' was not present or did not match the expected value on the RHEL 9 host."},{"group_id_src":"V-257876","group_tree":[{"id":"V-257876","title":"SRG-OS-000368-GPOS-00154","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-257876","severity":"medium","group_title":"SRG-OS-000368-GPOS-00154","rule_id_src":"SV-257876r958804_rule","rule_id":"SV-257876","rule_version":"RHEL-09-231175","rule_title":"RHEL 9 must mount /var/tmp with the nodev option.","fix_text":"Modify \"/etc/fstab\" to use the \"nodev\" option on the \"/var/tmp\" directory.","weight":"10.0","check_content":"Verify \"/var/tmp\" is mounted with the \"nodev\" option:\n\n$ mount | grep /var/tmp\n\n/dev/mapper/rhel-var-tmp on /var/tmp type xfs (rw,nodev,nosuid,noexec,seclabel)\n\nIf the \"/var/tmp\" file system is mounted without the \"nodev\" option, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"nodev\" mount option causes the system to not interpret character or block special devices. Executing character or block special devices from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.\n\nThe only legitimate location for device files is the \"/dev\" directory located on the root partition, with the exception of chroot jails if implemented.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001764"],"reference_identifier":"7385","uuid":"28c3f1ee-71fa-4196-b27e-c59cfcc6d0f9","stig_uuid":"b3b51a67-7722-426f-875b-86e3b52497cd","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL9_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: 0CA1B2F148A175723CD102698E0C79D622467F06\r\n~~~~~\r\nThe feature/role addressed by 'RHEL 9 must mount /var/tmp with the nodev option.' is not present or not in use on this the RHEL 9 host."},{"group_id_src":"V-257877","group_tree":[{"id":"V-257877","title":"SRG-OS-000368-GPOS-00154","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-257877","severity":"medium","group_title":"SRG-OS-000368-GPOS-00154","rule_id_src":"SV-257877r958804_rule","rule_id":"SV-257877","rule_version":"RHEL-09-231180","rule_title":"RHEL 9 must mount /var/tmp with the noexec option.","fix_text":"Modify \"/etc/fstab\" to use the \"noexec\" option on the \"/var/tmp\" directory.","weight":"10.0","check_content":"Verify \"/var/tmp\" is mounted with the \"noexec\" option:\n\n$ mount | grep /var/tmp\n\n/dev/mapper/rhel-var-tmp on /var/tmp type xfs (rw,nodev,nosuid,noexec,seclabel)\n\nIf the \"/var/tmp\" file system is mounted without the \"noexec\" option, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"noexec\" mount option causes the system to not execute binary files. This option must be used for mounting any file system not containing approved binary files, as they may be incompatible. Executing files from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001764"],"reference_identifier":"1674","uuid":"f13ebd97-a0e6-43f0-ad71-82acf43a824b","stig_uuid":"b3b51a67-7722-426f-875b-86e3b52497cd","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: D7886C90CD851EE573E3E40BF0871CB9BF1DC31F\r\n~~~~~\r\nConfiguration for 'RHEL 9 must mount /var/tmp with the noexec option.' matches the expected value on the RHEL 9 host."},{"group_id_src":"V-257878","group_tree":[{"id":"V-257878","title":"SRG-OS-000368-GPOS-00154","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-257878","severity":"medium","group_title":"SRG-OS-000368-GPOS-00154","rule_id_src":"SV-257878r958804_rule","rule_id":"SV-257878","rule_version":"RHEL-09-231185","rule_title":"RHEL 9 must mount /var/tmp with the nosuid option.","fix_text":"Modify \"/etc/fstab\" to use the \"nosuid\" option on the \"/var/tmp\" directory.","weight":"10.0","check_content":"Verify \"/var/tmp\" is mounted with the \"nosuid\" option:\n\n$ mount | grep /var/tmp\n\n/dev/mapper/rhel-var-tmp on /var/tmp type xfs (rw,nodev,nosuid,noexec,seclabel)\n\nIf the \"/var/tmp\" file system is mounted without the \"nosuid\" option, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"nosuid\" mount option causes the system to not execute \"setuid\" and \"setgid\" files with owner privileges. This option must be used for mounting any file system not containing approved \"setuid\" and \"setguid\" files. Executing files from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001764"],"reference_identifier":"7320","uuid":"2705796b-bc14-4c77-a193-60ca06c708b2","stig_uuid":"b3b51a67-7722-426f-875b-86e3b52497cd","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-257879","group_tree":[{"id":"V-257879","title":"SRG-OS-000405-GPOS-00184","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-257879","severity":"high","group_title":"SRG-OS-000405-GPOS-00184","rule_id_src":"SV-257879r1045454_rule","rule_id":"SV-257879","rule_version":"RHEL-09-231190","rule_title":"RHEL 9 local disk partitions must implement cryptographic mechanisms to prevent unauthorized disclosure or modification of all information that requires at rest protection.","fix_text":"Configure RHEL 9 to prevent unauthorized modification of all information at rest by using disk encryption.\n\nEncrypting a partition in an already installed system is more difficult, because existing partitions will need to be resized and changed.\n\nTo encrypt an entire partition, dedicate a partition for encryption in the partition layout.","weight":"10.0","check_content":"Note: If there is a documented and approved reason for not having data-at-rest encryption at the operating system level, such as encryption provided by a hypervisor or a disk storage array in a virtualized environment, this requirement is Not Applicable.\n\nVerify RHEL 9 prevents unauthorized disclosure or modification of all information requiring at-rest protection by using disk encryption. \n\nNote: If there is a documented and approved reason for not having data-at-rest encryption, this requirement is Not Applicable.\n\nList all block devices in tree-like format:\n\n$ sudo lsblk --tree\n\nNAME                       MAJ:MIN  RM   SIZE     RO    TYPE    MOUNTPOINTS\nzram0                      252:0    0    8G       0     disk    [SWAP]\nnvme0n1                    259:0    0    476.9G   0     disk\n|-nvme0n1p1                259:1    0    1G       0     part    /boot/efi\n|-nvme0n1p2                259:2    0    1G       0     part    /boot\n|-nvme0n1p3                259:3    0    474.9G   0     part\n  |-luks-<encrypted_id>    253:0    0    474.9G   0     crypt\n    |-rhel-root            253:1    0    16G      0     lvm     /\n    |-rhel-varcache        253:2    0    8G       0     lvm     /var/cache\n    |-rhel-vartmp          253:3    0    4G       0     lvm     /var/tmp\n    |-rhel-varlog          253:4    0    4G       0     lvm     /var/log\n    |-rhel-home            253:5    0    64G      0     lvm     /home\n    |-rhel-varlogaudit     253:6    0    4G       0     lvm     /var/log/audit\n\nVerify that the block device tree for each persistent filesystem, excluding the /boot and /boot/efi filesystems, has at least one parent block device of type \"crypt\", and that the encryption type is LUKS:\n\n$ sudo cryptsetup status luks-b74f6910-2547-4399-86b2-8b0252d926d7\n/dev/mapper/luks-b74f6910-2547-4399-86b2-8b0252d926d7 is active and is in use.\n  type:    LUKS2\n  cipher:  aes-xts-plain64\n  keysize: 512 bits\n  key location: keyring\n  device:  /dev/nvme0n1p3\n  sector size:  512\n  offset:  32768 sectors\n  size:    995986063 sectors\n  mode:    read/write\n\nIf there are persistent filesystems (other than /boot or /boot/efi) whose block device trees do not have a crypt block device of type LUKS, ask the administrator to indicate how persistent filesystems are encrypted. \n\nIf there is no evidence that persistent filesystems are encrypted, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"RHEL 9 systems handling data requiring \"data at rest\" protections must employ cryptographic mechanisms to prevent unauthorized disclosure and modification of the information at rest.\n\nSelection of a cryptographic mechanism is based on the need to protect the integrity of organizational information. The strength of the mechanism is commensurate with the security category and/or classification of the information. Organizations have the flexibility to either encrypt all information on storage devices (i.e., full disk encryption) or encrypt specific data structures (e.g., files, records, or fields).\n\nSatisfies: SRG-OS-000405-GPOS-00184, SRG-OS-000185-GPOS-00079, SRG-OS-000404-GPOS-00183","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001199","CCI-002475","CCI-002476"],"reference_identifier":"5498","uuid":"b4d508ff-b868-42f7-a61d-fd6cf320f321","stig_uuid":"b3b51a67-7722-426f-875b-86e3b52497cd","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL9_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: 4FE8DDE11D02A922E41C6150EDD7B84E6AE9A31D\r\n~~~~~\r\nThe feature/role addressed by 'RHEL 9 local disk partitions must implement cryptographic mechanisms to prevent unauthorized disclosure or modification of all information that requires at rest protection.' is not present or not in use on this the RHEL 9 host."},{"group_id_src":"V-257880","group_tree":[{"id":"V-257880","title":"SRG-OS-000095-GPOS-00049","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-257880","severity":"low","group_title":"SRG-OS-000095-GPOS-00049","rule_id_src":"SV-257880r1044951_rule","rule_id":"SV-257880","rule_version":"RHEL-09-231195","rule_title":"RHEL 9 must disable mounting of cramfs.","fix_text":"To configure the system to prevent the cramfs kernel module from being loaded, add the following lines to the file /etc/modprobe.d/blacklist.conf (or create blacklist.conf if it does not exist):\n\ninstall cramfs /bin/false\nblacklist cramfs","weight":"10.0","check_content":"Verify that RHEL 9 disables the ability to load the cramfs kernel module with the following command:\n\n$ grep -r cramfs /etc/modprobe.conf /etc/modprobe.d/* \n\ninstall cramfs /bin/false\nblacklist cramfs\n\nIf the command does not return any output or the lines are commented out, and use of cramfs is not documented with the information system security officer (ISSO) as an operational requirement, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"It is detrimental for operating systems to provide, or install by default, functionality exceeding requirements or mission objectives. These unnecessary capabilities or services are often overlooked and therefore may remain unsecured. They increase the risk to the platform by providing additional attack vectors.\n\nRemoving support for unneeded filesystem types reduces the local attack surface of the server.\n\nCompressed ROM/RAM file system (or cramfs) is a read-only file system designed for simplicity and space-efficiency. It is mainly used in embedded and small-footprint systems.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"2352","uuid":"b4e46364-89a4-4ad5-b680-a6ba9a20afcf","stig_uuid":"b3b51a67-7722-426f-875b-86e3b52497cd","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 0C5DD2CAF0F959E8CEBB7EF33EE9F1641E0AFD13\r\n~~~~~\r\nConfiguration for 'RHEL 9 must disable mounting of cramfs.' matches the expected value on the RHEL 9 host."},{"group_id_src":"V-257881","group_tree":[{"id":"V-257881","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-257881","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-257881r1184299_rule","rule_id":"SV-257881","rule_version":"RHEL-09-231200","rule_title":"RHEL 9 must prevent special devices on non-root local partitions.","fix_text":"Configure the \"/etc/fstab\" to use the \"nodev\" option on all non-root local partitions.","weight":"10.0","check_content":"Verify all nonroot local partitions are mounted with the \"nodev\" option with the following command:\n\n$ sudo mount | grep '^/dev\\S* on /\\S' | grep --invert-match 'nodev'\n\nIf any output is produced, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"nodev\" mount option causes the system to not interpret character or block special devices. Executing character or block special devices from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.\n\nThe only legitimate location for device files is the \"/dev\" directory located on the root partition, with the exception of chroot jails if implemented.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"4911","uuid":"d98c24db-6972-45fe-991b-4c73d5f28779","stig_uuid":"b3b51a67-7722-426f-875b-86e3b52497cd","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: A662B6A5FFE4922B4150AF7C32236B45C8975E79\r\n~~~~~\r\nRequired configuration for 'RHEL 9 must prevent special devices on non-root local partitions.' was not present or did not match the expected value on the RHEL 9 host."},{"group_id_src":"V-257882","group_tree":[{"id":"V-257882","title":"SRG-OS-000259-GPOS-00100","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-257882","severity":"medium","group_title":"SRG-OS-000259-GPOS-00100","rule_id_src":"SV-257882r991560_rule","rule_id":"SV-257882","rule_version":"RHEL-09-232010","rule_title":"RHEL 9 system commands must have mode 755 or less permissive.","fix_text":"Configure the system commands to be protected from unauthorized access.\n\nRun the following command, replacing \"[FILE]\" with any system command with a mode more permissive than \"755\".\n\n$ sudo chmod 755 [FILE]","weight":"10.0","check_content":"Verify the system commands contained in the following directories have mode \"755\" or less permissive with the following command:\n\n$ sudo find -L /bin /sbin /usr/bin /usr/sbin /usr/libexec /usr/local/bin /usr/local/sbin -perm /022 -exec ls -l {} \\;\n\nIf any system commands are found to be group-writable or world-writable, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If RHEL 9 allowed any user to make changes to software libraries, then those changes might be implemented without undergoing the appropriate testing and approvals that are part of a robust change management process.\n\nThis requirement applies to RHEL 9 with software libraries that are accessible and configurable, as in the case of interpreted languages. Software libraries also include privileged programs that execute with escalated privileges.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001499"],"reference_identifier":"7632","uuid":"3f4b2168-ad97-43eb-b5a7-94539c44bd83","stig_uuid":"b3b51a67-7722-426f-875b-86e3b52497cd","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 144607BE7E9C9FD9B2C752C037FB21DCA6B55B10\r\n~~~~~\r\nRequired configuration for 'RHEL 9 system commands must have mode 755 or less permissive.' was not present or did not match the expected value on the RHEL 9 host."},{"group_id_src":"V-257883","group_tree":[{"id":"V-257883","title":"SRG-OS-000259-GPOS-00100","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-257883","severity":"medium","group_title":"SRG-OS-000259-GPOS-00100","rule_id_src":"SV-257883r991560_rule","rule_id":"SV-257883","rule_version":"RHEL-09-232015","rule_title":"RHEL 9 library directories must have mode 755 or less permissive.","fix_text":"Configure the system-wide shared library directories (/lib, /lib64, /usr/lib and /usr/lib64) to be protected from unauthorized access. \n\nRun the following command, replacing \"[DIRECTORY]\" with any library directory with a mode more permissive than 755.\n\n$ sudo chmod 755 [DIRECTORY]","weight":"10.0","check_content":"Verify the system-wide shared library directories have mode \"755\" or less permissive with the following command:\n\n$ sudo find -L /lib /lib64 /usr/lib /usr/lib64 -perm /022 -type d -exec ls -l {} \\;\n\nIf any system-wide shared library file is found to be group-writable or world-writable, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If RHEL 9 allowed any user to make changes to software libraries, then those changes might be implemented without undergoing the appropriate testing and approvals that are part of a robust change management process.\n\nThis requirement applies to RHEL 9 with software libraries that are accessible and configurable, as in the case of interpreted languages. Software libraries also include privileged programs that execute with escalated privileges.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001499"],"reference_identifier":"2071","uuid":"aedf9f56-e2f3-4a7b-9f30-72c87993fd7e","stig_uuid":"b3b51a67-7722-426f-875b-86e3b52497cd","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: B53613C5FFBD4E2DACF25EFC3FF501C5B3FF6D4B\r\n~~~~~\r\nConfiguration for 'RHEL 9 library directories must have mode 755 or less permissive.' matches the expected value on the RHEL 9 host."},{"group_id_src":"V-257884","group_tree":[{"id":"V-257884","title":"SRG-OS-000259-GPOS-00100","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-257884","severity":"medium","group_title":"SRG-OS-000259-GPOS-00100","rule_id_src":"SV-257884r1106306_rule","rule_id":"SV-257884","rule_version":"RHEL-09-232020","rule_title":"RHEL 9 library files must have mode 755 or less permissive.","fix_text":"Configure the systemwide shared library files contained in the directories \"/lib\", \"/lib64\", \"/usr/lib\", and \"/usr/lib64\" to have mode 0755 or less permissive with the following command.\n\n$ sudo find /lib /lib64 /usr/lib /usr/lib64 -type f -name '*.so*' -perm /022 -exec chmod go-w {} +","weight":"10.0","check_content":"Verify the systemwide shared library files contained in the directories \"/lib\", \"/lib64\", \"/usr/lib\", and \"/usr/lib64\" have mode 0755 or less permissive.\n\nCheck that the systemwide shared library files have mode 0755 or less permissive with the following command:\n\n$ sudo find /lib /lib64 /usr/lib /usr/lib64 -type f -name '*.so*' -perm /022 -exec stat -c \"%n %a\" {} +\n\nIf any output is returned, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If RHEL 9 allowed any user to make changes to software libraries, then those changes might be implemented without undergoing the appropriate testing and approvals that are part of a robust change management process.\n\nThis requirement applies to RHEL 9 with software libraries that are accessible and configurable, as in the case of interpreted languages. Software libraries also include privileged programs that execute with escalated privileges.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001499"],"reference_identifier":"9756","uuid":"c5136ce4-23de-4634-a94e-f6454d91374e","stig_uuid":"b3b51a67-7722-426f-875b-86e3b52497cd","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: A5ECCFEE21B2331FB43C93D898F375660AF9A283\r\n~~~~~\r\nRequired configuration for 'RHEL 9 library files must have mode 755 or less permissive.' was not present or did not match the expected value on the RHEL 9 host."},{"group_id_src":"V-257885","group_tree":[{"id":"V-257885","title":"SRG-OS-000206-GPOS-00084","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-257885","severity":"medium","group_title":"SRG-OS-000206-GPOS-00084","rule_id_src":"SV-257885r1044953_rule","rule_id":"SV-257885","rule_version":"RHEL-09-232025","rule_title":"RHEL 9 /var/log directory must have mode 0755 or less permissive.","fix_text":"Configure the \"/var/log\" directory to a mode of \"0755\" by running the following command:\n\n$ sudo chmod 0755 /var/log","weight":"10.0","check_content":"Verify that the \"/var/log\" directory has a mode of \"0755\" or less permissive with the following command:\n\n$ stat -c '%a %n' /var/log\n\n755 /var/log\n\nIf \"/var/log\" does not have a mode of \"0755\" or less permissive, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Only authorized personnel should be aware of errors and the details of the errors. Error messages are an indicator of an organization's operational state or can identify the RHEL 9 system or platform. Additionally, personally identifiable information (PII) and operational information must not be revealed through error messages to unauthorized personnel or their designated representatives.\n\nThe structure and content of error messages must be carefully considered by the organization and development team. The extent to which the information system is able to identify and handle error conditions is guided by organizational policy and operational requirements.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001314"],"reference_identifier":"6591","uuid":"bbcfe375-0862-4e49-a717-582a1495b0cd","stig_uuid":"b3b51a67-7722-426f-875b-86e3b52497cd","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 21530B57724C666DD565FDBBD1D5AEA581F24C2F\r\n~~~~~\r\nRequired configuration for 'RHEL 9 /var/log directory must have mode 0755 or less permissive.' was not present or did not match the expected value on the RHEL 9 host."},{"group_id_src":"V-257886","group_tree":[{"id":"V-257886","title":"SRG-OS-000206-GPOS-00084","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-257886","severity":"medium","group_title":"SRG-OS-000206-GPOS-00084","rule_id_src":"SV-257886r1044955_rule","rule_id":"SV-257886","rule_version":"RHEL-09-232030","rule_title":"RHEL 9 /var/log/messages file must have mode 0640 or less permissive.","fix_text":"Configure the \"/var/log/messages\" file to have a mode of \"0640\" by running the following command:\n\n$ sudo chmod 0640 /var/log/messages","weight":"10.0","check_content":"Verify the \"/var/log/messages\" file has a mode of \"0640\" or less permissive with the following command:\n\n$ stat -c '%a %n' /var/log/messages\n\n600 /var/log/messages\n\nIf \"/var/log/messages\" does not have a mode of \"0640\" or less permissive, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Only authorized personnel should be aware of errors and the details of the errors. Error messages are an indicator of an organization's operational state or can identify the RHEL 9 system or platform. Additionally, personally identifiable information (PII) and operational information must not be revealed through error messages to unauthorized personnel or their designated representatives.\n\nThe structure and content of error messages must be carefully considered by the organization and development team. The extent to which the information system is able to identify and handle error conditions is guided by organizational policy and operational requirements.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001314"],"reference_identifier":"8777","uuid":"0329a816-f1f8-4b2c-91d0-8b3b51612e4f","stig_uuid":"b3b51a67-7722-426f-875b-86e3b52497cd","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 9F61561ABA6F37BE589A8980D9DD5290001DE422\r\n~~~~~\r\nConfiguration for 'RHEL 9 /var/log/messages file must have mode 0640 or less permissive.' matches the expected value on the RHEL 9 host."},{"group_id_src":"V-257887","group_tree":[{"id":"V-257887","title":"SRG-OS-000256-GPOS-00097","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-257887","severity":"medium","group_title":"SRG-OS-000256-GPOS-00097","rule_id_src":"SV-257887r991557_rule","rule_id":"SV-257887","rule_version":"RHEL-09-232035","rule_title":"RHEL 9 audit tools must have a mode of 0755 or less permissive.","fix_text":"Configure the audit tools to have a mode of \"0755\" by running the following command:\n\n$ sudo chmod 0755 [audit_tool]\n\nReplace \"[audit_tool]\" with each audit tool that has a more permissive mode than 0755.","weight":"10.0","check_content":"Verify the audit tools have a mode of \"0755\" or less with the following command:\n\n$ stat -c \"%a %n\" /sbin/auditctl /sbin/aureport /sbin/ausearch /sbin/autrace /sbin/auditd /sbin/rsyslogd /sbin/augenrules\n\n755 /sbin/auditctl\n755 /sbin/aureport\n755 /sbin/ausearch\n750 /sbin/autrace\n755 /sbin/auditd\n755 /sbin/rsyslogd\n755 /sbin/augenrules\n\nIf any of the audit tool files have a mode more permissive than \"0755\", this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Protecting audit information also includes identifying and protecting the tools used to view and manipulate log data. Therefore, protecting audit tools is necessary to prevent unauthorized operation on audit information.\n\nRHEL 9 systems providing tools to interface with audit information will leverage user permissions and roles identifying the user accessing the tools, and the corresponding rights the user enjoys, to make access decisions regarding the access to audit tools.\n\nAudit tools include, but are not limited to, vendor-provided and open source audit tools needed to successfully view and manipulate audit information system activity and records. Audit tools include custom queries and report generators.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001493"],"reference_identifier":"5030","uuid":"bf965541-96fd-4e14-9186-a3dc7ba62fb3","stig_uuid":"b3b51a67-7722-426f-875b-86e3b52497cd","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 4EA26C49586E8668749F584AB3B0BA76038CFA25\r\n~~~~~\r\nRequired configuration for 'RHEL 9 audit tools must have a mode of 0755 or less permissive.' was not present or did not match the expected value on the RHEL 9 host."},{"group_id_src":"V-257888","group_tree":[{"id":"V-257888","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-257888","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-257888r1134910_rule","rule_id":"SV-257888","rule_version":"RHEL-09-232040","rule_title":"RHEL 9 permissions of cron configuration files and directories must not be modified from the operating system defaults.","fix_text":"Run the following commands to restore the permissions of cron configuration files and directories to the operating system defaults:\n\n$ sudo dnf reinstall cronie crontabs\n$ rpm --setugids cronie crontabs\n$ rpm --setperms cronie crontabs","weight":"10.0","check_content":"Run the following command to verify that the owner, group, and mode of cron configuration files and directories match the operating system defaults:\n\n$ rpm --verify cronie crontabs | awk '! ($2 == \"c\" && $1 ~ /^.\\..\\.\\.\\.\\..\\./) {print $0}'\n\nIf the command returns any output, this is a finding.\n\nIf there are findings, run the following command to determine what the permissions are:\n\n$ ls -ld /etc/cron*\ndrwxr-xr-x. 2 root root  21 Oct  3  2024 /etc/cron.d\ndrwxr-xr-x. 2 root root   6 May  1 09:03 /etc/cron.daily\n-rw-r--r--. 1 root root   0 Oct  3  2024 /etc/cron.deny\ndrwxr-xr-x. 2 root root  22 Mar  5 12:49 /etc/cron.hourly\ndrwxr-xr-x. 2 root root   6 Mar 23  2022 /etc/cron.monthly\n-rw-r--r--. 1 root root 451 Mar 23  2022 /etc/crontab\ndrwxr-xr-x. 2 root root   6 Mar 23  2022 /etc/cron.weekly","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If the permissions of cron configuration files or directories are modified from the operating system defaults, it may be possible for individuals to insert unauthorized cron jobs that perform unauthorized actions, including potentially escalating privileges.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"6262","uuid":"0ed112d0-6d9a-4ec6-8f62-9fd132b2c2df","stig_uuid":"b3b51a67-7722-426f-875b-86e3b52497cd","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 4532D48F4754E59A1E2F2919E166F2A1E41523AD\r\n~~~~~\r\nConfiguration for 'RHEL 9 permissions of cron configuration files and directories must not be modified from the operating system defaults.' matches the expected value on the RHEL 9 host."},{"group_id_src":"V-257889","group_tree":[{"id":"V-257889","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-257889","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-257889r1184302_rule","rule_id":"SV-257889","rule_version":"RHEL-09-232045","rule_title":"All RHEL 9 local initialization files must have mode 0740 or less permissive.","fix_text":"Set the mode of the local initialization files to \"0740\" with the following command:\n\nNote: The example will be for the disauser user, who has a home directory of \"/home/disauser\".\n\n$ sudo chmod 0740 /home/disauser/.<INIT_FILE>","weight":"10.0","check_content":"Verify all local initialization files have a mode of \"0740\" or less permissive with the following command:\n\t\nNote: The example will be for the \"disauser\" user, who has a home directory of \"/home/disauser\".\n\t\n$ sudo find /home /root -maxdepth 2 -type f -name \".*\" -perm /037 -ls\n\n755 /home/disauser/.somepermissivefile\n\t\nIf any local initialization files are returned, this indicates a mode more permissive than \"0740\", and this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Local initialization files are used to configure the user's shell environment upon logon. Malicious modification of these files could compromise accounts upon logon.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"7972","uuid":"a892ba1b-9f3c-4fac-a78d-463ed91f3e36","stig_uuid":"b3b51a67-7722-426f-875b-86e3b52497cd","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 69302E0A6687C8F61FC01A8184C26435D34F187B\r\n~~~~~\r\nConfiguration for 'All RHEL 9 local initialization files must have mode 0740 or less permissive.' matches the expected value on the RHEL 9 host."},{"group_id_src":"V-257890","group_tree":[{"id":"V-257890","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-257890","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-257890r1184305_rule","rule_id":"SV-257890","rule_version":"RHEL-09-232050","rule_title":"All RHEL 9 local interactive user home directories must have mode 0750 or less permissive.","fix_text":"Change the mode of interactive user's home directories to \"0750\" using the following command:\n\nNote: The example will be for the user \"disauser\".\n\n$ sudo chmod 0750 /home/disauser","weight":"10.0","check_content":"Verify the assigned home directory of all local interactive users has a mode of \"0750\" or less permissive with the following command:\n\nNote: This may miss interactive users that have been assigned a privileged user identifier (UID). Evidence of interactive use may be obtained from a number of log files containing system logon information.\n\n$ stat -L -c '%a %n' $(awk -F: '($3>=1000)&&($7 !~ /nologin/){print $6}' /etc/passwd) 2>/dev/null\n\n700 /home/disauser\n\nIf home directories referenced in \"/etc/passwd\" do not have a mode of \"0750\" or less permissive, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Excessive permissions on local interactive user home directories may allow unauthorized access to user files by other users.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"1635","uuid":"9b1f5411-7ab8-4dee-b71c-9634fee34931","stig_uuid":"b3b51a67-7722-426f-875b-86e3b52497cd","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 7CF63A4FCA42B18A2AD3D9869DD7A1A53C38B34E\r\n~~~~~\r\nRequired configuration for 'All RHEL 9 local interactive user home directories must have mode 0750 or less permissive.' was not present or did not match the expected value on the RHEL 9 host."},{"group_id_src":"V-257891","group_tree":[{"id":"V-257891","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-257891","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-257891r991589_rule","rule_id":"SV-257891","rule_version":"RHEL-09-232055","rule_title":"RHEL 9 /etc/group file must have mode 0644 or less permissive to prevent unauthorized access.","fix_text":"Change the mode of the file \"/etc/group\" to \"0644\" by running the following command:\n\n$ sudo chmod 0644 /etc/group","weight":"10.0","check_content":"Verify that the \"/etc/group\" file has mode \"0644\" or less permissive with the following command:\n\n$ sudo stat -c \"%a %n\" /etc/group\n\n644 /etc/group\n\nIf a value of \"0644\" or less permissive is not returned, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"/etc/group\" file contains information regarding groups that are configured on the system. Protection of this file is important for system security.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"1817","uuid":"3a13c27c-3d76-40ff-aa56-ddacfd8e22e7","stig_uuid":"b3b51a67-7722-426f-875b-86e3b52497cd","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL9_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: C50194D807E9A23B6FB76172E310579097A7CEBB\r\n~~~~~\r\nThe feature/role addressed by 'RHEL 9 /etc/group file must have mode 0644 or less permissive to prevent unauthorized access.' is not present or not in use on this the RHEL 9 host."},{"group_id_src":"V-257892","group_tree":[{"id":"V-257892","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-257892","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-257892r991589_rule","rule_id":"SV-257892","rule_version":"RHEL-09-232060","rule_title":"RHEL 9 /etc/group- file must have mode 0644 or less permissive to prevent unauthorized access.","fix_text":"Change the mode of the file \"/etc/group-\" to \"0644\" by running the following command:\n\n$ sudo chmod 0644 /etc/group-","weight":"10.0","check_content":"Verify that the \"/etc/group-\" file has mode \"0644\" or less permissive with the following command:\n\n$ sudo stat -c \"%a %n\" /etc/group-\n\n644 /etc/group-\n\nIf a value of \"0644\" or less permissive is not returned, this is a finding.","check_content_ref":{"href":"Red_Hat_Enterprise_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"/etc/group-\" file is a backup file of \"/etc/group\", and as such, contains information regarding groups that are configured on the system. Protection of this file is important for system security.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"9970","uuid":"13b1ecf6-9956-42d2-b103-9d30010b0302","stig_uuid":"b3b51a67-7722-426f-875b-86e3b52497cd","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-RHEL9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: BB0DB82EC3700975824F8657926A70F53C9BC6C2\r\n~~~~~\r\nRequired configuration for 'RHEL 9 /etc/group- file must have mode 0644 or less permissive to prevent unauthorized access.' was not present or did not match the expected value on the RHEL 9 host."},{"group_id_src":"V-257893","group_tree":[{"id":"V-257893","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-257893","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-257893r991589_rule","rule_id":"SV-257893","rule_versi