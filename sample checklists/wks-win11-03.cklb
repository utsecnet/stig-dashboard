n-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 032D16559E0BB92C1F7FB9084DD829A603EE0A07\r\n~~~~~\r\nConfiguration for 'Importing of payment info must be disabled.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235738","group_tree":[{"id":"V-235738","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235738","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-235738r960963_rule","rule_id":"SV-235738","rule_version":"EDGE-00-000021","rule_title":"Importing of saved passwords must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow importing of saved passwords\" to \"disabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow importing of saved passwords\" must be set to \"disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"ImportSavedPasswords\" is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Allows users to import saved passwords from another browser into Microsoft Edge.\n\nIf this policy is enabled, the option to manually import saved passwords is automatically selected.\n\nIf this policy is disabled, saved passwords are not imported on first run, and users cannot import them manually.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"5283","uuid":"faf38adb-c049-451c-98bc-3207e0602f99","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: EA655BD94CC5C951CCEF4619EBD5586C01AEDEAF\r\n~~~~~\r\nRequired configuration for 'Importing of saved passwords must be disabled.' was not present or did not match the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235739","group_tree":[{"id":"V-235739","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235739","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-235739r960963_rule","rule_id":"SV-235739","rule_version":"EDGE-00-000022","rule_title":"Importing of search engine settings must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow importing of search engine settings\" to \"disabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow importing of search engine settings\" must be set to \"disabled\".\n\nProcedure: Use the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"ImportSearchEngine\" is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Allows users to import search engine settings from another browser into Microsoft Edge.\n\nIf this policy is enabled, the option to import search engine settings is automatically selected.\n\nIf this policy is disabled, search engine settings are not imported at first run, and users cannot import them manually.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"8019","uuid":"86cc1043-f82c-404b-b2ba-1d08b298ad74","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 371B71E61F2013FF2CB194F52B11352DA7933742\r\n~~~~~\r\nConfiguration for 'Importing of search engine settings must be disabled.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235740","group_tree":[{"id":"V-235740","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235740","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-235740r960963_rule","rule_id":"SV-235740","rule_version":"EDGE-00-000023","rule_title":"Importing of shortcuts must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow importing of shortcuts\" to \"disabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow importing of shortcuts\" must be set to \"disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"ImportShortcuts\" is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Allows users to import Shortcuts from another browser into Microsoft Edge.\n\nIf this policy is disabled, Shortcuts are not imported on first run.\n\nIf this policy is not configured, Shortcuts are imported on first run.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"3283","uuid":"85ab786c-c721-4aa3-b491-1fbce557767c","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-235741","group_tree":[{"id":"V-235741","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235741","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-235741r1007485_rule","rule_id":"SV-235741","rule_version":"EDGE-00-000024","rule_title":"AutoplayAllowed must be set to disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow media autoplay for websites\" to \"disabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow media autoplay for websites\" must be set to \"disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"AutoplayAllowed\" is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"This policy sets the media autoplay policy for websites.\n\nThe default setting \"Not configured\" respects the current media autoplay settings and lets users configure their autoplay settings.\n\nSetting to \"Enabled\" sets media autoplay to \"Allow\". All websites are allowed to autoplay media. Users cannot override this policy.\n\nSetting to \"Disabled\" sets media autoplay to \"Limit\". This limits websites that are allowed to autoplay media to webpages with high media engagement and active WebRTC streams. Prior to Microsoft Edge version 92, this would set media autoplay to \"Block\". Users cannot override this policy.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"9906","uuid":"feef1c31-e647-448a-ac41-82cb8da58b33","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 09C4504F036D14003BF82B39D8DA4EE9727E7D25\r\n~~~~~\r\nConfiguration for 'AutoplayAllowed must be set to disabled.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235742","group_tree":[{"id":"V-235742","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235742","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-235742r960963_rule","rule_id":"SV-235742","rule_version":"EDGE-00-000025","rule_title":"WebUSB must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Content settings/Control use of the WebUSB API\" to enabled\" and select \"Do not allow any site to request access to USB devices via the WebUSB API\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Content settings/Control use of the WebUSB API\" must be set to \"enabled\" with the option value set to \"Do not allow any site to request access to USB devices via the WebUSB API\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"DefaultWebUsbGuardSetting\" is not set to \"REG_DWORD = 2\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Set whether websites can access connected USB devices. Access can be blocked completely or the user asked each time a website wants to get access to connected USB devices.\n\nOverride this policy for specific URL patterns by using the WebUsbAskForUrls and WebUsbBlockedForUrls policies.\n\nIf this policy is not configured, sites can ask users whether they can access the connected USB devices ('AskWebUsb') by default, and users can change this setting.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"7437","uuid":"3c164503-e616-41ea-bdbd-7e74a304c741","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-235743","group_tree":[{"id":"V-235743","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235743","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-235743r960963_rule","rule_id":"SV-235743","rule_version":"EDGE-00-000026","rule_title":"Google Cast must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Cast/Enable Google Cast\" to \"disabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Cast/Enable Google Cast\" must be set to \"disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"EnableMediaRouter\" is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Enable this policy to enable Google Cast. Users will be able to launch it from the app menu, page context menus, media controls on Cast-enabled websites, and (if shown) the Cast toolbar icon.\n\nDisable this policy to disable Google Cast.\n\nBy default, Google Cast is enabled.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"9265","uuid":"17524852-d226-4fe8-8e30-4b0b68be6d98","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 53C75A35748CED7732A257AA10F4622DA77D6CF6\r\n~~~~~\r\nConfiguration for 'Google Cast must be disabled.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235744","group_tree":[{"id":"V-235744","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235744","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-235744r960963_rule","rule_id":"SV-235744","rule_version":"EDGE-00-000027","rule_title":"Web Bluetooth API must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Content settings/Control use of the Web Bluetooth API\" to \"enabled\" with the option value set to \"Do not allow any site to request access to Bluetooth devices via the Web Bluetooth API.","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Content settings/Control use of the Web Bluetooth API\" must be set to \"enabled\" with the option value set to \"Do not allow any site to request access to Bluetooth devices via the Web Bluetooth API\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"DefaultWebBluetoothGuardSetting\" is not set to \"REG_DWORD = 2\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Control whether websites can access nearby Bluetooth devices. Access can be blocked completely or the site required to ask the user each time it wants to access a Bluetooth device.\n\nIf this policy is not configured, the default value ('AskWebBluetooth', meaning users are asked each time) is used and users can change it.\n\nPolicy options mapping:\n- BlockWebBluetooth (2) = Do not allow any site to request access to Bluetooth devices via the Web Bluetooth API.\n- AskWebBluetooth (3) = Allow sites to ask the user to grant access to a nearby Bluetooth device.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"4455","uuid":"e5af7f3c-38f6-4ce3-82f9-fd42f0e2287f","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 7D53F76164B8B94A0D5BDD0A334CD467AB755CBA\r\n~~~~~\r\nConfiguration for 'Web Bluetooth API must be disabled.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235745","group_tree":[{"id":"V-235745","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235745","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-235745r960963_rule","rule_id":"SV-235745","rule_version":"EDGE-00-000028","rule_title":"Autofill for Credit Cards must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Enable AutoFill for credit cards\" to \"disabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Enable AutoFill for credit cards\" must be set to \"disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"AutofillCreditCardEnabled\" is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Enables the Microsoft Edge AutoFill feature and lets users auto complete credit card information in web forms using previously stored information.\n\nIf this policy is disabled, AutoFill never suggests or fills credit card information, nor will it save additional credit card information that users might submit while browsing the web.\n\nIf this policy is enabled or not configured, users can control AutoFill for credit cards.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"1358","uuid":"6272d37c-1961-48b4-908f-c48a2051a6e7","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: FF5D79FB6B2A37E4ECC94CDCF76E2BA27CC9D04F\r\n~~~~~\r\nRequired configuration for 'Autofill for Credit Cards must be disabled.' was not present or did not match the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235746","group_tree":[{"id":"V-235746","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235746","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-235746r960963_rule","rule_id":"SV-235746","rule_version":"EDGE-00-000029","rule_title":"Autofill for addresses must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Enable AutoFill for addresses\" to \"disabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Enable AutoFill for addresses\" must be set to \"disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"AutofillAddressEnabled\" is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Enables the AutoFill feature and allows users to auto-complete address information in web forms using previously stored information.\n\nIf this policy is disabled, AutoFill never suggests or fills credit card information, nor will it save additional credit card information that users might submit while browsing the web.\n\nIf this policy is enabled or not configured, users can control AutoFill for addresses in the user interface.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"1709","uuid":"fdd622b2-60fc-4d56-b622-c89d31ae06cf","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-235747","group_tree":[{"id":"V-235747","title":"SRG-APP-000175","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235747","severity":"medium","group_title":"SRG-APP-000175","rule_id_src":"SV-235747r961038_rule","rule_id":"SV-235747","rule_version":"EDGE-00-000030","rule_title":"Online revocation checks must be performed.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Enable online OCSP/CRL checks\" to \"Enabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Enable online OCSP/CRL checks\" must be set to \"Enabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"EnableOnlineRevocationChecks\" is not set to \"REG_DWORD = 1\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If you enable this policy, Microsoft Edge will perform soft-fail, online OCSP/CRL checks. \"Soft fail\" means that if the revocation server can't be reached, the certificate will be considered valid.\n\nIf you disable the policy or don't configure it, Microsoft Edge won't perform online revocation checks.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000185"],"reference_identifier":"1367","uuid":"fcdb84e9-285f-415b-8522-4c8f4388b9a1","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 6380769D9A421386A47704F783F13899F68A8789\r\n~~~~~\r\nConfiguration for 'Online revocation checks must be performed.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235748","group_tree":[{"id":"V-235748","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235748","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-235748r960963_rule","rule_id":"SV-235748","rule_version":"EDGE-00-000031","rule_title":"Personalization of ads, search, and news by sending browsing history to Microsoft must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow personalization of ads, search and news by sending browsing history to Microsoft\" to \"disabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow personalization of ads, search and news by sending browsing history to Microsoft\" must be set to \"disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"PersonalizationReportingEnabled\" is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"This policy prevents Microsoft from collecting a user's Microsoft Edge browsing history to be used for personalizing advertising, search, news and other Microsoft services.\n\nThis setting is only available for users with a Microsoft account. This setting is not available for child accounts or enterprise accounts.\n\nIf this policy is disabled, users cannot change or override the setting. If this policy is enabled or not configured, Microsoft Edge will default to the user's preference.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"6356","uuid":"ba406705-f0a0-493c-94be-ce8f0331b127","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 999AEDF2D5E7D048C75AA3A90F0DE05AC1C30872\r\n~~~~~\r\nConfiguration for 'Personalization of ads, search, and news by sending browsing history to Microsoft must be disabled.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235749","group_tree":[{"id":"V-235749","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235749","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-235749r960963_rule","rule_id":"SV-235749","rule_version":"EDGE-00-000032","rule_title":"Site tracking of a user\u2019s location must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Content settings/Default geolocation setting\" to \"enabled\" and select \"Don't allow any site to track users' physical location\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Content settings/Default geolocation setting\" must be set to \"enabled\" with the option value set to \"Don't allow any site to track users' physical location\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"DefaultGeolocationSetting\" is not set to \"REG_DWORD = 2\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Set whether websites can track users' physical locations. Tracking can be allowed by default (\"AllowGeolocation\") or denied by default (\"BlockGeolocation\"), or the user can be asked each time a website requests their location (\"AskGeolocation\").\n\nIf this policy is not configured, \"AskGeolocation\" is used and the user can change it.\n\nPolicy options mapping:\n- AllowGeolocation (1) = Allow sites to track users' physical location.\n- BlockGeolocation (2) = Do not allow any site to track users' physical location.\n- AskGeolocation (3) = Ask whenever a site wants to track users' physical location.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"8547","uuid":"21058208-5752-4923-be9b-ffd35ec9bb03","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 1D735648712F367314AD519265D2A44885C164EF\r\n~~~~~\r\nConfiguration for 'Site tracking of a user\u2019s location must be disabled.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235750","group_tree":[{"id":"V-235750","title":"SRG-APP-000080","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235750","severity":"medium","group_title":"SRG-APP-000080","rule_id_src":"SV-235750r960864_rule","rule_id":"SV-235750","rule_version":"EDGE-00-000033","rule_title":"Browser history must be saved.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Enable deleting browser and download history\" to \"disabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Enable deleting browser and download history\" must be set to \"disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"AllowDeletingBrowserHistory\" is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"This setting disables deleting browser history and download history and prevents users from changing this setting.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000166"],"reference_identifier":"1292","uuid":"6a5ccabd-687c-4d91-ad92-a29fb6203924","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 7F9C2F7B77987F2C23A6C8E22F6290067CAC204D\r\n~~~~~\r\nRequired configuration for 'Browser history must be saved.' was not present or did not match the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235751","group_tree":[{"id":"V-235751","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235751","severity":"low","group_title":"SRG-APP-000141","rule_id_src":"SV-235751r960963_rule","rule_id":"SV-235751","rule_version":"EDGE-00-000034","rule_title":"Edge development tools must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Control where developer tools can be used\" to \"enabled\" and select \"Don't allow using the developer tools\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Control where developer tools can be used\" with the option value set to \"Don't allow using the developer tools\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"DeveloperToolsAvailability\" is not set to \"REG_DWORD = 2\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"While the risk associated with browser development tools is more related to the proper design of a web application, a risk vector remains within the browser. The developer tools allow end users and application developers to view and edit all types of web application-related data via the browser. Page elements, source code, javascript, API calls, application data, etc., may all be viewed and potentially manipulated. Manipulation could be useful for troubleshooting legitimate issues, and this may be performed in a development environment. Manipulation could also be malicious and must be addressed.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"8489","uuid":"dbb027f9-238d-4da5-a6e7-d2ff735dd4b0","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 1736859F5762F3C5771A7C605E33B17CAEA95F6B\r\n~~~~~\r\nRequired configuration for 'Edge development tools must be disabled.' was not present or did not match the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235752","group_tree":[{"id":"V-235752","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235752","severity":"low","group_title":"SRG-APP-000141","rule_id_src":"SV-235752r1156563_rule","rule_id":"SV-235752","rule_version":"EDGE-00-000036","rule_title":"Download restrictions must be configured.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow download restrictions\" to \"Enabled\" and select one of the following: \"BlockDangerousDownloads\", \"Block potentially dangerous or unwanted downloads\", \"BlockAllDownloads\", or \"BlockMaliciousDownloads\".","weight":"10.0","check_content":"If this machine is on SIPRNet, this is Not Applicable.\n\nThe policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow download restrictions\" must be set to \"Enabled\" with the option value set to \"BlockDangerousDownloads\", \"Block potentially dangerous or unwanted downloads\", or \"BlockMaliciousDownloads\". The more restrictive option, \"Block all downloads\", is also acceptable.\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"DownloadRestrictions\" is set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"This configures the type of downloads that Microsoft Edge completely blocks without allowing users to override the security decision.\n\nSet \"BlockDangerousDownloads\" to allow all downloads except those that carry Microsoft Defender SmartScreen warnings of known dangerous downloads or that have dangerous file type extensions.\n\nSet \"BlockPotentiallyDangerousDownloads\" to allow all downloads except those that carry Microsoft Defender SmartScreen warnings of potentially dangerous or unwanted downloads or that have dangerous file type extensions.\n\nSet \"BlockAllDownloads\" to block all downloads.\n\nSet \"BlockMaliciousDownloads\" to allow all downloads except those that carry Microsoft Defender SmartScreen warnings of known malicious downloads.\n\nIf this policy is not configured or the \"DefaultDownloadSecurity\" option is not set, the downloads go through the usual security restrictions based on Microsoft Defender SmartScreen analysis results.\n\nPolicy options mapping:\n\nDefaultDownloadSecurity (0) = No special restrictions\n\nBlockDangerousDownloads (1) = Block malicious downloads and dangerous file types\n\nBlockPotentiallyDangerousDownloads (2) = Block potentially dangerous or unwanted downloads and dangerous file types\n\nBlockAllDownloads (3) = Block all downloads\n\nBlockMaliciousDownloads (4) = Block malicious downloads","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"6802","uuid":"fcb69ee4-ec5f-438c-bd80-3f6229c4b38f","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: 52A113175ADCF470940963D3ADB6A2FD750AB25C\r\n~~~~~\r\nThe feature/role addressed by 'Download restrictions must be configured.' is not present or not in use on this the Microsoft Edge browser."},{"group_id_src":"V-235753","group_tree":[{"id":"V-235753","title":"SRG-APP-000378","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235753","severity":"low","group_title":"SRG-APP-000378","rule_id_src":"SV-235753r1015297_rule","rule_id":"SV-235753","rule_version":"EDGE-00-000039","rule_title":"URLs must be allowlisted for plugin use if used.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Content settings/Allow pop-up windows on specific sites\" to \"Enabled\". A list of allowlisted URLs may be specified here.","weight":"10.0","check_content":"This requirement for \"Allow pop-up windows on specific sites\" is not required; this is optional.\n\nThe policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Content settings/Allow pop-up windows on specific sites\" must be set to \"Enabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\n\"PopupsAllowedForUrls\" must be set as follows:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\\PopupsAllowedForUrls\\1 = mydomain.com\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\\PopupsAllowedForUrls\\2 = myagency.mil\n\nIf configured, the list of domains for which Microsoft Edge allows pop-ups may be allowlisted.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Define a list of sites, based on URL patterns that can open pop-up windows.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-003980","CCI-001812"],"reference_identifier":"8939","uuid":"0db05345-e8de-4a7f-8d12-bbba7c867d00","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: C8197B2D9C62E435D2294D257DAA3E0AA281BF61\r\n~~~~~\r\nConfiguration for 'URLs must be allowlisted for plugin use if used.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235754","group_tree":[{"id":"V-235754","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235754","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-235754r960963_rule","rule_id":"SV-235754","rule_version":"EDGE-00-000041","rule_title":"Extensions installation must be blocklisted by default.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Extensions/Control which extensions cannot be installed\" to \"Enabled\". A list of blocklisted extensions may then be specified.","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Extensions/Control which extensions cannot be installed\" must be set to \"Enabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\\ExtensionInstallBlocklist\\1\n\nIf the value for \"1\" is not set to \"REG_SZ = *\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"List specific extensions that users cannot install in Microsoft Edge. When this policy is deployed, any extensions on this list that were previously installed will be disabled, and the user will not be able to enable them. If an item is removed from the list of blocked extensions, the extension is automatically reenabled anywhere it was previously installed.\n\nUse \"*\" to block all extensions that are not explicitly listed in the allow list.\n\nIf this policy is not configured, users can install any extension in Microsoft Edge.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"4943","uuid":"850debd8-db0f-4a9b-86db-54e81045429a","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: F35882B6FB3A4F62C399AC49843CF89307BEE901\r\n~~~~~\r\nConfiguration for 'Extensions installation must be blocklisted by default.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235755","group_tree":[{"id":"V-235755","title":"SRG-APP-000386","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235755","severity":"low","group_title":"SRG-APP-000386","rule_id_src":"SV-235755r961479_rule","rule_id":"SV-235755","rule_version":"EDGE-00-000042","rule_title":"Extensions that are approved for use must be allowlisted if used.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Extensions/Allow specific extensions to be installed\" to \"Enabled\".  A list of allowlisted extensions may then be specified.","weight":"10.0","check_content":"This requirement for \"Allow specific extensions to be installed\" is not required; this is optional.\n\nThe policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Extensions/Allow specific extensions to be installed\" must be set to \"Enabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\n\"ExtensionInstallAllowlist\" must be set as follows:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\\ExtensionInstallAllowlist\\1 = \"extension_id1\"\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\\ExtensionInstallAllowlist\\2 = \"extension_id2\"\n\nIf configured, the list of extensions for which Microsoft Edge allows to be installed may be allowlisted.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"By default, all extensions are allowed. However, if all extensions are blocked by setting the \"ExtensionInstallBlockList\" policy to \"*,\" users can only install extensions defined in this policy.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001774"],"reference_identifier":"6214","uuid":"294ce44a-d0ed-4e2d-9bf2-bf660f25a9f9","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: BB8C2716EAD96FE4278CF4075D7A8AA2F754AB9D\r\n~~~~~\r\nConfiguration for 'Extensions that are approved for use must be allowlisted if used.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235756","group_tree":[{"id":"V-235756","title":"SRG-APP-000400","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235756","severity":"medium","group_title":"SRG-APP-000400","rule_id_src":"SV-235756r961521_rule","rule_id":"SV-235756","rule_version":"EDGE-00-000043","rule_title":"The Password Manager must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Password manager and protection/Enable saving passwords to the password manager\" to \"disabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Password manager and protection/Enable saving passwords to the password manager\" must be set to \"disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"PasswordManagerEnabled\" is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Enable Microsoft Edge to save user passwords.\n\nIf this policy is enabled, users can save their passwords in Microsoft Edge. The next time the user visits the site, Microsoft Edge will enter the password automatically.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002007"],"reference_identifier":"4861","uuid":"5aaff548-f37f-4f54-aec2-865a5c698a2a","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: E7D458279D4F3B9DF87B534CE478C6758F329C1C\r\n~~~~~\r\nConfiguration for 'The Password Manager must be disabled.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235758","group_tree":[{"id":"V-235758","title":"SRG-APP-000456","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235758","severity":"high","group_title":"SRG-APP-000456","rule_id_src":"SV-235758r1117151_rule","rule_id":"SV-235758","rule_version":"EDGE-00-000045","rule_title":"The version of Microsoft Edge running on the system must be a supported version.","fix_text":"Install a supported version of Edge.","weight":"10.0","check_content":"Cross-reference the build information displayed with the Microsoft Edge site to identify, at minimum, the oldest supported build available. \n\nIf the installed version of Edge is not supported by Microsoft, this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Security flaws with software applications are discovered daily. Vendors are constantly updating and patching their products to address newly discovered security vulnerabilities. Organizations (including any contractor to the organization) are required to promptly install security-relevant software updates (e.g., patches, service packs, and hot fixes). Flaws discovered during security assessments, continuous monitoring, incident response activities, or information system error handling must also be addressed expeditiously. \n\nOrganization-defined time periods for updating security-relevant software may vary based on a variety of factors including, for example, the security category of the information system or the criticality of the update (i.e., severity of the vulnerability related to the discovered flaw). \n\nThis requirement will apply to software patch management solutions that are used to install patches across the enclave and also to applications themselves that are not part of that patch management solution. For example, many browsers today provide the capability to install their own patch software. Patch criticality, as well as system criticality will vary. Therefore, the tactical situations regarding the patch management process will also vary. This means that the time period used must be a configurable parameter. Time frames for application of security-relevant software updates may be dependent upon the Information Assurance Vulnerability Management (IAVM) process.\n\nThe application will be configured to check for and install security-relevant software updates within an identified time period from the availability of the update. The specific time period will be defined by an authoritative source (e.g., IAVM, CTOs, DTMs, and STIGs).","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002605"],"reference_identifier":"1005","uuid":"9bc3f0e6-e798-4013-bb1d-32cadd3471f5","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: A2DC7099F86818241ABF2B30CED8F751704910C6\r\n~~~~~\r\nConfiguration for 'The version of Microsoft Edge running on the system must be a supported version.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235760","group_tree":[{"id":"V-235760","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235760","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-235760r960963_rule","rule_id":"SV-235760","rule_version":"EDGE-00-000047","rule_title":"Site isolation for every site must be enabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Enable site isolation for every site\" to \"enabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Enable site isolation for every site\" must be set to \"enabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"SitePerProcess\" is not set to \"REG_DWORD = 1\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"SitePerProcess\" policy can be used to prevent users from opting out of the default behavior of isolating all sites. The \"IsolateOrigins\" policy can be used to isolate additional, finer-grained origins.\n\nEnabling this policy prevents users from opting out of the default behavior where each site runs in its own process.\n\nIf this policy is not disabled or configured, a user can opt out of site isolation (e.g., by using \"Disable site isolation\" entry in edge://flags.) Disabling the policy or not configuring the policy does not turn off Site Isolation.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"8162","uuid":"6bef62b5-634a-4cc7-b381-46e55f772c6f","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: A16939F2021AF01027D83D32D2E0A9DB3387818A\r\n~~~~~\r\nConfiguration for 'Site isolation for every site must be enabled.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235761","group_tree":[{"id":"V-235761","title":"SRG-APP-000142","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235761","severity":"medium","group_title":"SRG-APP-000142","rule_id_src":"SV-235761r1043177_rule","rule_id":"SV-235761","rule_version":"EDGE-00-000048","rule_title":"Supported authentication schemes must be configured.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/HTTP authentication/Supported authentication schemes\" to \"ntlm,negotiate\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/HTTP authentication/Supported authentication schemes\" must be set to  \"ntlm,negotiate\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"AuthSchemes\" is not set to \"REG_SZ = ntlm,negotiate\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"This setting specifies which HTTP authentication schemes are supported.\n\nThe policy can be configured by using these values: \"basic\", \"digest\", \"ntlm\", and \"negotiate\". Separate multiple values with commas.\n\nIf this policy is not configured, all four schemes are used.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000382"],"reference_identifier":"9752","uuid":"7197b8ee-6827-4479-a74d-fd5af8a2d7bc","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 9BC3175AC80F7EA80486A54EFC4087E49C90B819\r\n~~~~~\r\nConfiguration for 'Supported authentication schemes must be configured.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235763","group_tree":[{"id":"V-235763","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235763","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-235763r960963_rule","rule_id":"SV-235763","rule_version":"EDGE-00-000050","rule_title":"Microsoft Defender SmartScreen must be enabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/SmartScreen settings/Configure Microsoft Defender SmartScreen\" to \"Enabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/SmartScreen settings/Configure Microsoft Defender SmartScreen\" must be set to \"Enabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"SmartScreenEnabled\" is not set to \"REG_DWORD = 1\", this is a finding.\n\nIf this machine is on SIPRNet, this is Not Applicable.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"This policy setting configures Microsoft Defender SmartScreen, which provides warning messages to help protect  users from potential phishing scams and malicious software. By default, Microsoft Defender SmartScreen is turned on.\n\nIf this setting is enabled, Microsoft Defender SmartScreen is turned on.\n\nIf this setting is disabled, Microsoft Defender SmartScreen is turned off.\n\nIf this setting is not configured, users can choose whether to use Microsoft Defender SmartScreen.\n\nThis policy is available only on Windows instances that are joined to a Microsoft Active Directory domain, Windows 10 Pro or Enterprise instances that enrolled for device management, or macOS instances that are that are managed via MDM or joined to a domain via MCX.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"1222","uuid":"cadfe59b-bef1-42a4-94f2-6da56c981e75","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: C2DF99EAEE35D6AA64AD161ACC0E849A407C097E\r\n~~~~~\r\nRequired configuration for 'Microsoft Defender SmartScreen must be enabled.' was not present or did not match the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235764","group_tree":[{"id":"V-235764","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235764","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-235764r960963_rule","rule_id":"SV-235764","rule_version":"EDGE-00-000051","rule_title":"Microsoft Defender SmartScreen must be configured to block potentially unwanted apps.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/SmartScreen settings/Configure Microsoft Defender SmartScreen to block potentially unwanted apps\" to \"Enabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/SmartScreen settings/Configure Microsoft Defender SmartScreen to block potentially unwanted apps\" must be set to \"Enabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for SmartScreenPuaEnabled is not set to \"REG_DWORD = 1\", this is a finding.\n\nIf this machine is on SIPRNet, this is Not Applicable.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"This policy setting configures blocking for potentially unwanted apps with Microsoft Defender SmartScreen. Potentially unwanted app blocking with Microsoft Defender SmartScreen provides warning messages to help protect users from adware, coin miners, bundleware, and other low-reputation apps that are hosted by websites. Potentially unwanted app blocking with Microsoft Defender SmartScreen is turned off by default.\n\nIf this setting is enabled, potentially unwanted app blocking with Microsoft Defender SmartScreen is turned on.\n\nIf this setting is disabled, potentially unwanted app blocking with Microsoft Defender SmartScreen is turned off.\n\nIf this setting is not configured, users can choose whether to use potentially unwanted app blocking with Microsoft Defender SmartScreen.\n\nThis policy is available only on Windows instances that are joined to a Microsoft Active Directory domain, Windows 10 Pro or Enterprise instances that enrolled for device management, or macOS instances that are managed via MDM or joined to a domain via MCX.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"6261","uuid":"105714d0-203c-4cc4-8997-a8fb9918631d","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-235765","group_tree":[{"id":"V-235765","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235765","severity":"low","group_title":"SRG-APP-000141","rule_id_src":"SV-235765r960963_rule","rule_id":"SV-235765","rule_version":"EDGE-00-000052","rule_title":"The download location prompt must be configured.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Ask where to save downloaded files\" to \"enabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Ask where to save downloaded files\" must be set to \"enabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"PromptForDownloadLocation\" is not set to \"REG_DWORD = 1\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"This setting provides positive feedback before a download starts, limiting the possibility of inadvertent downloads without notifying the user.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"9587","uuid":"4000dbc6-8f16-42f6-ba48-a099c6c5c1d3","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: B2A1779BF134C32359EBE9F8FEA49C3E68E05D91\r\n~~~~~\r\nThe feature/role addressed by 'The download location prompt must be configured.' is not present or not in use on this the Microsoft Edge browser."},{"group_id_src":"V-235766","group_tree":[{"id":"V-235766","title":"SRG-APP-000148","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235766","severity":"medium","group_title":"SRG-APP-000148","rule_id_src":"SV-235766r1051115_rule","rule_id":"SV-235766","rule_version":"EDGE-00-000054","rule_title":"Tracking of browsing activity must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Block tracking of users' web-browsing activity\" to \"Balanced\" or \"Strict\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Block tracking of users' web-browsing activity\" must be set to \"Enabled\" with the option value set to \"Balanced\" or \"Strict\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"TrackingPrevention\" is not set to \"REG_DWORD = 2\" or \"REG_DWORD = 3\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The setting allows websites to be blocked from tracking users' web-browsing activity.\n\nIf this policy is disabled or is not configured, users can set their own level of tracking prevention.\n\nPolicy options mapping:\n- TrackingPreventionOff (0) = Off (no tracking prevention)\n- TrackingPreventionBasic (1) = Basic (blocks harmful trackers; content and ads will be personalized)\n- TrackingPreventionBalanced (2) = Balanced (blocks harmful trackers and trackers from sites user has not visited; content and ads will be less personalized)\n- TrackingPreventionStrict (3) = Strict (blocks harmful trackers and majority of trackers from all sites; content and ads will have minimal personalization; some parts of sites might not work)","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000388"],"reference_identifier":"3202","uuid":"131c1cf4-3913-4eea-b9e9-acea2bee7c1c","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: ECCFF79155E1EE575B2563E942A1F723E8BA6015\r\n~~~~~\r\nConfiguration for 'Tracking of browsing activity must be disabled.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235767","group_tree":[{"id":"V-235767","title":"SRG-APP-000149","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235767","severity":"medium","group_title":"SRG-APP-000149","rule_id_src":"SV-235767r960972_rule","rule_id":"SV-235767","rule_version":"EDGE-00-000055","rule_title":"A website's ability to query for payment methods must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow websites to query for available payment methods\" to \"disabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow websites to query for available payment methods\" must be set to \"disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for PaymentMethodQueryEnabled is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"This setting determines whether websites can check if the user has payment methods saved.\n\nIf this policy is disabled, websites that use \"PaymentRequest.canMakePayment\" or \"PaymentRequest.hasEnrolledInstrument\" API will be informed that no payment methods are available.\n\nIf this policy is enabled or is not set, websites can check to determine if the user has payment methods saved.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"8846","uuid":"8679d289-0814-4e60-8b2c-91d50183fd6e","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 10C16CF2A8768ED37D728B9BBA265F5C9BAEE9FA\r\n~~~~~\r\nConfiguration for 'A website's ability to query for payment methods must be disabled.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235768","group_tree":[{"id":"V-235768","title":"SRG-APP-000151","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235768","severity":"medium","group_title":"SRG-APP-000151","rule_id_src":"SV-235768r1015298_rule","rule_id":"SV-235768","rule_version":"EDGE-00-000056","rule_title":"Suggestions of similar web pages in the event of a navigation error must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Suggest similar pages when a webpage can't be found\" to \"Disabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Suggest similar pages when a webpage can't be found\" must be set to \"Disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for AlternateErrorPagesEnabled is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"This setting allows Microsoft Edge to issue a connection to a web service to generate URL and search suggestions for connectivity issues such as DNS errors.\n\nIf this policy is enabled, a web service is used to generate URL and search suggestions for network errors.\n\nIf this policy is disabled, no calls to the web service are made and a standard error page is shown.\n\nIf this policy is not configured, Microsoft Edge respects the user preference that is set under Services at edge://settings/privacy. Specifically, there is a \"Suggest similar pages when a webpage can't be found\" toggle, which the user can switch on or off. \n\nNote that if this policy has been enabled (AlternateErrorPagesEnabled), the \"Suggest similar pages when a webpage can't be found setting\" is turned on, but the user cannot change the setting by using the toggle. \n\nIf this policy is disabled, the \"Suggest similar pages when a webpage can't be found\" setting is turned off, and the user cannot change the setting by using the toggle.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381","CCI-000767"],"reference_identifier":"4024","uuid":"869ce598-2faa-488c-839a-7a7b98b9785e","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 888A9ABFC2C9F27DC80FE0ECC5043C40D5DA6487\r\n~~~~~\r\nConfiguration for 'Suggestions of similar web pages in the event of a navigation error must be disabled.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235769","group_tree":[{"id":"V-235769","title":"SRG-APP-000152","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235769","severity":"medium","group_title":"SRG-APP-000152","rule_id_src":"SV-235769r960981_rule","rule_id":"SV-235769","rule_version":"EDGE-00-000057","rule_title":"User feedback must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow user feedback\" to \"disabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow user feedback\" must be set to \"disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for UserFeedbackAllowed is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Microsoft Edge uses the Edge Feedback feature (enabled by default) to allow users to send feedback, suggestions, or customer surveys and to report any issues with the browser. By default, users cannot disable (turn off) the Edge Feedback feature.\n\nIf this policy is enabled or not configured, users can invoke Edge Feedback.\n\nIf this policy is disabled, users cannot invoke Edge Feedback.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"7426","uuid":"2f9c72b7-3898-4bc1-8216-ba23200d9d5f","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: D3D2C9D76089E836D83D4A6FF24F542238B65A5E\r\n~~~~~\r\nConfiguration for 'User feedback must be disabled.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235770","group_tree":[{"id":"V-235770","title":"SRG-APP-000153","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235770","severity":"medium","group_title":"SRG-APP-000153","rule_id_src":"SV-235770r960984_rule","rule_id":"SV-235770","rule_version":"EDGE-00-000058","rule_title":"The collections feature must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Enable the Collections feature\" to \"Disabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Enable the Collections feature\" must be set to \"Disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"EdgeCollectionsEnabled\" is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"This setting allows users to access the Collections feature, where they can collect, organize, share, and export content more efficiently and with Office integration.\n\nIf this policy is enabled or not configured, users can access and use the Collections feature in Microsoft Edge.\n\nIf this policy is disabled, users cannot access and use Collections in Microsoft Edge.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"7086","uuid":"33fc8ba2-208a-4f9f-9961-651d0c58068e","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: EAE71D419AC515D18AFD777C849B2C13B3BB11F1\r\n~~~~~\r\nConfiguration for 'The collections feature must be disabled.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235771","group_tree":[{"id":"V-235771","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235771","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-235771r960963_rule","rule_id":"SV-235771","rule_version":"EDGE-00-000059","rule_title":"The Share Experience feature must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Configure the Share experience\" to \"Don't allow using the Share experience\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Configure the Share experience\" must be set to \"enabled\" with the option value set to \"Don't allow using the Share experience\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"ConfigureShare\" is not set to \"REG_DWORD = 1\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If this policy is set to \"ShareAllowed\" (the default), users will be able to access the Windows 10 Share experience from the Settings and More menu in Microsoft Edge to share with other apps on the system.\n\nIf this policy is set to \"ShareDisallowed\", users will not be able to access the Windows 10 Share experience. If the Share button is on the toolbar, it will also be hidden.\n\nPolicy options mapping:\n- ShareAllowed (0) = Allow using the Share experience.\n- ShareDisallowed (1) = Do not allow using the Share experience.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"8763","uuid":"c67da563-9429-4360-95b1-41656b3ffbf7","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 9F8D81A79BB4676999C4B15BA2C1FD036258E09C\r\n~~~~~\r\nRequired configuration for 'The Share Experience feature must be disabled.' was not present or did not match the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235772","group_tree":[{"id":"V-235772","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235772","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-235772r960963_rule","rule_id":"SV-235772","rule_version":"EDGE-00-000060","rule_title":"Guest mode must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Enable guest mode\" to \"disabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Enable guest mode\" must be set to \"disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"BrowserGuestModeEnabled\" is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Enabling Guest mode allows the use of guest profiles in Microsoft Edge. In a guest profile, the browser does not import browsing data from existing profiles, and it deletes browsing data when all guest profiles are closed.\n\nIf this policy is enabled or not configured, Microsoft Edge lets users browse in guest profiles.\n\nIf this policy is disabled, Microsoft Edge does not let users browse in guest profiles.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"8298","uuid":"b12a00e8-0bf3-4321-a864-9fdece978d19","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 4879932001C811628597944FDFA6237E11A4A787\r\n~~~~~\r\nConfiguration for 'Guest mode must be disabled.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-235773","group_tree":[{"id":"V-235773","title":"SRG-APP-000156","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235773","severity":"medium","group_title":"SRG-APP-000156","rule_id_src":"SV-235773r960993_rule","rule_id":"SV-235773","rule_version":"EDGE-00-000061","rule_title":"Relaunch notification must be required.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Notify a user that a browser restart is recommended or required for pending updates\" web-browsing activity to \"Required\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Notify a user that a browser restart is recommended or required for pending updates\" must be set to \"Enabled\" with the option value set to \"Required\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"RelaunchNotification\" is not set to \"REG_DWORD = 2\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Users must be required to restart the browser to finish installation of pending updates and prevent users from continually using an old/vulnerable browser version.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"3785","uuid":"d9443bcd-bf0c-49d6-84aa-5c9d7b77abb8","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: D508352F04669B47E9E89A1DE07409A3C973811E\r\n~~~~~\r\nThe feature/role addressed by 'Relaunch notification must be required.' is not present or not in use on this the Microsoft Edge browser."},{"group_id_src":"V-235774","group_tree":[{"id":"V-235774","title":"SRG-APP-000157","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-235774","severity":"medium","group_title":"SRG-APP-000157","rule_id_src":"SV-235774r1015299_rule","rule_id":"SV-235774","rule_version":"EDGE-00-000062","rule_title":"The built-in DNS client must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Use built-in DNS client\" to \"disabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Use built-in DNS client\" must be set to \"disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"BuiltInDnsClientEnabled\" is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"This setting controls whether to use the built-in DNS client.\n\nThis does not affect which DNS servers are used; it only controls the software stack that is used to communicate with them. For example, if the operating system is configured to use an enterprise DNS server, that same server would be used by the built-in DNS client. However, it is however possible that the built-in DNS client will address servers in different ways by using more modern DNS-related protocols such as DNS-over-TLS.\n\nIf this policy is enabled, the built-in DNS client is used if it is available.\n\nIf this policy is disabled, the client is never used.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001941","CCI-001942"],"reference_identifier":"9485","uuid":"bb1d3c4f-370d-4127-b6c5-b02d6c46a1be","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 9993825C4368DB94A803C7957E8A03E19E693478\r\n~~~~~\r\nConfiguration for 'The built-in DNS client must be disabled.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-246736","group_tree":[{"id":"V-246736","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-246736","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-246736r960963_rule","rule_id":"SV-246736","rule_version":"EDGE-00-000063","rule_title":"Use of the QUIC protocol must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow QUIC protocol\" to \"Disabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow QUIC protocol\" must be set to \"Disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"QuicAllowed\" is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"QUIC is used by more than half of all connections from the Edge web browser to Google's servers, and this activity is undesirable in the DoD.\n\nIf you enable this policy or don't configure it, the QUIC protocol is allowed.\n\nIf you disable this policy, the QUIC protocol is blocked.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"3792","uuid":"d5e60be7-24c1-4adb-86ac-0ab72e911c27","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 805085F6F39418D8C01F1947BB8355CD9EEB5C69\r\n~~~~~\r\nConfiguration for 'Use of the QUIC protocol must be disabled.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-251694","group_tree":[{"id":"V-251694","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-251694","severity":"low","group_title":"SRG-APP-000141","rule_id_src":"SV-251694r960963_rule","rule_id":"SV-251694","rule_version":"EDGE-00-000064","rule_title":"The list of domains media autoplay allows must be allowlisted if used.","fix_text":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow media autoplay on specific sites\" may be set to \"allow\" for allowlisted domains.","weight":"10.0","check_content":"If this machine is on SIPRNet, this is Not Applicable.\n\nThis requirement for \"AutoplayAllowlist\" is not required; this is optional.\n\nThe policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Allow media autoplay on specific sites\" may be set to \"allow\" for allowlisted domains.\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nAutoplayAllowlist may be set as follows:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\\AutoplayAllowlist\\1 = mydomain.com\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\\AutoplayAllowlist\\2 = myagency.mil\n\nIf configured, the list of domains for which autoplay is allowed may be allowlisted.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Define a list of sites, based on URL patterns, that are allowed to autoplay media.\n\nIf this policy is not configured, the global default value from the AutoplayAllowed policy (if set) or the user's personal configuration is used for all sites.\n\nEDGE-00-000024 disables the AutoplayAllowed policy.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"5876","uuid":"5ffe22aa-c675-4497-81a0-51be623e101b","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 1F36A5CA124A07FA5BAE76E5D35D0271D46A81E9\r\n~~~~~\r\nRequired configuration for 'The list of domains media autoplay allows must be allowlisted if used.' was not present or did not match the expected value on the Microsoft Edge browser."},{"group_id_src":"V-260465","group_tree":[{"id":"V-260465","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-260465","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-260465r960963_rule","rule_id":"SV-260465","rule_version":"EDGE-00-000065","rule_title":"Visual Search must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Visual search enabled\" to \"Disabled\".","weight":"10.0","check_content":"Verify the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Visual search enabled\" is set to \"Disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"VisualSearchEnabled\" is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Visual Search allows for quick exploration of more related content about entities in an image.\n\nIf this policy is enabled or not configured, Visual Search will be enabled via image hover, context menu, and search in Sidebar.\n\nIf this policy is disabled, Visual Search will be disabled and more information about images will not be available via hover, context menu, and search in Sidebar.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"9646","uuid":"2991bfbb-0540-4c74-857d-52282e6ad70b","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: C007A1FC27F4EC9854231B2E6BE26DE376B804D6\r\n~~~~~\r\nRequired configuration for 'Visual Search must be disabled.' was not present or did not match the expected value on the Microsoft Edge browser."},{"group_id_src":"V-260466","group_tree":[{"id":"V-260466","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-260466","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-260466r960963_rule","rule_id":"SV-260466","rule_version":"EDGE-00-000066","rule_title":"Copilot must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Show Hubs Sidebar\" to \"Disabled\".","weight":"10.0","check_content":"Verify the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Show Hubs Sidebar\" is set to \"Disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"HubsSidebarEnabled\" is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The Sidebar is a launcher bar on the right side of Microsoft Edge's screen.\n\nIf this policy is enabled or not configured, the Sidebar will be shown. If this policy is disabled, the Sidebar will never be shown.\n\nDisabling Sidebar will disable Copilot.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"3559","uuid":"9fd14a7f-6999-4b74-aa6c-6551cb79cbca","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-260467","group_tree":[{"id":"V-260467","title":"SRG-APP-000080","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-260467","severity":"medium","group_title":"SRG-APP-000080","rule_id_src":"SV-260467r960864_rule","rule_id":"SV-260467","rule_version":"EDGE-00-000067","rule_title":"Session only-based cookies must be enabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Content settings/Configure cookies\" to \"Enabled\" with the option value set to \"Keep cookies for the duration of the session, except ones listed in 'SaveCookiesOnExit'\".","weight":"10.0","check_content":"Verify the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Content settings/Configure cookies\" is set to \"Enabled\" with the option value set to \"Keep cookies for the duration of the session, except ones listed in 'SaveCookiesOnExit'\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \u201cDefaultCookiesSetting\u201d is not set to \"REG_DWORD = 4\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Cookies must only be allowed per session and only for approved URLs as permanently stored cookies can be used for malicious intent. \n\nApproved URLs may be allowlisted via the \"CookiesAllowedForUrls\" or \"SaveCookiesOnExit\" policy settings, but these are not requirements.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000166"],"reference_identifier":"1075","uuid":"1aff391e-2a78-4420-98b0-a887155c2d6c","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 137CF6BA1498464DC336EEE0AAA97BFC920E2344\r\n~~~~~\r\nRequired configuration for 'Session only-based cookies must be enabled.' was not present or did not match the expected value on the Microsoft Edge browser."},{"group_id_src":"V-266981","group_tree":[{"id":"V-266981","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-266981","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-266981r1169858_rule","rule_id":"SV-266981","rule_version":"EDGE-00-000068","rule_title":"FriendlyURLs must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft EdgeConfigure the default paste format of URLs copied from Microsoft Edge, and determine if additional formats will be available to users\" to \"enabled\" and select \"The plain URL without any extra information, such as the page\u00b4s title. This is the recommended option when this policy is configured. For more information, see the description.\"","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Configure the default paste format of URLs copied from Microsoft Edge and determine if additional formats will be available to users\" must be set to \"enabled\" with the option value set to \"The plain URL without any extra information, such as the page\u00b4s title. This is the recommended option when this policy is configured. For more information, see the description.\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"ConfigureFriendlyURLFormat\" is not set to \"REG_DWORD = 1\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If FriendlyURLs are enabled, Microsoft Edge will compute additional representations of the URL and place them on the clipboard.\n\nThis policy configures what format will be pasted when the user pastes in external applications, or inside Microsoft Edge without the \"Paste As\" context menu item.\n\nIf configured, this policy makes a choice on behalf of the user. The options in edge://settings/shareCopyPaste will be grayed out, and the options in the \"Paste As\" context menu will not be available.\n\nNot configured = The user will be able to choose their preferred paste format. By default, this is set to the friendly URL format. The \"Paste As\" menu will be available in Microsoft Edge.\n\n1 = No additional formats will be stored on the clipboard. There will be no \"Paste as\" context menu item in Microsoft Edge and the only format available to paste will be the plain text URL format. Effectively, the friendly URL feature will be disabled.\n\n3 = The user will get a friendly URL whenever they paste into surfaces that accept rich text. The plain URL will still be available for non-rich surfaces. There will be no \"Paste As\" menu in Microsoft Edge.\n\n4 = (Not currently used)\n\nThe richer formats may not be well-supported in some paste destinations and/or websites. In these scenarios, the plain URL option is recommended when configuring this policy.\n\nThe recommended policy is available in Microsoft Edge 105 or later.\n\nPolicy options mapping:\n\nPlainText (1) = The plain URL without any extra information, such as the page's title. This is the recommended option when this policy is configured. For more information, see the description.\n\nTitledHyperlink (3) = Titled Hyperlink: A hyperlink that points to the copied URL, but whose visible text is the title of the destination page. This is the Friendly URL format.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"5594","uuid":"99a6ff59-e8ac-4257-9d6c-e8b1958c7e44","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 9CC7E776882564F7B755FC90CF620BABF91424EA\r\n~~~~~\r\nConfiguration for 'FriendlyURLs must be disabled.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-279940","group_tree":[{"id":"V-279940","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-279940","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-279940r1156561_rule","rule_id":"SV-279940","rule_version":"EDGE-00-000069","rule_title":"Access to Microsoft 365 Copilot writing assistance must be disabled.","fix_text":"Set the policy value for \"Control access to Microsoft 365 Copilot writing assistance in Microsoft Edge for Business\" to \"disabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Control access to Microsoft 365 Copilot writing assistance in Microsoft Edge for Business\" must be set to \"disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for \"ComposeInlineEnabled\" is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"This policy controls whether users can use writing support features in Microsoft Edge for Business, such as Rewrite, which utilizes Microsoft 365 Copilot Chat.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"1037","uuid":"c3d1af77-1aed-4825-973a-256c9712f957","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 60D7AEA3DD6B1BA84D58183ED628CE6281A3C3E9\r\n~~~~~\r\nConfiguration for 'Access to Microsoft 365 Copilot writing assistance must be disabled.' matches the expected value on the Microsoft Edge browser."},{"group_id_src":"V-283439","group_tree":[{"id":"V-283439","title":"SRG-APP-000141","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-283439","severity":"medium","group_title":"SRG-APP-000141","rule_id_src":"SV-283439r1192850_rule","rule_id":"SV-283439","rule_version":"EDGE-00-000070","rule_title":"Spell checking provided by Microsoft Editor must be disabled.","fix_text":"Set the policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Spell checking provided by Microsoft Editor\" to \"Disabled\".","weight":"10.0","check_content":"The policy value for \"Computer Configuration/Administrative Templates/Microsoft Edge/Spell checking provided by Microsoft Editor\" must be set to \"Disabled\".\n\nUse the Windows Registry Editor to navigate to the following key:\n\nHKLM\\SOFTWARE\\Policies\\Microsoft\\Edge\n\nIf the value for MicrosoftEditorProofingEnabled is not set to \"REG_DWORD = 0\", this is a finding.","check_content_ref":{"href":"Microsoft_Edge_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The Microsoft Editor service provides enhanced spell and grammar checking for editable text fields on web pages.\n\nIf this policy is enabled or incorrectly configured, Microsoft Editor spell check can be used for eligible text fields.\n\nIf you disable this policy, spell check can only be provided by local engines that use platform or Hunspell services. The results from these engines might be less informative than the results Microsoft Editor can provide.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000381"],"reference_identifier":"9247","uuid":"491379ce-9e91-4002-a90d-72a4e6753073","stig_uuid":"95ebad44-34ec-409d-9843-560e8458e095","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-MicrosoftEdge_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: 4F638B9C361C4BC33F6218351C86F6D9B396F6CA\r\n~~~~~\r\nThe feature/role addressed by 'Spell checking provided by Microsoft Editor must be disabled.' is not present or not in use on this the Microsoft Edge browser."}]}],"target_data":{"target_type":"Computing","host_name":"WKS-WIN11-03","ip_address":"10.30.6.14","mac_address":"00:1C:42:01:00:26","fqdn":"wks-win11-03.utsec.mil","comments":"","role":"Workstation","is_web_database":false,"technology_area":"None","web_db_site":"","web_db_instance":"","classification":""},"title":"Evaluate-STIG_COMBINED"}