s from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001764"],"reference_identifier":"2283","uuid":"24b8fe4c-645f-4936-baa7-21e78ed7d300","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: B382421187EE887E29FEA25DAB7A52CA21288F74\r\n~~~~~\r\nConfiguration for 'OL 9 must mount /var/log/audit with the nosuid option.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271663","group_tree":[{"id":"V-271663","title":"SRG-OS-000368-GPOS-00154","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271663","severity":"medium","group_title":"SRG-OS-000368-GPOS-00154","rule_id_src":"SV-271663r1091701_rule","rule_id":"SV-271663","rule_version":"OL09-00-002067","rule_title":"OL 9 must mount /var/tmp with the nodev option.","fix_text":"Configure OL 9 to mount /var/tmp with the nodev option.\n\nModify \"/etc/fstab\" to use the \"nodev\" option on the \"/var/tmp\" directory.","weight":"10.0","check_content":"Verify that OL 9 is configured to mount /var/tmp with the nodev option.\n\nVerify \"/var/tmp\" is mounted with the \"nodev\" option:\n\n$ mount | grep /var/tmp\n/dev/mapper/ol-var-tmp on /var/tmp type xfs (rw,nodev,nosuid,noexec,seclabel)\n\nIf the \"/var/tmp\" file system is mounted without the \"nodev\" option, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"nodev\" mount option causes the system to not interpret character or block special devices. Executing character or block special devices from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.\n\nThe only legitimate location for device files is the \"/dev\" directory located on the root partition, with the exception of chroot jails if implemented.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001764"],"reference_identifier":"6576","uuid":"0cd5fb51-6683-49c0-b300-46ee9739fd3b","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 34FC4FB33E0B7C687D744498B92149190EC53AE1\r\n~~~~~\r\nConfiguration for 'OL 9 must mount /var/tmp with the nodev option.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271664","group_tree":[{"id":"V-271664","title":"SRG-OS-000368-GPOS-00154","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271664","severity":"medium","group_title":"SRG-OS-000368-GPOS-00154","rule_id_src":"SV-271664r1091704_rule","rule_id":"SV-271664","rule_version":"OL09-00-002068","rule_title":"OL 9 must mount /var/tmp with the noexec option.","fix_text":"Configure OL 9 to mount /var/tmp with the noexec option.\n\nModify \"/etc/fstab\" to use the \"noexec\" option on the \"/var/tmp\" directory.","weight":"10.0","check_content":"Verify that OL 9 is configured to mount /var/tmp with the noexec option.\n\nVerify \"/var/tmp\" is mounted with the \"noexec\" option:\n\n$ mount | grep /var/tmp\n/dev/mapper/ol-var-tmp on /var/tmp type xfs (rw,nodev,nosuid,noexec,seclabel)\n\nIf the \"/var/tmp\" file system is mounted without the \"noexec\" option, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"noexec\" mount option causes the system to not execute binary files. This option must be used for mounting any file system not containing approved binary files, as they may be incompatible. Executing files from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001764"],"reference_identifier":"5199","uuid":"c4ab5bb9-3440-4851-b90f-03d6a5615088","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: B0734DAA296D3BCDBA70131C5F8957109232D92D\r\n~~~~~\r\nConfiguration for 'OL 9 must mount /var/tmp with the noexec option.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271665","group_tree":[{"id":"V-271665","title":"SRG-OS-000368-GPOS-00154","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271665","severity":"medium","group_title":"SRG-OS-000368-GPOS-00154","rule_id_src":"SV-271665r1091707_rule","rule_id":"SV-271665","rule_version":"OL09-00-002069","rule_title":"OL 9 must mount /var/tmp with the nosuid option.","fix_text":"Configure OL 9 to mount /var/tmp with the nosuid option.\n\nModify \"/etc/fstab\" to use the \"nosuid\" option on the \"/var/tmp\" directory.","weight":"10.0","check_content":"Verify that OL 9 is configured to mount /var/tmp with the nosuid option.\n\nVerify \"/var/tmp\" is mounted with the \"nosuid\" option:\n\n$ mount | grep /var/tmp\n/dev/mapper/ol-var-tmp on /var/tmp type xfs (rw,nodev,nosuid,noexec,seclabel)\n\nIf the \"/var/tmp\" file system is mounted without the \"nosuid\" option, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"nosuid\" mount option causes the system to not execute \"setuid\" and \"setgid\" files with owner privileges. This option must be used for mounting any file system not containing approved \"setuid\" and \"setguid\" files. Executing files from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001764"],"reference_identifier":"3077","uuid":"3295fe8b-5bea-4b85-9b1b-836796b06f3e","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 8AEE255042F95FBD16A3B00BF8C8DED0699E8115\r\n~~~~~\r\nRequired configuration for 'OL 9 must mount /var/tmp with the nosuid option.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271666","group_tree":[{"id":"V-271666","title":"SRG-OS-000368-GPOS-00154","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271666","severity":"medium","group_title":"SRG-OS-000368-GPOS-00154","rule_id_src":"SV-271666r1091710_rule","rule_id":"SV-271666","rule_version":"OL09-00-002070","rule_title":"OL 9 must prevent device files from being interpreted on file systems that contain user home directories.","fix_text":"Configure OL 9 to prevent device files from being interpreted on file systems that contain user home directories.\n\nModify \"/etc/fstab\" to use the \"nodev\" option on the \"/home\" directory.","weight":"10.0","check_content":"Verify that OL 9 is configured to mount /home with the nodev option.\n\nVerify \"/home\" is mounted with the \"nodev\" option with the following command:\n\nNote: If a separate file system has not been created for the user home directories (user home directories are mounted under \"/\"), this is automatically a finding, as the \"nodev\" option cannot be used on the \"/\" system.\n\n$ mount | grep /home\ntmpfs on /home type tmpfs (rw,nodev,nosuid,noexec,seclabel)\n\nIf the \"/home\" file system is mounted without the \"nodev\" option, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"nodev\" mount option causes the system to not interpret character or block special devices. Executing character or block special devices from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.\n\nThe only legitimate location for device files is the \"/dev\" directory located on the root partition, with the exception of chroot jails if implemented.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001764"],"reference_identifier":"6089","uuid":"4f38cf16-ca2b-49c8-841f-1388b2eab702","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: CD9F6CC9C1E304F917984A2B28F13BA884A6335B\r\n~~~~~\r\nConfiguration for 'OL 9 must prevent device files from being interpreted on file systems that contain user home directories.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271667","group_tree":[{"id":"V-271667","title":"SRG-OS-000368-GPOS-00154","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271667","severity":"medium","group_title":"SRG-OS-000368-GPOS-00154","rule_id_src":"SV-271667r1091713_rule","rule_id":"SV-271667","rule_version":"OL09-00-002071","rule_title":"OL 9 must prevent files with the setuid and setgid bit set from being executed on file systems that contain user home directories.","fix_text":"Configure OL 9 to prevent files with the setuid and setgid bit set from being executed on file systems that contain user home directories.\n\nModify \"/etc/fstab\" to use the \"nosuid\" option on the \"/home\" directory.","weight":"10.0","check_content":"Verify that OL 9 is configured to mount /home with the nosuid option.\n\nVerify \"/home\" is mounted with the \"nosuid\" option with the following command:\n\nNote: If a separate file system has not been created for the user home directories (user home directories are mounted under \"/\"), this is automatically a finding, as the \"nosuid\" option cannot be used on the \"/\" system.\n\n$ mount | grep /home\ntmpfs on /home type tmpfs (rw,nodev,nosuid,noexec,seclabel)\n\nIf the \"/home\" file system is mounted without the \"nosuid\" option, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"nosuid\" mount option causes the system to not execute \"setuid\" and \"setgid\" files with owner privileges. This option must be used for mounting any file system not containing approved \"setuid\" and \"setguid\" files. Executing files from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001764"],"reference_identifier":"9420","uuid":"0d63f40d-d192-4e49-be18-d8e542f8de65","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 66F48AA7C3DD6885E3A2C6FBC892FDEC94468699\r\n~~~~~\r\nConfiguration for 'OL 9 must prevent files with the setuid and setgid bit set from being executed on file systems that contain user home directories.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271668","group_tree":[{"id":"V-271668","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271668","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271668r1091716_rule","rule_id":"SV-271668","rule_version":"OL09-00-002072","rule_title":"OL 9 must prevent code from being executed on file systems that contain user home directories.","fix_text":"Configure OL 9 to prevent code from being executed on file systems that contain user home directories.\n\nModify \"/etc/fstab\" to use the \"noexec\" option on the \"/home\" directory.","weight":"10.0","check_content":"Verify that OL 9 is configured to mount /home with the nodexec option.\n\nVerify \"/home\" is mounted with the \"noexec\" option with the following command:\n\nNote: If a separate file system has not been created for the user home directories (user home directories are mounted under \"/\"), this is automatically a finding, as the \"noexec\" option cannot be used on the \"/\" system.\n\n$ mount | grep /home\ntmpfs on /home type xfs (rw,nodev,nosuid,noexec,seclabel)\n\nIf the \"/home\" file system is mounted without the \"noexec\" option, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The noexec mount option causes the system to not execute binary files. This option must be used for mounting any file system not containing approved binary files, as they may be incompatible. Executing files from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"4934","uuid":"f815b42b-9c49-47e4-a05b-d915a4e8d46d","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 6484AF430B1FBCB8A5933F81AA094F9E1E10CE1A\r\n~~~~~\r\nConfiguration for 'OL 9 must prevent code from being executed on file systems that contain user home directories.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271669","group_tree":[{"id":"V-271669","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271669","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271669r1184200_rule","rule_id":"SV-271669","rule_version":"OL09-00-002080","rule_title":"OL 9 must prevent special devices on nonroot local partitions.","fix_text":"Configure the \"/etc/fstab\" to use the \"nodev\" option on all nonroot local partitions.","weight":"10.0","check_content":"Verify OL 9 prevents special devices on nonroot local partitions.\n\nVerify all nonroot local partitions are mounted with the \"nodev\" option with the following command:\n\n$ mount | grep '^/dev\\S* on /\\S' | grep --invert-match 'nodev'\n\nIf any output is produced, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The \"nodev\" mount option causes the system to not interpret character or block special devices. Executing character or block special devices from untrusted file systems increases the opportunity for nonprivileged users to attain unauthorized administrative access.\n\nThe only legitimate location for device files is the \"/dev\" directory located on the root partition, with the exception of chroot jails if implemented.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"6423","uuid":"17131f0a-e017-4d2f-9c52-063d9104cf45","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 282E95979DFBF9BDD3FAE6938EB25A4C1338DE0F\r\n~~~~~\r\nConfiguration for 'OL 9 must prevent special devices on nonroot local partitions.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271670","group_tree":[{"id":"V-271670","title":"SRG-OS-000114-GPOS-00059","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271670","severity":"medium","group_title":"SRG-OS-000114-GPOS-00059","rule_id_src":"SV-271670r1091722_rule","rule_id":"SV-271670","rule_version":"OL09-00-002100","rule_title":"OL 9 must disable the graphical user interface automount function unless required.","fix_text":"Configure the GNOME desktop to disable automated mounting of removable media.\n\nThe dconf settings can be edited in the /etc/dconf/db/* location.\n\nUpdate the [org/gnome/desktop/media-handling] section of the \"/etc/dconf/db/local.d/00-security-settings\" database file and add or update the following lines:\n\n[org/gnome/desktop/media-handling]\nautomount-open=false\n\nUpdate the dconf system databases:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 disables the graphical user interface automount function with the following command:\n\n$ gsettings get org.gnome.desktop.media-handling automount-open \nfalse\n\nIf \"automount-open\" is set to \"true\", and is not documented with the information system security officer (ISSO) as an operational requirement, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Automatically mounting file systems permits easy introduction of unknown devices, thereby facilitating malicious activity.\n\nSatisfies: SRG-OS-000114-GPOS-00059, SRG-OS-000378-GPOS-00163","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000778","CCI-001958"],"reference_identifier":"1046","uuid":"1983eb9c-4e6e-4af9-9da6-104f98f6e44b","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: 0DB14242AEBD04AE9A336FA3FED415814E457EA9\r\n~~~~~\r\nThe feature/role addressed by 'OL 9 must disable the graphical user interface automount function unless required.' is not present or not in use on this the Oracle Linux 9 host."},{"group_id_src":"V-271671","group_tree":[{"id":"V-271671","title":"SRG-OS-000368-GPOS-00154","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271671","severity":"medium","group_title":"SRG-OS-000368-GPOS-00154","rule_id_src":"SV-271671r1091725_rule","rule_id":"SV-271671","rule_version":"OL09-00-002101","rule_title":"OL 9 must disable the graphical user interface autorun function unless required.","fix_text":"Configure the GNOME desktop to disable the autorun function on removable media.\n\nThe dconf settings can be edited in the /etc/dconf/db/* location.\n\nUpdate the [org/gnome/desktop/media-handling] section of the \"/etc/dconf/db/local.d/00-security-settings\" database file and add or update the following lines:\n\n[org/gnome/desktop/media-handling]\nautorun-never=true\n\nUpdate the dconf system databases:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 disables the graphical user interface autorun function with the following command:\n\n$ gsettings get org.gnome.desktop.media-handling autorun-never \ntrue\n\nIf \"autorun-never\" is set to \"false\", and is not documented with the information system security officer (ISSO) as an operational requirement, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Allowing autorun commands to execute may introduce malicious code to a system. Configuring this setting prevents autorun commands from executing.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001764"],"reference_identifier":"2566","uuid":"85cbb9e8-b86d-494c-b437-73a31698807e","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: 6246261C3B5B346D39E5C6E22B50DDC75FC7DDF5\r\n~~~~~\r\nThe feature/role addressed by 'OL 9 must disable the graphical user interface autorun function unless required.' is not present or not in use on this the Oracle Linux 9 host."},{"group_id_src":"V-271672","group_tree":[{"id":"V-271672","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271672","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271672r1092631_rule","rule_id":"SV-271672","rule_version":"OL09-00-002102","rule_title":"OL 9 must disable the user list at logon for graphical user interfaces.","fix_text":"Configure OL 9 to disable the user list at logon for graphical user interfaces.\n\nCreate a database to contain the systemwide screensaver settings (if it does not already exist) with the following command:\n\nNote: The example below is using the database \"local\" for the system, so if the system is using another database in \"/etc/dconf/profile/user\", the file should be created under the appropriate subdirectory.\n\n$ sudo touch /etc/dconf/db/local.d/02-login-screen\n\n[org/gnome/login-screen]\ndisable-user-list=true\n\nUpdate the system databases:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 disables the user logon list for graphical user interfaces with the following command:\n\n$ gsettings get org.gnome.login-screen disable-user-list\ntrue\n\nIf the setting is \"false\", this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Leaving the user list enabled is a security risk since it allows anyone with physical access to the system to enumerate known user accounts without authenticated access to the system.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"3516","uuid":"9bcd2235-ba83-4e57-91b7-657897a69670","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 2A91F6FD2A4496B9748669D3AF26824FA3D676B4\r\n~~~~~\r\nConfiguration for 'OL 9 must disable the user list at logon for graphical user interfaces.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271673","group_tree":[{"id":"V-271673","title":"SRG-OS-000029-GPOS-00010","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271673","severity":"medium","group_title":"SRG-OS-000029-GPOS-00010","rule_id_src":"SV-271673r1091731_rule","rule_id":"SV-271673","rule_version":"OL09-00-002103","rule_title":"OL 9 must initiate a session lock for graphical user interfaces when the screensaver is activated.","fix_text":"Configure OL 9 to initiate a session lock for graphical user interfaces when a screensaver is activated.\n\nCreate a database to contain the system-wide screensaver settings (if it does not already exist) with the following command: \n\nNote: The example below is using the database \"local\" for the system, so if the system is using another database in \"/etc/dconf/profile/user\", the file should be created under the appropriate subdirectory.\n\n$ sudo touch /etc/dconf/db/local.d/00-screensaver\n\n[org/gnome/desktop/screensaver]\nlock-delay=uint32 5\n\nThe \"uint32\" must be included along with the integer key values as shown.\n\nUpdate the system databases:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 initiates a session lock for graphical user interfaces when the screensaver is activated with the following command:\n\n$ gsettings get org.gnome.desktop.screensaver lock-delay\nuint32 5\n\nIf the \"uint32\" setting is not set to \"5\" or less, or is missing, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A session lock is a temporary action taken when a user stops work and moves away from the immediate physical vicinity of the information system but does not want to logout because of the temporary nature of the absence.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000057"],"reference_identifier":"8650","uuid":"43b23402-ccd0-4201-95d4-2305fd7350fe","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 46BC0024193D41240090157BDC63FD4A84277CD3\r\n~~~~~\r\nConfiguration for 'OL 9 must initiate a session lock for graphical user interfaces when the screensaver is activated.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271674","group_tree":[{"id":"V-271674","title":"SRG-OS-000029-GPOS-00010","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271674","severity":"medium","group_title":"SRG-OS-000029-GPOS-00010","rule_id_src":"SV-271674r1155332_rule","rule_id":"SV-271674","rule_version":"OL09-00-002104","rule_title":"OL 9 must automatically lock graphical user sessions after 15 minutes of inactivity.","fix_text":"Configure OL 9 to initiate a screensaver after a 10-minute period of inactivity for graphical user interfaces.\n\nCreate a database to contain the systemwide screensaver settings (if it does not already exist) with the following command:\n\n$ sudo touch /etc/dconf/db/local.d/00-screensaver\n\nEdit /etc/dconf/db/local.d/00-screensaver and add or update the following lines:\n\n[org/gnome/desktop/session]\n# Set the lock time out to 600 seconds before the session is considered idle\nidle-delay=uint32 600\n\nUpdate the system databases:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify OL 9 initiates a session lock after a 10-minute period of inactivity for graphical user interfaces with the following command:\n\n$ gsettings get org.gnome.desktop.session idle-delay\nuint32 600\n\nIf \"idle-delay\" is set to \"0\" or a value greater than \"600\", this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A session time-out lock is a temporary action taken when a user stops work and moves away from the immediate physical vicinity of the information system but does not logout because of the temporary nature of the absence. Rather than relying on the user to manually lock their operating system session prior to vacating the vicinity, the GNOME desktop can be configured to identify when a user's session has idled and take action to initiate a session lock.\n\nSatisfies: SRG-OS-000029-GPOS-00010, SRG-OS-000031-GPOS-00012","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000057","CCI-000060"],"reference_identifier":"5561","uuid":"8bd2dba0-f9a5-410b-88a3-cbd69c3bcbb6","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: EA6BEC573E32FCA004E0E3AD2115A457107CD26C\r\n~~~~~\r\nRequired configuration for 'OL 9 must automatically lock graphical user sessions after 15 minutes of inactivity.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271676","group_tree":[{"id":"V-271676","title":"SRG-OS-000031-GPOS-00012","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271676","severity":"medium","group_title":"SRG-OS-000031-GPOS-00012","rule_id_src":"SV-271676r1091740_rule","rule_id":"SV-271676","rule_version":"OL09-00-002106","rule_title":"OL 9 must conceal, via the session lock, information previously visible on the display with a publicly viewable image.","fix_text":"Configure OL 9 to conceal, via the session lock, information previously visible on the display with a publicly viewable image.\n\nThe dconf settings can be edited in the /etc/dconf/db/* location.\n\nAdd or update the [org/gnome/desktop/screensaver] section of the \"/etc/dconf/db/local.d/00-security-settings\" database file and add or update the following lines:\n\n[org/gnome/desktop/screensaver]\npicture-uri=''\n\nAdd the following line to \"/etc/dconf/db/local.d/locks/00-security-settings-lock\" to prevent user modification:\n\n/org/gnome/desktop/screensaver/picture-uri\n\nUpdate the dconf system databases:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 configures the screensaver to be blank with the following command:\n\n$ gsettings get org.gnome.desktop.screensaver picture-uri \n\nIf properly configured, the output should be \"''\".\n\nTo ensure that users cannot set the screensaver background, run the following: \n\n$ grep picture-uri /etc/dconf/db/local.d/locks/* \n\nIf properly configured, the output should be \"/org/gnome/desktop/screensaver/picture-uri\".\n\nIf it is not set or configured properly, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Setting the screensaver mode to blank-only conceals the contents of the display from passersby.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000060"],"reference_identifier":"1978","uuid":"7b60c6e4-0bd9-4110-ab41-7a262306c590","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 0A058BE96165EC380233DD771D57A1E7D323FE9A\r\n~~~~~\r\nRequired configuration for 'OL 9 must conceal, via the session lock, information previously visible on the display with a publicly viewable image.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271677","group_tree":[{"id":"V-271677","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271677","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271677r1091743_rule","rule_id":"SV-271677","rule_version":"OL09-00-002107","rule_title":"OL 9 must disable the ability of a user to accidentally press Ctrl-Alt-Del and cause a system to shut down or reboot.","fix_text":"Configure OL 9 to ignore the Ctrl-Alt-Del sequence in the GNOME desktop.\n\nAdd or update the [org/gnome/settings-daemon/plugins/media-keys] section of the /etc/dconf/db/local.d/00-security-settings database file and add or update the following lines:\n\n[org/gnome/settings-daemon/plugins/media-keys]\nlogout=['']\n\nRun the following command to update the database:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 is configured to ignore the Ctrl-Alt-Del sequence in the GNOME desktop with the following command:\n\n$ gsettings get org.gnome.settings-daemon.plugins.media-keys logout \n\"['']\"\n\nIf the GNOME desktop is configured to shut down when Ctrl-Alt-Del is pressed, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A locally logged-in user who presses Ctrl-Alt-Del, when at the console, can reboot the system. If accidentally pressed, as could happen in the case of mixed OS environment, this can create the risk of short-term loss of availability of systems due to unintentional reboot.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"6996","uuid":"e398f944-8715-4916-a02d-ed69a6300fd0","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 2A8AFD2AF7E3EB08B7370B0FF07BD3339913D9A9\r\n~~~~~\r\nConfiguration for 'OL 9 must disable the ability of a user to accidentally press Ctrl-Alt-Del and cause a system to shut down or reboot.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271678","group_tree":[{"id":"V-271678","title":"SRG-OS-000114-GPOS-00059","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271678","severity":"medium","group_title":"SRG-OS-000114-GPOS-00059","rule_id_src":"SV-271678r1091746_rule","rule_id":"SV-271678","rule_version":"OL09-00-002120","rule_title":"OL 9 must prevent a user from overriding the disabling of the graphical user interface automount function.","fix_text":"Configure the GNOME desktop to not allow a user to change the setting that disables automated mounting of removable media.\n\nAdd the following line to \"/etc/dconf/db/local.d/locks/00-security-settings-lock\" to prevent user modification:\n\n/org/gnome/desktop/media-handling/automount-open\n\nUpdate the dconf system databases:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 disables ability of the user to override the graphical user interface automount setting.\n\nDetermine which profile the system database is using with the following command:\n\n$ grep system-db /etc/dconf/profile/user\nsystem-db:local\n\nCheck that the automount setting is locked from nonprivileged user modification with the following command:\n\nNote: The example below is using the database \"local\" for the system, so the path is \"/etc/dconf/db/local.d\". This path must be modified if a database other than \"local\" is being used.\n\n$ grep 'automount-open' /etc/dconf/db/local.d/locks/* \n/org/gnome/desktop/media-handling/automount-open\n\nIf the command does not return at least the example result, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A nonprivileged account is any operating system account with authorizations of a nonprivileged user.\n\nSatisfies: SRG-OS-000114-GPOS-00059, SRG-OS-000378-GPOS-00163","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000778","CCI-001958"],"reference_identifier":"4738","uuid":"4c927e33-2ec6-45dd-a19b-ce0d1e4e4648","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: BA51180DB1F58D82A84A3D8111D025174BBE2E32\r\n~~~~~\r\nConfiguration for 'OL 9 must prevent a user from overriding the disabling of the graphical user interface automount function.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271679","group_tree":[{"id":"V-271679","title":"SRG-OS-000114-GPOS-00059","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271679","severity":"medium","group_title":"SRG-OS-000114-GPOS-00059","rule_id_src":"SV-271679r1091749_rule","rule_id":"SV-271679","rule_version":"OL09-00-002121","rule_title":"OL 9 must prevent a user from overriding the disabling of the graphical user interface autorun function.","fix_text":"Configure the GNOME desktop to not allow a user to change the setting that disables autorun on removable media.\n\nAdd the following line to \"/etc/dconf/db/local.d/locks/00-security-settings-lock\" to prevent user modification:\n\n/org/gnome/desktop/media-handling/autorun-never\n\nUpdate the dconf system databases:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 disables ability of the user to override the graphical user interface autorun setting.\n\nDetermine which profile the system database is using with the following command:\n\n$ grep system-db /etc/dconf/profile/user\nsystem-db:local\n\nCheck that the automount setting is locked from nonprivileged user modification with the following command:\n\nNote: The example below is using the database \"local\" for the system, so the path is \"/etc/dconf/db/local.d\". This path must be modified if a database other than \"local\" is being used.\n\n$ grep 'autorun-never' /etc/dconf/db/local.d/locks/* \n/org/gnome/desktop/media-handling/autorun-never\n\nIf the command does not return at least the example result, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Techniques used to address this include protocols using nonces (e.g., numbers generated for a specific one-time use) or challenges (e.g., TLS, WS_Security). Additional techniques include time-synchronous or challenge-response one-time authenticators.\n\nSatisfies: SRG-OS-000114-GPOS-00059, SRG-OS-000378-GPOS-00163","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000778","CCI-001958"],"reference_identifier":"7699","uuid":"3d6be404-5739-4aee-9c48-f26461e67de2","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-271680","group_tree":[{"id":"V-271680","title":"SRG-OS-000023-GPOS-00006","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271680","severity":"medium","group_title":"SRG-OS-000023-GPOS-00006","rule_id_src":"SV-271680r1091752_rule","rule_id":"SV-271680","rule_version":"OL09-00-002122","rule_title":"OL 9 must prevent a user from overriding the banner-message-enable setting for the graphical user interface.","fix_text":"Configure OL 9 to prevent a user from overriding the banner setting for graphical user interfaces. \n\nCreate a database to contain the system-wide graphical user logon settings (if it does not already exist) with the following command:\n\n$ sudo touch /etc/dconf/db/local.d/locks/session\n\nAdd the following setting to prevent nonprivileged users from modifying it:\n\n/org/gnome/login-screen/banner-message-enable\n\nRun the following command to update the database:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 prevents a user from overriding settings for graphical user interfaces. \n\nDetermine which profile the system database is using with the following command:\n\n$ grep system-db /etc/dconf/profile/user\nsystem-db:local\n\nCheck that graphical settings are locked from nonprivileged user modification with the following command:\n\nNote: The example below is using the database \"local\" for the system, so the path is \"/etc/dconf/db/local.d\". This path must be modified if a database other than \"local\" is being used.\n\n$ grep banner-message-enable /etc/dconf/db/local.d/locks/* \n/org/gnome/login-screen/banner-message-enable\n\nIf the output is not \"/org/gnome/login-screen/banner-message-enable\", the line is commented out, or the line is missing, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Display of a standardized and approved use notification before granting access to the operating system ensures privacy and security notification verbiage used is consistent with applicable federal laws, Executive Orders, directives, policies, regulations, standards, and guidance.\n\nFor U.S. government systems, system use notifications are required only for access via login interfaces with human users and are not required when such human interfaces do not exist.\n\nSatisfies: SRG-OS-000023-GPOS-00006, SRG-OS-000228-GPOS-00088","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000048","CCI-001384","CCI-001385","CCI-001386","CCI-001387","CCI-001388"],"reference_identifier":"7799","uuid":"fcd81d80-35c1-4e11-be30-3beecbd919c7","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 3A9943E339B24DB6B2B30928F7E4C27C094514D7\r\n~~~~~\r\nConfiguration for 'OL 9 must prevent a user from overriding the banner-message-enable setting for the graphical user interface.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271681","group_tree":[{"id":"V-271681","title":"SRG-OS-000028-GPOS-00009","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271681","severity":"medium","group_title":"SRG-OS-000028-GPOS-00009","rule_id_src":"SV-271681r1091755_rule","rule_id":"SV-271681","rule_version":"OL09-00-002123","rule_title":"OL 9 must prevent a user from overriding the screensaver lock-enabled setting for the graphical user interface.","fix_text":"Configure OL 9 to prevent a user from overriding settings for graphical user interfaces.\n\nCreate a database to contain the system-wide screensaver settings (if it does not already exist) with the following command: \n\nNote: The example below is using the database \"local\" for the system, so if the system is using another database in \"/etc/dconf/profile/user\", the file should be created under the appropriate subdirectory.\n\n$ sudo touch /etc/dconf/db/local.d/locks/session\n\nAdd the following setting to prevent nonprivileged users from modifying it:\n\n/org/gnome/desktop/screensaver/lock-enabled\n\nUpdate the system databases:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 prevents a user from overriding settings for graphical user interfaces. \n\nDetermine which profile the system database is using with the following command:\n\n$ grep system-db /etc/dconf/profile/user\nsystem-db:local\n\nCheck that graphical settings are locked from nonprivileged user modification with the following command:\n\nNote: The example below is using the database \"local\" for the system, so the path is \"/etc/dconf/db/local.d\". This path must be modified if a database other than \"local\" is being used.\n\n$ grep -i lock-enabled /etc/dconf/db/local.d/locks/*\n/org/gnome/desktop/screensaver/lock-enabled\n\nIf the command does not return at least the example result, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A session time-out lock is a temporary action taken when a user stops work and moves away from the immediate physical vicinity of the information system but does not log out because of the temporary nature of the absence. Rather than relying on the user to manually lock their operating system session prior to vacating the vicinity, operating systems need to be able to identify when a user's session has idled and take action to initiate the session lock.\n\nThe session lock is implemented at the point where session activity can be determined and/or controlled.\n\nImplementing session settings will have little value if a user is able to manipulate these settings from the defaults prescribed in the other requirements of this implementation guide.\n\nSatisfies: SRG-OS-000028-GPOS-00009, SRG-OS-000030-GPOS-00011","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000056","CCI-000057"],"reference_identifier":"9239","uuid":"2fa4beb8-26ad-41c4-a1ed-d695b14262e6","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 259BE6797FDEA666F29CAFAD97246EB92C748040\r\n~~~~~\r\nConfiguration for 'OL 9 must prevent a user from overriding the screensaver lock-enabled setting for the graphical user interface.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271682","group_tree":[{"id":"V-271682","title":"SRG-OS-000029-GPOS-00010","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271682","severity":"medium","group_title":"SRG-OS-000029-GPOS-00010","rule_id_src":"SV-271682r1091758_rule","rule_id":"SV-271682","rule_version":"OL09-00-002124","rule_title":"OL 9 must prevent a user from overriding the session idle-delay setting for the graphical user interface.","fix_text":"Configure OL 9 to prevent a user from overriding settings for graphical user interfaces.\n\nCreate a database to contain the system-wide screensaver settings (if it does not already exist) with the following command: \n\nNote: The example below is using the database \"local\" for the system, so if the system is using another database in \"/etc/dconf/profile/user\", the file should be created under the appropriate subdirectory.\n\n$ sudo touch /etc/dconf/db/local.d/locks/session\n\nAdd the following setting to prevent nonprivileged users from modifying it:\n\n/org/gnome/desktop/session/idle-delay\n\nUpdate the system databases:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 prevents a user from overriding settings for graphical user interfaces. \n\nDetermine which profile the system database is using with the following command:\n\n$ grep system-db /etc/dconf/profile/user\nsystem-db:local\n\nCheck that graphical settings are locked from nonprivileged user modification with the following command:\n\nNote: The example below is using the database \"local\" for the system, so the path is \"/etc/dconf/db/local.d\". This path must be modified if a database other than \"local\" is being used.\n\n$ grep -i idle /etc/dconf/db/local.d/locks/*\n/org/gnome/desktop/session/idle-delay\n\nIf the command does not return at least the example result, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A session time-out lock is a temporary action taken when a user stops work and moves away from the immediate physical vicinity of the information system but does not logout because of the temporary nature of the absence. Rather than relying on the user to manually lock their operating system session prior to vacating the vicinity, the GNOME desktop can be configured to identify when a user's session has idled and take action to initiate the session lock. As such, users should not be allowed to change session settings.\n\nSatisfies: SRG-OS-000029-GPOS-00010, SRG-OS-000031-GPOS-00012","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000057","CCI-000060"],"reference_identifier":"4013","uuid":"9fff15e1-7ee2-4f43-be74-6d4bc8450f20","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 37EA153EC3964AA82CC3B99D46290A848F9B4119\r\n~~~~~\r\nRequired configuration for 'OL 9 must prevent a user from overriding the session idle-delay setting for the graphical user interface.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271683","group_tree":[{"id":"V-271683","title":"SRG-OS-000029-GPOS-00010","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271683","severity":"medium","group_title":"SRG-OS-000029-GPOS-00010","rule_id_src":"SV-271683r1091761_rule","rule_id":"SV-271683","rule_version":"OL09-00-002125","rule_title":"OL 9 must prevent a user from overriding the session lock-delay setting for the graphical user interface.","fix_text":"Configure OL 9 to prevent a user from overriding settings for graphical user interfaces.\n\nCreate a database to contain the system-wide screensaver settings (if it does not already exist) with the following command: \n\nNote: The example below is using the database \"local\" for the system, so if the system is using another database in \"/etc/dconf/profile/user\", the file should be created under the appropriate subdirectory.\n\n$ sudo touch /etc/dconf/db/local.d/locks/session\n\nAdd the following setting to prevent nonprivileged users from modifying it:\n\n/org/gnome/desktop/screensaver/lock-delay\n\nUpdate the system databases:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 prevents a user from overriding settings for graphical user interfaces. \n\nDetermine which profile the system database is using with the following command:\n\n$ grep system-db /etc/dconf/profile/user\nsystem-db:local\n\nCheck that graphical settings are locked from nonprivileged user modification with the following command:\n\nNote: The example below is using the database \"local\" for the system, so the path is \"/etc/dconf/db/local.d\". This path must be modified if a database other than \"local\" is being used.\n\n$ grep -i lock-delay /etc/dconf/db/local.d/locks/*\n/org/gnome/desktop/screensaver/lock-delay\n\nIf the command does not return at least the example result, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A session time-out lock is a temporary action taken when a user stops work and moves away from the immediate physical vicinity of the information system but does not logout because of the temporary nature of the absence. Rather than relying on the user to manually lock their operating system session prior to vacating the vicinity, the GNOME desktop can be configured to identify when a user's session has idled and take action to initiate the session lock. As such, users should not be allowed to change session settings.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000057"],"reference_identifier":"9384","uuid":"6c569e99-0f19-42ac-9161-81d5d854b4ec","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: B2588D5F539BE3FE2A55746E4A7C3FFD67C06EAE\r\n~~~~~\r\nConfiguration for 'OL 9 must prevent a user from overriding the session lock-delay setting for the graphical user interface.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271684","group_tree":[{"id":"V-271684","title":"SRG-OS-000028-GPOS-00009","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271684","severity":"medium","group_title":"SRG-OS-000028-GPOS-00009","rule_id_src":"SV-271684r1091764_rule","rule_id":"SV-271684","rule_version":"OL09-00-002126","rule_title":"OL 9 must prevent a user from overriding the disabling of the graphical user smart card removal action.","fix_text":"Configure OL 9 must prevent a user from overriding the disabling of the graphical user smart card removal action.\n\nAdd the following line to \"/etc/dconf/db/local.d/locks/00-security-settings-lock\":\n\n/org/gnome/settings-daemon/peripherals/smartcard/removal-action\n\nUpdate the dconf system databases:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 disables ability of the user to override the smart card removal action setting.\n\nDetermine which profile the system database is using with the following command:\n\n$ grep system-db /etc/dconf/profile/user\nsystem-db:local\n\nCheck that the removal action setting is locked from nonprivileged user modification with the following command:\n\nNote: The example below is using the database \"local\" for the system, so the path is \"/etc/dconf/db/local.d\". This path must be modified if a database other than \"local\" is being used.\n\n$ grep 'removal-action' /etc/dconf/db/local.d/locks/* \n/org/gnome/settings-daemon/peripherals/smartcard/removal-action\n\nIf the command does not return at least the example result, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A session lock is a temporary action taken when a user stops work and moves away from the immediate physical vicinity of the information system but does not want to log out because of the temporary nature of the absence.\n\nThe session lock is implemented at the point where session activity can be determined. Rather than be forced to wait for a period of time to expire before the user session can be locked, OL 9 must provide users with the ability to manually invoke a session lock so users can secure their session if it is necessary to temporarily vacate the immediate physical vicinity.\n\nSatisfies: SRG-OS-000028-GPOS-00009, SRG-OS-000030-GPOS-00011","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000056","CCI-000057"],"reference_identifier":"2461","uuid":"42d72864-80ce-4688-a1ad-8bb236d22efe","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: 43E2915827113511C46D44C9CE1336D2039AB2CD\r\n~~~~~\r\nThe feature/role addressed by 'OL 9 must prevent a user from overriding the disabling of the graphical user smart card removal action.' is not present or not in use on this the Oracle Linux 9 host."},{"group_id_src":"V-271685","group_tree":[{"id":"V-271685","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271685","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271685r1091767_rule","rule_id":"SV-271685","rule_version":"OL09-00-002127","rule_title":"OL 9 must disable the ability of a user to restart the system from the login screen.","fix_text":"Configure OL 9 to disable a user's ability to restart the system.\n\nAdd or update the [org/gnome/settings-daemon/] section of the /etc/dconf/db/local.d/00-security-settings\" database file and add or update the following lines:\n\n[org/gnome/settings-daemon/peripherals/smartcard]\ndisable-restart-buttons='true'\n\nThen update the dconf system databases:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 disables a user's ability to restart the system with the following command:\n\n$ grep -R disable-restart-buttons /etc/dconf/db/*\n/etc/dconf/db/distro.d/20-authselect:disable-restart-buttons='true'\n\nIf the \"disable-restart-button\" setting is not set to \"true\", is missing or commented out from the dconf database files, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A user who is at the console can reboot the system at the login screen. If restart or shutdown buttons are pressed at the login screen, this can create the risk of short-term loss of availability of systems due to reboot.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"6084","uuid":"10ca9748-3437-4a90-a136-c8c623a39b0d","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 2337A9C4D107142AF62221842A5912C3F5DEE5A5\r\n~~~~~\r\nConfiguration for 'OL 9 must disable the ability of a user to restart the system from the login screen.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271686","group_tree":[{"id":"V-271686","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271686","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271686r1091770_rule","rule_id":"SV-271686","rule_version":"OL09-00-002128","rule_title":"OL 9 must prevent a user from overriding the disable-restart-buttons setting for the graphical user interface.","fix_text":"Configure OL 9 to prevent a user from overriding the disable-restart-buttons setting for graphical user interfaces. \n\nCreate a database to contain the system-wide graphical user logon settings (if it does not already exist) with the following command:\n\n$ sudo touch /etc/dconf/db/local.d/locks/session\n\nAdd the following line to prevent nonprivileged users from modifying it:\n\n/org/gnome/login-screen/disable-restart-buttons\n\nRun the following command to update the database:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 prevents a user from overriding the disable-restart-buttons setting for graphical user interfaces. \n\nDetermine which profile the system database is using with the following command:\n\n$ grep system-db /etc/dconf/profile/user\nsystem-db:local\n\nCheck that graphical settings are locked from nonprivileged user modification with the following command:\n\nNote: The example below is using the database \"local\" for the system, so the path is \"/etc/dconf/db/local.d\". This path must be modified if a database other than \"local\" is being used.\n\n$ grep disable-restart-buttons /etc/dconf/db/local.d/locks/* \n/org/gnome/login-screen/disable-restart-buttons\n\nIf the command does not return at least the example result, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A user who is at the console can reboot the system at the login screen. If restart or shutdown buttons are pressed at the login screen, this can create the risk of short-term loss of availability of systems due to reboot.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"9758","uuid":"35dedbc0-a784-4974-9205-dc07d8abdf8d","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 8FC4B1BAF9D108AC67DFBF7EFE4B4B234289F3F3\r\n~~~~~\r\nConfiguration for 'OL 9 must prevent a user from overriding the disable-restart-buttons setting for the graphical user interface.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271687","group_tree":[{"id":"V-271687","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271687","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271687r1091773_rule","rule_id":"SV-271687","rule_version":"OL09-00-002129","rule_title":"OL 9 must prevent a user from overriding the Ctrl-Alt-Del sequence settings for the graphical user interface.","fix_text":"Configure OL 9 to disallow the user changing the Ctrl-Alt-Del sequence in the GNOME desktop.\n\nCreate a database to container system-wide graphical user logon settings (if it does not already exist) with the following command:\n\n$ sudo touch /etc/dconf/db/local.d/locks/session\n\nAdd the following line to the session locks file to prevent nonprivileged users from modifying the Ctrl-Alt-Del setting:\n\n/org/gnome/settings-daemon/plugins/media-keys/logout\n\nRun the following command to update the database:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 users cannot enable the Ctrl-Alt-Del sequence in the GNOME desktop with the following command:\n\n$ grep logout /etc/dconf/db/local.d/locks/* \n/org/gnome/settings-daemon/plugins/media-keys/logout\n\nIf the output is not \"/org/gnome/settings-daemon/plugins/media-keys/logout\", the line is commented out, or the line is missing, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A locally logged-in user who presses Ctrl-Alt-Del, when at the console, can reboot the system. If accidentally pressed, as could happen in the case of mixed OS environment, this can create the risk of short-term loss of availability of systems due to unintentional reboot.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"2302","uuid":"c12a1db4-5bdd-4a40-a62f-9a755890c7b1","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 25700FE237B31144FB9EEB958F4C2D0ED6E6B323\r\n~~~~~\r\nRequired configuration for 'OL 9 must prevent a user from overriding the Ctrl-Alt-Del sequence settings for the graphical user interface.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271688","group_tree":[{"id":"V-271688","title":"SRG-OS-000023-GPOS-00006","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271688","severity":"medium","group_title":"SRG-OS-000023-GPOS-00006","rule_id_src":"SV-271688r1091776_rule","rule_id":"SV-271688","rule_version":"OL09-00-002150","rule_title":"OL 9 must be configured to enable the display of the Standard Mandatory DOD Notice and Consent Banner before granting local or remote access to the system via a graphical user logon.","fix_text":"Configure OL 9 to display the Standard Mandatory DOD Notice and Consent Banner before granting access to the system via a graphical user logon.\n\nCreate a database to contain the system-wide graphical user logon settings (if it does not already exist) with the following command:\n\n$ sudo touch /etc/dconf/db/local.d/01-banner-message\n\nAdd the following lines to the [org/gnome/login-screen] section of the \"/etc/dconf/db/local.d/01-banner-message\":\n\n[org/gnome/login-screen]\n\nbanner-message-enable=true\n\nRun the following command to update the database:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 displays a banner before granting access to the operating system via a graphical user logon.\n\nDetermine if the operating system displays a banner at the logon screen with the following command:\n\n$ gsettings get org.gnome.login-screen banner-message-enable\ntrue\n\nIf the result is \"false\", this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Display of a standardized and approved use notification before granting access to the operating system ensures privacy and security notification verbiage used is consistent with applicable federal laws, Executive Orders, directives, policies, regulations, standards, and guidance.\n\nFor U.S. government systems, system use notifications are required only for access via login interfaces with human users and are not required when such human interfaces do not exist.\n\nSatisfies: SRG-OS-000023-GPOS-00006, SRG-OS-000228-GPOS-00088","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000048","CCI-001384","CCI-001385","CCI-001386","CCI-001387","CCI-001388"],"reference_identifier":"1861","uuid":"7c7d09c7-16fb-4a20-88f2-221698f40af8","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-271689","group_tree":[{"id":"V-271689","title":"SRG-OS-000023-GPOS-00006","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271689","severity":"medium","group_title":"SRG-OS-000023-GPOS-00006","rule_id_src":"SV-271689r1091779_rule","rule_id":"SV-271689","rule_version":"OL09-00-002151","rule_title":"OL 9 must display the Standard Mandatory DOD Notice and Consent Banner before granting local or remote access to the system via a graphical user logon.","fix_text":"Configure the operating system to display the Standard Mandatory DOD Notice and Consent Banner before granting access to the system.\n\nAdd the following lines to the [org/gnome/login-screen] section of the \"/etc/dconf/db/local.d/01-banner-message\":\n\nbanner-message-text='You are accessing a U.S. Government (USG) Information System (IS) that is provided for USG-authorized use only.\\nBy using this IS (which includes any device attached to this IS), you consent to the following conditions:\\n-The USG routinely intercepts and monitors communications on this IS for purposes including, but not limited to, penetration testing, COMSEC monitoring, network operations and defense, personnel misconduct (PM), law enforcement (LE), and counterintelligence (CI) investigations.\\n-At any time, the USG may inspect and seize data stored on this IS.\\n-Communications using, or data stored on, this IS are not private, are subject to routine monitoring, interception, and search, and may be disclosed or used for any USG-authorized purpose.\\n-This IS includes security measures (e.g., authentication and access controls) to protect USG interests--not for your personal benefit or privacy.\\n-Notwithstanding the above, using this IS does not constitute consent to PM, LE or CI investigative searching or monitoring of the content of privileged communications, or work product, related to personal representation or services by attorneys, psychotherapists, or clergy, and their assistants. Such communications and work product are private and confidential. See User Agreement for details.'\n\nNote: The \"\\n \" characters are for formatting only. They will not be displayed on the graphical interface.\n\nRun the following command to update the database:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 displays the Standard Mandatory DOD Notice and Consent Banner before granting access to the operating system via a graphical user logon.\n\nCheck that the operating system displays the exact Standard Mandatory DOD Notice and Consent Banner text with the command:\n\n$ gsettings get org.gnome.login-screen banner-message-text\n\nbanner-message-text=\n'You are accessing a U.S. Government (USG) Information System (IS) that is provided for USG-authorized use only.\\nBy using this IS (which includes any device attached to this IS), you consent to the following conditions:\\n-The USG routinely intercepts and monitors communications on this IS for purposes including, but not limited to, penetration testing, COMSEC monitoring, network operations and defense, personnel misconduct (PM), law enforcement (LE), and counterintelligence (CI) investigations.\\n-At any time, the USG may inspect and seize data stored on this IS.\\n-Communications using, or data stored on, this IS are not private, are subject to routine monitoring, interception, and search, and may be disclosed or used for any USG-authorized purpose.\\n-This IS includes security measures (e.g., authentication and access controls) to protect USG interests--not for your personal benefit or privacy.\\n-Notwithstanding the above, using this IS does not constitute consent to PM, LE or CI investigative searching or monitoring of the content of privileged communications, or work product, related to personal representation or services by attorneys, psychotherapists, or clergy, and their assistants. Such communications and work product are private and confidential. See User Agreement for details.'\n\nNote: The \"\\n \" characters are for formatting only. They will not be displayed on the graphical interface.\n\nIf the banner does not match the Standard Mandatory DOD Notice and Consent Banner exactly, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Display of a standardized and approved use notification before granting access to the operating system ensures privacy and security notification verbiage used is consistent with applicable federal laws, Executive Orders, directives, policies, regulations, standards, and guidance.\n\nSystem use notifications are required only for access via logon interfaces with human users and are not required when such human interfaces do not exist.\n\nThe banner must be formatted in accordance with applicable DOD policy. Use the following verbiage for operating systems that can accommodate banners of 1300 characters:\n\n\"You are accessing a U.S. Government (USG) Information System (IS) that is provided for USG-authorized use only.\n\nBy using this IS (which includes any device attached to this IS), you consent to the following conditions:\n\n-The USG routinely intercepts and monitors communications on this IS for purposes including, but not limited to, penetration testing, COMSEC monitoring, network operations and defense, personnel misconduct (PM), law enforcement (LE), and counterintelligence (CI) investigations.\n\n-At any time, the USG may inspect and seize data stored on this IS.\n\n-Communications using, or data stored on, this IS are not private, are subject to routine monitoring, interception, and search, and may be disclosed or used for any USG-authorized purpose.\n\n-This IS includes security measures (e.g., authentication and access controls) to protect USG interests--not for your personal benefit or privacy.\n\n-Notwithstanding the above, using this IS does not constitute consent to PM, LE or CI investigative searching or monitoring of the content of privileged communications, or work product, related to personal representation or services by attorneys, psychotherapists, or clergy, and their assistants. Such communications and work product are private and confidential. See User Agreement for details.\"\n\nSatisfies: SRG-OS-000023-GPOS-00006, SRG-OS-000228-GPOS-00088","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000048"],"reference_identifier":"4992","uuid":"2e05da7f-8dd5-40ac-af98-cdb9dba233f9","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: CB09E985BEF02256CFDB0C7FDA7546674604BDDC\r\n~~~~~\r\nConfiguration for 'OL 9 must display the Standard Mandatory DOD Notice and Consent Banner before granting local or remote access to the system via a graphical user logon.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271690","group_tree":[{"id":"V-271690","title":"SRG-OS-000028-GPOS-00009","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271690","severity":"medium","group_title":"SRG-OS-000028-GPOS-00009","rule_id_src":"SV-271690r1092634_rule","rule_id":"SV-271690","rule_version":"OL09-00-002160","rule_title":"OL 9 must be able to directly initiate a session lock for all connection types using smart card when the smart card is removed.","fix_text":"Configure OL 9 to enable a user's session lock until that user reestablishes access using established identification and authentication procedures.\n\nSelect or create an authselect profile and incorporate the \"with-smartcard-lock-on-removal\" feature with the following example:\n\n$ sudo authselect select sssd with-smartcard with-smartcard-lock-on-removal\n\nAlternatively, the dconf settings can be edited in the /etc/dconf/db/* location.\n\nAdd or update the [org/gnome/settings-daemon/peripherals/smartcard] section of the /etc/dconf/db/local.d/00-security-settings\" database file and add or update the following lines:\n\n[org/gnome/settings-daemon/peripherals/smartcard]\nremoval-action='lock-screen'\n\nUpdate the dconf system databases:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 enables a user's session lock until that user reestablishes access using established identification and authentication procedures with the following command:\n\n$ grep -R removal-action /etc/dconf/db/*\n/etc/dconf/db/distro.d/20-authselect:removal-action='lock-screen'\n\nIf the \"removal-action='lock-screen'\" setting is missing or commented out from the dconf database files, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A session lock is a temporary action taken when a user stops work and moves away from the immediate physical vicinity of the information system but does not want to log out because of the temporary nature of the absence.\n\nThe session lock is implemented at the point where session activity can be determined. Rather than be forced to wait for a period of time to expire before the user session can be locked, OL 9 needs to provide users with the ability to manually invoke a session lock so users can secure their session if it is necessary to temporarily vacate the immediate physical vicinity.\n\nSatisfies: SRG-OS-000028-GPOS-00009, SRG-OS-000030-GPOS-00011","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000056","CCI-000057"],"reference_identifier":"5820","uuid":"e7cc2010-baa6-4819-a510-c00e4c5843d3","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 8F01BD236DF58D5D4EB0475FB22A873D8D92CE01\r\n~~~~~\r\nConfiguration for 'OL 9 must be able to directly initiate a session lock for all connection types using smart card when the smart card is removed.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271691","group_tree":[{"id":"V-271691","title":"SRG-OS-000480-GPOS-00229","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271691","severity":"high","group_title":"SRG-OS-000480-GPOS-00229","rule_id_src":"SV-271691r1091785_rule","rule_id":"SV-271691","rule_version":"OL09-00-002161","rule_title":"OL 9 must not allow unattended or automatic logon via the graphical user interface.","fix_text":"Configure the GNOME desktop display manager to disable automatic login.\n\nSet AutomaticLoginEnable to false in the [daemon] section in /etc/gdm/custom.conf. For example:\n\n[daemon]\nAutomaticLoginEnable=false","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 does not allow an unattended or automatic logon to the system via a graphical user interface.\n\nCheck for the value of the \"AutomaticLoginEnable\" in the \"/etc/gdm/custom.conf\" file with the following command:\n\n$  grep -i automaticlogin /etc/gdm/custom.conf\n[daemon]\nAutomaticLoginEnable=false\n\nIf the value of \"AutomaticLoginEnable\" is not set to \"false\", this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Failure to restrict system access to authenticated users negatively impacts operating system security.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"2921","uuid":"5e4fc717-38cc-4482-861c-641c7def94f1","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: C50FA5E6966FB302D11D88B2DAF05EADF3BC6881\r\n~~~~~\r\nRequired configuration for 'OL 9 must not allow unattended or automatic logon via the graphical user interface.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271692","group_tree":[{"id":"V-271692","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271692","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271692r1091788_rule","rule_id":"SV-271692","rule_version":"OL09-00-002162","rule_title":"OL 9 effective dconf policy must match the policy keyfiles.","fix_text":"Update the dconf databases by running the following command:\n\n$ sudo dconf update","weight":"10.0","check_content":"This requirement assumes the use of the OL 9 default graphical user interface\u2014the GNOME desktop environment. If the system does not have any graphical user interface installed, this requirement is Not Applicable.\n\nVerify that OL 9 effective dconf policy matches the policy keyfiles.\n\nCheck the last modification time of the local databases, comparing it to the last modification time of the related keyfiles. The following command will check every dconf database and compare its modification time to the related system keyfiles:\n\n$ function dconf_needs_update { for db in $(find /etc/dconf/db -maxdepth 1 -type f); do db_mtime=$(stat -c %Y \"$db\"); keyfile_mtime=$(stat -c %Y \"$db\".d/* | sort -n | tail -1); if [ -n \"$db_mtime\" ] && [ -n \"$keyfile_mtime\" ] && [ \"$db_mtime\" -lt \"$keyfile_mtime\" ]; then echo \"$db needs update\"; return 1; fi; done; }; dconf_needs_update\n\nIf the command has any output, then a dconf database needs to be updated, and this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Unlike text-based keyfiles, the binary database is impossible to check through most automated and all manual means; therefore, to evaluate dconf configuration, both have to be true at the same time - configuration files have to be compliant, and the database needs to be more recent than those keyfiles, which gives confidence that it reflects them.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"8974","uuid":"72d5e70a-cf99-446c-99d2-cdad107cdcdc","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: F78DF1B88D9DE315E8DB38DD98DECBF66C6A8218\r\n~~~~~\r\nThe feature/role addressed by 'OL 9 effective dconf policy must match the policy keyfiles.' is not present or not in use on this the Oracle Linux 9 host."},{"group_id_src":"V-271693","group_tree":[{"id":"V-271693","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271693","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271693r1091791_rule","rule_id":"SV-271693","rule_version":"OL09-00-002301","rule_title":"OL 9 must define default permissions for the bash shell.","fix_text":"Configure OL 9 to define default permissions for all authenticated users using the bash shell.\n\nAdd or edit the lines for the \"umask\" parameter in the \"/etc/bashrc\" file to \"077\":\n\numask 077","weight":"10.0","check_content":"Verify that OL 9 \"umask\" setting is configured correctly in the \"/etc/bashrc\" file with the following command:\n\nNote: If the value of the \"umask\" parameter is set to \"000\" \"/etc/bashrc\" file, the severity of this requirement is raised to a CAT I.\n\n$ grep umask /etc/bashrc \numask 077\numask 077  \n\nIf the value for the \"umask\" parameter is not \"077\", or the \"umask\" parameter is missing or is commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The umask controls the default access mode assigned to newly created files. A umask of 077 limits new files to mode 600 or less permissive. Although umask can be represented as a four-digit number, the first digit representing special access modes is typically ignored or required to be \"0\". This requirement applies to the globally configured system defaults and the local interactive user defaults for each account on the system.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"9582","uuid":"bba3ed93-6406-4820-8224-7c7a7e95ba04","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: C7272A5131F681558EF1B71D1BFA87D4A19E6756\r\n~~~~~\r\nConfiguration for 'OL 9 must define default permissions for the bash shell.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271694","group_tree":[{"id":"V-271694","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271694","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271694r1091794_rule","rule_id":"SV-271694","rule_version":"OL09-00-002302","rule_title":"OL 9 must define default permissions for the c shell.","fix_text":"Configure OL 9 to define default permissions for all authenticated users using the c shell.\n\nAdd or edit the lines for the \"umask\" parameter in the \"/etc/csh.cshrc\" file to \"077\":\n\numask 077","weight":"10.0","check_content":"Verify that OL 9 \"umask\" setting is configured correctly in the \"/etc/csh.cshrc\" file with the following command:\n\nNote: If the value of the \"umask\" parameter is set to \"000\" \"/etc/csh.cshrc\" file, the severity of this requirement is raised to a CAT I.\n\n$ grep umask /etc/csh.cshrc \numask 077\numask 077  \n\nIf the value for the \"umask\" parameter is not \"077\", or the \"umask\" parameter is missing or is commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The umask controls the default access mode assigned to newly created files. A umask of 077 limits new files to mode 600 or less permissive. Although umask can be represented as a four-digit number, the first digit representing special access modes is typically ignored or required to be \"0\". This requirement applies to the globally configured system defaults and the local interactive user defaults for each account on the system.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"1568","uuid":"100786e9-1188-4e33-9d90-f9b336fc4f01","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: F9CB1DEB8D8AEFE2B0630B6477F4F9D3A67FDA3C\r\n~~~~~\r\nConfiguration for 'OL 9 must define default permissions for the c shell.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271695","group_tree":[{"id":"V-271695","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271695","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271695r1091797_rule","rule_id":"SV-271695","rule_version":"OL09-00-002303","rule_title":"OL 9 must define default permissions for the system default profile.","fix_text":"Configure OL 9 to define default permissions for all authenticated users in such a way that the user can only read and modify their own files.\n\nAdd or edit the lines for the \"umask\" parameter in the \"/etc/profile\" file to \"077\":\n\numask 077","weight":"10.0","check_content":"Verify that OL 9 \"umask\" setting is configured correctly in the \"/etc/profile\" file with the following command:\n\nNote: If the value of the \"umask\" parameter is set to \"000\" \"/etc/profile\" file, the severity of this requirement is raised to a CAT I.\n\n$ grep umask /etc/profile \numask 077\n\nIf the value for the \"umask\" parameter is not \"077\", or the \"umask\" parameter is missing or is commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The umask controls the default access mode assigned to newly created files. A umask of 077 limits new files to mode 600 or less permissive. Although umask can be represented as a four-digit number, the first digit representing special access modes is typically ignored or required to be \"0\". This requirement applies to the globally configured system defaults and the local interactive user defaults for each account on the system.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"6698","uuid":"496bf6c1-eb2e-4685-b0ea-3540d3bc93b2","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 63C24C7D5FA52C16A2E086C22E1E22EE8D70FBC1\r\n~~~~~\r\nConfiguration for 'OL 9 must define default permissions for the system default profile.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271696","group_tree":[{"id":"V-271696","title":"SRG-OS-000480-GPOS-00228","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271696","severity":"medium","group_title":"SRG-OS-000480-GPOS-00228","rule_id_src":"SV-271696r1091800_rule","rule_id":"SV-271696","rule_version":"OL09-00-002304","rule_title":"OL 9 must define default permissions for all authenticated users in such a way that the user can only read and modify their own files.","fix_text":"Configure OL 9 to define default permissions for all authenticated users in such a way that the user can only read and modify their own files.\n\nAdd or edit the lines for the \"UMASK\" parameter in the \"/etc/login.defs\" file to \"077\":\n\nUMASK 077","weight":"10.0","check_content":"Verify that OL 9 defines default permissions for all authenticated users in such a way that the user can only read and modify their own files with the following command:\n\nNote: If the value of the \"UMASK\" parameter is set to \"000\" in \"/etc/login.defs\" file, the severity of this requirement is raised to a CAT I.\n\n$ grep -i umask /etc/login.defs\nUMASK 077\n\nIf the value for the \"UMASK\" parameter is not \"077\", or the \"UMASK\" parameter is missing or is commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Setting the most restrictive default permissions ensures that when new accounts are created, they do not have unnecessary access.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"5962","uuid":"cb0a0a9c-774c-4417-906a-57b74477431a","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: EF94E7E294992F7B75E4E48C76D2FC87396C2A50\r\n~~~~~\r\nRequired configuration for 'OL 9 must define default permissions for all authenticated users in such a way that the user can only read and modify their own files.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271697","group_tree":[{"id":"V-271697","title":"SRG-OS-000096-GPOS-00050","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271697","severity":"low","group_title":"SRG-OS-000096-GPOS-00050","rule_id_src":"SV-271697r1184202_rule","rule_id":"SV-271697","rule_version":"OL09-00-002320","rule_title":"OL 9 must disable the chrony daemon from acting as a server.","fix_text":"Configure OL 9 to disable the chrony daemon from acting as a server by adding/modifying the following line in the /etc/chrony.conf file:\n\nport 0","weight":"10.0","check_content":"Note: If the server is serving as an NTP server, this is not applicable.\n\nVerify OL 9 disables the chrony daemon from acting as a server with the following command:\n\n$ grep -w port /etc/chrony.conf\nport 0\n\nIf the \"port\" option is not set to \"0\", is commented out, or is missing, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Minimizing the exposure of the server functionality of the chrony daemon diminishes the attack surface.\n\nSatisfies: SRG-OS-000096-GPOS-00050, SRG-OS-000095-GPOS-00049","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000382","CCI-000381"],"reference_identifier":"2891","uuid":"4091282c-9dee-4175-87f3-28a9c216e43e","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 3E593AFEA5518F3CF0EB474C481BDDBB4EF63DC6\r\n~~~~~\r\nRequired configuration for 'OL 9 must disable the chrony daemon from acting as a server.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271698","group_tree":[{"id":"V-271698","title":"SRG-OS-000096-GPOS-00050","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271698","severity":"low","group_title":"SRG-OS-000096-GPOS-00050","rule_id_src":"SV-271698r1091806_rule","rule_id":"SV-271698","rule_version":"OL09-00-002321","rule_title":"OL 9 must disable network management of the chrony daemon.","fix_text":"Configure OL 9 to disable network management of the chrony daemon by adding/modifying the following line in the /etc/chrony.conf file:\n\ncmdport 0","weight":"10.0","check_content":"Verify that OL 9 disables network management of the chrony daemon with the following command:\n\n$ grep -w cmdport /etc/chrony.conf\ncmdport 0\n\nIf the \"cmdport\" option is not set to \"0\", is commented out, or is missing, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Not exposing the management interface of the chrony daemon on the network diminishes the attack space.\n\nSatisfies: SRG-OS-000096-GPOS-00050, SRG-OS-000095-GPOS-00049","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000382","CCI-000381"],"reference_identifier":"1397","uuid":"3c4424fa-7f60-4626-a28d-b01e9f16146d","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 98515C9EB27344677E8F4A9F24B84692B925E46C\r\n~~~~~\r\nConfiguration for 'OL 9 must disable network management of the chrony daemon.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271699","group_tree":[{"id":"V-271699","title":"SRG-OS-000355-GPOS-00143","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271699","severity":"medium","group_title":"SRG-OS-000355-GPOS-00143","rule_id_src":"SV-271699r1091809_rule","rule_id":"SV-271699","rule_version":"OL09-00-002323","rule_title":"OL 9 must securely compare internal information system clocks at least every 24 hours.","fix_text":"Configure OL 9 to securely compare internal information system clocks at least every 24 hours with an NTP server by adding/modifying the following line in the /etc/chrony.conf file.\n\nserver [ntp.server.name] iburst maxpoll 16","weight":"10.0","check_content":"Verify that OL 9 securely compares internal information system clocks at least every 24 hours with an NTP server with the following command:\n\n$ grep maxpoll /etc/chrony.conf\nserver 0.us.pool.ntp.mil iburst maxpoll 16\n\nIf the \"maxpoll\" option is set to a number greater than 16 or the line is commented out, this is a finding.\n\nVerify the \"chrony.conf\" file is configured to an authoritative DOD time source by running the following command:\n\n$ grep -i server /etc/chrony.conf\nserver 0.us.pool.ntp.mil \n\nIf the parameter \"server\" is not set or is not set to an authoritative DOD time source, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Inaccurate time stamps make it more difficult to correlate events and can lead to an inaccurate analysis. Determining the correct time a particular event occurred on a system is critical when conducting forensic analysis and investigating system events. Sources outside the configured acceptable allowance (drift) may be inaccurate.\n\nSynchronizing internal information system clocks provides uniformity of time stamps for information systems with multiple system clocks and systems connected over a network.\n\nDepending on the infrastructure being used the \"pool\" directive may not be supported.\n\nAuthoritative time sources include the United States Naval Observatory (USNO) time servers, a time server designated for the appropriate DOD network (NIPRNet/SIPRNet), and/or the Global Positioning System (GPS).\n\nSatisfies: SRG-OS-000355-GPOS-00143, SRG-OS-000356-GPOS-00144, SRG-OS-000359-GPOS-00146","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004923","CCI-004926","CCI-001890"],"reference_identifier":"6380","uuid":"1d1559b5-fb1b-4e75-8392-00175a5a1da3","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 09CE7D23B3D5A18F0FE6BDE8C5471807DF358F26\r\n~~~~~\r\nConfiguration for 'OL 9 must securely compare internal information system clocks at least every 24 hours.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271700","group_tree":[{"id":"V-271700","title":"SRG-OS-000062-GPOS-00031","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271700","severity":"low","group_title":"SRG-OS-000062-GPOS-00031","rule_id_src":"SV-271700r1091812_rule","rule_id":"SV-271700","rule_version":"OL09-00-002330","rule_title":"OL 9 must enable Linux audit logging for the USBGuard daemon.","fix_text":"Configure OL 9 USBGuard AuditBackend to use the audit system.\n\nAdd or edit the following line in /etc/usbguard/usbguard-daemon.conf \n\nAuditBackend=LinuxAudit","weight":"10.0","check_content":"Verify that OL 9 Linux Audit logging is enabled for the USBGuard daemon with the following command:\n\n$ sudo grep AuditBackend /etc/usbguard/usbguard-daemon.conf \nAuditBackend=LinuxAudit \n\nIf \"AuditBackend\" is not set to \"LinuxAudit\", this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Without the capability to generate audit records, it would be difficult to establish, correlate, and investigate the events relating to an incident or identify those responsible for one.\n\nIf auditing is enabled late in the startup process, the actions of some startup processes may not be audited. Some audit systems also maintain state information only available if auditing is enabled before a given process is created.\n\nAudit records can be generated from various components within the information system (e.g., module or policy filter).\n\nThe list of audited events is the set of events for which audits are to be generated. This set of events is typically a subset of the list of all events for which the system is capable of generating audit records.\n\nDOD has defined the list of events for which OL 9 will provide an audit record generation capability as the following:\n\n1. Successful and unsuccessful attempts to access, modify, or delete privileges, security objects, security levels, or categories of information (e.g., classification levels);\n\n2. Access actions, such as successful and unsuccessful logon attempts, privileged activities or other system-level access, starting and ending time for user access to the system, concurrent logons from different workstations, successful and unsuccessful accesses to objects, all program initiations, and all direct access to the information system;\n\n3. All account creations, modifications, disabling, and terminations; and \n\n4. All kernel module load, unload, and restart actions.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000169"],"reference_identifier":"4527","uuid":"f9051fc3-a0a1-4fee-8f3f-7e63e006450d","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: BC96A1959AD99FC3ECDEBBFEA1207D48635B8992\r\n~~~~~\r\nRequired configuration for 'OL 9 must enable Linux audit logging for the USBGuard daemon.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271701","group_tree":[{"id":"V-271701","title":"SRG-OS-000378-GPOS-00163","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271701","severity":"medium","group_title":"SRG-OS-000378-GPOS-00163","rule_id_src":"SV-271701r1091815_rule","rule_id":"SV-271701","rule_version":"OL09-00-002331","rule_title":"OL 9 must block unauthorized peripherals before establishing a connection.","fix_text":"Configure the operating system to enable the blocking of unauthorized peripherals with the following command:\n\nNote: This command must be run from a root shell and will create an allow list for any USB devices currently connect to the system.\n\n# usbguard generate-policy --no-hash > /etc/usbguard/rules.conf\n\nNote: Enabling and starting USBGuard without properly configuring it for an individual system will immediately prevent any access over a USB device such as a keyboard or mouse.","weight":"10.0","check_content":"Verify that OL 9 USBGuard has a policy configured with the following command:\n\n$ usbguard list-rules\nallow id 1d6b:0001 serial\n\nIf the command does not return results or an error is returned, ask the SA to indicate how unauthorized peripherals are being blocked.\n\nIf there is no evidence that unauthorized peripherals are being blocked before establishing a connection, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The USBguard-daemon is the main component of the USBGuard software framework. It runs as a service in the background and enforces the USB device authorization policy for all USB devices. The policy is defined by a set of rules using a rule language described in the usbguard-rules.conf file. The policy and the authorization state of USB devices can be modified during runtime using the usbguard tool.\n\nThe system administrator (SA) must work with the site information system security officer (ISSO) to determine a list of authorized peripherals and establish rules within the USBGuard software framework to allow only authorized devices.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001958"],"reference_identifier":"4710","uuid":"fec75b24-b9ed-4c78-9bba-cb149bc9bebe","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: EB9B1183E704C046717F024E96893379CE8622D4\r\n~~~~~\r\nConfiguration for 'OL 9 must block unauthorized peripherals before establishing a connection.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271703","group_tree":[{"id":"V-271703","title":"SRG-OS-000032-GPOS-00013","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271703","severity":"medium","group_title":"SRG-OS-000032-GPOS-00013","rule_id_src":"SV-271703r1091821_rule","rule_id":"SV-271703","rule_version":"OL09-00-002340","rule_title":"OL 9 must log SSH connection attempts and failures to the server.","fix_text":"Configure OL 9 to log connection attempts add or modify the following line in \"/etc/ssh/sshd_config\" or in a file in \"/etc/ssh/sshd_config.d\".\n\nLogLevel VERBOSE\n\nRestart the SSH daemon for the settings to take effect:\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 logs SSH connection attempts and failures to the server.\n\nCheck what the SSH daemon's \"LogLevel\" option is set to with the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*loglevel'\nLogLevel VERBOSE\n\nIf a value of \"VERBOSE\" is not returned, the line is commented out, or is missing, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"SSH provides several logging levels with varying amounts of verbosity. \"DEBUG\" is specifically not recommended other than strictly for debugging SSH communications since it provides so much data that it is difficult to identify important security information. \"INFO\" or \"VERBOSE\" level is the basic level that only records login activity of SSH users. In many situations, such as Incident Response, it is important to determine when a particular user was active on a system. The logout record can eliminate those users who disconnected, which helps narrow the field.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000067"],"reference_identifier":"1541","uuid":"bf5fb555-48b9-4c02-ab6f-9ffc9b2b6d42","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: F0A2A612B8CA2DB0B82B506042E1CCA6F8FAA7FB\r\n~~~~~\r\nConfiguration for 'OL 9 must log SSH connection attempts and failures to the server.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271704","group_tree":[{"id":"V-271704","title":"SRG-OS-000364-GPOS-00151","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271704","severity":"medium","group_title":"SRG-OS-000364-GPOS-00151","rule_id_src":"SV-271704r1091824_rule","rule_id":"SV-271704","rule_version":"OL09-00-002341","rule_title":"OL 9 SSH daemon must not allow Generic Security Service Application Program Interface (GSSAPI) authentication.","fix_text":"Configure the SSH daemon to not allow GSSAPI authentication.\n\nAdd or uncomment the following line to \"/etc/ssh/sshd_config\" or to a file in \"/etc/ssh/sshd_config.d\" and set the value to \"no\":\n\nGSSAPIAuthentication no\n\nThe SSH service must be restarted for changes to take effect:\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 SSH daemon does not allow GSSAPI authentication with the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*gssapiauthentication'\nGSSAPIAuthentication no\n\nIf the value is returned as \"yes\", the returned line is commented out, no output is returned, and the use of GSSAPI authentication has not been documented with the information system security officer (ISSO), this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"GSSAPI authentication is used to provide additional authentication mechanisms to applications. Allowing GSSAPI authentication through SSH exposes the system's GSSAPI to remote hosts, increasing the attack surface of the system.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001813"],"reference_identifier":"4454","uuid":"a9d30d06-bf04-4ead-86a1-d6ec2220c966","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: B5825C97B3146247156819CD57275984F91FCC1E\r\n~~~~~\r\nRequired configuration for 'OL 9 SSH daemon must not allow Generic Security Service Application Program Interface (GSSAPI) authentication.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271705","group_tree":[{"id":"V-271705","title":"SRG-OS-000423-GPOS-00187","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271705","severity":"medium","group_title":"SRG-OS-000423-GPOS-00187","rule_id_src":"SV-271705r1091827_rule","rule_id":"SV-271705","rule_version":"OL09-00-002342","rule_title":"OL 9 must force a frequent session key renegotiation for SSH connections to the server.","fix_text":"Configure OL 9 to force a frequent session key renegotiation for SSH connections to the server by adding or modifying the following line in the \"/etc/ssh/sshd_config\" or in a file in \"/etc/ssh/sshd_config.d\":\n\nRekeyLimit 1G 1h\n\nRestart the SSH daemon for the settings to take effect.\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 SSH server is configured to force frequent session key renegotiation with the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*rekeylimit'\nRekeyLimit 1G 1h\n\nIf \"RekeyLimit\" does not have a maximum data amount and maximum time defined, is missing or commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Without protection of the transmitted information, confidentiality and integrity may be compromised because unprotected communications can be intercepted and either read or altered. \n\nThis requirement applies to both internal and external networks and all types of information system components from which information can be transmitted (e.g., servers, mobile devices, notebook computers, printers, copiers, scanners, and facsimile machines). Communication paths outside the physical protection of a controlled boundary are exposed to the possibility of interception and modification. \n\nProtecting the confidentiality and integrity of organizational information can be accomplished by physical means (e.g., employing physical distribution systems) or by logical means (e.g., employing cryptographic techniques). If physical means of protection are employed, then logical means (cryptography) do not have to be employed, and vice versa.\n\nSession key regeneration limits the chances of a session key becoming compromised.\n\nSatisfies: SRG-OS-000423-GPOS-00187, SRG-OS-000033-GPOS-00014, SRG-OS-000424-GPOS-00188","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002418","CCI-000068","CCI-002421"],"reference_identifier":"8703","uuid":"153deb71-06a4-402b-9309-3f151187a0aa","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: ACFFC566DC76B18488B32FA42B8F736E68AF7744\r\n~~~~~\r\nThe feature/role addressed by 'OL 9 must force a frequent session key renegotiation for SSH connections to the server.' is not present or not in use on this the Oracle Linux 9 host."},{"group_id_src":"V-271706","group_tree":[{"id":"V-271706","title":"SRG-OS-000106-GPOS-00053","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271706","severity":"high","group_title":"SRG-OS-000106-GPOS-00053","rule_id_src":"SV-271706r1091830_rule","rule_id":"SV-271706","rule_version":"OL09-00-002343","rule_title":"OL 9 SSHD must not allow blank passwords.","fix_text":"Configure OL 9 to prevent SSH users from logging on with blank passwords by editing the following line in \"/etc/ssh/sshd_config\" or in a file in \"/etc/ssh/sshd_config.d\":\n\nPermitEmptyPasswords no\n\nRestart the SSH daemon for the settings to take effect:\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 remote access using SSH prevents logging on with a blank password with the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*permitemptypasswords'\nPermitEmptyPasswords no\n\nIf the \"PermitEmptyPasswords\" keyword is set to \"yes\", is missing, or is commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If an account has an empty password, anyone could log on and run commands with the privileges of that account. Accounts with empty passwords should never be used in operational environments.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000766"],"reference_identifier":"5912","uuid":"3a6aae62-bb3a-4d29-ba4f-e3d0b5181ee5","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: B4825DFA0207A53C31D491B0C970F05728900293\r\n~~~~~\r\nConfiguration for 'OL 9 SSHD must not allow blank passwords.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271707","group_tree":[{"id":"V-271707","title":"SRG-OS-000125-GPOS-00065","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271707","severity":"high","group_title":"SRG-OS-000125-GPOS-00065","rule_id_src":"SV-271707r1091833_rule","rule_id":"SV-271707","rule_version":"OL09-00-002344","rule_title":"OL 9 must enable the Pluggable Authentication Module (PAM) interface for SSHD.","fix_text":"Configure the OL 9 SSHD to use the UsePAM interface by adding or modifying the following line in \"/etc/ssh/sshd_config\" or in a file in \"/etc/ssh/sshd_config.d\".\n\nUsePAM yes\n\nRestart the SSH daemon for the settings to take effect:\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 SSHD is configured to allow for the UsePAM interface with the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*usepam'\nUsePAM yes\n\nIf the \"UsePAM\" keyword is set to \"no\", is missing, or is commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"When UsePAM is set to \"yes\", PAM runs through account and session types properly. This is important when restricted access to services based off of IP, time, or other factors of the account is needed. Additionally, this ensures users can inherit certain environment variables on login or disallow access to the server.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000877"],"reference_identifier":"5605","uuid":"38795d81-e4d8-42da-9995-5094ff462f29","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 2E72BCE7DCDB14CD708983E21ED8D7DDA3F7F08C\r\n~~~~~\r\nConfiguration for 'OL 9 must enable the Pluggable Authentication Module (PAM) interface for SSHD.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271708","group_tree":[{"id":"V-271708","title":"SRG-OS-000109-GPOS-00056","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271708","severity":"medium","group_title":"SRG-OS-000109-GPOS-00056","rule_id_src":"SV-271708r1092594_rule","rule_id":"SV-271708","rule_version":"OL09-00-002345","rule_title":"OL 9 must not permit direct logons to the root account using remote access via SSH.","fix_text":"Configure OL 9 to prevent SSH users from logging on directly as root by adding or modifying the following line in \"/etc/ssh/sshd_config\" or in a file in \"/etc/ssh/sshd_config.d\".\n\nPermitRootLogin no\n\nRestart the SSH daemon for the settings to take effect:\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 remote access using SSH prevents users from logging on directly as \"root\" with the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*permitrootlogin'\nPermitRootLogin no\n\nIf the \"PermitRootLogin\" keyword is set to \"yes\", is missing, or is commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Even though the communications channel may be encrypted, an additional layer of security is gained by extending the policy of not logging directly on as root. In addition, logging in with a user-specific account provides individual accountability of actions performed on the system and also helps to minimize direct attack attempts on root's password.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-004045"],"reference_identifier":"5444","uuid":"7c992543-920d-4ba2-a4e8-57032c73ce3e","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 71FC63EBE1B980AFDC0C5F6631BE8BCE8A3A35CF\r\n~~~~~\r\nRequired configuration for 'OL 9 must not permit direct logons to the root account using remote access via SSH.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271709","group_tree":[{"id":"V-271709","title":"SRG-OS-000163-GPOS-00072","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271709","severity":"medium","group_title":"SRG-OS-000163-GPOS-00072","rule_id_src":"SV-271709r1091839_rule","rule_id":"SV-271709","rule_version":"OL09-00-002346","rule_title":"OL 9 must be configured so that all network connections associated with SSH traffic terminate after becoming unresponsive.","fix_text":"Note: This setting must be applied in conjunction with ClientAliveInterval to function correctly.\n\nConfigure the SSH server to terminate a user session automatically after the SSH client has become unresponsive.\n\nModify or append the following lines in the \"/etc/ssh/sshd_config\" or in a file in \"/etc/ssh/sshd_config.d\":\n\nClientAliveCountMax 1\n\nIn order for the changes to take effect, the SSH daemon must be restarted.\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 is configured so that all network connections associated with SSH traffic terminate after becoming unresponsive.\n\nVerify that the \"ClientAliveCountMax\" is set to \"1\" by performing the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*clientalivecountmax'\nClientAliveCountMax 1\n\nIf \"ClientAliveCountMax\" does not exist, is not set to a value of \"1\" in \"/etc/ssh/sshd_config\", or is commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Terminating an unresponsive SSH session within a short time period reduces the window of opportunity for unauthorized personnel to take control of a management session enabled on the console or console port that has been left unattended. In addition, quickly terminating an idle SSH session will also free up resources committed by the managed network element.\n\nTerminating network connections associated with communications sessions includes, for example, deallocating associated TCP/IP address/port pairs at the operating system level and deallocating networking assignments at the application level if multiple application sessions are using a single operating system-level network connection. This does not mean the operating system terminates all sessions or network access; it only ends the unresponsive session and releases the resources associated with that session.\n\nOL 9 uses /etc/ssh/sshd_config for configurations of OpenSSH. Within the sshd_config, the product of the values of \"ClientAliveInterval\" and \"ClientAliveCountMax\" are used to establish the inactivity threshold. The \"ClientAliveInterval\" is a timeout interval in seconds, after which if no data has been received from the client, SSHD will send a message through the encrypted channel to request a response from the client. The \"ClientAliveCountMax\" is the number of client alive messages that may be sent without SSHD receiving any messages back from the client. If this threshold is met, sshd will disconnect the client. For more information on these settings and others, refer to the sshd_config man pages.\n\nSatisfies: SRG-OS-000163-GPOS-00072, SRG-OS-000279-GPOS-00109","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001133","CCI-002361"],"reference_identifier":"7015","uuid":"6197a936-7c44-4bf3-acbe-488c762ba447","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: D6CAF26F90C7505C50BCCEB5316AA5CDFC2578F9\r\n~~~~~\r\nRequired configuration for 'OL 9 must be configured so that all network connections associated with SSH traffic terminate after becoming unresponsive.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271710","group_tree":[{"id":"V-271710","title":"SRG-OS-000163-GPOS-00072","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271710","severity":"medium","group_title":"SRG-OS-000163-GPOS-00072","rule_id_src":"SV-271710r1092596_rule","rule_id":"SV-271710","rule_version":"OL09-00-002347","rule_title":"OL 9 must be configured so that all network connections associated with SSH traffic are terminated after 10 minutes of becoming unresponsive.","fix_text":"Note: This setting must be applied in conjunction with ClientAliveCountMax\" setting to function correctly.\n\nConfigure the SSH server to terminate a user session automatically after the SSH client has been unresponsive for 10 minutes.\n\nModify or append the following lines in the \"/etc/ssh/sshd_config\" or in a file in \"/etc/ssh/sshd_config.d\":\n\nClientAliveInterval 600\n\nIn order for the changes to take effect, the SSH daemon must be restarted.\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 is configured so that all network connections associated with SSH traffic are terminated after 10 minutes of becoming unresponsive.\n\nVerify that the \"ClientAliveInterval\" variable is set to a value of \"600\" or less by performing the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*clientaliveinterval'\nClientAliveInterval 600\n\nIf \"ClientAliveInterval\" does not exist, does not have a value of \"600\" or less in \"/etc/ssh/sshd_config\", or is commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Terminating an unresponsive SSH session within a short time period reduces the window of opportunity for unauthorized personnel to take control of a management session enabled on the console or console port that has been left unattended. In addition, quickly terminating an idle SSH session will also free up resources committed by the managed network element.\n\nTerminating network connections associated with communications sessions includes, for example, deallocating associated TCP/IP address/port pairs at the operating system level and deallocating networking assignments at the application level if multiple application sessions are using a single operating system-level network connection. This does not mean the operating system terminates all sessions or network access; it only ends the unresponsive session and releases the resources associated with that session.\n\nOL 9 uses /etc/ssh/sshd_config for configurations of OpenSSH. Within the sshd_config, the product of the values of \"ClientAliveInterval\" and \"ClientAliveCountMax\" are used to establish the inactivity threshold. The \"ClientAliveInterval\" is a timeout interval in seconds, after which if no data has been received from the client, SSHD will send a message through the encrypted channel to request a response from the client. The \"ClientAliveCountMax\" is the number of client alive messages that may be sent without SSHD receiving any messages back from the client. If this threshold is met, SSHD will disconnect the client. For more information on these settings and others, refer to the sshd_config man pages.\n\nSatisfies: SRG-OS-000163-GPOS-00072, SRG-OS-000279-GPOS-00109, SRG-OS-000395-GPOS-00175","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001133","CCI-002361","CCI-002891"],"reference_identifier":"6432","uuid":"5e98808c-e562-4dc0-9083-9825d97102bb","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 3EB2B30DA761D2D8EEF8F366C42E1ADB855E14B5\r\n~~~~~\r\nRequired configuration for 'OL 9 must be configured so that all network connections associated with SSH traffic are terminated after 10 minutes of becoming unresponsive.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271711","group_tree":[{"id":"V-271711","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271711","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271711r1091845_rule","rule_id":"SV-271711","rule_version":"OL09-00-002348","rule_title":"OL 9 SSH daemon must not allow rhosts authentication.","fix_text":"Configure the SSH daemon to not allow rhosts authentication.\n\nAdd the following line to \"/etc/ssh/sshd_config\" or to a file in \"/etc/ssh/sshd_config.d\" or uncomment the line and set the value to \"yes\":\n\nIgnoreRhosts yes\n\nThe SSH service must be restarted for changes to take effect:\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 SSH daemon does not allow rhosts authentication with the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*ignorerhosts'\nIgnoreRhosts yes\n\nIf the value is returned as \"no\", the returned line is commented out, or no output is returned, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"SSH trust relationships mean a compromise on one host can allow an attacker to move trivially to other hosts.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"9751","uuid":"bc95e1d4-fdd2-433d-a105-8d6d145071dd","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: AFF04D16342BEBFF6686A9EC342AC231B7481A21\r\n~~~~~\r\nConfiguration for 'OL 9 SSH daemon must not allow rhosts authentication.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271712","group_tree":[{"id":"V-271712","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271712","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271712r1091848_rule","rule_id":"SV-271712","rule_version":"OL09-00-002349","rule_title":"OL 9 SSH daemon must not allow known hosts authentication.","fix_text":"Configure the SSH daemon to not allow known hosts authentication.\n\nAdd the following line to \"/etc/ssh/sshd_config\" or to a file in \"/etc/ssh/sshd_config.d\" or uncomment the line and set the value to \"yes\":\n\nIgnoreUserKnownHosts yes\n\nThe SSH service must be restarted for changes to take effect:\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 SSH daemon does not allow known hosts authentication with the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*ignoreuserknownhosts'\nIgnoreUserKnownHosts yes\n\nIf the value is returned as \"no\", the returned line is commented out, or no output is returned, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Configuring the IgnoreUserKnownHosts setting for the SSH daemon provides additional assurance that remote login via SSH will require a password, even in the event of misconfiguration elsewhere.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"5347","uuid":"d5552775-e4b4-4c53-8618-51425a47450c","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: A878B379B4AAE103BE7DA5A47915D343F091BE3F\r\n~~~~~\r\nConfiguration for 'OL 9 SSH daemon must not allow known hosts authentication.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271713","group_tree":[{"id":"V-271713","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271713","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271713r1091851_rule","rule_id":"SV-271713","rule_version":"OL09-00-002350","rule_title":"OL 9 SSH daemon must disable remote X connections for interactive users.","fix_text":"Configure the SSH daemon to not allow X11 forwarding.\n\nAdd the following line to \"/etc/ssh/sshd_config\" or to a file in \"/etc/ssh/sshd_config.d\" or uncomment the line and set the value to \"no\":\n\nX11Forwarding no\n\nThe SSH service must be restarted for changes to take effect:\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 SSH daemon does not allow X11Forwarding with the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*x11forwarding'\nX11forwarding no\n\nIf the value is returned as \"yes\", the returned line is commented out, or no output is returned, and X11 forwarding is not documented with the information system security officer (ISSO) as an operational requirement, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"When X11 forwarding is enabled, there may be additional exposure to the server and client displays if the SSHD proxy display is configured to listen on the wildcard address. By default, SSHD binds the forwarding server to the loopback address and sets the hostname part of the DISPLAY environment variable to localhost. This prevents remote hosts from connecting to the proxy display.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"5816","uuid":"4182a74e-5799-40de-9d5a-88ed3da15369","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 740A35DEB19FF7E07331717AFDCD7DF70A229D79\r\n~~~~~\r\nConfiguration for 'OL 9 SSH daemon must disable remote X connections for interactive users.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271714","group_tree":[{"id":"V-271714","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271714","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271714r1091854_rule","rule_id":"SV-271714","rule_version":"OL09-00-002351","rule_title":"OL 9 SSH daemon must perform strict mode checking of home directory configuration files.","fix_text":"Configure the SSH daemon to perform strict mode checking of home directory configuration files.\n\nAdd the following line to \"/etc/ssh/sshd_config\" or to a file in \"/etc/ssh/sshd_config.d\" or uncomment the line and set the value to \"yes\":\n\nStrictModes yes\n\nThe SSH service must be restarted for changes to take effect:\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 SSH daemon performs strict mode checking of home directory configuration files with the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*strictmodes'\nStrictModes yes\n\nIf the \"StrictModes\" keyword is set to \"no\", the returned line is commented out, or no output is returned, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If other users have access to modify user-specific SSH configuration files, they may be able to log into the system as another user.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"7515","uuid":"7d86ba60-e512-4745-9a49-59a5ee86dab1","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 63916D6B9B539EDC5CFA02C4ECC328CC294FC00D\r\n~~~~~\r\nConfiguration for 'OL 9 SSH daemon must perform strict mode checking of home directory configuration files.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271715","group_tree":[{"id":"V-271715","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271715","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271715r1091857_rule","rule_id":"SV-271715","rule_version":"OL09-00-002352","rule_title":"OL 9 SSH daemon must display the date and time of the last successful account logon upon an SSH logon.","fix_text":"Configure the SSH daemon to provide users with feedback on when account accesses last occurred.\n\nAdd the following line to \"/etc/ssh/sshd_config\" or to a file in \"/etc/ssh/sshd_config.d\" or uncomment the line and set the value to \"yes\":\n\nPrintLastLog yes\n\nThe SSH service must be restarted for changes to take effect:\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 SSH daemon provides users with feedback on when account accesses last occurred with the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*printlastlog'\nPrintLastLog yes\n\nIf the \"PrintLastLog\" keyword is set to \"no\", the returned line is commented out, or no output is returned, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Providing users feedback on when account accesses last occurred facilitates user recognition and reporting of unauthorized account use.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"8772","uuid":"1b37fb83-ea2f-4ce9-a216-c247dab2992b","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 01BEDB15ED4E1B0C35ECB23C35658C0CA55FE470\r\n~~~~~\r\nConfiguration for 'OL 9 SSH daemon must display the date and time of the last successful account logon upon an SSH logon.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271716","group_tree":[{"id":"V-271716","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271716","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271716r1091860_rule","rule_id":"SV-271716","rule_version":"OL09-00-002354","rule_title":"OL 9 SSH daemon must prevent remote hosts from connecting to the proxy display.","fix_text":"Configure the SSH daemon to prevent remote hosts from connecting to the proxy display.\n\nAdd the following line to \"/etc/ssh/sshd_config\" or to a file in \"/etc/ssh/sshd_config.d\" or uncomment the line and set the value to \"yes\":\n\nX11UseLocalhost yes\n\nThe SSH service must be restarted for changes to take effect:\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 SSH daemon prevents remote hosts from connecting to the proxy display with the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*x11uselocalhost'\nX11UseLocalhost yes\n\nIf the \"X11UseLocalhost\" keyword is set to \"no\", is missing, or is commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"When X11 forwarding is enabled, there may be additional exposure to the server and client displays if the SSHD proxy display is configured to listen on the wildcard address. By default, SSHD binds the forwarding server to the loopback address and sets the hostname part of the \"DISPLAY\" environment variable to localhost. This prevents remote hosts from connecting to the proxy display.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"5282","uuid":"2bc9c7da-708d-4cd7-a560-db3d4cd1098c","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 56918092E787C2B9CCFAE1F47545DF4B5374B321\r\n~~~~~\r\nConfiguration for 'OL 9 SSH daemon must prevent remote hosts from connecting to the proxy display.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271717","group_tree":[{"id":"V-271717","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271717","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271717r1091863_rule","rule_id":"SV-271717","rule_version":"OL09-00-002355","rule_title":"OL 9 SSH daemon must not allow compression or must only allow compression after successful authentication.","fix_text":"Configure the SSH daemon to not allow compression.\n\nAdd the following line to \"/etc/ssh/sshd_config\" or to a file in \"/etc/ssh/sshd_config.d\" or uncomment the line and set the value to \"delayed\" or \"no\":\n\nCompression no\n\nThe SSH service must be restarted for changes to take effect:\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 SSH daemon performs compression after a user successfully authenticates with the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*compression'\nCompression delayed\n\nIf the \"Compression\" keyword is set to \"yes\", is missing, or the returned line is commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If compression is allowed in an SSH connection prior to authentication, vulnerabilities in the compression software could result in compromise of the system from an unauthenticated connection, potentially with root privileges.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"5754","uuid":"74e6caee-c39a-4f95-88cb-638f991d7437","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: CEF7EC0123E3472774217171DEBC114AA9277D11\r\n~~~~~\r\nRequired configuration for 'OL 9 SSH daemon must not allow compression or must only allow compression after successful authentication.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271718","group_tree":[{"id":"V-271718","title":"SRG-OS-000364-GPOS-00151","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271718","severity":"medium","group_title":"SRG-OS-000364-GPOS-00151","rule_id_src":"SV-271718r1091866_rule","rule_id":"SV-271718","rule_version":"OL09-00-002356","rule_title":"OL 9 SSH daemon must not allow Kerberos authentication.","fix_text":"Configure the SSH daemon to not allow Kerberos authentication.\n\nAdd the following line in \"/etc/ssh/sshd_config\" or to a file in \"/etc/ssh/sshd_config.d\" or uncomment the line and set the value to \"no\":\n\nKerberosAuthentication no\n\nThe SSH service must be restarted for changes to take effect:\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 SSH daemon does not allow Kerberos authentication with the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*kerberosauthentication'\nKerberosAuthentication no\n\nIf the value is returned as \"yes\", the returned line is commented out, no output is returned, and the use of Kerberos authentication has not been documented with the information system security officer (ISSO), this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Kerberos authentication for SSH is often implemented using Generic Security Service Application Program Interface (GSSAPI). If Kerberos is enabled through SSH, the SSH daemon provides a means of access to the system's Kerberos implementation. Vulnerabilities in the system's Kerberos implementations may be subject to exploitation.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001813"],"reference_identifier":"7734","uuid":"b7014d0d-fe19-48b7-a1d6-7cbf49c46f1b","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 0B6EDD6E5494595425F12C2E80B5EFE804137A2E\r\n~~~~~\r\nConfiguration for 'OL 9 SSH daemon must not allow Kerberos authentication.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271719","group_tree":[{"id":"V-271719","title":"SRG-OS-000480-GPOS-00229","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271719","severity":"medium","group_title":"SRG-OS-000480-GPOS-00229","rule_id_src":"SV-271719r1091869_rule","rule_id":"SV-271719","rule_version":"OL09-00-002357","rule_title":"OL 9 must not allow a noncertificate trusted host SSH logon to the system.","fix_text":"Configure OL 9 to not allow a noncertificate trusted host SSH logon to access the system.\n\nAdd or modify the following line in \"/etc/ssh/sshd_config\" or in a file in \"/etc/ssh/sshd_config.d\".\n\nHostbasedAuthentication no\n\nRestart the SSH daemon for the settings to take effect:\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 does not allow a noncertificate trusted host SSH logon to the system with the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*hostbasedauthentication'\nHostbasedAuthentication no\n\nIf the \"HostbasedAuthentication\" keyword is not set to \"no\", is missing, or is commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"SSH trust relationships mean a compromise on one host can allow an attacker to move trivially to other hosts.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"5708","uuid":"b123c277-3632-448a-a263-14c66d2a8dc3","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: F17CA978C7D22EACEC15AEC7D0631AEA68E8029F\r\n~~~~~\r\nConfiguration for 'OL 9 must not allow a noncertificate trusted host SSH logon to the system.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271720","group_tree":[{"id":"V-271720","title":"SRG-OS-000480-GPOS-00229","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271720","severity":"medium","group_title":"SRG-OS-000480-GPOS-00229","rule_id_src":"SV-271720r1091872_rule","rule_id":"SV-271720","rule_version":"OL09-00-002358","rule_title":"OL 9 must not allow users to override SSH environment variables.","fix_text":"Configure the OL 9 SSH daemon to not allow unattended or automatic logon to the system.\n\nAdd or edit the following line in the \"/etc/ssh/sshd_config\" or in a file in \"/etc/ssh/sshd_config.d\":\n\nPermitUserEnvironment no\n\nRestart the SSH daemon for the setting to take effect:\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 does not allow users to override SSH environment variables.\n\nVerify that unattended or automatic logon via SSH is disabled with the following command:\n\n$ sudo /usr/sbin/sshd -dd 2>&1 | awk '/filename/ {print $4}' | tr -d '\\r' | tr '\\n' ' ' | xargs sudo grep -iH '^\\s*permituserenvironment'\nPermitUserEnvironment no\n\nIf \"PermitUserEnvironment\" is set to \"yes\", is missing completely, or is commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"SSH environment options potentially allow users to bypass access restriction in some configurations.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"2590","uuid":"86821b8f-e702-46b9-9b71-d2b59afdbad2","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 5A2DC1C624C61D874455D1E95F871DF04DF47D69\r\n~~~~~\r\nConfiguration for 'OL 9 must not allow users to override SSH environment variables.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271721","group_tree":[{"id":"V-271721","title":"SRG-OS-000105-GPOS-00052","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271721","severity":"medium","group_title":"SRG-OS-000105-GPOS-00052","rule_id_src":"SV-271721r1091875_rule","rule_id":"SV-271721","rule_version":"OL09-00-002359","rule_title":"OL 9 SSHD must accept public key authentication.","fix_text":"Configure OL 9 to accept public key authentication by adding or modifying the following line in \"/etc/ssh/sshd_config\".\n\nPubkeyAuthentication yes\n\nRestart the SSH daemon for the settings to take effect:\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 SSH daemon accepts public key encryption with the following command:\n \n$ sudo grep -i PubkeyAuthentication /etc/ssh/sshd_config\nPubkeyAuthentication yes\n \nIf \"PubkeyAuthentication\" is set to no, the line is commented out, or the line is missing, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Without the use of multifactor authentication, the ease of access to privileged functions is greatly increased. Multifactor authentication requires using two or more factors to achieve authentication. A privileged account is defined as an information system account with authorizations of a privileged user. A DOD CAC with DOD-approved PKI is an example of multifactor authentication.\n\nSatisfies: SRG-OS-000105-GPOS-00052, SRG-OS-000106-GPOS-00053, SRG-OS-000107-GPOS-00054, SRG-OS-000108-GPOS-00055","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000765","CCI-000766"],"reference_identifier":"9269","uuid":"36386399-febe-4bed-85f3-3dcb3ccb4222","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 1125D6AA48D2FFC93022B8B169577912CB5BB5AE\r\n~~~~~\r\nConfiguration for 'OL 9 SSHD must accept public key authentication.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271722","group_tree":[{"id":"V-271722","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271722","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271722r1091878_rule","rule_id":"SV-271722","rule_version":"OL09-00-002360","rule_title":"OL 9 must require reauthentication when using the \"sudo\" command.","fix_text":"Configure OL 9 to reauthenticate \"sudo\" commands after the specified timeout:\n\nAdd the following line to \"/etc/sudoers\":\n\nDefaults timestamp_timeout=0","weight":"10.0","check_content":"Verify that OL 9 requires reauthentication when using the \"sudo\" command to elevate privileges with the following command:\n\n$ sudo grep -i 'timestamp_timeout' /etc/sudoers /etc/sudoers.d/*\n/etc/sudoers:Defaults timestamp_timeout=0\n\nIf results are returned from more than one file location, this is a finding.\n\nIf \"timestamp_timeout\" is set to a negative number, is commented out, or no results are returned, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Without reauthentication, users may access resources or perform tasks for which they do not have authorization. \n\nWhen operating systems provide the capability to escalate a functional capability, it is critical the organization requires the user to reauthenticate when using the \"sudo\" command.\n\nIf the value is set to an integer less than \"0\", the user's time stamp will not expire and the user will not have to reauthenticate for privileged actions until the user's session is terminated.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"7432","uuid":"6f016046-4b6b-4e36-a6c8-5329e7de0894","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 00EE24CD4AA60A3E37268FA199F0A3C6A52582AB\r\n~~~~~\r\nConfiguration for 'OL 9 must require reauthentication when using the \"sudo\" command.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271723","group_tree":[{"id":"V-271723","title":"SRG-OS-000312-GPOS-00123","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271723","severity":"medium","group_title":"SRG-OS-000312-GPOS-00123","rule_id_src":"SV-271723r1091881_rule","rule_id":"SV-271723","rule_version":"OL09-00-002361","rule_title":"OL 9 must restrict the use of the su command.","fix_text":"Configure OL 9 to require users to be in the \"wheel\" group to run su command.\n\nIn file \"/etc/pam.d/su\", uncomment the following line:\n\n\"#auth    required    pam_wheel.so use_uid\"\n\nOr use the following command to update /etc/pam.d/su \n\n$ sed '/^[[:space:]]*#[[:space:]]*auth[[:space:]]\\+required[[:space:]]\\+pam_wheel\\.so[[:space:]]\\+use_uid$/s/^[[:space:]]*#//' -i /etc/pam.d/su\n\nIf necessary, create a \"wheel\" group and add administrative users to the group.\n\n$ grep wheel /etc/group","weight":"10.0","check_content":"Verify that OL 9 requires uses to be members of the \"wheel\" group with the following command:\n\n$ grep pam_wheel /etc/pam.d/su \nauth             required        pam_wheel.so use_uid \n\nIf a line for \"pam_wheel.so\" does not exist, or is commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The su program allows to run commands with a substitute user and group ID. It is commonly used to run commands as the root user. Limiting access to such commands is considered a good security practice.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002165"],"reference_identifier":"3236","uuid":"1bab9c36-ee95-4af3-97f8-97721f682ea7","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 76A28F47AB7F7718F7E864C515AED05679F6CCCF\r\n~~~~~\r\nRequired configuration for 'OL 9 must restrict the use of the su command.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271724","group_tree":[{"id":"V-271724","title":"SRG-OS-000327-GPOS-00127","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271724","severity":"medium","group_title":"SRG-OS-000327-GPOS-00127","rule_id_src":"SV-271724r1091884_rule","rule_id":"SV-271724","rule_version":"OL09-00-002362","rule_title":"OL 9 must require users to reauthenticate for privilege escalation.","fix_text":"Configure OL 9 to not allow users to execute privileged actions without authenticating.\n\nRemove any occurrence of \"!authenticate\" found in \"/etc/sudoers\" file or files in the \"/etc/sudoers.d\" directory.\n\n$ sudo sed -i '/\\!authenticate/ s/^/# /g' /etc/sudoers /etc/sudoers.d/*","weight":"10.0","check_content":"Verify that OL 9 requires users to reauthenticate for privilege escalation.\n\nVerify that \"/etc/sudoers\" has no occurrences of \"!authenticate\" with the following command:\n\n$ sudo grep -ri '!authenticate' /etc/sudoers /etc/sudoers.d/*\n\nIf any occurrences of \"!authenticate\" are returned, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Without reauthentication, users may access resources or perform tasks for which they do not have authorization.\n\nWhen operating systems provide the capability to escalate a functional capability, it is critical that the user reauthenticate.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002234"],"reference_identifier":"8421","uuid":"668b6003-8754-4201-bda3-5652bca37d24","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: FB6244FF8DFFB9D3FDD70F4F4F30F5609BCEB88F\r\n~~~~~\r\nConfiguration for 'OL 9 must require users to reauthenticate for privilege escalation.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271725","group_tree":[{"id":"V-271725","title":"SRG-OS-000327-GPOS-00127","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271725","severity":"medium","group_title":"SRG-OS-000327-GPOS-00127","rule_id_src":"SV-271725r1155318_rule","rule_id":"SV-271725","rule_version":"OL09-00-002363","rule_title":"OL 9 must require users to provide a password for privilege escalation.","fix_text":"Configure OL 9 to not allow users to execute privileged actions without authenticating with a password.\n\nRemove any occurrence of \"NOPASSWD\" found in \"/etc/sudoers\" file or files in the \"/etc/sudoers.d\" directory.\n\n$ sudo sed -i '/NOPASSWD/ s/^/# /g' /etc/sudoers /etc/sudoers.d/*","weight":"10.0","check_content":"Verify OL 9 requires users to provide a password for privilege escalation.\n\nVerify \"/etc/sudoers\" has no occurrences of \"NOPASSWD\" with the following command:\n\n$ sudo grep -iR nopasswd /etc/sudoers /etc/sudoers.d/\n\nIf any occurrences of \"NOPASSWD\" are returned from the command and have not been documented with the information system security officer (ISSO) as an organizationally defined administrative group using multifactor authentication (MFA), this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Without reauthentication, users may access resources or perform tasks for which they do not have authorization.\n\nWhen operating systems provide the capability to escalate a functional capability, it is critical that the user reauthenticate.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002234"],"reference_identifier":"5786","uuid":"a7883cd0-0924-4d8b-9ab4-8ed7fa52a0ae","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 0E2272241776D2FEB413C333E0EDA71446694011\r\n~~~~~\r\nRequired configuration for 'OL 9 must require users to provide a password for privilege escalation.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271726","group_tree":[{"id":"V-271726","title":"SRG-OS-000327-GPOS-00127","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271726","severity":"medium","group_title":"SRG-OS-000327-GPOS-00127","rule_id_src":"SV-271726r1091890_rule","rule_id":"SV-271726","rule_version":"OL09-00-002364","rule_title":"OL 9 must not be configured to bypass password requirements for privilege escalation.","fix_text":"Configure the operating system to require users to supply a password for privilege escalation.\n\nRemove any occurrences of \" pam_succeed_if \" in the  \"/etc/pam.d/sudo\" file.","weight":"10.0","check_content":"Verify that OL 9 is not configured to bypass password requirements for privilege escalation with the following command:\n\n$ grep pam_succeed_if /etc/pam.d/sudo \n\nIf any occurrences of \"pam_succeed_if\" are returned, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Without reauthentication, users may access resources or perform tasks for which they do not have authorization. When operating systems provide the capability to escalate a functional capability, it is critical the user reauthenticate.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002234"],"reference_identifier":"5407","uuid":"68c4615f-435c-46c8-a0bf-d0ded902eda3","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 0BFD9FA97737D8B533A6C5D516642937148DDF70\r\n~~~~~\r\nRequired configuration for 'OL 9 must not be configured to bypass password requirements for privilege escalation.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271727","group_tree":[{"id":"V-271727","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271727","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271727r1091893_rule","rule_id":"SV-271727","rule_version":"OL09-00-002370","rule_title":"OL 9 must disable the use of user namespaces.","fix_text":"Configure OL 9 to disable the use of user namespaces by adding the following line to a file, in the \"/etc/sysctl.d\" directory:\n\nNote: User namespaces are used primarily for Linux containers. If containers are in use, this requirement is Not Applicable. \n\nuser.max_user_namespaces = 0\n\nThe system configuration files need to be reloaded for the changes to take effect. To reload the contents of the files, run the following command:\n\n$ sudo sysctl --system","weight":"10.0","check_content":"Note: User namespaces are used primarily for Linux containers. If containers are in use, this requirement is Not Applicable.\n\nVerify that OL 9 disables the use of user namespaces with the following commands:\n\n$ sysctl user.max_user_namespaces\nuser.max_user_namespaces = 0\n\nIf the returned line does not have a value of \"0\", or a line is not returned, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"User namespaces are used primarily for Linux containers. The value \"0\" disallows the use of user namespaces.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"2957","uuid":"fa4d9a78-515b-414e-bd06-385c41dc3a0f","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 51053011143EC3C503B89533A4D8833288196EE2\r\n~~~~~\r\nConfiguration for 'OL 9 must disable the use of user namespaces.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271728","group_tree":[{"id":"V-271728","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271728","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271728r1091896_rule","rule_id":"SV-271728","rule_version":"OL09-00-002380","rule_title":"OL 9 must disable the kernel.core_pattern.","fix_text":"Configure OL 9 to disable storing core dumps.\n\nAdd or edit the following line in a system configuration file, in the \"/etc/sysctl.d/\" directory:\n\nkernel.core_pattern = |/bin/false\n\nThe system configuration files need to be reloaded for the changes to take effect. To reload the contents of the files, run the following command:\n\n$ sudo sysctl --system","weight":"10.0","check_content":"Verify that OL 9 disables storing core dumps with the following commands:\n\n$ sysctl kernel.core_pattern\nkernel.core_pattern = |/bin/false\n\nIf the returned line does not have a value of \"|/bin/false\", or a line is not returned and the need for core dumps is not documented with the information system security officer (ISSO) as an operational requirement, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A core dump includes a memory image taken at the time the operating system terminates an application. The memory image could contain sensitive data and is generally useful only for developers trying to debug problems.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"3566","uuid":"23616b21-023d-45c9-bb5b-eb77f97b39c1","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-271729","group_tree":[{"id":"V-271729","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271729","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271729r1155325_rule","rule_id":"SV-271729","rule_version":"OL09-00-002381","rule_title":"OL 9 must disable core dump backtraces.","fix_text":"Configure the operating system to disable core dump backtraces.\n\nAdd or modify the following line in /etc/systemd/coredump.conf:\n\nProcessSizeMax=0","weight":"10.0","check_content":"Note: If kernel dumps are disabled in accordance with OL09-00-002380, this requirement is not applicable.\n\nVerify OL 9 disables core dump backtraces by issuing the following command:\n\n$ grep -i process /etc/systemd/coredump.conf\nProcessSizeMax=0\n\nIf the \"ProcessSizeMax\" item is missing, commented out, or the value is anything other than \"0\" and the need for core dumps is not documented with the information system security officer (ISSO) as an operational requirement for all domains that have the \"core\" item assigned, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A core dump includes a memory image taken at the time the operating system terminates an application. The memory image could contain sensitive data and is generally useful only for developers or system operators trying to debug problems.\n\nEnabling core dumps on production systems is not recommended; however, there may be overriding operational requirements to enable advanced debugging. Permitting temporary enablement of core dumps during such situations must be reviewed through local needs and policy.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"4897","uuid":"ff85b95c-5a42-40c6-8897-aea1aec69c9a","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-271730","group_tree":[{"id":"V-271730","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271730","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271730r1155327_rule","rule_id":"SV-271730","rule_version":"OL09-00-002382","rule_title":"OL 9 must disable storing core dumps.","fix_text":"Configure the operating system to disable storing core dumps for all users.\n\nAdd or modify the following line in /etc/systemd/coredump.conf:\n\nStorage=none","weight":"10.0","check_content":"Note: If kernel dumps are disabled in accordance with OL09-00-002380, this requirement is not applicable.\n\nVerify OL 9 disables storing core dumps for all users by issuing the following command:\n\n$ grep -i storage /etc/systemd/coredump.conf\nStorage=none\n\nIf the \"Storage\" item is missing, commented out, or the value is anything other than \"none\" and the need for core dumps is not documented with the information system security officer (ISSO) as an operational requirement for all domains that have the \"core\" item assigned, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A core dump includes a memory image taken at the time the operating system terminates an application. The memory image could contain sensitive data and is generally useful only for developers or system operators trying to debug problems. Enabling core dumps on production systems is not recommended; however, there may be overriding operational requirements to enable advanced debugging. Permitting temporary enablement of core dumps during such situations must be reviewed through local needs and policy.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"5847","uuid":"f77641d6-603f-46ae-8327-a42f4a548855","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: D0ED94C088652E44A8E26516271415D2AAE80805\r\n~~~~~\r\nConfiguration for 'OL 9 must disable storing core dumps.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271731","group_tree":[{"id":"V-271731","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271731","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271731r1155302_rule","rule_id":"SV-271731","rule_version":"OL09-00-002383","rule_title":"OL 9 must disable core dumps for all users.","fix_text":"Configure OL 9 to disable core dumps for all users.\n\nAdd the following line to the top of the /etc/security/limits.conf or in a single \".conf\" file defined in /etc/security/limits.d/:\n\n* hard core 0\n\nRemove or comment out any entries for users or groups with a value set to anything other than \"0\".","weight":"10.0","check_content":"Note: If kernel dumps are disabled in accordance with OL09-00-002380, this requirement is not applicable.\n\nVerify OL 9 disables core dumps for all users by issuing the following command:\n\n$ grep -r -s core /etc/security/limits.conf /etc/security/limits.d/*.conf\n\n/etc/security/limits.conf:* hard core 0\n\nThis can be set as a global domain (with the * wildcard) but may be set differently for multiple domains.\n\nIf the \"core\" item is missing or commented out, or the value is anything other than \"0\", and the need for core dumps is not documented with the information system security officer (ISSO) as an operational requirement for all domains that have the \"core\" item assigned, this is a finding.\n\nIf entries exist for users or groups with a value set to anything other than \"0\", this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A core dump includes a memory image taken at the time the operating system terminates an application. The memory image could contain sensitive data and is generally useful only for developers trying to debug problems.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"8503","uuid":"7dfe9ade-f411-4335-ba0f-b532a1985906","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 20A36B495A8438450C4E18EA27F6A77198C9CF45\r\n~~~~~\r\nRequired configuration for 'OL 9 must disable core dumps for all users.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271732","group_tree":[{"id":"V-271732","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271732","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271732r1155329_rule","rule_id":"SV-271732","rule_version":"OL09-00-002384","rule_title":"OL 9 must disable acquiring, saving, and processing core dumps.","fix_text":"Configure the system to disable the systemd-coredump.socket with the following command:\n\n$ sudo systemctl mask --now systemd-coredump.socket\n\nCreated symlink /etc/systemd/system/systemd-coredump.socket -> /dev/null\n\nReload the daemon for this change to take effect.\n\n$ sudo systemctl daemon-reload","weight":"10.0","check_content":"Note: If kernel dumps are disabled in accordance with OL09-00-002380, this requirement is not applicable.\n\nVerify OL 9 is not configured to acquire, save, or process core dumps with the following command:\n\n$ systemctl status systemd-coredump.socket\nsystemd-coredump.socket\nLoaded: masked (Reason: Unit systemd-coredump.socket is masked.)\nActive: inactive (dead)\n\nIf the \"systemd-coredump.socket\" is loaded and not masked and the need for core dumps is not documented with the information system security officer (ISSO) as an operational requirement, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A core dump includes a memory image taken at the time the operating system terminates an application. The memory image could contain sensitive data and is generally useful only for developers trying to debug problems.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"6295","uuid":"0e2af8c9-3ab7-43be-af92-53f77c156e7d","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 175B959A65030B969D50B1014D9858F7EB6B9F2E\r\n~~~~~\r\nConfiguration for 'OL 9 must disable acquiring, saving, and processing core dumps.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271733","group_tree":[{"id":"V-271733","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271733","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271733r1092598_rule","rule_id":"SV-271733","rule_version":"OL09-00-002385","rule_title":"OL 9 must be configured so that the kdump service is disabled.","fix_text":"Configure OL 9 to disable and mask the kdump service.\n\nTo disable the kdump service, run the following command:\n\n$ sudo systemctl disable --now kdump\n\nTo mask the kdump service, run the following command:\n\n$ sudo systemctl mask --now kdump","weight":"10.0","check_content":"Verify that OL 9 kdump service is disabled or masked in system boot configuration with the following command:\n\n$ systemctl is-enabled  kdump  \ndisabled (or masked)\n\nVerify that the kdump service is not active (i.e., not running) through current runtime configuration with the following command:\n\n$ systemctl is-active kdump \ninactive \n\nVerify that the kdump service is masked with the following command:\n\n$ systemctl show  kdump  | grep \"LoadState\\|UnitFileState\" \nLoadState=masked \nUnitFileState=masked \n\nIf the \"kdump\" service is loaded or active, and is not masked, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Kernel core dumps may contain the full contents of system memory at the time of the crash. Kernel core dumps consume a considerable amount of disk space and may result in denial of service by exhausting the available space on the target file system partition. Unless the system is used for kernel development or testing, there is little need to run the kdump service.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"8836","uuid":"2c8b88c6-4c1c-423a-9712-54d41e09d41f","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-271734","group_tree":[{"id":"V-271734","title":"SRG-OS-000433-GPOS-00192","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271734","severity":"medium","group_title":"SRG-OS-000433-GPOS-00192","rule_id_src":"SV-271734r1091914_rule","rule_id":"SV-271734","rule_version":"OL09-00-002390","rule_title":"OL 9 must clear SLUB/SLAB objects to prevent use-after-free attacks.","fix_text":"Configure OL 9 to enable poisoning of SLUB/SLAB objects with the following commands:\n\n$ sudo grubby --update-kernel=ALL --args=\"slub_debug=P\"\n\nAdd or modify the following line in \"/etc/default/grub\" to ensure the configuration survives kernel updates:\n\nGRUB_CMDLINE_LINUX=\"slub_debug=P\"","weight":"10.0","check_content":"Verify that OL 9 GRUB 2 is configured to enable poisoning of SLUB/SLAB objects to mitigate use-after-free vulnerabilities with the following commands:\n\nCheck that the current GRUB 2 configuration has poisoning of SLUB/SLAB objects enabled:\n\n$ sudo grubby --info=ALL | grep args | grep -v 'slub_debug=P' \nIf any output is returned, this is a finding.\n\nCheck that poisoning of SLUB/SLAB objects is enabled by default to persist in kernel updates: \n\n$ sudo grep slub_debug /etc/default/grub\nGRUB_CMDLINE_LINUX=\"slub_debug=P\"\n\nIf \"slub_debug\" is not set to \"P\", is missing or commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Some adversaries launch attacks with the intent of executing code in nonexecutable regions of memory or in memory locations that are prohibited. Security safeguards employed to protect memory include, for example, data execution prevention and address space layout randomization. Data execution prevention safeguards can be either hardware-enforced or software-enforced with hardware providing the greater strength of mechanism.\n\nPoisoning writes an arbitrary value to freed pages, so any modification or reference to that page after being freed or before being initialized will be detected and prevented. This prevents many types of use-after-free vulnerabilities at little performance cost. Also prevents leak of data and detection of corrupted memory.\n\nSLAB objects are blocks of physically contiguous memory. SLUB is the unqueued SLAB allocator.\n\nSatisfies: SRG-OS-000433-GPOS-00192, SRG-OS-000134-GPOS-00068","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002824","CCI-001084"],"reference_identifier":"8514","uuid":"042b908f-debc-43c2-b700-097bd94cdf9b","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: ABC15015CE8BC11DB5E2CF293D175EECECDCF38F\r\n~~~~~\r\nConfiguration for 'OL 9 must clear SLUB/SLAB objects to prevent use-after-free attacks.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271735","group_tree":[{"id":"V-271735","title":"SRG-OS-000433-GPOS-00193","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271735","severity":"low","group_title":"SRG-OS-000433-GPOS-00193","rule_id_src":"SV-271735r1091917_rule","rule_id":"SV-271735","rule_version":"OL09-00-002391","rule_title":"OL 9 must enable mitigations against processor-based vulnerabilities.","fix_text":"Configure OL 9 to enable kernel page-table isolation with the following command:\n\n$ sudo grubby --update-kernel=ALL --args=\"pti=on\"\n\nAdd or modify the following line in \"/etc/default/grub\" to ensure the configuration survives kernel updates:\n\nGRUB_CMDLINE_LINUX=\"pti=on\"","weight":"10.0","check_content":"Verify that OL 9 enables kernel page-table isolation with the following command:\n\n$ sudo grubby --info=ALL | grep pti\nargs=\"ro crashkernel=auto resume=/dev/mapper/ol-swap rd.lvm.lv=ol/root rd.lvm.lv=ol/swap rhgb quiet fips=1 audit=1 audit_backlog_limit=8192 pti=on \n\nIf the \"pti\" entry does not equal \"on\", or is missing, this is a finding.\n\nCheck that kernel page-table isolation is enabled by default to persist in kernel updates: \n\n$ sudo grep pti /etc/default/grub\nGRUB_CMDLINE_LINUX=\"pti=on\"\n\nIf \"pti\" is not set to \"on\", is missing or commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Kernel page-table isolation is a kernel feature that mitigates the Meltdown security vulnerability and hardens the kernel against attempts to bypass kernel address space layout randomization (KASLR).\n\nSatisfies: SRG-OS-000433-GPOS-00193, SRG-OS-000095-GPOS-00049","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002824","CCI-000381"],"reference_identifier":"6101","uuid":"9838957c-cc99-42b9-9007-36eb31cc1c97","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: C8082870E9023590EDF8FD45D16B687D83EE939B\r\n~~~~~\r\nConfiguration for 'OL 9 must enable mitigations against processor-based vulnerabilities.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271736","group_tree":[{"id":"V-271736","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271736","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271736r1091920_rule","rule_id":"SV-271736","rule_version":"OL09-00-002392","rule_title":"OL 9 must disable the ability of systemd to spawn an interactive boot process.","fix_text":"Configure OL 9 to allocate sufficient audit_backlog_limit to disable the ability of systemd to spawn an interactive boot process with the following command:\n\n$ sudo grubby --update-kernel=ALL --remove-args=\"systemd.confirm_spawn\"","weight":"10.0","check_content":"Verify that OL 9 GRUB 2 is configured to disable interactive boot.\n\nCheck that the current GRUB 2 configuration disables the ability of systemd to spawn an interactive boot process with the following command:\n\n$ sudo grubby --info=ALL | grep args | grep 'systemd.confirm_spawn'\n\nIf any output is returned, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Using interactive or recovery boot, the console user could disable auditing, firewalls, or other services, weakening system security.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"6975","uuid":"3ec3a2d5-dc92-41db-9606-7c16f6b3cfb2","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 8C7609107CCAEC07F8D528FF2656E5C8C719B1D9\r\n~~~~~\r\nRequired configuration for 'OL 9 must disable the ability of systemd to spawn an interactive boot process.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271737","group_tree":[{"id":"V-271737","title":"SRG-OS-000134-GPOS-00068","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271737","severity":"medium","group_title":"SRG-OS-000134-GPOS-00068","rule_id_src":"SV-271737r1094967_rule","rule_id":"SV-271737","rule_version":"OL09-00-002393","rule_title":"OL 9 must disable virtual system calls.","fix_text":"Document the use of virtual system calls with the ISSO as an operational requirement or disable them with the following command:\n\n$ sudo grubby --update-kernel=ALL --args=\"vsyscall=none\"\n\nAdd or modify the following line in \"/etc/default/grub\" to ensure the configuration survives kernel updates:\n\nGRUB_CMDLINE_LINUX=\"vsyscall=none\"","weight":"10.0","check_content":"Verify that OL 9 disables virtual system calls. \n\nCheck the current GRUB 2 configuration with the following command:\n\n$ sudo grubby --info=ALL | grep args | grep -v 'vsyscall=none'\n\nIf any output is returned, this is a finding.\n\nCheck that virtual system calls are disabled by default to persist in kernel updates with the following command: \n\n$ grep vsyscall /etc/default/grub\nGRUB_CMDLINE_LINUX=\"vsyscall=none\"\n\nIf \"vsyscall\" is not set to \"none\", is missing or commented out, and is not documented with the information system security officer (ISSO) as an operational requirement, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"System calls are special routines in the Linux kernel, which userspace applications ask to do privileged tasks. Invoking a system call is an expensive operation because the processor must interrupt the currently executing task and switch context to kernel mode and then back to userspace after the system call completes. Virtual system calls map into user space a page that contains some variables and the implementation of some system calls. This allows the system calls to be executed in userspace to alleviate the context switching expense.\n\nVirtual system calls provide an opportunity of attack for a user who has control of the return instruction pointer. Disabling virtual system calls help to prevent return-oriented programming (ROP) attacks via buffer overflows and overruns. If the system intends to run containers based on OL 6 components, virtual system calls will have to be enabled so the components function properly.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001084"],"reference_identifier":"3489","uuid":"b96bc3b9-3195-4cba-9583-09f839bd5b89","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: B88E33F2D1BED839A246D0F40782F58AB3907B56\r\n~~~~~\r\nRequired configuration for 'OL 9 must disable virtual system calls.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271738","group_tree":[{"id":"V-271738","title":"SRG-OS-000134-GPOS-00068","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271738","severity":"medium","group_title":"SRG-OS-000134-GPOS-00068","rule_id_src":"SV-271738r1092600_rule","rule_id":"SV-271738","rule_version":"OL09-00-002394","rule_title":"OL 9 must clear the page allocator to prevent use-after-free attacks.","fix_text":"Configure OL 9 to enable page poisoning with the following commands:\n\n$ sudo grubby --update-kernel=ALL --args=\"page_poison=1\"\n\nAdd or modify the following line in \"/etc/default/grub\" to ensure the configuration survives kernel updates:\n\nGRUB_CMDLINE_LINUX=\"page_poison=1\"","weight":"10.0","check_content":"Verify that OL 9 clears the page allocator to prevent use-after-free attacks.\n\nVerify that GRUB 2 is configured to enable page poisoning to mitigate use-after-free vulnerabilities.\n\nCheck that the current GRUB 2 configuration has page poisoning enabled with the following command:\n\n$ sudo grubby --info=ALL | grep args | grep -v 'page_poison=1'\n\nIf any output is returned, this is a finding.\n\nCheck that page poisoning is enabled by default to persist in kernel updates with the following command: \n\n$ grep page_poison /etc/default/grub\nGRUB_CMDLINE_LINUX=\"page_poison=1\"\n\nIf \"page_poison\" is not set to \"1\", is missing or commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Poisoning writes an arbitrary value to freed pages, so any modification or reference to that page after being freed or before being initialized will be detected and prevented. This prevents many types of use-after-free vulnerabilities at little performance cost. Also prevents leak of data and detection of corrupted memory.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001084"],"reference_identifier":"6033","uuid":"ea6fb544-3a12-4808-b9aa-b385c53048e6","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 51F774D27376538EF4E36FA05F4D4FD4E770B460\r\n~~~~~\r\nRequired configuration for 'OL 9 must clear the page allocator to prevent use-after-free attacks.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271739","group_tree":[{"id":"V-271739","title":"SRG-OS-000269-GPOS-00103","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271739","severity":"medium","group_title":"SRG-OS-000269-GPOS-00103","rule_id_src":"SV-271739r1091929_rule","rule_id":"SV-271739","rule_version":"OL09-00-002400","rule_title":"OL 9 systemd-journald service must be enabled.","fix_text":"Configure OL 9 to enable the systemd-journald service with the following command:\n\n$ sudo systemctl enable --now systemd-journald","weight":"10.0","check_content":"Verify that OL 9 systemd-journald is active with the following command:\n\n$ systemctl is-active systemd-journald\nactive\n\nIf the systemd-journald service is not active, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"In the event of a system failure, OL 9 must preserve any information necessary to determine cause of failure and any information necessary to return to operations with least disruption to system processes.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001665"],"reference_identifier":"6843","uuid":"b2e8f0c3-e90c-40d8-bc1d-d5e9dd0933e0","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: CE8309D3F0C2FB0D1BA51A446CDE408EAD2598B2\r\n~~~~~\r\nRequired configuration for 'OL 9 systemd-journald service must be enabled.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271740","group_tree":[{"id":"V-271740","title":"SRG-OS-000312-GPOS-00123","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271740","severity":"medium","group_title":"SRG-OS-000312-GPOS-00123","rule_id_src":"SV-271740r1091932_rule","rule_id":"SV-271740","rule_version":"OL09-00-002401","rule_title":"OL 9 must enable kernel parameters to enforce discretionary access control on hardlinks.","fix_text":"Configure OL 9 to enable DAC on hardlinks with the following:\n\nAdd or edit the following line in a system configuration file in the \"/etc/sysctl.d/\" directory:\n\nfs.protected_hardlinks = 1\n\nLoad settings from all system configuration files with the following command:\n\n$ sudo sysctl --system","weight":"10.0","check_content":"Verify that OL 9 is configured to enable DAC on hardlinks.\n\nCheck the status of the fs.protected_hardlinks kernel parameter with the following command:\n\n$ sudo sysctl fs.protected_hardlinks\nfs.protected_hardlinks = 1\n\nIf \"fs.protected_hardlinks\" is not set to \"1\" or is missing, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"By enabling the fs.protected_hardlinks kernel parameter, users can no longer create soft or hard links to files they do not own. Disallowing such hardlinks mitigates vulnerabilities based on insecure file system accessed by privileged programs, avoiding an exploitation vector exploiting unsafe use of open() or creat().\n\nSatisfies: SRG-OS-000312-GPOS-00123, SRG-OS-000324-GPOS-00125","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002165","CCI-002235"],"reference_identifier":"1953","uuid":"9b28c1f5-7e8e-4e7c-a65f-c23e677f7ac6","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 319EEEFFEFB3AE31CD110CA4C0C35CE25905A26B\r\n~~~~~\r\nRequired configuration for 'OL 9 must enable kernel parameters to enforce discretionary access control on hardlinks.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271741","group_tree":[{"id":"V-271741","title":"SRG-OS-000312-GPOS-00123","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271741","severity":"medium","group_title":"SRG-OS-000312-GPOS-00123","rule_id_src":"SV-271741r1091935_rule","rule_id":"SV-271741","rule_version":"OL09-00-002402","rule_title":"OL 9 must enable kernel parameters to enforce discretionary access control on symlinks.","fix_text":"Configure OL 9 to enable DAC on symlinks with the following:\n\nAdd or edit the following line in a system configuration file in the \"/etc/sysctl.d/\" directory:\n\nfs.protected_symlinks = 1\n\nLoad settings from all system configuration files with the following command:\n\n$ sudo sysctl --system","weight":"10.0","check_content":"Verify that OL 9 is configured to enable DAC on symlinks.\n\nCheck the status of the fs.protected_symlinks kernel parameter with the following command:\n\n$ sudo sysctl fs.protected_symlinks\nfs.protected_symlinks = 1\n\nIf \"fs.protected_symlinks \" is not set to \"1\" or is missing, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"By enabling the fs.protected_symlinks kernel parameter, symbolic links are permitted to be followed only when outside a sticky world-writable directory, or when the user identifier (UID) of the link and follower match, or when the directory owner matches the symlink's owner. Disallowing such symlinks helps mitigate vulnerabilities based on insecure file system accessed by privileged programs, avoiding an exploitation vector exploiting unsafe use of open() or creat().\n\nSatisfies: SRG-OS-000312-GPOS-00123, SRG-OS-000324-GPOS-00125","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002165","CCI-002235"],"reference_identifier":"4314","uuid":"27c86f3e-5d77-4cd8-955e-c9ebb4792b48","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 66C807BE263E41A6D3BA18B39615ABCEA30DFD7C\r\n~~~~~\r\nConfiguration for 'OL 9 must enable kernel parameters to enforce discretionary access control on symlinks.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271742","group_tree":[{"id":"V-271742","title":"SRG-OS-000324-GPOS-00125","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271742","severity":"medium","group_title":"SRG-OS-000324-GPOS-00125","rule_id_src":"SV-271742r1091938_rule","rule_id":"SV-271742","rule_version":"OL09-00-002403","rule_title":"OL 9 debug-shell systemd service must be disabled.","fix_text":"Configure OL 9 to mask the debug-shell systemd service with the following command:\n\n$ sudo systemctl disable --now debug-shell.service\n$ sudo systemctl mask --now debug-shell.service","weight":"10.0","check_content":"Verify that OL 9 is configured to mask the debug-shell systemd service with the following command:\n\n$ systemctl status debug-shell.service\ndebug-shell.service\nLoaded: masked (Reason: Unit debug-shell.service is masked.)\nActive: inactive (dead)\n\nIf the \"debug-shell.service\" is loaded and not masked, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The debug-shell requires no authentication and provides root privileges to anyone who has physical access to the machine. While this feature is disabled by default, masking it adds an additional layer of assurance that it will not be enabled via a dependency in systemd. This also prevents attackers with physical access from trivially bypassing security on the machine through valid troubleshooting configurations and gaining root access when the system is rebooted.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002235"],"reference_identifier":"8391","uuid":"6262dc2c-d588-429b-8d0e-9b347e531a5a","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: EDB6F0380088692FA806F59752471784557196F9\r\n~~~~~\r\nConfiguration for 'OL 9 debug-shell systemd service must be disabled.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271743","group_tree":[{"id":"V-271743","title":"SRG-OS-000033-GPOS-00014","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271743","severity":"high","group_title":"SRG-OS-000033-GPOS-00014","rule_id_src":"SV-271743r1184204_rule","rule_id":"SV-271743","rule_version":"OL09-00-002404","rule_title":"OL 9 IP tunnels must use 140-3 approved cryptographic algorithms.","fix_text":"Configure IPsec to use the systemwide cryptographic policy.\n\nAdd the following line to \"/etc/ipsec.conf\":\n\ninclude /etc/crypto-policies/back-ends/libreswan.config","weight":"10.0","check_content":"Note: If the IPsec service is not installed, this requirement is Not Applicable.\n\nVerify the IPsec service uses the systemwide cryptographic policy with the following command:\n\n$ grep include /etc/ipsec.conf /etc/ipsec.d/*.conf\n/etc/ipsec.conf:include /etc/crypto-policies/back-ends/libreswan.config\n\nIf the IPsec configuration file does not contain \"include /etc/crypto-policies/back-ends/libreswan.config\", this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Overriding the system crypto policy makes the behavior of the Libreswan service violate expectations and makes system configuration more fragmented.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000068"],"reference_identifier":"8896","uuid":"c10f4cdb-36d7-4eae-ba54-df527c23d0dd","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 9361849039B4FAF751DF57B2EA89AA64F21C9B93\r\n~~~~~\r\nConfiguration for 'OL 9 IP tunnels must use 140-3 approved cryptographic algorithms.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271744","group_tree":[{"id":"V-271744","title":"SRG-OS-000046-GPOS-00022","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271744","severity":"medium","group_title":"SRG-OS-000046-GPOS-00022","rule_id_src":"SV-271744r1091944_rule","rule_id":"SV-271744","rule_version":"OL09-00-002405","rule_title":"OL 9 must have mail aliases to notify the information system security officer (ISSO) and system administrator (SA) (at a minimum) in the event of an audit processing failure.","fix_text":"Configure OL 9 to have mail aliases notify the ISSO and SA (at a minimum) in the event of an audit processing failure.\n\nEdit the aliases map file (by default /etc/aliases) used by Postfix and configure a root alias (using the user ISSO as an example):\n\nroot:    ISSO\n\nUpdate the aliases database with the command:\n\n$ sudo newaliases","weight":"10.0","check_content":"Verify that OL 9 is configured to notify the appropriate interactive users in the event of an audit processing failure.\n\nFind the alias maps that are being used with the following command:\n\n$ postconf alias_maps \nalias_maps = hash:/etc/aliases\n\nQuery the Postfix alias maps for an alias for the root user with the following command:\n\n$ postmap -q root hash:/etc/aliases\nisso\n\nIf an alias is not set, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"It is critical for the appropriate personnel to be aware if a system is at risk of failing to process audit logs as required. Without this notification, the security personnel may be unaware of an impending failure of the audit capability, and system operation may be adversely affected.\n\nAudit processing failures include software/hardware errors, failures in the audit capturing mechanisms, and audit storage capacity being reached or exceeded.\n\nThis requirement applies to each audit data storage repository (i.e., distinct information system component where audit records are stored), the centralized audit storage capacity of organizations (i.e., all audit data storage repositories combined), or both.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000139"],"reference_identifier":"9226","uuid":"0a9b3539-fb34-4af8-a18a-c15d0c1d00d2","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 2630311E53D88A4A3D338BEF3FB45CBCD42F5C28\r\n~~~~~\r\nRequired configuration for 'OL 9 must have mail aliases to notify the information system security officer (ISSO) and system administrator (SA) (at a minimum) in the event of an audit processing failure.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271745","group_tree":[{"id":"V-271745","title":"SRG-OS-000132-GPOS-00067","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271745","severity":"medium","group_title":"SRG-OS-000132-GPOS-00067","rule_id_src":"SV-271745r1117266_rule","rule_id":"SV-271745","rule_version":"OL09-00-002406","rule_title":"OL 9 must restrict access to the kernel message buffer.","fix_text":"Configure OL 9 to restrict access to the kernel message buffer.\n\nAdd or edit the following line in /etc/sysctl.d/99-sysctl.conf system configuration file:\n\nkernel.dmesg_restrict = 1\n\nLoad settings from all system configuration files with the following command:\n\n$ sudo sysctl --system","weight":"10.0","check_content":"Verify that OL 9 is configured to restrict access to the kernel message buffer with the following commands:\n\nCheck the status of the kernel.dmesg_restrict kernel parameter.\n\n$ sudo sysctl kernel.dmesg_restrict\nkernel.dmesg_restrict = 1\n\nIf \"kernel.dmesg_restrict\" is not set to \"1\" or is missing, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Preventing unauthorized information transfers mitigates the risk of information, including encrypted representations of information, produced by the actions of prior users/roles (or the actions of processes acting on behalf of prior users/roles) from being available to any current users/roles (or current processes) that obtain access to shared system resources (e.g., registers, main memory, hard disks) after those resources have been released back to information systems. The control of information in shared resources is also commonly referred to as object reuse and residual information protection.\n\nThis requirement generally applies to the design of an information technology product, but it can also apply to the configuration of particular information system components that are, or use, such products. This can be verified by acceptance/validation processes in DOD or other government agencies.\n\nThere may be shared resources with configurable protections (e.g., files in storage) that may be assessed on specific information system components.\n\nRestricting access to the kernel message buffer limits access to only root. This prevents attackers from gaining additional system information as a nonprivileged user.\n\nSatisfies: SRG-OS-000132-GPOS-00067, SRG-OS-000138-GPOS-00069","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001082","CCI-001090"],"reference_identifier":"8526","uuid":"69abf493-1c02-411b-b32b-33aa1db1e521","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 82F0F65241D6EFD74A5A334ECAAA7ABB8EA939D1\r\n~~~~~\r\nConfiguration for 'OL 9 must restrict access to the kernel message buffer.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271746","group_tree":[{"id":"V-271746","title":"SRG-OS-000132-GPOS-00067","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271746","severity":"medium","group_title":"SRG-OS-000132-GPOS-00067","rule_id_src":"SV-271746r1117266_rule","rule_id":"SV-271746","rule_version":"OL09-00-002407","rule_title":"OL 9 must prevent kernel profiling by nonprivileged users.","fix_text":"Configure OL 9 to prevent kernel profiling by nonprivileged users.\n\nAdd or edit the following line in /etc/sysctl.d/99-sysctl.conf system configuration file:\n\nkernel.perf_event_paranoid = 2\n\nLoad settings from all system configuration files with the following command:\n\n$ sudo sysctl --system","weight":"10.0","check_content":"Verify that OL 9 is configured to prevent kernel profiling by nonprivileged users with the following commands:\n\nCheck the status of the kernel.perf_event_paranoid kernel parameter.\n\n$ sysctl kernel.perf_event_paranoid\nkernel.perf_event_paranoid = 2\n\nIf \"kernel.perf_event_paranoid\" is not set to \"2\" or is missing, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Preventing unauthorized information transfers mitigates the risk of information, including encrypted representations of information, produced by the actions of prior users/roles (or the actions of processes acting on behalf of prior users/roles) from being available to any current users/roles (or current processes) that obtain access to shared system resources (e.g., registers, main memory, hard disks) after those resources have been released back to information systems. The control of information in shared resources is also commonly referred to as object reuse and residual information protection.\n\nThis requirement generally applies to the design of an information technology product, but it can also apply to the configuration of particular information system components that are, or use, such products. This can be verified by acceptance/validation processes in DOD or other government agencies.\n\nThere may be shared resources with configurable protections (e.g., files in storage) that may be assessed on specific information system components.\n\nSetting the kernel.perf_event_paranoid kernel parameter to \"2\" prevents attackers from gaining additional system information as a nonprivileged user.\n\nSatisfies: SRG-OS-000132-GPOS-00067, SRG-OS-000138-GPOS-00069","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001082","CCI-001090"],"reference_identifier":"3423","uuid":"d4fd67df-fcd1-4fb7-892a-27674c4a418c","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 99F3E38116E562E6A8251E801DE4CA13A9703749\r\n~~~~~\r\nRequired configuration for 'OL 9 must prevent kernel profiling by nonprivileged users.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271747","group_tree":[{"id":"V-271747","title":"SRG-OS-000132-GPOS-00067","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271747","severity":"medium","group_title":"SRG-OS-000132-GPOS-00067","rule_id_src":"SV-271747r1117266_rule","rule_id":"SV-271747","rule_version":"OL09-00-002408","rule_title":"OL 9 must restrict exposed kernel pointer addresses access.","fix_text":"Configure OL 9 to prevent the leak of kernel pointers to unprivileged users.\n\nAdd or edit the following line in /etc/sysctl.d/99-sysctl.conf system configuration file:\n\nkernel.kptr_restrict = 1\n\nReload settings from all system configuration files with the following command:\n\n$ sudo sysctl --system","weight":"10.0","check_content":"Verify that OL 9 restricts access to exposed kernel pointers with the following command:\n\n$ sysctl kernel.kptr_restrict \nkernel.kptr_restrict = 1","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Exposing kernel pointers (through procfs or \"seq_printf()\") exposes kernel writeable structures, which may contain functions pointers. If a write vulnerability occurs in the kernel, allowing write access to any of this structure, the kernel can be compromised. This option disallows any program without the CAP_SYSLOG capability to get the addresses of kernel pointers by replacing them with \"0\".\n\nSatisfies: SRG-OS-000132-GPOS-00067, SRG-OS-000433-GPOS-00192","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001082","CCI-002824"],"reference_identifier":"1969","uuid":"054bdb04-d6ba-42f6-b862-a0d09e1d8ce1","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: BAEDBE7CF92B8AC0E21C709943083608BED09B8A\r\n~~~~~\r\nConfiguration for 'OL 9 must restrict exposed kernel pointer addresses access.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271748","group_tree":[{"id":"V-271748","title":"SRG-OS-000132-GPOS-00067","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271748","severity":"medium","group_title":"SRG-OS-000132-GPOS-00067","rule_id_src":"SV-271748r1117266_rule","rule_id":"SV-271748","rule_version":"OL09-00-002409","rule_title":"OL 9 must disable access to network bpf system call from nonprivileged processes.","fix_text":"Configure OL 9 to prevent privilege escalation thru the kernel by disabling access to the bpf syscall by adding the following line to a file, in the \"/etc/sysctl.d\" directory:\n\nkernel.unprivileged_bpf_disabled = 1\n\nThe system configuration files need to be reloaded for the changes to take effect. To reload the contents of the files, run the following command:\n\n$ sudo sysctl --system","weight":"10.0","check_content":"Verify that OL 9 prevents privilege escalation thru the kernel by disabling access to the bpf system call with the following commands:\n\n$ sysctl kernel.unprivileged_bpf_disabled\nkernel.unprivileged_bpf_disabled = 1\n\nIf the returned line does not have a value of \"1\", or a line is not returned, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Loading and accessing the packet filters programs and maps using the bpf() system call has the potential of revealing sensitive information about the kernel state.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001082"],"reference_identifier":"7208","uuid":"95d5b074-54bf-48fc-8cc6-ff83deceb97d","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: A7A2BBE76224875CE4E8B80DB39F29ECC0431F84\r\n~~~~~\r\nConfiguration for 'OL 9 must disable access to network bpf system call from nonprivileged processes.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271749","group_tree":[{"id":"V-271749","title":"SRG-OS-000132-GPOS-00067","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271749","severity":"medium","group_title":"SRG-OS-000132-GPOS-00067","rule_id_src":"SV-271749r1117266_rule","rule_id":"SV-271749","rule_version":"OL09-00-002410","rule_title":"OL 9 must restrict usage of ptrace to descendant processes.","fix_text":"Configure OL 9 to restrict usage of ptrace to descendant processes by adding the following line to \"/etc/sysctl.d/99-sysctl.conf\":\n\nkernel.yama.ptrace_scope = 1\n\nThe system configuration files need to be reloaded for the changes to take effect. To reload the contents of the files, run the following command:\n\n$ sudo sysctl --system","weight":"10.0","check_content":"Verify that OL 9 restricts usage of ptrace to descendant processes with the following commands:\n\n$ sysctl kernel.yama.ptrace_scope\nkernel.yama.ptrace_scope = 1\n\nIf the returned line does not have a value of \"1\", or a line is not returned, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Unrestricted usage of ptrace allows compromised binaries to run ptrace on other processes of the user. Like this, the attacker can steal sensitive information from the target processes (e.g., SSH sessions, web browser, etc.) without any additional assistance from the user (i.e., without resorting to phishing).","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001082"],"reference_identifier":"9397","uuid":"6aa9be99-6b33-49fe-86a8-41d7b40d415e","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 17495FD70A028450FD78DFD3FA31608CD3FB9F04\r\n~~~~~\r\nConfiguration for 'OL 9 must restrict usage of ptrace to descendant processes.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271750","group_tree":[{"id":"V-271750","title":"SRG-OS-000163-GPOS-00072","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271750","severity":"medium","group_title":"SRG-OS-000163-GPOS-00072","rule_id_src":"SV-271750r1091962_rule","rule_id":"SV-271750","rule_version":"OL09-00-002411","rule_title":"OL 9 must automatically exit interactive command shell user sessions after 15 minutes of inactivity.","fix_text":"Configure OL 9 to exit interactive command shell user sessions after 15 minutes of inactivity.\n\nAdd or edit the following line in \"/etc/profile.d/tmout.sh\":\n\n#!/bin/bash\n\ndeclare -xr TMOUT=900","weight":"10.0","check_content":"Verify that OL 9 is configured to exit interactive command shell user sessions after 15 minutes of inactivity or less with the following command:\n\n$ grep -i tmout /etc/profile /etc/profile.d/*.sh\n/etc/profile.d/tmout.sh:declare -xr TMOUT=900\n\nIf \"TMOUT\" is not set to \"900\" or less in a script located in the \"/etc/'profile.d/ directory, is missing or is commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Terminating an idle interactive command shell user session within a short time period reduces the window of opportunity for unauthorized personnel to take control of it when left unattended in a virtual terminal or physical console.\n\nSatisfies: SRG-OS-000163-GPOS-00072, SRG-OS-000029-GPOS-00010","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001133","CCI-000057"],"reference_identifier":"9590","uuid":"2899af86-3d75-4d41-9b16-d28432536258","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 1045A76DED9BD1AF879A1216F0EEE2831E5BEDD9\r\n~~~~~\r\nConfiguration for 'OL 9 must automatically exit interactive command shell user sessions after 15 minutes of inactivity.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271751","group_tree":[{"id":"V-271751","title":"SRG-OS-000324-GPOS-00125","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271751","severity":"high","group_title":"SRG-OS-000324-GPOS-00125","rule_id_src":"SV-271751r1184206_rule","rule_id":"SV-271751","rule_version":"OL09-00-002412","rule_title":"OL 9 must be configured so that the systemd Ctrl-Alt-Delete burst key sequence is disabled.","fix_text":"Configure OL 9 to disable the CtrlAltDelBurstAction by adding it to a drop file in a \"/etc/systemd/system.conf.d/\" configuration file:\n\nIf no drop file exists, create one with the following command:\n\n$ sudo mkdir -p /etc/systemd/system.conf.d && sudo vi /etc/systemd/system.conf.d/55-CtrlAltDel-BurstAction.conf\n\nEdit the file to contain the setting by adding the following text:\n\nCtrlAltDelBurstAction=none\n\nReload the daemon for this change to take effect.\n\n$ sudo systemctl daemon-reload","weight":"10.0","check_content":"Verify OL 9 is configured to not reboot the system when Ctrl-Alt-Delete is pressed seven times within two seconds with the following command:\n\n$ sudo grep -iR CtrlAltDelBurstAction /etc/systemd/system*\n/etc/systemd/system.conf.d/55-CtrlAltDel-BurstAction:CtrlAltDelBurstAction=none\n\nIf the \"CtrlAltDelBurstAction\" is not set to \"none\", commented out, or is missing, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A locally logged-on user who presses Ctrl-Alt-Delete when at the console can reboot the system. If accidentally pressed, as could happen in the case of a mixed OS environment, this can create the risk of short-term loss of availability of systems due to unintentional reboot. In a graphical user environment, risk of unintentional reboot from the Ctrl-Alt-Delete sequence is reduced because the user will be prompted before any action is taken.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002235"],"reference_identifier":"6309","uuid":"af1cc464-66bd-4093-8de0-3bf5ec0371ee","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: D12E7A88DF7DD8C20E607E5F238F910928D3672C\r\n~~~~~\r\nConfiguration for 'OL 9 must be configured so that the systemd Ctrl-Alt-Delete burst key sequence is disabled.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271752","group_tree":[{"id":"V-271752","title":"SRG-OS-000324-GPOS-00125","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271752","severity":"high","group_title":"SRG-OS-000324-GPOS-00125","rule_id_src":"SV-271752r1091968_rule","rule_id":"SV-271752","rule_version":"OL09-00-002413","rule_title":"OL 9 must be configured so that the x86 Ctrl-Alt-Delete key sequence is disabled.","fix_text":"Configure OL 9 to disable the ctrl-alt-del.target with the following command:\n\n$ sudo systemctl disable --now ctrl-alt-del.target\n$ sudo systemctl mask --now ctrl-alt-del.target","weight":"10.0","check_content":"Verify that OL 9 is not configured to reboot the system when Ctrl-Alt-Delete is pressed with the following command:\n\n$ systemctl status ctrl-alt-del.target\nctrl-alt-del.target\nLoaded: masked (Reason: Unit ctrl-alt-del.target is masked.)\nActive: inactive (dead)\n\nIf the \"ctrl-alt-del.target\" is loaded and not masked, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"A locally logged-on user who presses Ctrl-Alt-Delete when at the console can reboot the system. If accidentally pressed, as could happen in the case of a mixed OS environment, this can create the risk of short-term loss of availability of systems due to unintentional reboot. In a graphical user environment, risk of unintentional reboot from the Ctrl-Alt-Delete sequence is reduced because the user will be prompted before any action is taken.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002235"],"reference_identifier":"2040","uuid":"420e6936-00fa-4570-bd05-b538f383df91","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 147F66F048B5BCCEA061175B9961C3EE5DE977CF\r\n~~~~~\r\nConfiguration for 'OL 9 must be configured so that the x86 Ctrl-Alt-Delete key sequence is disabled.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271753","group_tree":[{"id":"V-271753","title":"SRG-OS-000027-GPOS-00008","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271753","severity":"low","group_title":"SRG-OS-000027-GPOS-00008","rule_id_src":"SV-271753r1091971_rule","rule_id":"SV-271753","rule_version":"OL09-00-002415","rule_title":"OL 9 must limit the number of concurrent sessions to ten for all accounts and/or account types.","fix_text":"Configure OL 9 to limit the number of concurrent sessions to \"10\" for all accounts and/or account types.\n\nAdd the following line to the /etc/security/limits.conf or in a \".conf\" file defined in /etc/security/limits.d/:\n\n* hard maxlogins 10","weight":"10.0","check_content":"Verify that OL 9 limits the number of concurrent sessions to \"10\" for all accounts and/or account types with the following command:\n\n$ grep -r -s maxlogins /etc/security/limits.conf /etc/security/limits.d/*.conf\n/etc/security/limits.conf:* hard maxlogins 10\n\nThis can be set as a global domain (with the * wildcard) but may be set differently for multiple domains.\n\nIf the \"maxlogins\" item is missing, commented out, or the value is set greater than \"10\" and is not documented with the information system security officer (ISSO) as an operational requirement for all domains that have the \"maxlogins\" item assigned, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Operating system management includes the ability to control the number of users and user sessions that use an operating system. Limiting the number of allowed users and sessions per user is helpful in reducing the risks related to denial-of-service (DoS) attacks.\n\nThis requirement addresses concurrent sessions for information system accounts and does not address concurrent sessions by single users via multiple system accounts. The maximum number of concurrent sessions must be defined based on mission needs and the operational environment for each system.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000054"],"reference_identifier":"4192","uuid":"717abfb0-d717-4133-97af-c7dcaa787616","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 79CD111BD2A4FCE1BF55E1BEA3FD808227B1F8A2\r\n~~~~~\r\nConfiguration for 'OL 9 must limit the number of concurrent sessions to ten for all accounts and/or account types.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271754","group_tree":[{"id":"V-271754","title":"SRG-OS-000329-GPOS-00128","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271754","severity":"medium","group_title":"SRG-OS-000329-GPOS-00128","rule_id_src":"SV-271754r1184208_rule","rule_id":"SV-271754","rule_version":"OL09-00-002416","rule_title":"OL 9 must automatically lock an account when three unsuccessful logon attempts occur during a 15-minute time period.","fix_text":"Configure OL 9 to lock out the \"root\" account after a number of incorrect login attempts within 15 minutes using \"pam_faillock.so\" by enabling the feature using the following command:\n \n$ sudo authselect enable-feature with-faillock  \n\nThen edit the \"/etc/security/faillock.conf\" file as follows:\n\nfail_interval = 900","weight":"10.0","check_content":"Verify OL 9 locks an account after three unsuccessful logon attempts within a period of 15 minutes with the following command:\n\n$ grep fail_interval /etc/security/faillock.conf \nfail_interval = 900\n\nIf the \"fail_interval\" option is not set to \"900\" or less (but not \"0\"), the line is commented out, or the line is missing, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"By limiting the number of failed logon attempts the risk of unauthorized system access via user password guessing, otherwise known as brute-forcing, is reduced. Limits are imposed by locking the account.\n\nSatisfies: SRG-OS-000329-GPOS-00128, SRG-OS-000021-GPOS-00005","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002238","CCI-000044"],"reference_identifier":"3840","uuid":"e6cbd5fc-bf44-4ddd-aba0-34b543700f84","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: 7DB3B5FBEAA2101DD306F6AA4A0360D690C19F2C\r\n~~~~~\r\nThe feature/role addressed by 'OL 9 must automatically lock an account when three unsuccessful logon attempts occur during a 15-minute time period.' is not present or not in use on this the Oracle Linux 9 host."},{"group_id_src":"V-271755","group_tree":[{"id":"V-271755","title":"SRG-OS-000329-GPOS-00128","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271755","severity":"medium","group_title":"SRG-OS-000329-GPOS-00128","rule_id_src":"SV-271755r1091977_rule","rule_id":"SV-271755","rule_version":"OL09-00-002417","rule_title":"OL 9 must maintain an account lock until the locked account is released by an administrator.","fix_text":"Configure OL 9 to lock an account until released by an administrator after three unsuccessful logon attempts with the command:\n \n$ sudo authselect enable-feature with-faillock  \n\nThen edit the \"/etc/security/faillock.conf\" file as follows:\n\nunlock_time = 0","weight":"10.0","check_content":"Verify that OL 9 is configured to lock an account until released by an administrator after three unsuccessful logon attempts with the command:\n\n$ grep 'unlock_time =' /etc/security/faillock.conf\nunlock_time = 0\n\nIf the \"unlock_time\" option is not set to \"0\", the line is missing, or commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"By limiting the number of failed logon attempts the risk of unauthorized system access via user password guessing, otherwise known as brute-forcing, is reduced. Limits are imposed by locking the account.\n\nSatisfies: SRG-OS-000329-GPOS-00128, SRG-OS-000021-GPOS-00005","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002238","CCI-000044"],"reference_identifier":"7433","uuid":"c4e77c11-1658-4f2d-b687-28c08bce0395","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: A394D5B7A4607565C3E8F0F9A0204988B39A9307\r\n~~~~~\r\nRequired configuration for 'OL 9 must maintain an account lock until the locked account is released by an administrator.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271756","group_tree":[{"id":"V-271756","title":"SRG-OS-000405-GPOS-00184","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271756","severity":"high","group_title":"SRG-OS-000405-GPOS-00184","rule_id_src":"SV-271756r1091980_rule","rule_id":"SV-271756","rule_version":"OL09-00-002418","rule_title":"OL 9 local disk partitions must implement cryptographic mechanisms to prevent unauthorized disclosure or modification of all information that requires at rest protection.","fix_text":"Configure OL 9 to prevent unauthorized modification of all information at rest by using disk encryption.\n\nEncrypting a partition in an already installed system is more difficult, because existing partitions will need to be resized and changed.\n\nTo encrypt an entire partition, dedicate a partition for encryption in the partition layout.","weight":"10.0","check_content":"Note: If there is a documented and approved reason for not having data-at-rest encryption, this requirement is Not Applicable.\n\nVerify that OL 9 prevents unauthorized disclosure or modification of all information requiring at-rest protection by using disk encryption. \n\nVerify all system partitions are encrypted with the following command:\n\n$ sudo blkid\n/dev/map per/ol-root:  UUID=\"67b7d7fe-de60-6fd0-befb-e6748cf97743\" TYPE=\"crypto_LUKS\"\n\nEvery persistent disk partition present must be of type \"crypto_LUKS\". If any partitions other than the boot partition or pseudo file systems (such as /proc or /sys) or temporary file systems (that are tmpfs) are not type \"crypto_LUKS\", ask the administrator to indicate how the partitions are encrypted. If there is no evidence that these partitions are encrypted, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"OL 9 systems handling data requiring \"data at rest\" protections must employ cryptographic mechanisms to prevent unauthorized disclosure and modification of the information at rest.\n\nSelection of a cryptographic mechanism is based on the need to protect the integrity of organizational information. The strength of the mechanism is commensurate with the security category and/or classification of the information. Organizations have the flexibility to either encrypt all information on storage devices (i.e., full disk encryption) or encrypt specific data structures (e.g., files, records, or fields).\n\nSatisfies: SRG-OS-000405-GPOS-00184, SRG-OS-000185-GPOS-00079, SRG-OS-000404-GPOS-00183","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002476","CCI-001199","CCI-002475"],"reference_identifier":"3798","uuid":"4c235e15-48a7-4ceb-8d51-7a8c0be87046","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: ACDA5EB6CEBB75D47B423E7F197E881814BB0003\r\n~~~~~\r\nThe feature/role addressed by 'OL 9 local disk partitions must implement cryptographic mechanisms to prevent unauthorized disclosure or modification of all information that requires at rest protection.' is not present or not in use on this the Oracle Linux 9 host."},{"group_id_src":"V-271757","group_tree":[{"id":"V-271757","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271757","severity":"high","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271757r1092604_rule","rule_id":"SV-271757","rule_version":"OL09-00-002419","rule_title":"OL 9 file systems must not contain shosts.equiv files.","fix_text":"Remove any found \"shosts.equiv\" files from the system.\n\n$ sudo rm /[path]/[to]/[file]/shosts.equiv","weight":"10.0","check_content":"Verify that OL 9 has no \"shosts.equiv\" files on the system with the following command:\n\n$ sudo find / -name shosts.equiv\n\nIf a \"shosts.equiv\" file is found, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The shosts.equiv files are used to configure host-based authentication for the system via SSH. Host-based authentication is not sufficient for preventing unauthorized access to the system, as it does not require interactive identification and authentication of a connection request, or for the use of two-factor authentication.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"1688","uuid":"27c305ac-409c-48a8-8d46-aae0fdb21527","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: 4B9848883EC8306EABD5229C0E553B04B9C66598\r\n~~~~~\r\nThe feature/role addressed by 'OL 9 file systems must not contain shosts.equiv files.' is not present or not in use on this the Oracle Linux 9 host."},{"group_id_src":"V-271758","group_tree":[{"id":"V-271758","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271758","severity":"high","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271758r1091986_rule","rule_id":"SV-271758","rule_version":"OL09-00-002420","rule_title":"OL 9 file systems must not contain .shosts files.","fix_text":"Remove any found \".shosts\" files from the system.\n\n$ sudo rm /[path]/[to]/[file]/.shosts","weight":"10.0","check_content":"Verify that OL 9 has no \".shosts\" files on the system with the following command:\n\n$ sudo find / -name .shosts\n\nIf a \".shosts\" file is found, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"The .shosts files are used to configure host-based authentication for individual users or the system via SSH. Host-based authentication is not sufficient for preventing unauthorized access to the system, as it does not require interactive identification and authentication of a connection request, or for the use of two-factor authentication.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"6970","uuid":"2dcfd20b-791d-4cb5-977a-1db18e90f288","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 64C43EEA7FBF850464B7607C685442F5EE099BFA\r\n~~~~~\r\nConfiguration for 'OL 9 file systems must not contain .shosts files.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271759","group_tree":[{"id":"V-271759","title":"SRG-OS-000423-GPOS-00187","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271759","severity":"high","group_title":"SRG-OS-000423-GPOS-00187","rule_id_src":"SV-271759r1184210_rule","rule_id":"SV-271759","rule_version":"OL09-00-002421","rule_title":"OL 9 must implement DOD-approved encryption in the bind package.","fix_text":"Configure BIND to use the system crypto policy.\n\nAdd the following line to the \"options\" section in \"/etc/named.conf\":\n\ninclude \"/etc/crypto-policies/back-ends/bind.config\";","weight":"10.0","check_content":"Note: If the \"bind\" package is not installed, this requirement is Not Applicable.\n\nVerify OL 9 BIND uses the system crypto policy with the following command:\n\n$ sudo grep include /etc/named.conf \ninclude \"/etc/crypto-policies/back-ends/bind.config\";' \n\nIf BIND is installed and the BIND config file does not include the \"/etc/crypto-policies/back-ends/bind.config\" directive, or the line is commented out, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Without cryptographic integrity protections, information can be altered by unauthorized users without detection.\n\nCryptographic mechanisms used for protecting the integrity of information include, for example, signed hash functions using asymmetric cryptography enabling distribution of the public key to verify the hash information while maintaining the confidentiality of the secret key used to generate the hash.\n\nOL 9 incorporates system-wide crypto policies by default. The employed algorithms can be viewed in the /etc/crypto-policies/back-ends/ directory.\n\nSatisfies: SRG-OS-000423-GPOS-00187, SRG-OS-000426-GPOS-00190","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002418","CCI-002422"],"reference_identifier":"9326","uuid":"b93e1ff4-1aff-4255-a245-b6d6d2eb94c1","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 54E99D6635F0301439BAC9DE0DD9F4F8FEE6064E\r\n~~~~~\r\nRequired configuration for 'OL 9 must implement DOD-approved encryption in the bind package.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271760","group_tree":[{"id":"V-271760","title":"SRG-OS-000433-GPOS-00192","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271760","severity":"medium","group_title":"SRG-OS-000433-GPOS-00192","rule_id_src":"SV-271760r1091992_rule","rule_id":"SV-271760","rule_version":"OL09-00-002422","rule_title":"OL 9 must implement nonexecutable data to protect its memory from unauthorized code execution.","fix_text":"Update the GRUB 2 bootloader configuration.\n\nRun the following command:\n\n$ sudo grubby --update-kernel=ALL --remove-args=noexec","weight":"10.0","check_content":"Verify that OL 9 ExecShield is enabled on 64-bit systems with the following command:\n\n$ sudo dmesg | grep '[NX|DX]*protection' \n[ 0.000000] NX (Execute Disable) protection: active\n\nIf \"dmesg\" does not show \"NX (Execute Disable) protection\" active, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"ExecShield uses the segmentation feature on all x86 systems to prevent execution in memory higher than a certain address. It writes an address as a limit in the code segment descriptor, to control where code can be executed, on a per-process basis. When the kernel places a process's memory regions such as the stack and heap higher than this address, the hardware prevents execution in that address range. This is enabled by default on the latest Oracle systems if supported by the hardware.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002824"],"reference_identifier":"6283","uuid":"76cb3bef-eef0-4487-926f-fc9dd3fa0c63","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-271761","group_tree":[{"id":"V-271761","title":"SRG-OS-000433-GPOS-00193","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271761","severity":"medium","group_title":"SRG-OS-000433-GPOS-00193","rule_id_src":"SV-271761r1091995_rule","rule_id":"SV-271761","rule_version":"OL09-00-002423","rule_title":"OL 9 must implement address space layout randomization (ASLR) to protect its memory from unauthorized code execution.","fix_text":"Configure OL 9 to implement address space layout randomization (ASLR) to protect its memory from unauthorized code execution.\n\nAdd or edit the following line in a system configuration file in the \"/etc/sysctl.d/\" directory:\n\nkernel.randomize_va_space = 2\n\nReload settings from all system configuration files with the following command:\n\n$ sudo sysctl --system","weight":"10.0","check_content":"Verify that OL 9 is implementing ASLR with the following command:\n\n$ sysctl kernel.randomize_va_space\nkernel.randomize_va_space = 2\n\nIf \"kernel.randomize_va_space\" is not set to \"2\" or is missing, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"ASLR makes it more difficult for an attacker to predict the location of attack code they have introduced into a process' address space during an attempt at exploitation. Additionally, ASLR makes it more difficult for an attacker to know the location of existing code to repurpose it using return-oriented programming (ROP) techniques.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-002824"],"reference_identifier":"4703","uuid":"d5020cea-350d-4a3b-ad15-34c48aec5613","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 1C13C6EEB649FAC5519875699984AE0D54FD5E3A\r\n~~~~~\r\nConfiguration for 'OL 9 must implement address space layout randomization (ASLR) to protect its memory from unauthorized code execution.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271763","group_tree":[{"id":"V-271763","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271763","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271763r1092001_rule","rule_id":"SV-271763","rule_version":"OL09-00-002425","rule_title":"OL 9 must be configured to prevent unrestricted mail relaying.","fix_text":"Modify the postfix configuration file to restrict client connections to the local network with the following command:\n\n$ sudo postconf -e 'smtpd_client_restrictions = permit_mynetworks,reject'","weight":"10.0","check_content":"Note: If postfix is not installed, this requirement is Not Applicable.\n\nVerify that OL 9 is configured to prevent unrestricted mail relaying with the following command:\n\n$ postconf -n smtpd_client_restrictions \nsmtpd_client_restrictions = permit_mynetworks,reject \n\nIf the \"smtpd_client_restrictions\" parameter contains any entries other than \"permit_mynetworks\" and \"reject\", and the additional entries have not been documented with the information system security officer (ISSO), this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If unrestricted mail relaying is permitted, unauthorized senders could use this host as a mail relay for the purpose of sending spam or other unauthorized activity.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"4624","uuid":"f6bfc7d6-260c-4076-ab61-b43851bded44","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: 530A9B8CED8F96E507B78AFD56C169DD354D9FDD\r\n~~~~~\r\nThe feature/role addressed by 'OL 9 must be configured to prevent unrestricted mail relaying.' is not present or not in use on this the Oracle Linux 9 host."},{"group_id_src":"V-271764","group_tree":[{"id":"V-271764","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271764","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271764r1092004_rule","rule_id":"SV-271764","rule_version":"OL09-00-002426","rule_title":"OL 9 Trivial File Transfer Protocol (TFTP) daemon must be configured to operate in secure mode if the TFTP server is required.","fix_text":"Configure the TFTP daemon to operate in secure mode.\n\nFind the path for the systemd service.\n\n$ sudo systemctl show tftp | grep FragmentPath=\nFragmentPath=/etc/systemd/system/tftp.service\n\nEdit the ExecStart line on that file to add the -s option with a subdirectory.\n\nExecStart=/usr/sbin/in.tftpd -s /var/lib/tftpboot","weight":"10.0","check_content":"Verify that OL 9 TFTP daemon is configured to operate in secure mode.\n\nCheck if a TFTP server is installed with the following command:\n\n$ sudo dnf list --installed tftp-server\nInstalled Packages\ntftp-server.x86_64                                       5.2-38.el9                                       @ol9_appstream\n\nNote: If a TFTP server is not installed, this requirement is Not Applicable.\n\nIf a TFTP server is installed, check for the server arguments with the following command: \n\n$ systemctl cat tftp | grep ExecStart\nExecStart=/usr/sbin/in.tftpd -s /var/lib/tftpboot\n\nIf the \"ExecStart\" line does not have a \"-s\" option, and a subdirectory is not assigned, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Restricting TFTP to a specific directory prevents remote users from copying, transferring, or overwriting system files. Using the \"-s\" option causes the TFTP service to only serve files from the given directory.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"4484","uuid":"49c83c2a-ed64-459f-a433-0c1cecb42ebc","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-271766","group_tree":[{"id":"V-271766","title":"SRG-OS-000366-GPOS-00153","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271766","severity":"medium","group_title":"SRG-OS-000366-GPOS-00153","rule_id_src":"SV-271766r1092010_rule","rule_id":"SV-271766","rule_version":"OL09-00-002428","rule_title":"OL 9 must prevent the loading of a new kernel for later execution.","fix_text":"Configure OL 9 to prevent the loading of a new kernel for later execution.\n\nAdd or edit the following line in a system configuration file in the \"/etc/sysctl.d/\" directory:\n\nkernel.kexec_load_disabled = 1\n\nLoad settings from all system configuration files with the following command:\n\n$ sudo sysctl --system","weight":"10.0","check_content":"Verify that OL 9 is configured to disable kernel image loading.\n\nCheck the status of the kernel.kexec_load_disabled kernel parameter with the following command:\n\n$ sysctl kernel.kexec_load_disabled\nkernel.kexec_load_disabled = 1\n\nIf \"kernel.kexec_load_disabled\" is not set to \"1\" or is missing, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Changes to any software components can have significant effects on the overall security of the operating system. This requirement ensures the software has not been tampered with and that it has been provided by a trusted vendor.\n\nDisabling kexec_load prevents an unsigned kernel image (that could be a windows kernel or modified vulnerable kernel) from being loaded. Kexec can be used subvert the entire secureboot process and should be avoided at all costs especially since it can load unsigned kernel images.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-003992"],"reference_identifier":"7556","uuid":"7b7300e0-6762-4806-8c99-e4e910533084","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: C4E8065ECE371CD79AFC371F3970C4B33B084E80\r\n~~~~~\r\nConfiguration for 'OL 9 must prevent the loading of a new kernel for later execution.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271768","group_tree":[{"id":"V-271768","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271768","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271768r1092016_rule","rule_id":"SV-271768","rule_version":"OL09-00-002430","rule_title":"OL 9 must enable hardening for the Berkeley Packet Filter (BPF) just-in-time compiler.","fix_text":"Configure OL 9 to enable hardening for the BPF JIT compiler by adding the following line to a file, in the \"/etc/sysctl.d\" directory:\n\nnet.core.bpf_jit_harden = 2\n\nThe system configuration files need to be reloaded for the changes to take effect. To reload the contents of the files, run the following command:\n\n$ sudo sysctl --system","weight":"10.0","check_content":"Verify that OL 9 enables hardening for the BPF JIT with the following commands:\n\n$ sudo sysctl net.core.bpf_jit_harden\nnet.core.bpf_jit_harden = 2\n\nIf the returned line does not have a value of \"2\", or a line is not returned, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"When hardened, the extended BPF just-in-time (JIT) compiler will randomize any kernel addresses in the BPF programs and maps and will not expose the JIT addresses in \"/proc/kallsyms\".","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"5259","uuid":"ddbeef8e-0fa1-4310-aaa0-c5c2ac60537f","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 9AD4B1E266FD9565BAD76B34CFB18433CA302CFC\r\n~~~~~\r\nConfiguration for 'OL 9 must enable hardening for the Berkeley Packet Filter (BPF) just-in-time compiler.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271769","group_tree":[{"id":"V-271769","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271769","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271769r1092019_rule","rule_id":"SV-271769","rule_version":"OL09-00-002500","rule_title":"OL 9 must be configured so that all system device files are correctly labeled to prevent unauthorized modification.","fix_text":"Configure OL 9 to correctly label all system devices.\n\nRestore the SELinux policy for the affected device file from the system policy database using the following command:\n\n$ sudo restorecon -v <device_path>\n\nSubstituting \"<device_path>\" with the path to the affected device file (from the output of the previous commands). An example device file path would be \"/dev/ttyUSB0\". If the output of the above command does not indicate that the device was relabeled to a more specific SELinux type label, then the SELinux policy of the system must be updated with more specific policy for the device class specified. If a package was used to install support for a device class, that package could be reinstalled using the following command:\n\n$ sudo dnf reinstall -y <package_name>\n\nIf a package was not used to install the SELinux policy for a given device class, then it must be generated manually and provide specific type labels.","weight":"10.0","check_content":"Verify that OL 9 configures all system device files to be correctly labeled to prevent unauthorized modification.\n\nList all device files on the system that are incorrectly labeled with the following commands:\n\nNote: Device files are normally found under \"/dev\", but applications may place device files in other directories and may necessitate a search of the entire system.\n\n$ sudo find /dev -context *:device_t:* \\( -type c -o -type b \\) -printf \"%p %Z\\n\"\n\n$ sudo find /dev -context *:unlabeled_t:* \\( -type c -o -type b \\) -printf \"%p %Z\\n\"\n\nNote: There are device files, such as \"/dev/dtrace/helper\" or \"/dev/vmci\", that are used for system trace capabilities or when the operating system is a host virtual machine. They will not be owned by a user on the system and require the \"device_t\" label to operate. These device files are not a finding.\n\nIf there is output from either of these commands, other than already noted, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If an unauthorized or modified device is allowed to exist on the system, there is the possibility the system may perform unintended or unauthorized operations.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"8128","uuid":"3b668d38-8b56-45ed-9988-25560c344813","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-271770","group_tree":[{"id":"V-271770","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271770","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271770r1092022_rule","rule_id":"SV-271770","rule_version":"OL09-00-002501","rule_title":"OL 9 must not have unauthorized accounts.","fix_text":"Remove unauthorized local interactive user accounts with the following command where <unauthorized_user> is the unauthorized account:\n\n$ sudo userdel  <unauthorized_user>","weight":"10.0","check_content":"Verify that OL 9 prohibits unauthorized interactive user accounts with the following command:\n\n$ less /etc/passwd  \nroot:x:0:0:root:/root:/bin/bash\n...\ngames:x:12:100:games:/usr/games:/sbin/nologin\nscsaustin:x:1001:1001:scsaustin:/home/scsaustin:/bin/bash\ndjohnson:x:1002:1002:djohnson:/home/djohnson:/bin/bash\n\nInteractive user account, generally will have a user identifier (UID) of 1000 or greater, a home directory in a specific partition, and an interactive shell.\n\nObtain the list of interactive user accounts authorized to be on the system from the system administrator or information system security officer (ISSO) and compare it to the list of local interactive user accounts on the system.\n\nIf there are unauthorized local user accounts on the system, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Accounts providing no operational purpose provide additional opportunities for system compromise. Unnecessary accounts include user accounts for individuals not requiring access to the system and application accounts for applications not installed on the system.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"6256","uuid":"b4409056-4645-425f-a97c-02573742550d","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 6F330CCFA6C73215B1E02F487EEDA369B3495F78\r\n~~~~~\r\nConfiguration for 'OL 9 must not have unauthorized accounts.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271771","group_tree":[{"id":"V-271771","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271771","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271771r1092025_rule","rule_id":"SV-271771","rule_version":"OL09-00-002502","rule_title":"OL 9 SSH private host key files must have mode 0640 or less permissive.","fix_text":"Configure the mode of SSH private host key files under \"/etc/ssh\" to \"0640\" with the following command:\n\n$ sudo chmod 0640 /etc/ssh/ssh_host*key\n\nRestart the SSH daemon for the changes to take effect:\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 SSH private host key files have a mode of \"0640\" or less permissive with the following command:\n\n$ ls -l /etc/ssh/*_key\n640 /etc/ssh/ssh_host_dsa_key\n640 /etc/ssh/ssh_host_ecdsa_key\n640 /etc/ssh/ssh_host_ed25519_key\n640 /etc/ssh/ssh_host_rsa_key\n\nIf any private host key file has a mode more permissive than \"0640\", this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If an unauthorized user obtains the private SSH host key file, the host could be impersonated.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"4160","uuid":"fd40786f-d94a-4101-83fd-6afc9fe2149d","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-271772","group_tree":[{"id":"V-271772","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271772","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271772r1092028_rule","rule_id":"SV-271772","rule_version":"OL09-00-002503","rule_title":"OL 9 SSH public host key files must have mode 0644 or less permissive.","fix_text":"Change the mode of public host key files under \"/etc/ssh\" to \"0644\" with the following command:\n\n$ sudo chmod 0644 /etc/ssh/*key.pub\n\nRestart the SSH daemon for the changes to take effect:\n\n$ sudo systemctl restart sshd.service","weight":"10.0","check_content":"Verify that OL 9 SSH public host key files have a mode of \"0644\" or less permissive with the following command:\n\nNote: SSH public key files may be found in other directories on the system depending on the installation.\n\n$ sudo stat -c \"%a %n\" /etc/ssh/*.pub\n644 /etc/ssh/ssh_host_dsa_key.pub\n644 /etc/ssh/ssh_host_ecdsa_key.pub\n644 /etc/ssh/ssh_host_ed25519_key.pub\n644 /etc/ssh/ssh_host_rsa_key.pub\n\nIf any key.pub file has a mode more permissive than \"0644\", this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If a public host key file is modified by an unauthorized user, the SSH service may be compromised.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"2202","uuid":"38fbf723-4a78-467f-860e-da9f816df74a","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-271773","group_tree":[{"id":"V-271773","title":"SRG-OS-000259-GPOS-00100","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271773","severity":"medium","group_title":"SRG-OS-000259-GPOS-00100","rule_id_src":"SV-271773r1155299_rule","rule_id":"SV-271773","rule_version":"OL09-00-002504","rule_title":"OL 9 system commands must be group-owned by root or a system account.","fix_text":"Configure the system commands to be protected from unauthorized access.\n\nRun the following command, replacing \"[FILE]\" with any system command file not group-owned by \"root\" or a required system account.\n\n$ sudo chgrp root [FILE]","weight":"10.0","check_content":"Verify OL 9 system commands contained in the following directories are group-owned by \"root\", or a required system account, with the following command:\n\n$ sudo find -L /bin /sbin /usr/bin /usr/sbin /usr/libexec /usr/local/bin /usr/local/sbin ! -group root -exec ls -l {} \\;\n\nIf any system commands are returned and is not group-owned by a required system account, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If OL 9 allowed any user to make changes to software libraries, then those changes might be implemented without undergoing the appropriate testing and approvals that are part of a robust change management process.\n\nThis requirement applies to OL 9 with software libraries that are accessible and configurable, as in the case of interpreted languages. Software libraries also include privileged programs that execute with escalated privileges.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001499"],"reference_identifier":"9605","uuid":"effe80de-0229-46b3-aded-5e82fdfdb73a","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 238071DC2DEDF2A6B402B743C7951379F9E643A1\r\n~~~~~\r\nConfiguration for 'OL 9 system commands must be group-owned by root or a system account.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271774","group_tree":[{"id":"V-271774","title":"SRG-OS-000259-GPOS-00100","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271774","severity":"medium","group_title":"SRG-OS-000259-GPOS-00100","rule_id_src":"SV-271774r1092034_rule","rule_id":"SV-271774","rule_version":"OL09-00-002505","rule_title":"OL 9 system commands must be owned by root.","fix_text":"Configure the system commands to be protected from unauthorized access.\n\nRun the following command, replacing \"[FILE]\" with any system command file not owned by \"root\".\n\n$ sudo chown root [FILE]","weight":"10.0","check_content":"Verify that OL 9 system commands contained in the following directories are owned by \"root\" with the following command:\n\n$ sudo find -L /bin /sbin /usr/bin /usr/sbin /usr/libexec /usr/local/bin /usr/local/sbin ! -user root -exec ls -l {} \\;\n\nIf any system commands are found to not be owned by root, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If OL 9 allowed any user to make changes to software libraries, then those changes might be implemented without undergoing the appropriate testing and approvals that are part of a robust change management process.\n\nThis requirement applies to OL 9 with software libraries that are accessible and configurable, as in the case of interpreted languages. Software libraries also include privileged programs that execute with escalated privileges.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001499"],"reference_identifier":"7800","uuid":"5dcdcb07-92e2-4df2-b744-3a7a321e208e","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: CDAFCF8FBEC0CAAC7A0F76EC2F700C383AAA3B91\r\n~~~~~\r\nConfiguration for 'OL 9 system commands must be owned by root.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271775","group_tree":[{"id":"V-271775","title":"SRG-OS-000259-GPOS-00100","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271775","severity":"medium","group_title":"SRG-OS-000259-GPOS-00100","rule_id_src":"SV-271775r1092037_rule","rule_id":"SV-271775","rule_version":"OL09-00-002506","rule_title":"OL 9 system commands must have mode 755 or less permissive.","fix_text":"Configure the system commands to be protected from unauthorized access.\n\nRun the following command, replacing \"[FILE]\" with any system command with a mode more permissive than \"755\".\n\n$ sudo chmod 755 [FILE]","weight":"10.0","check_content":"Verify that OL 9 system commands contained in the following directories have mode \"755\" or less permissive with the following command:\n\n$ sudo find -L /bin /sbin /usr/bin /usr/sbin /usr/libexec /usr/local/bin /usr/local/sbin -perm /022 -exec ls -l {} \\;\n\nIf any system commands are found to be group-writable or world-writable, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If OL 9 allowed any user to make changes to software libraries, then those changes might be implemented without undergoing the appropriate testing and approvals that are part of a robust change management process.\n\nThis requirement applies to OL 9 with software libraries that are accessible and configurable, as in the case of interpreted languages. Software libraries also include privileged programs that execute with escalated privileges.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001499"],"reference_identifier":"5318","uuid":"9b7b12bf-33c0-4e64-ae5b-2d2dd6e9e41a","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: CCF59A921D94320F1B32AC37A9AE1066ADA3E4B7\r\n~~~~~\r\nRequired configuration for 'OL 9 system commands must have mode 755 or less permissive.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271776","group_tree":[{"id":"V-271776","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271776","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271776r1092040_rule","rule_id":"SV-271776","rule_version":"OL09-00-002507","rule_title":"OL 9 SSH server configuration file must be group-owned by root.","fix_text":"Configure the \"/etc/ssh/sshd_config\" file to be group-owned by root with the following command:\n\n$ sudo chgrp root /etc/ssh/sshd_config","weight":"10.0","check_content":"Verify that OL 9 configures group ownership of the \"/etc/ssh/sshd_config\" file with the following command:\n\n$ ls -al /etc/ssh/sshd_config\nrw-------. 1 root root 3669 Feb 22 11:34 /etc/ssh/sshd_config\n\nIf the \"/etc/ssh/sshd_config\" file does not have a group owner of \"root\", this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Service configuration files enable or disable features of their respective services, which if configured incorrectly, can lead to insecure and vulnerable configurations. Therefore, service configuration files must be owned by the correct group to prevent unauthorized changes.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"7078","uuid":"a942da6d-27fc-4578-832b-d25fcfa098f8","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 29BFCC03F8F7D164D7DD78F951157115CCC88498\r\n~~~~~\r\nConfiguration for 'OL 9 SSH server configuration file must be group-owned by root.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271777","group_tree":[{"id":"V-271777","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271777","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271777r1092043_rule","rule_id":"SV-271777","rule_version":"OL09-00-002508","rule_title":"OL 9 SSH server configuration file must be owned by root.","fix_text":"Configure the \"/etc/ssh/sshd_config\" file to be owned by root with the following command:\n\n$ sudo chown root /etc/ssh/sshd_config","weight":"10.0","check_content":"Verify that OL 9 configures ownership of the \"/etc/ssh/sshd_config\" file with the following command:\n\n$ ls -al /etc/ssh/sshd_config\nrw-------. 1 root root 3669 Feb 22 11:34 /etc/ssh/sshd_config\n\nIf the \"/etc/ssh/sshd_config\" file does not have an owner of \"root\", this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Service configuration files enable or disable features of their respective services, which if configured incorrectly, can lead to insecure and vulnerable configurations. Therefore, service configuration files must be owned by the correct group to prevent unauthorized changes.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"7156","uuid":"90a89d8e-6e4d-481f-960f-8b5562ff9732","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: BCF6CE0F1C858E93D82B7F9FA7F7ED5D3DFA01B9\r\n~~~~~\r\nConfiguration for 'OL 9 SSH server configuration file must be owned by root.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271778","group_tree":[{"id":"V-271778","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271778","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271778r1092046_rule","rule_id":"SV-271778","rule_version":"OL09-00-002509","rule_title":"OL 9 SSH server configuration file must have mode 0600 or less permissive.","fix_text":"Configure the \"/etc/ssh/sshd_config\" permissions to be \"0600\" with the following command:\n\n$ sudo chmod 0600 /etc/ssh/sshd_config","weight":"10.0","check_content":"Verify that OL 9 configures permissions of the \"/etc/ssh/sshd_config\" file with the following command:\n\n$ ls -al /etc/ssh/sshd_config\nrw-------. 1 root root 3669 Feb 22 11:34 /etc/ssh/sshd_config\n\nIf the \"/etc/ssh/sshd_config\" permissions are not \"0600\", this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Service configuration files enable or disable features of their respective services that if configured incorrectly can lead to insecure and vulnerable configurations. Therefore, service configuration files should be owned by the correct group to prevent unauthorized changes.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"5522","uuid":"97033472-33ea-44c5-a6fb-d1345fc3535d","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 74ADB5E4E76DD9DF38F485DA469CB411FB7BBBEE\r\n~~~~~\r\nConfiguration for 'OL 9 SSH server configuration file must have mode 0600 or less permissive.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271779","group_tree":[{"id":"V-271779","title":"SRG-OS-000138-GPOS-00069","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271779","severity":"medium","group_title":"SRG-OS-000138-GPOS-00069","rule_id_src":"SV-271779r1137695_rule","rule_id":"SV-271779","rule_version":"OL09-00-002510","rule_title":"OL 9 must be configured so that a sticky bit must be set on all public directories.","fix_text":"Configure all world-writable directories to have the sticky bit set to prevent unauthorized and unintended information transferred via shared system resources.\n\nSet the sticky bit on all world-writable directories using the command, replace \"[World-Writable Directory]\" with any directory path missing the sticky bit:\n\n$ sudo chmod a+t [World-Writable Directory]","weight":"10.0","check_content":"Verify that OL 9 world-writable directories have the sticky bit set.\n\nDetermine if all world-writable directories have the sticky bit set by running the following command:\n\n$ sudo find / -type d \\( -perm -0002 -a ! -perm -1000 \\) -print 2>/dev/null\ndrwxrwxrwt 7 root root 4096 Jul 26 11:19 /tmp\n\nIf any of the returned directories are world-writable and do not have the sticky bit set, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Preventing unauthorized information transfers mitigates the risk of information, including encrypted representations of information, produced by the actions of prior users/roles (or the actions of processes acting on behalf of prior users/roles) from being available to any current users/roles (or current processes) that obtain access to shared system resources (e.g., registers, main memory, hard disks) after those resources have been released back to information systems. The control of information in shared resources is also commonly referred to as object reuse and residual information protection.\n\nThis requirement generally applies to the design of an information technology product, but it can also apply to the configuration of particular information system components that are, or use, such products. This can be verified by acceptance/validation processes in DOD or other government agencies.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001090"],"reference_identifier":"7329","uuid":"c927d669-1b1c-47e7-8ef1-919c0deb3897","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 6E125FF1510743ACF9755C2C7C25604DE228B51C\r\n~~~~~\r\nConfiguration for 'OL 9 must be configured so that a sticky bit must be set on all public directories.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271780","group_tree":[{"id":"V-271780","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271780","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271780r1092052_rule","rule_id":"SV-271780","rule_version":"OL09-00-002511","rule_title":"OL 9 local files and directories must have a valid group owner.","fix_text":"Configure OL 9 local files and directories to have a valid group owner.\n\nEither remove all files and directories from OL 9 that do not have a valid group, or assign a valid group to all files and directories on the system with the \"chgrp\" command:\n\n$ sudo chgrp <group> <file>","weight":"10.0","check_content":"Verify that OL 9 local files and directories have a valid group with the following command:\n\n$ df --local -P | awk {'if (NR!=1) print $6'} | sudo xargs -I '{}' find '{}' -xdev -nogroup\n\nIf any files on the system do not have an assigned group, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Files without a valid group owner may be unintentionally inherited if a group is assigned the same Group Identifier (GID) as the GID of the files without a valid group owner.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"3089","uuid":"23db8f12-0f4a-49ff-858d-7861f20d2c88","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: B64751959183B79DF5493C191B1C620FE62F1134\r\n~~~~~\r\nConfiguration for 'OL 9 local files and directories must have a valid group owner.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271781","group_tree":[{"id":"V-271781","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271781","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271781r1092055_rule","rule_id":"SV-271781","rule_version":"OL09-00-002512","rule_title":"OL 9 local files and directories must have a valid owner.","fix_text":"Configure OL 9 local files and directories to have a valid owner.\n\nEither remove all files and directories from the system that do not have a valid user, or assign a valid user to all unowned files and directories on OL 9 with the \"chown\" command:\n\n$ sudo chown <user> <file>","weight":"10.0","check_content":"Verify that OL 9 local files and directories on OL 9 have a valid owner with the following command:\n\n$ df --local -P | awk {'if (NR!=1) print $6'} | sudo xargs -I '{}' find '{}' -xdev -nouser\n\nIf any files on the system do not have an assigned owner, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Unowned files and directories may be unintentionally inherited if a user is assigned the same user identifier \"UID\" as the UID of the unowned files.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"2634","uuid":"199e672a-69f3-4a8c-bb80-ae14e7ef7107","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_applicable","overrides":{},"comments":"Not applicable - capability not installed/enabled on this asset.","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) marked this Not_Applicable on 07/23/2026\r\nResultHash: F46E964C6B513CF6CBD7B1DA5C49BD6B9E85DA16\r\n~~~~~\r\nThe feature/role addressed by 'OL 9 local files and directories must have a valid owner.' is not present or not in use on this the Oracle Linux 9 host."},{"group_id_src":"V-271782","group_tree":[{"id":"V-271782","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271782","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271782r1184213_rule","rule_id":"SV-271782","rule_version":"OL09-00-002513","rule_title":"OL 9 local initialization files must have mode 0740 or less permissive.","fix_text":"Set the mode of the local initialization files to \"0740\" with the following command:\n\nNote: The example will be for the disauser user who has a home directory of \"/home/disauser\".\n\n$ sudo chmod 0740 /home/disauser/.<INIT_FILE>","weight":"10.0","check_content":"Verify OL 9 configures all local initialization files to have a mode of \"0740\" or less permissive with the following command:\n\nNote: The example will be for the \"disauser\" user, who has a home directory of \"/home/disauser\".\n\n$ sudo ls -al /home/disauser/.[^.]* | more\n-rwxr-xr-x 1 disauser users 896 Mar 10 2011 .profile\n-rwxr-xr-x 1 disauser users 497 Jan 6 2007 .login\n-rwxr-xr-x 1 disauser users 886 Jan 6 2007 .something\n\nIf any local initialization files have a mode more permissive than \"0740\", this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Local initialization files are used to configure the user's shell environment upon logon. Malicious modification of these files could compromise accounts upon logon.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"3315","uuid":"052f36e6-ab67-4617-bc64-13ed2b817ff1","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: 22E1F6E4849D72B655A887B0182AB19B93A34B74\r\n~~~~~\r\nRequired configuration for 'OL 9 local initialization files must have mode 0740 or less permissive.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271783","group_tree":[{"id":"V-271783","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271783","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271783r1184216_rule","rule_id":"SV-271783","rule_version":"OL09-00-002514","rule_title":"OL 9 local interactive user home directories must be group-owned by the home directory owner's primary group.","fix_text":"Change the group owner of a local interactive user's home directory to the group found in \"/etc/passwd\" using the following command:\n\nNote: The example will be for the user \"disauser\", who has a home directory of \"/home/disauser\", and has a primary group of users.\n\n$ sudo chgrp users /home/disauser","weight":"10.0","check_content":"Verify OL 9 configures assigned home directories of all local interactive users to be group-owned by that user's primary GID with the following command:\n\nNote: This may miss local interactive users that have been assigned a privileged user identifier (UID). Evidence of interactive use may be obtained from a number of log files containing system logon information. The returned directory \"/home/disauser\" is used as an example.\n\n$ sudo ls -ld $(awk -F: '($3>=1000)&&($7 !~ /nologin/){print $6}' /etc/passwd)\ndrwxr-x--- 2 disauser admin 4096 Jun 5 12:41 disauser\n\nCheck the user's primary group with the following command:\n\n$ sudo grep $(grep disauser /etc/passwd | awk -F: '{print $4}') /etc/group\nadmin:x:250:disauser,doduser,nsauser\n\nIf the user home directory referenced in \"/etc/passwd\" is not group-owned by that user's primary GID, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If the Group Identifier (GID) of a local interactive user's home directory is not the same as the primary GID of the user, this would allow unauthorized access to the user's files, and users that share the same group may not be able to access files that they legitimately should.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"6847","uuid":"b6cc6dd1-4c51-41d7-8497-269c42adef72","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"open","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be OPEN on 07/23/2026\r\nResultHash: EE7DE10696F646CEEA1E3103CF022D3CA70E8957\r\n~~~~~\r\nRequired configuration for 'OL 9 local interactive user home directories must be group-owned by the home directory owner's primary group.' was not present or did not match the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271784","group_tree":[{"id":"V-271784","title":"SRG-OS-000480-GPOS-00227","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271784","severity":"medium","group_title":"SRG-OS-000480-GPOS-00227","rule_id_src":"SV-271784r1184219_rule","rule_id":"SV-271784","rule_version":"OL09-00-002515","rule_title":"OL 9 local interactive user home directories must have mode 0750 or less permissive.","fix_text":"Change the mode of interactive user's home directories to \"0750\" using the following command:\n\nNote: The example will be for the user \"disauser\".\n\n$ sudo chmod 0750 /home/disauser","weight":"10.0","check_content":"Verify OL 9 configures assigned home directories of all local interactive users to have a mode of \"0750\" or less permissive with the following command:\n\nNote: This may miss interactive users that have been assigned a privileged user identifier (UID). Evidence of interactive use may be obtained from a number of log files containing system logon information.\n\n$ sudo ls -ld $(awk -F: '($3>=1000)&&($7 !~ /nologin/){print $6}' /etc/passwd)\ndrwxr-x--- 2 disauser admin 4096 Jun 5 12:41 disauser\n\nIf home directories referenced in \"/etc/passwd\" do not have a mode of \"0750\" or less permissive, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"Excessive permissions on local interactive user home directories may allow unauthorized access to user files by other users.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-000366"],"reference_identifier":"5909","uuid":"73aa5de0-717e-4435-9240-7bb2ba01a229","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 8C7BD09268A3AA45CF6FDB4C3229B6BBC5FB2D9F\r\n~~~~~\r\nConfiguration for 'OL 9 local interactive user home directories must have mode 0750 or less permissive.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271785","group_tree":[{"id":"V-271785","title":"SRG-OS-000138-GPOS-00069","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271785","severity":"medium","group_title":"SRG-OS-000138-GPOS-00069","rule_id_src":"SV-271785r1155290_rule","rule_id":"SV-271785","rule_version":"OL09-00-002516","rule_title":"OL 9 world-writable directories must be owned by root, sys, bin, or an application user.","fix_text":"Configure all OL 9 public directories to be owned by root or a system account to prevent unauthorized and unintended information transferred via shared system resources.\n\nUse the following command template to set ownership of public directories to root or a system account:\n\n$ sudo chown [root or system account] [Public Directory]","weight":"10.0","check_content":"Verify OL 9 world writable directories are owned by root, a system account, or an application account with the following command:\n\n$ sudo find / -xdev -type d -perm -0002 -uid +999 -exec stat -c \"%U, %u, %A, %n\" {} \\; 2>/dev/null\n\nIf there is output that indicates world-writable directories are owned by any account other than root or an approved system account, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If a world-writable directory is not owned by root, sys, bin, or an application user identifier (UID), unauthorized users may be able to modify files created by others.\n\nThe only authorized public directories are those temporary directories supplied with the system or those designed to be temporary file repositories. The setting is normally reserved for directories used by the system and by users for temporary file storage, (e.g., /tmp), and for directories requiring global read/write access.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001090"],"reference_identifier":"4853","uuid":"3a4d1531-5e92-4005-8957-68c118b2de5d","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 2B1C788E47C3EE3177D41DEC10A37FD3AAA2FA3F\r\n~~~~~\r\nConfiguration for 'OL 9 world-writable directories must be owned by root, sys, bin, or an application user.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271786","group_tree":[{"id":"V-271786","title":"SRG-OS-000259-GPOS-00100","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271786","severity":"medium","group_title":"SRG-OS-000259-GPOS-00100","rule_id_src":"SV-271786r1092070_rule","rule_id":"SV-271786","rule_version":"OL09-00-002520","rule_title":"OL 9 library directories must be group-owned by root or a system account.","fix_text":"Configure the system-wide shared library directories (/lib, /lib64, /usr/lib and /usr/lib64) to be protected from unauthorized access.\n\nRun the following command, replacing \"[DIRECTORY]\" with any library directory not group-owned by \"root\".\n\n$ sudo chgrp root [DIRECTORY]","weight":"10.0","check_content":"Verify that OL 9 system-wide shared library directories are group-owned by \"root\" with the following command:\n\n$ sudo find /lib /lib64 /usr/lib /usr/lib64 ! -group root -type d -exec stat -c \"%n %G\" '{}' \\;\n\nIf any system-wide shared library directory is returned and is not group-owned by a required system account, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If OL 9 allowed any user to make changes to software libraries, then those changes might be implemented without undergoing the appropriate testing and approvals that are part of a robust change management process.\n\nThis requirement applies to OL 9 with software libraries that are accessible and configurable, as in the case of interpreted languages. Software libraries also include privileged programs that execute with escalated privileges.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001499"],"reference_identifier":"4815","uuid":"ba930351-cf31-4228-b027-2c6ed5676bdc","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: A1A250ECC21B9CD7FAE951EF715DC5D7E2DAE6B6\r\n~~~~~\r\nConfiguration for 'OL 9 library directories must be group-owned by root or a system account.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271787","group_tree":[{"id":"V-271787","title":"SRG-OS-000259-GPOS-00100","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271787","severity":"medium","group_title":"SRG-OS-000259-GPOS-00100","rule_id_src":"SV-271787r1092073_rule","rule_id":"SV-271787","rule_version":"OL09-00-002521","rule_title":"OL 9 library directories must be owned by root.","fix_text":"Configure the system-wide shared library directories within (/lib, /lib64, /usr/lib and /usr/lib64) to be protected from unauthorized access.\n\nRun the following command, replacing \"[DIRECTORY]\" with any library directory not owned by \"root\".\n\n$ sudo chown root [DIRECTORY]","weight":"10.0","check_content":"Verify that OL 9 system-wide shared library directories are owned by \"root\" with the following command:\n\n$ sudo find /lib /lib64 /usr/lib /usr/lib64 ! -user root -type d -exec stat -c \"%n %U\" '{}' \\;\n\nIf any system-wide shared library directory is not owned by root, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If OL 9 allowed any user to make changes to software libraries, then those changes might be implemented without undergoing the appropriate testing and approvals that are part of a robust change management process.\n\nThis requirement applies to OL 9 with software libraries that are accessible and configurable, as in the case of interpreted languages. Software libraries also include privileged programs that execute with escalated privileges.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001499"],"reference_identifier":"4452","uuid":"60543dc5-f088-4b91-84ab-f005beaacae8","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: C27DB2EEF2593532C0BDBC6D683D48788AA833E0\r\n~~~~~\r\nConfiguration for 'OL 9 library directories must be owned by root.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271788","group_tree":[{"id":"V-271788","title":"SRG-OS-000259-GPOS-00100","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271788","severity":"medium","group_title":"SRG-OS-000259-GPOS-00100","rule_id_src":"SV-271788r1155305_rule","rule_id":"SV-271788","rule_version":"OL09-00-002522","rule_title":"OL 9 library directories must have mode 755 or less permissive.","fix_text":"Configure the systemwide shared library directories (/lib, /lib64, /usr/lib and /usr/lib64) to be protected from unauthorized access. \n\nRun the following command, replacing \"[DIRECTORY]\" with any library directory with a mode more permissive than 755.\n\n$ sudo chmod 755 [DIRECTORY]","weight":"10.0","check_content":"Verify OL 9 systemwide shared library directories have mode \"755\" or less permissive with the following command:\n\n$ sudo find -L /lib /lib64 /usr/lib /usr/lib64 -perm /022 -type d -exec ls -l {} \\;\n\nIf any systemwide shared library directory is found to be group-writable or world-writable, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If OL 9 allowed any user to make changes to software libraries, then those changes might be implemented without undergoing the appropriate testing and approvals that are part of a robust change management process.\n\nThis requirement applies to OL 9 with software libraries that are accessible and configurable, as in the case of interpreted languages. Software libraries also include privileged programs that execute with escalated privileges.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001499"],"reference_identifier":"2365","uuid":"709165b1-9e03-49cb-ae86-b79fb041287a","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"notafinding","overrides":{},"comments":"","finding_details":"Evaluate-STIG 1.2604.2 (Scan-OracleLinux9_Checks) found this to be NotAFinding on 07/23/2026\r\nResultHash: 061966BAC912504E9B56ACE442F762F7555413A6\r\n~~~~~\r\nConfiguration for 'OL 9 library directories must have mode 755 or less permissive.' matches the expected value on the Oracle Linux 9 host."},{"group_id_src":"V-271789","group_tree":[{"id":"V-271789","title":"SRG-OS-000259-GPOS-00100","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271789","severity":"medium","group_title":"SRG-OS-000259-GPOS-00100","rule_id_src":"SV-271789r1134863_rule","rule_id":"SV-271789","rule_version":"OL09-00-002523","rule_title":"OL 9 library files must be group owned by root or a system account.","fix_text":"Configure the OL 9 systemwide shared library files contained in the directories \"/lib\", \"/lib64\", \"/usr/lib\", and \"/usr/lib64\" to be group owned by root with the following command:\n\n$ sudo find /lib /lib64 /usr/lib /usr/lib64 -type f -name '*.so*' ! -group root -exec chown :root {} +","weight":"10.0","check_content":"Verify that OL 9 systemwide shared library files contained in the directories \"/lib\", \"/lib64\", \"/usr/lib\", and \"/usr/lib64\" are group owned by root with the following command:\n\n$ sudo find /lib /lib64 /usr/lib /usr/lib64 -type f -name '*.so*' ! -group root -exec stat -c \"%n %G\" {} +\n\nIf any output is returned, this is a finding.","check_content_ref":{"href":"Oracle_Linux_9_STIG.xml","name":"M"},"classification":"UNCLASSIFIED","discussion":"If OL 9 allowed any user to make changes to software libraries, then those changes might be implemented without undergoing the appropriate testing and approvals that are part of a robust change management process.\n\nThis requirement applies to OL 9 with software libraries that are accessible and configurable, as in the case of interpreted languages. Software libraries also include privileged programs that execute with escalated privileges.","false_positives":"","false_negatives":"","documentable":"false","security_override_guidance":"","potential_impacts":"","third_party_tools":"","ia_controls":"","responsibility":"","mitigations":"","mitigation_control":"","legacy_ids":[],"ccis":["CCI-001499"],"reference_identifier":"8930","uuid":"953b2802-04d4-48fd-ba28-80ddd93e8223","stig_uuid":"9f4b762d-8654-4328-882b-f95f4ce5315e","status":"not_reviewed","overrides":{},"comments":"","finding_details":""},{"group_id_src":"V-271790","group_tree":[{"id":"V-271790","title":"SRG-OS-000259-GPOS-00100","description":"<GroupDescription></GroupDescription>"}],"group_id":"V-271790","severity":"medium","group_title":"SRG-OS-000259-GPOS-00100","rule_id_src":"SV-271790r1134866_rule","rule_id":"SV-271790","rule_version":"OL09-00-002524","rule_title":"OL 9 library files must be owned by root.","fix_text":"Configure the systemwide shared library files contained in the directories \"/lib\", \"/lib64\", \"/usr/lib\", and \"/usr/lib64\" 